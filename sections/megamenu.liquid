              <svg class="pet-nav-chev-{{ section.id }}" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><polyline points="6 9 12 15 18 9"/></svg>
            {% endif %}
          </a>

          {% if has_mega %}
            <div class="pet-mega-{{ section.id }}">
              <div class="pet-mega-inner-{{ section.id }}">

                {% if mega_block.settings.menu_1 != blank %}
                  <div class="pet-mega-col-{{ section.id }}">
                    <h4 class="pet-mega-h-{{ section.id }}">
                      <span class="pet-mega-icon-{{ section.id }}">{{ mega_block.settings.icon_1 }}</span>
                      <span>{{ mega_block.settings.title_1 }}</span>
                    </h4>
                    <ul class="pet-mega-list-{{ section.id }}">
                      {% for childlink in linklists[mega_block.settings.menu_1].links %}
                        {%- liquid
                          assign lt = childlink.title
                          assign bh = ''
                          if lt contains '[Sarı:'
                            assign rb = lt | split: '[Sarı:' | last | split: ']' | first
                            assign bh = '<span class="pet-mega-badge-' | append: section.id | append: ' pet-mega-badge-y-' | append: section.id | append: '">' | append: rb | append: '</span>'
                            assign sr = '[Sarı:' | append: rb | append: ']'
                            assign lt = lt | remove: sr
                          elsif lt contains '[Kırmızı:'
                            assign rb = lt | split: '[Kırmızı:' | last | split: ']' | first
                            assign bh = '<span class="pet-mega-badge-' | append: section.id | append: ' pet-mega-badge-r-' | append: section.id | append: '">' | append: rb | append: '</span>'
                            assign sr = '[Kırmızı:' | append: rb | append: ']'
                            assign lt = lt | remove: sr
                          endif
                        -%}
                        <li class="pet-mega-row-{{ section.id }}">
                          <a href="{{ childlink.url }}" class="pet-mega-link-{{ section.id }}">{{ lt | strip }}</a>
                          {{ bh }}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}

                {% if mega_block.settings.menu_2 != blank %}
                  <div class="pet-mega-col-{{ section.id }}">
                    <h4 class="pet-mega-h-{{ section.id }}">
                      <span class="pet-mega-icon-{{ section.id }}">{{ mega_block.settings.icon_2 }}</span>
                      <span>{{ mega_block.settings.title_2 }}</span>
                    </h4>
                    <ul class="pet-mega-list-{{ section.id }}">
                      {% for childlink in linklists[mega_block.settings.menu_2].links %}
                        {%- liquid
                          assign lt = childlink.title
                          assign bh = ''
                          if lt contains '[Sarı:'
                            assign rb = lt | split: '[Sarı:' | last | split: ']' | first
                            assign bh = '<span class="pet-mega-badge-' | append: section.id | append: ' pet-mega-badge-y-' | append: section.id | append: '">' | append: rb | append: '</span>'
                            assign sr = '[Sarı:' | append: rb | append: ']'
                            assign lt = lt | remove: sr
                          elsif lt contains '[Kırmızı:'
                            assign rb = lt | split: '[Kırmızı:' | last | split: ']' | first
                            assign bh = '<span class="pet-mega-badge-' | append: section.id | append: ' pet-mega-badge-r-' | append: section.id | append: '">' | append: rb | append: '</span>'
                            assign sr = '[Kırmızı:' | append: rb | append: ']'
                            assign lt = lt | remove: sr
                          endif
                        -%}
                        <li class="pet-mega-row-{{ section.id }}">
                          <a href="{{ childlink.url }}" class="pet-mega-link-{{ section.id }}">{{ lt | strip }}</a>
                          {{ bh }}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}

                {% if mega_block.settings.menu_3 != blank %}
                  <div class="pet-mega-col-{{ section.id }}">
                    <h4 class="pet-mega-h-{{ section.id }}">
                      <span class="pet-mega-icon-{{ section.id }}">{{ mega_block.settings.icon_3 }}</span>
                      <span>{{ mega_block.settings.title_3 }}</span>
                    </h4>
                    <ul class="pet-mega-list-{{ section.id }}">
                      {% for childlink in linklists[mega_block.settings.menu_3].links %}
                        {%- liquid
                          assign lt = childlink.title
                          assign bh = ''
                          if lt contains '[Sarı:'
                            assign rb = lt | split: '[Sarı:' | last | split: ']' | first
                            assign bh = '<span class="pet-mega-badge-' | append: section.id | append: ' pet-mega-badge-y-' | append: section.id | append: '">' | append: rb | append: '</span>'
                            assign sr = '[Sarı:' | append: rb | append: ']'
                            assign lt = lt | remove: sr
                          elsif lt contains '[Kırmızı:'
                            assign rb = lt | split: '[Kırmızı:' | last | split: ']' | first
                            assign bh = '<span class="pet-mega-badge-' | append: section.id | append: ' pet-mega-badge-r-' | append: section.id | append: '">' | append: rb | append: '</span>'
                            assign sr = '[Kırmızı:' | append: rb | append: ']'
                            assign lt = lt | remove: sr
                          endif
                        -%}
                        <li class="pet-mega-row-{{ section.id }}">
                          <a href="{{ childlink.url }}" class="pet-mega-link-{{ section.id }}">{{ lt | strip }}</a>
                          {{ bh }}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}

                {% if mega_block.settings.card_title != blank %}
                  <a href="{{ mega_block.settings.card_link | default: '#' }}" class="pet-mega-card-{{ section.id }}">
                    {% if mega_block.settings.card_tag != blank %}
                      <span class="pet-mega-card-tag-{{ section.id }}">{{ mega_block.settings.card_tag }}</span>
                    {% endif %}
                    <div>
                      <h5 class="pet-mega-card-title-{{ section.id }}">{{ mega_block.settings.card_title }}</h5>
                      {% if mega_block.settings.card_subtitle != blank %}
                        <p class="pet-mega-card-sub-{{ section.id }}">{{ mega_block.settings.card_subtitle }}</p>
                      {% endif %}
                    </div>
                    <span class="pet-mega-card-cta-{{ section.id }}">
                      Keşfet
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square" stroke-linejoin="miter"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
                    </span>
                  </a>
                {% elsif mega_block.settings.menu_4 != blank %}
                  <div class="pet-mega-col-{{ section.id }}">
                    <h4 class="pet-mega-h-{{ section.id }}">
                      <span class="pet-mega-icon-{{ section.id }}">{{ mega_block.settings.icon_4 }}</span>
                      <span>{{ mega_block.settings.title_4 }}</span>
                    </h4>
                    <ul class="pet-mega-list-{{ section.id }}">
                      {% for childlink in linklists[mega_block.settings.menu_4].links %}
                        {%- liquid
                          assign lt = childlink.title
                          assign bh = ''
                          if lt contains '[Sarı:'
                            assign rb = lt | split: '[Sarı:' | last | split: ']' | first
                            assign bh = '<span class="pet-mega-badge-' | append: section.id | append: ' pet-mega-badge-y-' | append: section.id | append: '">' | append: rb | append: '</span>'
                            assign sr = '[Sarı:' | append: rb | append: ']'
                            assign lt = lt | remove: sr
                          elsif lt contains '[Kırmızı:'
                            assign rb = lt | split: '[Kırmızı:' | last | split: ']' | first
                            assign bh = '<span class="pet-mega-badge-' | append: section.id | append: ' pet-mega-badge-r-' | append: section.id | append: '">' | append: rb | append: '</span>'
                            assign sr = '[Kırmızı:' | append: rb | append: ']'
                            assign lt = lt | remove: sr
                          endif
                        -%}
                        <li class="pet-mega-row-{{ section.id }}">
                          <a href="{{ childlink.url }}" class="pet-mega-link-{{ section.id }}">{{ lt | strip }}</a>
                          {{ bh }}
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                {% endif %}

              </div>
            </div>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</header>

<div class="pet-overlay-{{ section.id }}" id="MOver-{{ section.id }}"></div>
<aside class="pet-drawer-{{ section.id }}" id="MDr-{{ section.id }}">
  <div class="pet-dh-{{ section.id }}">
    <span class="pet-dh-logo-{{ section.id }}">
      <span class="pet-logo-mark-{{ section.id }}" style="width:32px;height:32px;font-size:16px;">{{ section.settings.logo_emoji }}</span>
      {{ section.settings.logo_text }}
    </span>
    <button class="pet-dh-close-{{ section.id }}" id="MCl-{{ section.id }}" aria-label="Menüyü kapat">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
  </div>
  <div class="pet-db-{{ section.id }}">
    {% for link in linklists[section.settings.menu].links %}
      {% assign is_hl = false %}
      {% if section.settings.highlight_keyword != blank and link.title contains section.settings.highlight_keyword %}
        {% assign is_hl = true %}
      {% endif %}
      <a href="{{ link.url }}" class="pet-db-link-{{ section.id }}{% if is_hl %} is-hl{% endif %}">
        {{ link.title }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><polyline points="9 18 15 12 9 6"/></svg>
      </a>
    {% endfor %}
  </div>
</aside>

<script>
(function() {
  var bO = document.getElementById('MBtn-{{ section.id }}');
  var bC = document.getElementById('MCl-{{ section.id }}');
  var dr = document.getElementById('MDr-{{ section.id }}');
  var ov = document.getElementById('MOver-{{ section.id }}');
  var hd = document.getElementById('PetH-{{ section.id }}');

  function open() { dr.classList.add('is-open'); ov.classList.add('is-open'); document.body.style.overflow = 'hidden'; }
  function close() { dr.classList.remove('is-open'); ov.classList.remove('is-open'); document.body.style.overflow = ''; }

  if (bO) bO.addEventListener('click', open);
  if (bC) bC.addEventListener('click', close);
  if (ov) ov.addEventListener('click', close);

  if (hd) {
    var sh = function() {
      if (window.scrollY > 4) hd.classList.add('is-scrolled');
      else hd.classList.remove('is-scrolled');
    };
    window.addEventListener('scroll', sh, { passive: true });
    sh();
  }

  // Search dropdown
  var sw = document.getElementById('PSearch-{{ section.id }}');
  var sb = document.getElementById('PSearchBar-{{ section.id }}');
  var si = document.getElementById('PSearchInput-{{ section.id }}');

  if (sw && si && sb) {
    function openSearch() {
      sw.classList.add('is-open');
      sb.classList.add('is-focus');
    }
    function closeSearch() {
      sw.classList.remove('is-open');
      sb.classList.remove('is-focus');
    }

    si.addEventListener('focus', openSearch);
    si.addEventListener('click', openSearch);

    document.addEventListener('click', function(e) {
      if (!sw.contains(e.target)) closeSearch();
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') {
        closeSearch();
        si.blur();
      }
    });
  }
})();
</script>

