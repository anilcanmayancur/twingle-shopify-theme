      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter" style="color:var(--muted);"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="search" name="q" placeholder="{{ section.settings.search_placeholder }}" aria-label="Ara">
    </form>
  </div>

  <div class="pet-nav-w-{{ section.id }}">
    <ul class="pet-nav-{{ section.id }}">
      {% for link in linklists[section.settings.menu].links %}

        {% assign is_hl = false %}
        {% if section.settings.highlight_keyword != blank and link.title contains section.settings.highlight_keyword %}
          {% assign is_hl = true %}
        {% endif %}

        {% assign has_mega = false %}
        {% assign mega_block = null %}
        {% for block in section.blocks %}
          {% if block.type == 'mega_menu' %}
            {% assign t1 = block.settings.trigger | downcase | strip %}
            {% assign t2 = link.title | downcase | strip %}
            {% if t1 == t2 %}
              {% assign has_mega = true %}
              {% assign mega_block = block %}
              {% break %}
            {% endif %}
          {% endif %}
        {% endfor %}

        <li class="pet-nav-item-{{ section.id }}{% if is_hl %} is-hl{% endif %}">
          <a href="{{ link.url }}" class="pet-nav-link-{{ section.id }}">
            {{ link.title }}
