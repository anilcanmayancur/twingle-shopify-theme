<section class="pet-blog" id="section-{{ section.id }}">
  <div class="pet-blog__container">
    <header class="pet-blog__header">
      <h2 class="pet-blog__title">{{ section.settings.title }}{% if section.settings.title_highlight != blank %} <span class="pet-blog__hl">{{ section.settings.title_highlight }}</span>{% endif %}</h2>
      {%- if section.settings.blog != blank and section.settings.btn_label != blank -%}
        <a href="{{ section.settings.blog.url }}" class="pet-blog__view-all">
          {{ section.settings.btn_label }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </header>

    <div class="pet-blog__track">
      {%- if section.settings.blog != blank and section.settings.blog.articles_count > 0 -%}
        {%- for article in section.settings.blog.articles limit: section.settings.limit -%}
          {%- assign word_count = article.content | strip_html | split: ' ' | size -%}
          {%- assign read_time = word_count | divided_by: 200 | at_least: 1 -%}
          <a href="{{ article.url }}" class="pet-blog__card">
            <div class="pet-blog__img">
              {%- if article.image -%}
                <img
                  src="{{ article.image | image_url: width: 600 }}"
                  srcset="{{ article.image | image_url: width: 400 }} 400w, {{ article.image | image_url: width: 600 }} 600w, {{ article.image | image_url: width: 800 }} 800w"
                  sizes="(max-width: 768px) 72vw, 300px"
                  alt="{{ article.title }}"
                  width="600"
                  height="340"
                  loading="lazy"
                >
              {%- else -%}
                <div class="pet-blog__img-placeholder">
                  <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
                </div>
              {%- endif -%}
            </div>
            <div class="pet-blog__info">
              <span class="pet-blog__category">{{ article.tags.first | default: 'Rehber' }}</span>
              <h3 class="pet-blog__card-title">{{ article.title }}</h3>
              <div class="pet-blog__meta">
                <span>{{ article.published_at | date: "%d.%m.%Y" }}</span>
                <span class="pet-blog__meta-dot"></span>
                <span>{{ read_time }} dk okuma</span>
              </div>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          {%- capture cat -%}{%- cycle 'Kedi Sağlığı', 'Köpek Bakımı', 'Beslenme' -%}{%- endcapture -%}
          {%- capture t -%}{%- cycle 'Kısırlaştırılmış Kedi İçin Doğru Mama Seçimi', 'Yavru Köpekte İlk 6 Ay Rehberi', 'Evde Profesyonel Tüy Bakımı' -%}{%- endcapture -%}
          <div class="pet-blog__card">
            <div class="pet-blog__img">
              <div class="pet-blog__img-placeholder">
                <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
              </div>
            </div>
            <div class="pet-blog__info">
              <span class="pet-blog__category">{{ cat }}</span>
              <h3 class="pet-blog__card-title">{{ t }}</h3>
              <div class="pet-blog__meta">
                <span>10.05.2026</span>
                <span class="pet-blog__meta-dot"></span>
                <span>5 dk okuma</span>
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .pet-blog {
    --pet-primary: #7B3FF2;
    --pet-ink: #1F1342;
    --pet-body: #5A4F75;
    padding: 48px 0;
    background: #FAFAFA;
  }

  .pet-blog__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .pet-blog__header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 24px;
  }

  .pet-blog__title {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700;
    color: var(--pet-ink);
    margin: 0;
    line-height: 1.3;
  }

  .pet-blog__hl {
    background: linear-gradient(135deg, var(--pet-primary), #A78BFA);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pet-blog__view-all {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 14px;
    font-weight: 600;
    color: var(--pet-primary);
    text-decoration: none;
    white-space: nowrap;
    transition: opacity 0.2s ease;
  }

  @media (hover: hover) {
    .pet-blog__view-all:hover {
      opacity: 0.7;
    }
  }

  .pet-blog__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding-bottom: 4px;
  }

  .pet-blog__track::-webkit-scrollbar {
    height: 3px;
  }

  .pet-blog__track::-webkit-scrollbar-track {
    background: transparent;
  }

  .pet-blog__track::-webkit-scrollbar-thumb {
    background: rgba(123, 63, 242, 0.12);
    border-radius: 10px;
  }

  .pet-blog__card {
    min-width: 270px;
    max-width: 300px;
    flex-shrink: 0;
    scroll-snap-align: start;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    transition: box-shadow 0.3s ease;
  }

  @media (hover: hover) {
    .pet-blog__card:hover {
      box-shadow: 0 4px 20px rgba(123, 63, 242, 0.08);
    }

    .pet-blog__card:hover .pet-blog__img img {
      transform: scale(1.03);
    }
  }

  .pet-blog__img {
    width: 100%;
    aspect-ratio: 16 / 10;
    overflow: hidden;
    background: #F4F0FF;
  }

  .pet-blog__img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
  }

  .pet-blog__img-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--pet-primary);
    opacity: 0.4;
  }

  .pet-blog__info {
    padding: 18px 20px 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    flex: 1;
  }

  .pet-blog__category {
    font-size: 11px;
    font-weight: 700;
    color: var(--pet-primary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .pet-blog__card-title {
    font-size: 15px;
    font-weight: 600;
    color: var(--pet-ink);
    margin: 0;
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pet-blog__meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--pet-body);
    margin-top: auto;
    padding-top: 8px;
  }

  .pet-blog__meta-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--pet-body);
    opacity: 0.4;
  }

  @media (max-width: 768px) {
    .pet-blog {
      padding: 32px 0;
    }

    .pet-blog__container {
      padding: 0 16px;
    }

    .pet-blog__header {
      margin-bottom: 16px;
    }

    .pet-blog__card {
      min-width: 240px;
      max-width: 72vw;
    }

    .pet-blog__track {
      margin: 0 -16px;
      padding-left: 16px;
      padding-right: 16px;
    }

    .pet-blog__info {
      padding: 14px 16px 16px;
    }
  }
</style>

{% schema %}
{
  "name": "Premium Blog",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Başlık",
      "default": "Evcil Hayvan"
    },
    {
      "type": "text",
      "id": "title_highlight",
      "label": "Vurgu",
      "default": "Rehberi"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog Seçin"
    },
    {
      "type": "range",
      "id": "limit",
      "min": 3,
      "max": 12,
      "step": 1,
      "label": "Yazı Limiti",
      "default": 6
    },
    {
      "type": "text",
      "id": "btn_label",
      "label": "Buton",
      "default": "Tüm Yazılar"
    }
  ],
  "presets": [
    {
      "name": "Premium Blog"
    }
  ]
}
{% endschema %}