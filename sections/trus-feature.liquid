<style>
.pet-trust-{{ section.id }} {
  --pet-primary: {{ section.settings.primary_color }};
  --pet-primary-light: {{ section.settings.primary_light_color }};
  --pet-primary-deep: {{ section.settings.primary_deep_color }};
  --pet-bg: {{ section.settings.bg_color }};
  --pet-card: {{ section.settings.card_bg }};
  --pet-ink: #1F1342;
  --pet-body: #5A4F75;
  --pet-line: rgba(123, 63, 242, 0.10);

  background-color: var(--pet-bg);
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  font-family: inherit, 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
}

.pet-trust-{{ section.id }} *,
.pet-trust-{{ section.id }} *::before,
.pet-trust-{{ section.id }} *::after {
  box-sizing: border-box;
}

.pet-trust-container-{{ section.id }} {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 24px;
}

.pet-trust-wrapper-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat({{ section.blocks.size }}, minmax(0, 1fr));
  background-color: var(--pet-card);
  border: 1px solid var(--pet-line);
  border-radius: 22px;
  overflow: hidden;
  box-shadow:
    0 1px 2px rgba(31, 19, 66, 0.03),
    0 6px 20px -12px rgba(123, 63, 242, 0.08);
}

.pet-trust-item-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 14px;
  padding: 22px 22px;
  position: relative;
  transition: background-color 0.25s ease;
}

.pet-trust-item-{{ section.id }}:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0;
  top: 22%;
  bottom: 22%;
  width: 1px;
  background: var(--pet-line);
}

.pet-trust-item-{{ section.id }}:hover {
  background-color: rgba(123, 63, 242, 0.025);
}

.pet-trust-item-{{ section.id }}:hover .pet-trust-icon-box-{{ section.id }} {
  background: linear-gradient(135deg, rgba(183, 148, 244, 0.32) 0%, rgba(123, 63, 242, 0.20) 100%);
  border-color: rgba(123, 63, 242, 0.28);
}

/* SOFT icon box: soft purple bg + purple icon. NOT dominant. */
.pet-trust-icon-box-{{ section.id }} {
  width: 46px;
  height: 46px;
  border-radius: 13px;
  background: linear-gradient(135deg, rgba(183, 148, 244, 0.20) 0%, rgba(123, 63, 242, 0.12) 100%);
  border: 1px solid rgba(123, 63, 242, 0.16);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  font-size: 20px;
  transition: background 0.3s ease, border-color 0.3s ease, transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
}

.pet-trust-icon-box-{{ section.id }} svg {
  width: 22px;
  height: 22px;
  color: var(--pet-primary);
}

.pet-trust-icon-box-{{ section.id }} img {
  width: 24px;
  height: 24px;
  object-fit: contain;
  display: block;
}

.pet-trust-text-box-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 3px;
  min-width: 0;
}

.pet-trust-title-{{ section.id }} {
  font-size: 15.5px;
  font-weight: 700;
  color: var(--pet-ink);
  margin: 0;
  line-height: 1.25;
  letter-spacing: -0.01em;
}

.pet-trust-subtitle-{{ section.id }} {
  font-size: 13px;
  color: var(--pet-body);
  margin: 0;
  line-height: 1.4;
  font-weight: 500;
}

/* ===== TABLET (≤990px) ===== */
@media screen and (max-width: 990px) {
  .pet-trust-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
  }

  .pet-trust-wrapper-{{ section.id }} {
    {%- if section.blocks.size >= 4 -%}
      grid-template-columns: repeat(2, minmax(0, 1fr));
    {%- elsif section.blocks.size == 3 -%}
      grid-template-columns: repeat(2, minmax(0, 1fr));
    {%- else -%}
      grid-template-columns: 1fr;
    {%- endif -%}
  }

  .pet-trust-item-{{ section.id }}::after {
    display: none;
  }

  {%- if section.blocks.size >= 4 -%}
  .pet-trust-item-{{ section.id }}:nth-child(odd):not(:last-child)::after {
    display: block;
    top: 22%;
    bottom: 22%;
    right: 0;
    width: 1px;
    height: auto;
    background: var(--pet-line);
  }
  .pet-trust-item-{{ section.id }}:nth-child(-n+2)::before {
    content: "";
    position: absolute;
    bottom: 0;
    left: 22px;
    right: 22px;
    height: 1px;
    background: var(--pet-line);
  }
  {%- elsif section.blocks.size == 3 -%}
  .pet-trust-item-{{ section.id }}:first-child::after {
    display: block;
    top: 22%;
    bottom: 22%;
    right: 0;
    width: 1px;
    background: var(--pet-line);
  }
  .pet-trust-item-{{ section.id }}:nth-child(3) {
    grid-column: 1 / -1;
    border-top: 1px solid var(--pet-line);
  }
  {%- endif -%}
}

/* ===== MOBİL (≤640px) — kompakt ===== */
@media screen and (max-width: 640px) {
  .pet-trust-{{ section.id }} {
    padding-top: 18px;
    padding-bottom: 18px;
  }

  .pet-trust-container-{{ section.id }} {
    padding: 0 16px;
  }

  .pet-trust-wrapper-{{ section.id }} {
    grid-template-columns: 1fr;
    border-radius: 16px;
  }

  .pet-trust-item-{{ section.id }} {
    padding: 12px 14px;
    gap: 12px;
  }

  .pet-trust-item-{{ section.id }}::after,
  .pet-trust-item-{{ section.id }}::before {
    display: none !important;
  }
  .pet-trust-item-{{ section.id }}:not(:last-child) {
    border-bottom: 1px solid var(--pet-line);
  }
  {%- if section.blocks.size == 3 -%}
  .pet-trust-item-{{ section.id }}:nth-child(3) {
    grid-column: auto;
    border-top: none;
  }
  {%- endif -%}

  .pet-trust-icon-box-{{ section.id }} {
    width: 38px;
    height: 38px;
    border-radius: 11px;
  }
  .pet-trust-icon-box-{{ section.id }} svg {
    width: 18px;
    height: 18px;
  }
  .pet-trust-icon-box-{{ section.id }} img {
    width: 20px;
    height: 20px;
  }
  .pet-trust-icon-box-{{ section.id }} {
    font-size: 17px;
  }

  .pet-trust-title-{{ section.id }} {
    font-size: 14px;
    line-height: 1.2;
  }
  .pet-trust-subtitle-{{ section.id }} {
    font-size: 12px;
    line-height: 1.35;
  }
  .pet-trust-text-box-{{ section.id }} {
    gap: 2px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .pet-trust-icon-box-{{ section.id }} {
    transition: none !important;
  }
}
</style>

<section class="pet-trust-{{ section.id }}">
  <div class="pet-trust-container-{{ section.id }}">
    <div class="pet-trust-wrapper-{{ section.id }}">

      {% for block in section.blocks %}
        {%- comment -%}
          Auto-detect: "auto" seçiliyse VEYA mevcut bloklarda eski "truck" default'una takılı kalmışsa
          ve emoji default değilse, emoji'ye göre uygun SVG'yi seç.
        {%- endcomment -%}
        {%- assign final_icon = block.settings.icon -%}
        {%- assign emoji = block.settings.emoji -%}

        {%- if final_icon == 'auto' or final_icon == blank -%}
          {%- case emoji -%}
            {%- when '🚚', '🚀', '🛻' -%}{%- assign final_icon = 'truck' -%}
            {%- when '🔒', '🛡️', '🔐' -%}{%- assign final_icon = 'shield' -%}
            {%- when '🔄', '↩️', '♻️' -%}{%- assign final_icon = 'refresh' -%}
            {%- when '🐾', '🐶', '🐱' -%}{%- assign final_icon = 'paw' -%}
            {%- when '🌿', '🍃', '🌱' -%}{%- assign final_icon = 'leaf' -%}
            {%- when '⭐', '🌟' -%}{%- assign final_icon = 'star' -%}
            {%- when '💜', '❤️', '🧡', '💛', '💚', '💙' -%}{%- assign final_icon = 'heart' -%}
            {%- when '🎧', '☎️', '📞' -%}{%- assign final_icon = 'headset' -%}
            {%- when '🏅', '🏆', '🎖️' -%}{%- assign final_icon = 'medal' -%}
            {%- when '📦', '📮' -%}{%- assign final_icon = 'package' -%}
            {%- when '⏱️', '⏰', '🕐' -%}{%- assign final_icon = 'clock' -%}
            {%- when '🎁', '🛍️' -%}{%- assign final_icon = 'gift' -%}
            {%- else -%}{%- assign final_icon = 'shield' -%}
          {%- endcase -%}
        {%- endif -%}

        <div class="pet-trust-item-{{ section.id }}" {{ block.shopify_attributes }}>
          <div class="pet-trust-icon-box-{{ section.id }}">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 100 | image_tag: loading: 'lazy', alt: block.settings.title }}
            {% else %}
              {% case final_icon %}
                {% when 'truck' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 18V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v11a1 1 0 0 0 1 1h2"/>
                    <path d="M15 18H9"/>
                    <path d="M19 18h2a1 1 0 0 0 1-1v-3.65a1 1 0 0 0-.22-.624l-3.48-4.35A1 1 0 0 0 17.52 8H14"/>
                    <circle cx="17" cy="18" r="2"/>
                    <circle cx="7" cy="18" r="2"/>
                  </svg>
                {% when 'shield' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/>
                    <path d="m9 12 2 2 4-4"/>
                  </svg>
                {% when 'refresh' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8"/>
                    <path d="M21 3v5h-5"/>
                    <path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16"/>
                    <path d="M8 16H3v5"/>
                  </svg>
                {% when 'paw' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="4" r="2"/>
                    <circle cx="18" cy="8" r="2"/>
                    <circle cx="20" cy="16" r="2"/>
                    <path d="M9 10a5 5 0 0 1 5 5v3.5a3.5 3.5 0 0 1-6.84 1.045Q6.52 17.48 4.46 16.84A3.5 3.5 0 0 1 5.5 10Z"/>
                  </svg>
                {% when 'leaf' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.3c1.7 2.4 2 6.7-1.5 11.1-2.6 3.3-6.7 4.6-6.7 4.6Z"/>
                    <path d="M2 21c0-3 1.85-5.36 5.08-6"/>
                  </svg>
                {% when 'star' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                  </svg>
                {% when 'heart' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/>
                  </svg>
                {% when 'headset' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M3 18v-6a9 9 0 0 1 18 0v6"/>
                    <path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/>
                  </svg>
                {% when 'medal' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="15" r="6"/>
                    <path d="M9 11.84V3l3 3 3-3v8.84"/>
                  </svg>
                {% when 'package' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="m7.5 4.27 9 5.15"/>
                    <path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/>
                    <path d="m3.3 7 8.7 5 8.7-5"/>
                    <path d="M12 22V12"/>
                  </svg>
                {% when 'clock' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="10"/>
                    <polyline points="12 6 12 12 16 14"/>
                  </svg>
                {% when 'gift' %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="3" y="8" width="18" height="4" rx="1"/>
                    <path d="M12 8v13"/>
                    <path d="M19 12v7a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2v-7"/>
                    <path d="M7.5 8a2.5 2.5 0 0 1 0-5A4.8 8 0 0 1 12 8a4.8 8 0 0 1 4.5-5 2.5 2.5 0 0 1 0 5"/>
                  </svg>
                {% else %}
                  {{ block.settings.emoji }}
              {% endcase %}
            {% endif %}
          </div>
          <div class="pet-trust-text-box-{{ section.id }}">
            <h3 class="pet-trust-title-{{ section.id }}">{{ block.settings.title }}</h3>
            <p class="pet-trust-subtitle-{{ section.id }}">{{ block.settings.subtitle }}</p>
          </div>
        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Badges",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section Background",
      "default": "#FAF7FF"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary Color (Mor)",
      "default": "#7B3FF2"
    },
    {
      "type": "color",
      "id": "primary_light_color",
      "label": "Açık Mor",
      "default": "#B794F4"
    },
    {
      "type": "color",
      "id": "primary_deep_color",
      "label": "Koyu Mor",
      "default": "#5B2FB2"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Max Width",
      "default": 1300
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Top",
      "default": 25
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 25
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "İkon",
          "info": "'Otomatik' bırakırsan emoji'ye göre uygun ikon seçilir.",
          "options": [
            { "value": "auto",    "label": "✨ Otomatik (emoji'ye göre)" },
            { "value": "truck",   "label": "🚚 Kargo" },
            { "value": "shield",  "label": "🛡️ Güvenli" },
            { "value": "refresh", "label": "🔄 İade" },
            { "value": "paw",     "label": "🐾 Pet" },
            { "value": "leaf",    "label": "🌿 Doğal" },
            { "value": "star",    "label": "⭐ Premium" },
            { "value": "heart",   "label": "💜 Sevgi" },
            { "value": "headset", "label": "🎧 Destek" },
            { "value": "medal",   "label": "🏅 Kalite" },
            { "value": "package", "label": "📦 Paket" },
            { "value": "clock",   "label": "⏱️ Saat" },
            { "value": "gift",    "label": "🎁 Hediye" }
          ],
          "default": "auto"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Özel İkon (opsiyonel)",
          "info": "Görsel yüklenirse SVG ikon yerine bu kullanılır."
        },
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji (auto modda eşleştirme için)",
          "default": "🚚"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Aynı Gün Kargo"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "16:00'a kadar verilen siparişler"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "icon": "truck",
            "emoji": "🚚",
            "title": "Aynı Gün Kargo",
            "subtitle": "16:00'a kadar verilen siparişler"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "shield",
            "emoji": "🛡️",
            "title": "Güvenli Ödeme",
            "subtitle": "256-bit SSL şifreleme"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "refresh",
            "emoji": "🔄",
            "title": "14 Gün Kolay İade",
            "subtitle": "Tam ücret iadesi garantisi"
          }
        },
        {
          "type": "badge",
          "settings": {
            "icon": "paw",
            "emoji": "🐾",
            "title": "Veteriner Onaylı",
            "subtitle": "Sadece güvenilir markalar"
          }
        }
      ]
    }
  ]
}
{% endschema %}
