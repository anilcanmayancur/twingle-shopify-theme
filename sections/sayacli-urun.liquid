{%- assign fav_collection = collections[section.settings.collection] -%}
{%- assign fav_limit = section.settings.product_limit -%}

<style>
.pet-favs-{{ section.id }} {
  --pet-primary: {{ section.settings.primary_color }};
  --pet-primary-light: {{ section.settings.primary_light_color }};
  --pet-primary-deep: {{ section.settings.primary_deep_color }};
  --pet-bg: {{ section.settings.bg_color }};
  --pet-ink: #1F1342;
  --pet-body: #5A4F75;
  --pet-line: rgba(123, 63, 242, 0.14);
  --pet-card: #FFFFFF;
  --pet-star: #F59E0B;

  position: relative;
  background:
    radial-gradient(700px 400px at 85% 10%, rgba(123, 63, 242, 0.06), transparent 60%),
    radial-gradient(500px 350px at 5% 90%, rgba(123, 63, 242, 0.04), transparent 55%),
    var(--pet-bg);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  font-family: inherit;
  overflow: hidden;
  isolation: isolate;
}

.pet-favs-{{ section.id }} *,
.pet-favs-{{ section.id }} *::before,
.pet-favs-{{ section.id }} *::after { box-sizing: border-box; }

.pet-favs-{{ section.id }}::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(123, 63, 242, 0.12) 1px, transparent 1px);
  background-size: 26px 26px;
  opacity: 0.25;
  mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.pet-favs-wrap-{{ section.id }} {
  position: relative;
  z-index: 1;
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ===== HEADER ===== */
.pet-favs-header-{{ section.id }} {
  text-align: center;
  margin-bottom: 32px;
}

.pet-favs-badge-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: var(--pet-card);
  color: var(--pet-ink);
  padding: 7px 16px 7px 7px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 14px;
  border: 1px solid var(--pet-line);
  box-shadow: 0 4px 12px -6px rgba(123, 63, 242, 0.18);
}

.pet-favs-badge-dot-{{ section.id }} {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--pet-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.pet-favs-badge-dot-{{ section.id }} svg { width: 10px; height: 10px; fill: #fff; }

.pet-favs-title-{{ section.id }} {
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 800;
  color: var(--pet-ink);
  line-height: 1.15;
  margin: 0 0 8px 0;
  letter-spacing: -0.025em;
  text-wrap: balance;
}

.pet-favs-title-{{ section.id }} .highlight {
  color: var(--pet-primary);
  position: relative;
  display: inline-block;
}
.pet-favs-title-{{ section.id }} .highlight::after {
  content: "";
  position: absolute;
  left: 0; right: 0; bottom: 0.06em;
  height: 0.2em;
  background: var(--pet-primary-light);
  opacity: 0.4;
  border-radius: 4px;
  z-index: -1;
}

.pet-favs-subtitle-{{ section.id }} {
  font-size: 15px;
  color: var(--pet-body);
  margin: 0;
}

/* ===== SOCIAL PROOF — tek satır scroll ===== */
.pet-favs-social-{{ section.id }} {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  margin-top: 18px;
  flex-wrap: nowrap;
  overflow-x: auto;
  scrollbar-width: none;
  -webkit-overflow-scrolling: touch;
  padding: 2px 0;
}
.pet-favs-social-{{ section.id }}::-webkit-scrollbar { display: none; }

.pet-favs-social-item-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: var(--pet-card);
  padding: 6px 14px 6px 8px;
  border-radius: 100px;
  border: 1px solid var(--pet-line);
  font-size: 12px;
  font-weight: 600;
  color: var(--pet-ink);
  box-shadow: 0 2px 8px -4px rgba(123, 63, 242, 0.1);
  white-space: nowrap;
  flex-shrink: 0;
}

.pet-favs-social-item-{{ section.id }} svg { width: 16px; height: 16px; flex-shrink: 0; }

/* ===== MASAÜSTÜ: 4'lü GRID ===== */
.pet-favs-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 16px;
}

/* ===== CARD ===== */
.pet-favs-card-{{ section.id }} {
  display: flex;
  flex-direction: column;
  background: var(--pet-card);
  border: 1px solid rgba(123, 63, 242, 0.08);
  border-radius: 16px;
  overflow: hidden;
  text-decoration: none;
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  -webkit-tap-highlight-color: transparent;
  box-shadow: 0 1px 2px rgba(31, 19, 66, 0.03), 0 4px 12px -6px rgba(123, 63, 242, 0.06);
}

@media (hover: hover) {
  .pet-favs-card-{{ section.id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 1px 2px rgba(31, 19, 66, 0.04), 0 16px 36px -10px rgba(123, 63, 242, 0.18), 0 32px 50px -20px rgba(123, 63, 242, 0.1);
  }
}

/* Image */
.pet-favs-img-{{ section.id }} {
  position: relative;
  aspect-ratio: 1 / 1;
  background: linear-gradient(135deg, #F8F4FF 0%, #F0EBFF 100%);
  overflow: hidden;
  display: block;
}

.pet-favs-img-{{ section.id }} img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

@media (hover: hover) {
  .pet-favs-card-{{ section.id }}:hover .pet-favs-img-{{ section.id }} img { transform: scale(1.04); }
}

/* Tags */
.pet-favs-tag-{{ section.id }} {
  position: absolute;
  top: 10px;
  left: 10px;
  z-index: 2;
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.pet-favs-pill-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 3px;
  padding: 4px 8px;
  border-radius: 100px;
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.02em;
  text-transform: uppercase;
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
}

.pet-favs-pill-sale-{{ section.id }} { background: rgba(123, 63, 242, 0.9); color: #fff; }

.pet-favs-pill-hot-{{ section.id }} {
  background: rgba(255,255,255,0.85);
  color: var(--pet-primary);
  border: 1px solid rgba(123, 63, 242, 0.12);
}
.pet-favs-pill-hot-{{ section.id }} svg { width: 10px; height: 10px; fill: var(--pet-primary); stroke: none; }

/* Heart */
.pet-favs-heart-{{ section.id }} {
  position: absolute;
  top: 10px;
  right: 10px;
  z-index: 2;
  width: 30px;
  height: 30px;
  border-radius: 50%;
  background: rgba(255,255,255,0.85);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  border: 1px solid rgba(123, 63, 242, 0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  padding: 0;
  transition: background 0.2s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}
.pet-favs-heart-{{ section.id }} svg { width: 14px; height: 14px; stroke: var(--pet-primary); fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }

@media (hover: hover) {
  .pet-favs-heart-{{ section.id }}:hover { background: var(--pet-primary); transform: scale(1.1); }
  .pet-favs-heart-{{ section.id }}:hover svg { stroke: #fff; fill: #fff; }
}

/* Body */
.pet-favs-body-{{ section.id }} {
  padding: 12px 14px 16px;
  display: flex;
  flex-direction: column;
  flex-grow: 1;
  gap: 5px;
}

.pet-favs-product-title-{{ section.id }} {
  font-size: 13px;
  font-weight: 600;
  color: var(--pet-ink);
  line-height: 1.3;
  text-decoration: none;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}

/* 5 Yıldız */
.pet-favs-stars-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 1px;
}
.pet-favs-star-icon-{{ section.id }} { width: 13px; height: 13px; fill: var(--pet-star); stroke: none; }
.pet-favs-stars-count-{{ section.id }} { font-size: 11px; color: var(--pet-body); font-weight: 500; margin-left: 3px; }

/* Proof */
.pet-favs-proof-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 10.5px;
  color: var(--pet-body);
  font-weight: 500;
}
.pet-favs-proof-{{ section.id }} svg { width: 12px; height: 12px; flex-shrink: 0; fill: var(--pet-primary); opacity: 0.6; stroke: none; }

/* Prices */
.pet-favs-prices-{{ section.id }} { display: flex; align-items: baseline; gap: 6px; margin-top: 2px; }
.pet-favs-price-{{ section.id }} { font-size: 16px; font-weight: 800; color: var(--pet-primary); letter-spacing: -0.02em; }
.pet-favs-compare-{{ section.id }} { font-size: 12px; color: #8B8299; text-decoration: line-through; }

/* CTA */
.pet-favs-cta-{{ section.id }} { margin-top: auto; padding-top: 4px; }

.pet-favs-btn-{{ section.id }} {
  width: 100%;
  padding: 10px 16px;
  border-radius: 100px;
  font-size: 12.5px;
  font-weight: 600;
  color: #fff;
  background: var(--pet-primary);
  border: none;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: background 0.25s ease, box-shadow 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 4px 12px -4px rgba(123, 63, 242, 0.3);
  text-decoration: none;
  -webkit-tap-highlight-color: transparent;
}

.pet-favs-btn-{{ section.id }} svg { width: 13px; height: 13px; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; flex-shrink: 0; }

@media (hover: hover) {
  .pet-favs-btn-{{ section.id }}:hover { background: var(--pet-primary-deep); box-shadow: 0 6px 20px -4px rgba(123, 63, 242, 0.4); transform: translateY(-1px); }
}

.pet-favs-btn-{{ section.id }}:disabled { background: #D1C9E0; box-shadow: none; cursor: not-allowed; }

/* View All */
.pet-favs-viewall-{{ section.id }} { text-align: center; margin-top: 28px; }

.pet-favs-viewall-link-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  color: var(--pet-primary);
  font-size: 14px;
  font-weight: 600;
  text-decoration: none;
  padding: 10px 24px;
  border-radius: 100px;
  border: 1px solid var(--pet-line);
  background: var(--pet-card);
  transition: border-color 0.25s ease, box-shadow 0.25s ease;
}

.pet-favs-viewall-link-{{ section.id }} svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.5; stroke-linecap: round; stroke-linejoin: round; }

@media (hover: hover) {
  .pet-favs-viewall-link-{{ section.id }}:hover { border-color: var(--pet-primary); box-shadow: 0 4px 16px -4px rgba(123, 63, 242, 0.2); }
}

/* ===== TABLET (≤1100px) ===== */
@media screen and (max-width: 1100px) {
  .pet-favs-grid-{{ section.id }} { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}

/* ===== MOBİL (≤768px): SLIDER ===== */
@media screen and (max-width: 768px) {
  .pet-favs-{{ section.id }} {
    padding: {{ section.settings.padding_top | times: 0.6 | round }}px 0 {{ section.settings.padding_bottom | times: 0.6 | round }}px;
  }
  .pet-favs-{{ section.id }}::before { opacity: 0.15; }
  .pet-favs-wrap-{{ section.id }} { padding: 0 16px; }
  .pet-favs-header-{{ section.id }} { margin-bottom: 20px; }

  .pet-favs-badge-{{ section.id }} { font-size: 11px; padding: 6px 14px 6px 6px; margin-bottom: 10px; }
  .pet-favs-title-{{ section.id }} { font-size: clamp(20px, 5.5vw, 28px); }
  .pet-favs-subtitle-{{ section.id }} { font-size: 13px; }

  /* Social proof — mobilde tek satır scroll */
  .pet-favs-social-{{ section.id }} {
    justify-content: flex-start;
    gap: 8px;
    margin-top: 14px;
    padding: 2px 4px;
  }
  .pet-favs-social-item-{{ section.id }} { font-size: 11px; padding: 5px 10px 5px 7px; }

  /* Grid → Slider */
  .pet-favs-grid-{{ section.id }} {
    display: flex;
    gap: 12px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    padding: 4px 2px 8px 2px;
  }
  .pet-favs-grid-{{ section.id }}::-webkit-scrollbar { display: none; }

  .pet-favs-card-{{ section.id }} {
    flex: 0 0 52vw;
    max-width: 220px;
    scroll-snap-align: start;
    border-radius: 14px;
  }

  .pet-favs-body-{{ section.id }} { padding: 10px 12px 14px; gap: 4px; }
  .pet-favs-product-title-{{ section.id }} { font-size: 12px; }
  .pet-favs-star-icon-{{ section.id }} { width: 11px; height: 11px; }
  .pet-favs-stars-count-{{ section.id }} { font-size: 10px; }
  .pet-favs-proof-{{ section.id }} { font-size: 10px; }
  .pet-favs-price-{{ section.id }} { font-size: 14px; }
  .pet-favs-compare-{{ section.id }} { font-size: 11px; }
  .pet-favs-btn-{{ section.id }} { padding: 9px 12px; font-size: 11.5px; min-height: 38px; }

  .pet-favs-tag-{{ section.id }} { top: 8px; left: 8px; gap: 3px; }
  .pet-favs-pill-{{ section.id }} { padding: 3px 7px; font-size: 9px; }
  .pet-favs-heart-{{ section.id }} { top: 8px; right: 8px; width: 28px; height: 28px; }
  .pet-favs-heart-{{ section.id }} svg { width: 12px; height: 12px; }
}

/* ===== KÜÇÜK MOBİL (≤420px) ===== */
@media screen and (max-width: 420px) {
  .pet-favs-{{ section.id }} { padding: 20px 0; }
  .pet-favs-wrap-{{ section.id }} { padding: 0 12px; }

  .pet-favs-card-{{ section.id }} { flex: 0 0 48vw; max-width: 200px; }
  .pet-favs-body-{{ section.id }} { padding: 8px 10px 12px; }
  .pet-favs-product-title-{{ section.id }} { font-size: 11.5px; -webkit-line-clamp: 1; }
  .pet-favs-price-{{ section.id }} { font-size: 13px; }
  .pet-favs-btn-{{ section.id }} { padding: 8px 10px; font-size: 11px; min-height: 36px; }
  .pet-favs-proof-{{ section.id }} { display: none; }
  .pet-favs-viewall-link-{{ section.id }} { font-size: 13px; padding: 9px 20px; }
}

@media (prefers-reduced-motion: reduce) {
  .pet-favs-card-{{ section.id }},
  .pet-favs-card-{{ section.id }} img,
  .pet-favs-heart-{{ section.id }},
  .pet-favs-btn-{{ section.id }} { transition: none !important; }
}
</style>

<section class="pet-favs-{{ section.id }}" aria-label="En Çok Favorilenenler">
  <div class="pet-favs-wrap-{{ section.id }}">

    <div class="pet-favs-header-{{ section.id }}">
      {% if section.settings.badge_text != blank %}
        <div class="pet-favs-badge-{{ section.id }}">
          <span class="pet-favs-badge-dot-{{ section.id }}">
            <svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.6L22 12l-7.6 2.4L12 22l-2.4-7.6L2 12l7.6-2.4L12 2z"/></svg>
          </span>
          {{ section.settings.badge_text }}
        </div>
      {% endif %}

      {% if section.settings.title != blank %}
        <h2 class="pet-favs-title-{{ section.id }}">
          {{ section.settings.title | replace: '[', '<span class="highlight">' | replace: ']', '</span>' }}
        </h2>
      {% endif %}

      {% if section.settings.subtitle != blank %}
        <p class="pet-favs-subtitle-{{ section.id }}">{{ section.settings.subtitle }}</p>
      {% endif %}

      {% if section.settings.show_social_proof %}
        <div class="pet-favs-social-{{ section.id }}">
          {% if section.settings.proof_reviews != blank %}
            <span class="pet-favs-social-item-{{ section.id }}">
              <svg viewBox="0 0 24 24" fill="var(--pet-star)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {{ section.settings.proof_reviews }}
            </span>
          {% endif %}
          {% if section.settings.proof_buyers != blank %}
            <span class="pet-favs-social-item-{{ section.id }}">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--pet-primary)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
              {{ section.settings.proof_buyers }}
            </span>
          {% endif %}
          {% if section.settings.proof_shipping != blank %}
            <span class="pet-favs-social-item-{{ section.id }}">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--pet-primary)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" opacity="0.7"><polyline points="20 6 9 17 4 12"/></svg>
              {{ section.settings.proof_shipping }}
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>

    <div class="pet-favs-grid-{{ section.id }}">
      {% if fav_collection != blank and fav_collection.products.size > 0 %}
        {% for product in fav_collection.products limit: fav_limit %}
          {%- assign has_discount = false -%}
          {%- assign discount_pct = 0 -%}
          {%- if product.compare_at_price > product.price -%}
            {%- assign has_discount = true -%}
            {%- assign saved = product.compare_at_price | minus: product.price -%}
            {%- assign discount_pct = saved | times: 100 | divided_by: product.compare_at_price -%}
          {%- endif -%}

          <div class="pet-favs-card-{{ section.id }}">
            <a href="{{ product.url }}" class="pet-favs-img-{{ section.id }}">
              {% if product.featured_image != blank %}
                <img src="{{ product.featured_image | image_url: width: 400 }}"
                     srcset="{{ product.featured_image | image_url: width: 240 }} 240w,
                             {{ product.featured_image | image_url: width: 320 }} 320w,
                             {{ product.featured_image | image_url: width: 400 }} 400w"
                     sizes="(max-width: 420px) 48vw, (max-width: 768px) 52vw, (max-width: 1100px) 30vw, 22vw"
                     alt="{{ product.title | escape }}"
                     loading="lazy"
                     decoding="async"
                     width="400"
                     height="400">
              {% endif %}

              <div class="pet-favs-tag-{{ section.id }}">
                {% if has_discount %}
                  <span class="pet-favs-pill-{{ section.id }} pet-favs-pill-sale-{{ section.id }}">%{{ discount_pct }}</span>
                {% endif %}
                {% if forloop.index <= 4 %}
                  <span class="pet-favs-pill-{{ section.id }} pet-favs-pill-hot-{{ section.id }}">
                    <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                    Popüler
                  </span>
                {% endif %}
              </div>
            </a>

            <button class="pet-favs-heart-{{ section.id }}" aria-label="Favorilere ekle">
              <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            </button>

            <div class="pet-favs-body-{{ section.id }}">
              <a href="{{ product.url }}" class="pet-favs-product-title-{{ section.id }}">{{ product.title }}</a>

              <div class="pet-favs-stars-{{ section.id }}">
                {% for i in (1..5) %}
                  <svg class="pet-favs-star-icon-{{ section.id }}" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endfor %}
                <span class="pet-favs-stars-count-{{ section.id }}">({{ product.metafields.judgeme.review_count | default: '0' }})</span>
              </div>

              <div class="pet-favs-proof-{{ section.id }}">
                <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
                <span>{{ product.metafields.custom.recent_orders | default: section.settings.default_recent_orders }} kişi aldı</span>
              </div>

              <div class="pet-favs-prices-{{ section.id }}">
                <span class="pet-favs-price-{{ section.id }}">{{ product.price | money }}</span>
                {% if has_discount %}
                  <span class="pet-favs-compare-{{ section.id }}">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>

              <div class="pet-favs-cta-{{ section.id }}">
                {% if product.available %}
                  {% if product.variants.size > 1 %}
                    <a href="{{ product.url }}" class="pet-favs-btn-{{ section.id }}">
                      Seçenekleri Gör
                      <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                    </a>
                  {% else %}
                    <form method="post" action="/cart/add">
                      <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                      <button type="submit" class="pet-favs-btn-{{ section.id }}">
                        Sepete Ekle
                        <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
                      </button>
                    </form>
                  {% endif %}
                {% else %}
                  <button class="pet-favs-btn-{{ section.id }}" disabled>Tükendi</button>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}

      {% else %}
        {% for i in (1..4) %}
          <div class="pet-favs-card-{{ section.id }}">
            <div class="pet-favs-img-{{ section.id }}" style="display:flex;align-items:center;justify-content:center;">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#C4B5D4" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="m21 15-5-5L5 21"/>
              </svg>
            </div>
            <div class="pet-favs-body-{{ section.id }}">
              <span class="pet-favs-product-title-{{ section.id }}">Örnek Premium Ürün {{ i }}</span>
              <div class="pet-favs-stars-{{ section.id }}">
                {% for s in (1..5) %}
                  <svg class="pet-favs-star-icon-{{ section.id }}" viewBox="0 0 24 24" fill="#D1C9E0"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endfor %}
              </div>
              <div class="pet-favs-prices-{{ section.id }}">
                <span class="pet-favs-price-{{ section.id }}">₺299</span>
                <span class="pet-favs-compare-{{ section.id }}">₺399</span>
              </div>
              <div class="pet-favs-cta-{{ section.id }}"><span class="pet-favs-btn-{{ section.id }}">Sepete Ekle</span></div>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    {% if fav_collection != blank and section.settings.show_view_all %}
      <div class="pet-favs-viewall-{{ section.id }}">
        <a href="{{ fav_collection.url }}" class="pet-favs-viewall-link-{{ section.id }}">
          Tümünü Gör
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Premium Favoriler",
  "settings": [
    { "type": "header", "content": "Section" },
    { "type": "color", "id": "bg_color",            "label": "Background",    "default": "#FDFBFF" },
    { "type": "color", "id": "primary_color",       "label": "Primary Color", "default": "#7B3FF2" },
    { "type": "color", "id": "primary_light_color", "label": "Light Accent",  "default": "#B794F4" },
    { "type": "color", "id": "primary_deep_color",  "label": "Deep Accent",   "default": "#5B2FB2" },
    { "type": "range", "id": "max_width", "min": 1000, "max": 1800, "step": 50, "unit": "px", "label": "Max Width", "default": 1400 },

    { "type": "header", "content": "Heading" },
    { "type": "text",     "id": "badge_text", "label": "Badge",    "default": "En Popüler" },
    { "type": "textarea", "id": "title",      "label": "Title",    "info": "Mor vurgu: [kelime]", "default": "En Çok [Favorilenenler]" },
    { "type": "text",     "id": "subtitle",   "label": "Subtitle", "default": "Binlerce pet sahibinin tekrar tekrar tercih ettiği premium ürünler" },

    { "type": "header", "content": "Social Proof" },
    { "type": "checkbox", "id": "show_social_proof",     "label": "Social proof göster",     "default": true },
    { "type": "text",     "id": "proof_reviews",         "label": "Puan metni",              "default": "4.9 Ortalama Puan" },
    { "type": "text",     "id": "proof_buyers",          "label": "Müşteri metni",           "default": "50.000+ Mutlu Müşteri" },
    { "type": "text",     "id": "proof_shipping",        "label": "Kargo metni",             "default": "Ücretsiz Kargo" },
    { "type": "text",     "id": "default_recent_orders", "label": "Varsayılan satış sayısı", "default": "12" },

    { "type": "header", "content": "Koleksiyon" },
    {
      "type": "collection",
      "id": "collection",
      "label": "Koleksiyon",
      "info": "Shopify admin'den koleksiyon sıralamasını 'En çok satan' yaparak otomatik sıralama sağlayın."
    },
    { "type": "range",    "id": "product_limit", "min": 4, "max": 16, "step": 1, "label": "Ürün limiti", "default": 8 },
    { "type": "checkbox", "id": "show_view_all", "label": "Tümünü Gör butonu", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top",    "min": 0, "max": 120, "step": 5, "unit": "px", "label": "Padding Top",    "default": 50 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 50 }
  ],
  "presets": [
    {
      "name": "Premium Favoriler",
      "settings": {
        "badge_text": "En Popüler",
        "title": "En Çok [Favorilenenler]",
        "subtitle": "Binlerce pet sahibinin tekrar tekrar tercih ettiği premium ürünler"
      }
    }
  ]
}
{% endschema %}