<style>
.pet-ps-{{ section.id }} {
  --pet-primary: {{ section.settings.primary_color }};
  --pet-primary-light: {{ section.settings.primary_light_color }};
  --pet-primary-deep: {{ section.settings.primary_deep_color }};
  --pet-bg: {{ section.settings.bg_color }};
  --pet-card: #FFFFFF;
  --pet-image-bg: {{ section.settings.image_bg }};
  --pet-ink: #1F1342;
  --pet-body: #5A4F75;
  --pet-mute: #8B8299;
  --pet-line: rgba(123, 63, 242, 0.10);
  --pet-line-strong: rgba(123, 63, 242, 0.18);

  background-color: var(--pet-bg);
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, sans-serif;
  overflow: hidden;
}

.pet-ps-{{ section.id }} *,
.pet-ps-{{ section.id }} *::before,
.pet-ps-{{ section.id }} *::after {
  box-sizing: border-box;
}

.pet-ps-container-{{ section.id }} {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 16px;
}

@media (min-width: 750px) {
  .pet-ps-container-{{ section.id }} {
    padding: 0 24px;
  }
}

/* HEADER */
.pet-ps-header-{{ section.id }} {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  margin-bottom: 16px;
  gap: 16px;
}

.pet-ps-title-wrap-{{ section.id }} {
  display: flex;
  align-items: baseline;
  gap: 10px;
  min-width: 0;
}

.pet-ps-title-{{ section.id }} {
  font-size: 17px;
  font-weight: 800;
  color: var(--pet-ink);
  margin: 0;
  letter-spacing: -0.025em;
  line-height: 1.15;
}

.pet-ps-count-{{ section.id }} {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--pet-mute);
  letter-spacing: 0;
  white-space: nowrap;
}

@media (min-width: 750px) {
  .pet-ps-title-{{ section.id }} {
    font-size: clamp(20px, 1.9vw, {{ section.settings.title_size }}px);
    line-height: 1.15;
  }
  .pet-ps-count-{{ section.id }} {
    font-size: 13px;
  }
}

.pet-ps-actions-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}

.pet-ps-nav-{{ section.id }} {
  display: flex;
  gap: 6px;
}

.pet-ps-nav-btn-{{ section.id }} {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  background: var(--pet-card);
  border: 1.5px solid var(--pet-line-strong);
  color: var(--pet-ink);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.2s ease;
  padding: 0;
}

.pet-ps-nav-btn-{{ section.id }} svg {
  width: 12px;
  height: 12px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.4;
  stroke-linecap: square;
  stroke-linejoin: miter;
}

.pet-ps-nav-btn-{{ section.id }}:hover:not(:disabled) {
  background: var(--pet-primary);
  border-color: var(--pet-primary);
  color: #FFFFFF;
}

.pet-ps-nav-btn-{{ section.id }}:disabled {
  opacity: 0.35;
  cursor: not-allowed;
}

.pet-ps-view-all-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: var(--pet-primary);
  text-decoration: none;
  font-size: 12.5px;
  font-weight: 600;
  transition: gap 0.2s ease, color 0.2s ease;
  white-space: nowrap;
  padding: 6px 0;
}

@media (min-width: 750px) {
  .pet-ps-view-all-{{ section.id }} {
    font-size: 14px;
  }
}

.pet-ps-view-all-{{ section.id }}:hover {
  gap: 10px;
  color: var(--pet-primary-deep);
}

.pet-ps-view-all-{{ section.id }} svg {
  width: 13px;
  height: 13px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.4;
  stroke-linecap: square;
  stroke-linejoin: miter;
}

/* TRACK */
.pet-ps-track-wrapper-{{ section.id }} {
  position: relative;
  margin: 0 -16px;
  padding: 0 16px;
}

@media (min-width: 750px) {
  .pet-ps-track-wrapper-{{ section.id }} {
    margin: 0 -24px;
    padding: 0 24px;
  }
}

.pet-ps-track-{{ section.id }} {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  scroll-snap-type: x mandatory;
  scroll-behavior: smooth;
  scrollbar-width: none;
  padding: 4px 0 12px;
  -webkit-overflow-scrolling: touch;
}

@media (min-width: 750px) {
  .pet-ps-track-{{ section.id }} {
    gap: 12px;
  }
}

.pet-ps-track-{{ section.id }}::-webkit-scrollbar {
  display: none;
}

/* MOBİL: 2.5 kart - daha kompakt */
.pet-ps-slide-{{ section.id }} {
  flex: 0 0 calc((100% - 25px) / 2.5);
  scroll-snap-align: start;
  min-width: 0;
}

/* SMALL TABLET: 3 kart */
@media (min-width: 540px) {
  .pet-ps-slide-{{ section.id }} {
    flex: 0 0 calc((100% - 20px) / 3);
  }
}

/* TABLET: 4 kart */
@media (min-width: 750px) {
  .pet-ps-slide-{{ section.id }} {
    flex: 0 0 calc((100% - 36px) / 4);
  }
}

/* DESKTOP: 5 kart (kompakt görünüm) */
@media (min-width: 1024px) {
  .pet-ps-slide-{{ section.id }} {
    flex: 0 0 calc((100% - 48px) / 5);
  }
}

/* WIDE DESKTOP: 6 kart */
@media (min-width: 1440px) {
  .pet-ps-slide-{{ section.id }} {
    flex: 0 0 calc((100% - 60px) / 6);
  }
}

/* External product-card snippet */
.pet-ps-slide-{{ section.id }} > .forspaceon-pc-card,
.pet-ps-slide-{{ section.id }} > .product-card,
.pet-ps-slide-{{ section.id }} > .card {
  border-radius: 12px;
  transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.25s ease, border-color 0.25s ease;
}

.pet-ps-slide-{{ section.id }} > .forspaceon-pc-card:hover,
.pet-ps-slide-{{ section.id }} > .product-card:hover,
.pet-ps-slide-{{ section.id }} > .card:hover {
  border-color: var(--pet-primary-light);
  box-shadow: 0 8px 24px -12px rgba(123, 63, 242, 0.18);
  transform: translateY(-2px);
}

/* Kart konteyneri snippet'e bırakıldı; sadece slider için ufak hizalama */
.pet-ps-slide-{{ section.id }} .forspaceon-pc-card {
  height: 100%;
}


/* EMPTY STATE */
.pet-ps-empty-{{ section.id }} {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12px;
  padding: 60px 24px;
  border: 2px dashed var(--pet-line-strong);
  border-radius: 14px;
  background: rgba(123, 63, 242, 0.02);
  text-align: center;
}

.pet-ps-empty-icon-{{ section.id }} {
  width: 56px;
  height: 56px;
  border-radius: 14px;
  background: var(--pet-image-bg);
  color: var(--pet-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.pet-ps-empty-title-{{ section.id }} {
  font-size: 15px;
  font-weight: 700;
  color: var(--pet-ink);
  margin: 0;
}

.pet-ps-empty-desc-{{ section.id }} {
  font-size: 13px;
  color: var(--pet-body);
  margin: 0;
  max-width: 360px;
}

/* PAGINATION */
.pet-ps-pagination-{{ section.id }} {
  display: none;
  justify-content: center;
  align-items: center;
  gap: 6px;
  margin-top: 14px;
}

.pet-ps-dot-{{ section.id }} {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: rgba(123, 63, 242, 0.18);
  transition: all 0.3s ease;
  display: inline-block;
}

.pet-ps-dot-{{ section.id }}.is-active {
  background-color: var(--pet-primary);
  width: 22px;
  border-radius: 4px;
}

@media screen and (max-width: 768px) {
  .pet-ps-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.55 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.55 | round }}px;
  }

  .pet-ps-header-{{ section.id }} {
    margin-bottom: 14px;
  }

  .pet-ps-nav-{{ section.id }} {
    display: none;
  }

  .pet-ps-pagination-{{ section.id }} {
    display: flex;
  }
}

@media screen and (max-width: 420px) {
  .pet-ps-{{ section.id }} {
    padding-top: 22px;
    padding-bottom: 22px;
  }

  .pet-ps-container-{{ section.id }} {
    padding: 0 12px;
  }

  .pet-ps-track-wrapper-{{ section.id }} {
    margin: 0 -12px;
    padding: 0 12px;
  }

  /* En küçük mobilde 2.3 kart */
  .pet-ps-slide-{{ section.id }} {
    flex: 0 0 calc((100% - 18px) / 2.3);
  }

  .pet-ps-track-{{ section.id }} {
    gap: 9px;
    padding-right: 12px;
  }
}

@media (prefers-reduced-motion: reduce) {
  .pet-ps-track-{{ section.id }} {
    scroll-behavior: auto;
  }
}
</style>

<section class="pet-ps-{{ section.id }}">
  <div class="pet-ps-container-{{ section.id }}">

    <div class="pet-ps-header-{{ section.id }}">
      <div class="pet-ps-title-wrap-{{ section.id }}">
        <h2 class="pet-ps-title-{{ section.id }}">{{ section.settings.title }}</h2>
        {% if section.settings.show_count and section.settings.collection != blank and section.settings.collection.products_count > 0 %}
          {%- assign visible_count = section.settings.collection.products_count -%}
          {%- if visible_count > section.settings.limit -%}{%- assign visible_count = section.settings.limit -%}{%- endif -%}
          <span class="pet-ps-count-{{ section.id }}">{{ visible_count }} ürün</span>
        {% endif %}
      </div>

      <div class="pet-ps-actions-{{ section.id }}">
        {% if section.settings.show_nav_buttons %}
          <div class="pet-ps-nav-{{ section.id }}">
            <button type="button" class="pet-ps-nav-btn-{{ section.id }}" data-direction="prev" aria-label="Önceki">
              <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <button type="button" class="pet-ps-nav-btn-{{ section.id }}" data-direction="next" aria-label="Sonraki">
              <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        {% endif %}

        {% if section.settings.btn_label != blank and section.settings.collection != blank %}
          <a href="{{ section.settings.collection.url }}" class="pet-ps-view-all-{{ section.id }}">
            {{ section.settings.btn_label }}
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        {% endif %}
      </div>
    </div>

    {% if section.settings.collection != blank and section.settings.collection.products_count > 0 %}
      <div class="pet-ps-track-wrapper-{{ section.id }}">
        <div class="pet-ps-track-{{ section.id }}" id="Slider-{{ section.id }}">
          {% for product in section.settings.collection.products limit: section.settings.limit %}
            <div class="pet-ps-slide-{{ section.id }}">
              {% render 'product-card', product: product %}
            </div>
          {% endfor %}
        </div>
      </div>

      {% if section.settings.show_pagination %}
        <div class="pet-ps-pagination-{{ section.id }}">
          <span class="pet-ps-dot-{{ section.id }} is-active"></span>
          <span class="pet-ps-dot-{{ section.id }}"></span>
          <span class="pet-ps-dot-{{ section.id }}"></span>
        </div>
      {% endif %}

    {% else %}
      <div class="pet-ps-empty-{{ section.id }}">
        <span class="pet-ps-empty-icon-{{ section.id }}">
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M3 9h18"/>
            <path d="M9 21V9"/>
          </svg>
        </span>
        <h3 class="pet-ps-empty-title-{{ section.id }}">Henüz koleksiyon seçilmedi</h3>
        <p class="pet-ps-empty-desc-{{ section.id }}">Bu slider'da gösterilecek ürünleri tema editörü → bu bölümü düzenle → <strong>Select Collection</strong> alanından seç.</p>
      </div>
    {% endif %}

  </div>
</section>

<script>
(function() {
  var track = document.getElementById('Slider-{{ section.id }}');
  if (!track) return;

  var navBtns = document.querySelectorAll('.pet-ps-nav-btn-{{ section.id }}');
  var dots = document.querySelectorAll('.pet-ps-pagination-{{ section.id }} .pet-ps-dot-{{ section.id }}');

  function getScrollAmount() {
    var slide = track.querySelector('.pet-ps-slide-{{ section.id }}');
    if (!slide) return track.clientWidth * 0.8;
    var styles = window.getComputedStyle(track);
    var gap = parseFloat(styles.gap || styles.columnGap || '10');
    return slide.offsetWidth + gap;
  }

  function maxScroll() {
    return track.scrollWidth - track.clientWidth;
  }

  function updateButtons() {
    var max = maxScroll();
    navBtns.forEach(function(btn) {
      var dir = btn.getAttribute('data-direction');
      if (max <= 0) { btn.disabled = true; return; }
      if (dir === 'prev') {
        btn.disabled = track.scrollLeft <= 1;
      } else {
        btn.disabled = track.scrollLeft >= max - 1;
      }
    });
  }

  function updateDots() {
    if (dots.length !== 3) return;
    var max = maxScroll();
    if (max <= 0) {
      dots.forEach(function(d, i) { d.classList.toggle('is-active', i === 0); });
      return;
    }
    var percent = track.scrollLeft / max;
    if (percent < 0) percent = 0;
    if (percent > 1) percent = 1;
    var activeIndex = percent < 0.34 ? 0 : (percent < 0.67 ? 1 : 2);
    dots.forEach(function(d, i) { d.classList.toggle('is-active', i === activeIndex); });
  }

  navBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var dir = btn.getAttribute('data-direction');
      var amount = getScrollAmount();
      track.scrollBy({ left: dir === 'prev' ? -amount : amount, behavior: 'smooth' });
    });
  });

  var ticking = false;
  track.addEventListener('scroll', function() {
    if (!ticking) {
      window.requestAnimationFrame(function() {
        updateButtons();
        updateDots();
        ticking = false;
      });
      ticking = true;
    }
  });

  window.addEventListener('resize', function() {
    updateButtons();
    updateDots();
  });

  updateButtons();
  updateDots();
})();
</script>

{% schema %}
{
  "name": "Pet Product Slider",
  "settings": [
    { "type": "header", "content": "Colors" },
    { "type": "color", "id": "bg_color", "label": "Section Background", "default": "#FFFFFF" },
    { "type": "color", "id": "image_bg", "label": "Card Image Background", "default": "#F6F2FF" },
    { "type": "color", "id": "primary_color", "label": "Primary Color", "default": "#7B3FF2" },
    { "type": "color", "id": "primary_light_color", "label": "Açık Mor", "default": "#B794F4" },
    { "type": "color", "id": "primary_deep_color", "label": "Koyu Mor", "default": "#5B2FB2" },

    { "type": "header", "content": "Header" },
    { "type": "text", "id": "title", "label": "Section Title", "default": "Çok Satanlar" },
    { "type": "range", "id": "title_size", "min": 18, "max": 36, "step": 1, "unit": "px", "label": "Desktop Title Size", "default": 24 },
    { "type": "checkbox", "id": "show_count", "label": "Ürün Sayısı Göster (başlık yanında)", "default": true },
    { "type": "text", "id": "btn_label", "label": "View All Button Label", "default": "Tümünü Gör" },

    { "type": "header", "content": "Slider" },
    { "type": "collection", "id": "collection", "label": "Select Collection" },
    { "type": "range", "id": "limit", "min": 4, "max": 24, "step": 1, "label": "Maximum Products", "default": 10 },
    { "type": "checkbox", "id": "show_nav_buttons", "label": "Prev/Next Butonları", "default": true },
    { "type": "checkbox", "id": "show_pagination", "label": "Mobile Dots", "default": true },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "max_width", "min": 1000, "max": 1800, "step": 20, "unit": "px", "label": "Max Width", "default": 1440 },
    { "type": "range", "id": "padding_top", "min": 0, "max": 120, "step": 2, "unit": "px", "label": "Padding Top", "default": 30 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 120, "step": 2, "unit": "px", "label": "Padding Bottom", "default": 30 }
  ],
  "presets": [
    { "name": "Pet Product Slider" }
  ]
}
{% endschema %}