{% style %}
  :root {
    --tw-primary: {{ section.settings.primary_color }};
    --tw-text: {{ section.settings.text_color }};
    --tw-bg: {{ section.settings.bg_color }};
    --tw-light-gray: #f7f7f7;
    --tw-border: #eeeeee;
  }

  .twinkle-product-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: var(--tw-bg);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: var(--tw-text);
  }

  .twinkle-product-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* Breadcrumb */
  .twinkle-breadcrumb {
    font-size: 13px;
    color: #666;
    margin-bottom: 30px;
    text-align: center;
  }
  .twinkle-breadcrumb a {
    color: #666;
    text-decoration: none;
  }
  .twinkle-breadcrumb a:hover {
    color: var(--tw-primary);
  }

  /* Main Layout */
  .twinkle-product-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 40px;
  }
  .twinkle-product-media-col {
    width: calc(50% - 20px);
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  .twinkle-product-info-col {
    width: calc(50% - 20px);
  }

  /* Media Gallery (Thumbnails + Square Image) */
  .twinkle-gallery-wrapper {
    display: flex;
    gap: 20px;
    align-items: stretch;
  }
  
  .twinkle-gallery-thumbs {
    width: 80px;
    display: flex;
    flex-direction: column;
    position: relative;
    flex-shrink: 0;
  }
  .twinkle-thumb-nav {
    width: 100%;
    height: 30px;
    background: var(--tw-light-gray);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    border: none;
    color: #333;
    border-radius: 4px;
    margin-bottom: 10px;
    transition: background 0.2s;
  }
  .twinkle-thumb-nav:hover {
    background: #e0e0e0;
  }
  .twinkle-thumb-nav.nav-down {
    margin-bottom: 0;
    margin-top: 10px;
  }
  .twinkle-thumb-track {
    flex-grow: 1;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
    scroll-behavior: smooth;
    max-height: 500px; /* Kare boyutu aşmaması için */
  }
  .twinkle-thumb-track::-webkit-scrollbar {
    display: none;
  }
  .twinkle-thumb-item {
    width: 100%;
    aspect-ratio: 1/1;
    border: 1px solid var(--tw-border);
    border-radius: 8px;
    padding: 5px;
    cursor: pointer;
    background: #fff;
    transition: border 0.3s;
    flex-shrink: 0;
  }
  .twinkle-thumb-item.active {
    border-color: var(--tw-primary);
  }
  .twinkle-thumb-item img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Main Square Image */
  .twinkle-main-image {
    width: calc(100% - 100px);
    aspect-ratio: 1 / 1; /* Tam kare */
    background: var(--tw-light-gray);
    border-radius: 12px;
    position: relative;
    overflow: hidden;
  }
  .twinkle-main-image img {
    width: 100%;
    height: 100%;
    object-fit: cover; /* Kareyi boşluksuz doldurur */
    object-position: center;
    position: absolute;
    top: 0;
    left: 0;
  }

  /* Trust Badges Under Image */
  .twinkle-image-trust {
    display: flex;
    background: #f4f5f9;
    border-radius: 8px;
    padding: 15px;
    justify-content: space-between;
  }
  .twinkle-it-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    font-weight: 600;
    color: #444;
  }
  .twinkle-it-item svg {
    width: 16px;
    height: 16px;
    fill: #5c6c9a;
  }

  /* Right Side Info */
  .twinkle-block {
    margin-bottom: 20px;
  }
  .twinkle-discount-badge {
    display: inline-block;
    background: var(--tw-primary);
    color: #fff;
    font-size: 12px;
    font-weight: bold;
    padding: 4px 10px;
    border-radius: 15px;
    margin-bottom: 10px;
  }
  .twinkle-brand {
    font-size: 13px;
    color: #666;
    margin-bottom: 5px;
  }
  .twinkle-brand span {
    color: var(--tw-primary);
  }
  .twinkle-title {
    font-size: 26px;
    font-weight: 700;
    margin: 0 0 10px 0;
    line-height: 1.2;
  }
  
  .twinkle-price-wrap {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 15px;
  }
  .twinkle-compare-price {
    font-size: 18px;
    color: #999;
    text-decoration: line-through;
  }
  .twinkle-current-price {
    font-size: 22px;
    font-weight: 700;
    color: var(--tw-primary);
  }
  .twinkle-reviews {
    display: flex;
    align-items: center;
    gap: 5px;
    font-size: 13px;
    color: var(--tw-primary);
  }
  .twinkle-reviews svg {
    width: 14px;
    height: 14px;
    fill: #f59e0b;
  }

  /* Fire Alert */
  .twinkle-fire-alert {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #e53e3e;
    font-size: 14px;
    font-weight: 600;
  }
  .twinkle-fire-alert svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  /* Bullets */
  .twinkle-bullets {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 14px;
    color: #555;
    line-height: 1.8;
  }
  .twinkle-bullets li {
    position: relative;
    padding-left: 15px;
  }
  .twinkle-bullets li::before {
    content: "•";
    position: absolute;
    left: 0;
    color: #999;
  }

  /* Countdown Timer */
  .twinkle-countdown-box {
    margin-top: 10px;
  }
  .twinkle-countdown-title {
    font-size: 14px;
    font-weight: 600;
    margin-bottom: 10px;
  }
  .twinkle-timer {
    display: flex;
    gap: 8px;
  }
  .twinkle-t-box {
    border: 1px solid #eee;
    padding: 4px 6px;
    text-align: center;
    border-radius: 6px;
    min-width: 50px;
  }
  .twinkle-t-val {
    display: block;
    font-size: 16px;
    font-weight: 700;
    color: #e53e3e;
  }
  .twinkle-t-lbl {
    display: block;
    font-size: 9px;
    color: #999;
    text-transform: uppercase;
  }

  /* Form & Buttons */
  .twinkle-add-form {
    display: flex;
    flex-wrap: wrap;
    gap: 15px;
    margin-top: 25px;
  }
  .twinkle-qty {
    display: flex;
    align-items: center;
    border: 1px solid var(--tw-border);
    border-radius: 25px;
    padding: 0 15px;
    background: var(--tw-light-gray);
    height: 48px;
  }
  .twinkle-qty button {
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: #555;
    padding: 0 10px;
  }
  .twinkle-qty input {
    width: 40px;
    text-align: center;
    border: none;
    background: transparent;
    font-size: 16px;
    font-weight: 600;
    outline: none;
    -moz-appearance: textfield;
  }
  .twinkle-add-btn {
    flex-grow: 1;
    background: var(--tw-primary);
    color: #fff;
    border: none;
    border-radius: 25px;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    height: 48px;
    transition: opacity 0.3s;
  }
  .twinkle-add-btn:hover {
    opacity: 0.9;
  }

  /* Actions (Wishlist Only) */
  .twinkle-actions {
    display: flex;
    gap: 20px;
    margin-top: 15px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--tw-border);
  }
  .twinkle-action-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: none;
    border: none;
    cursor: pointer;
    font-size: 14px;
    font-weight: 600;
    color: #444;
  }
  .twinkle-action-btn svg {
    width: 18px;
    height: 18px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
  }
  .twinkle-action-btn.active svg {
    fill: var(--tw-primary);
    stroke: var(--tw-primary);
  }

  /* Info Lists */
  .twinkle-info-list {
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    font-size: 14px;
  }
  .twinkle-info-item {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .twinkle-info-item svg {
    width: 18px;
    height: 18px;
    fill: currentColor;
    flex-shrink: 0;
  }
  .twinkle-info-item span strong {
    color: #222;
  }

  /* Safe Checkout */
  .twinkle-safe-checkout {
    background: var(--tw-light-gray);
    border-radius: 8px;
    padding: 20px;
    text-align: center;
    margin-top: 20px;
  }
  .twinkle-safe-checkout p {
    font-size: 13px;
    font-weight: 600;
    margin: 0 0 10px 0;
  }
  .twinkle-payment-icons {
    display: flex;
    justify-content: center;
    gap: 5px;
    flex-wrap: wrap;
    align-items: center;
  }
  .twinkle-payment-icons svg {
    height: 24px;
    width: auto;
  }
  .twinkle-payment-icons img {
    height: auto;
    object-fit: contain;
  }

  /* Responsive Adjustments */
  @media screen and (max-width: 991px) {
    .twinkle-product-media-col, .twinkle-product-info-col {
      width: 100%;
    }
  }
  @media screen and (max-width: 768px) {
    .twinkle-gallery-wrapper {
      flex-direction: column-reverse;
      height: auto;
    }
    .twinkle-main-image {
      width: 100%;
      aspect-ratio: 1/1; /* Mobilde de kare kalır */
    }
    .twinkle-gallery-thumbs {
      width: 100%;
      flex-direction: row;
    }
    .twinkle-thumb-track {
      flex-direction: row;
      overflow-x: auto;
      overflow-y: hidden;
      max-height: none;
    }
    .twinkle-thumb-nav {
      display: none; /* Mobilde oklar gizlenir, yana kaydırılır */
    }
    .twinkle-thumb-item {
      width: 70px;
      height: 70px;
    }
    .twinkle-image-trust {
      flex-wrap: wrap;
    }
  }
{% endstyle %}

<div class="twinkle-product-section-{{ section.id }}">
  <div class="twinkle-product-container">
    
    <div class="twinkle-breadcrumb">
      <a href="/">{{ section.settings.bc_home }}</a> / 
      {% if collection %}
        <a href="{{ collection.url }}">{{ collection.title }}</a> / 
      {% else %}
        <a href="/collections/all">{{ section.settings.bc_shop }}</a> / 
      {% endif %}
      {{ product.title }}
    </div>

    <div class="twinkle-product-grid">
      
      <div class="twinkle-product-media-col">
        
        <div class="twinkle-gallery-wrapper">
          <div class="twinkle-gallery-thumbs">
            <button class="twinkle-thumb-nav nav-up" aria-label="Yukarı">
               <svg viewBox="0 0 24 24" width="16" height="16"><path d="M7.41 15.41L12 10.83l4.59 4.58L18 14l-6-6-6 6z"/></svg>
            </button>
            <div class="twinkle-thumb-track" id="twinkle-thumb-track">
              {% for media in product.media %}
                <div class="twinkle-thumb-item {% if forloop.first %}active{% endif %}" data-img="{{ media | img_url: 'master' }}">
                  <img src="{{ media | img_url: '150x150', crop: 'center' }}" alt="{{ media.alt | escape }}">
                </div>
              {% endfor %}
            </div>
            <button class="twinkle-thumb-nav nav-down" aria-label="Aşağı">
              <svg viewBox="0 0 24 24" width="16" height="16"><path d="M7.41 8.59L12 13.17l4.59-4.58L18 10l-6 6-6-6 1.41-1.41z"/></svg>
            </button>
          </div>

          <div class="twinkle-main-image">
            <img id="twinkle-main-img" src="{{ product.featured_media | img_url: 'master' }}" alt="{{ product.title | escape }}">
          </div>
        </div>

        <div class="twinkle-image-trust">
          <div class="twinkle-it-item">
            <svg viewBox="0 0 24 24"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
            {{ section.settings.trust_1 }}
          </div>
          <div class="twinkle-it-item">
            <svg viewBox="0 0 24 24"><path d="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8z"/><path d="M12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z"/></svg>
            {{ section.settings.trust_2 }}
          </div>
          <div class="twinkle-it-item">
            <svg viewBox="0 0 24 24"><path d="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zM6 18.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm13.5-9l1.96 2.5H17V9.5h2.5zm-1.5 9c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"/></svg>
            {{ section.settings.trust_3 }}
          </div>
        </div>
      </div>

      <div class="twinkle-product-info-col">
        {% for block in section.blocks %}
          {% case block.type %}
            
            {% when 'title_price' %}
              <div class="twinkle-block" {{ block.shopify_attributes }}>
                {% if product.compare_at_price > product.price %}
                  {% assign discount = product.compare_at_price | minus: product.price | times: 100.0 | divided_by: product.compare_at_price | round %}
                  <div class="twinkle-discount-badge">-{{ discount }}%</div>
                {% endif %}
                
                <div class="twinkle-brand">{{ block.settings.brand_label }} <span>{{ product.vendor }}</span></div>
                <h1 class="twinkle-title">{{ product.title }}</h1>
                
                <div class="twinkle-price-wrap">
                  {% if product.compare_at_price > product.price %}
                    <span class="twinkle-compare-price">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="twinkle-current-price">{{ product.price | money }}</span>
                  
                  <div class="twinkle-reviews">
                    {% render 'judgeme_widgets', widget_type: 'judgeme_preview_badge', jm_style: '', concierge_install: true, product: product %}
                    {% if product.metafields.judgeme.badge == blank %}
                       <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                       <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                       <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                       <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                       <svg viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
                       <span>{{ block.settings.review_text }}</span>
                    {% endif %}
                  </div>
                </div>
              </div>

            {% when 'fire_alert' %}
              <div class="twinkle-block twinkle-fire-alert" {{ block.shopify_attributes }}>
                <svg viewBox="0 0 24 24"><path d="M19.48,13.03A4,4,0,0,1,16,19h-4a2,2,0,0,1-2-2v-1a1,1,0,0,0-1-1H7.52a2.48,2.48,0,0,1,0-4.95A4.45,4.45,0,0,1,10.1,9h1A1,1,0,0,0,12,8V6.52a2.48,2.48,0,0,1,4.95,0A4.45,4.45,0,0,1,16.5,9.6a4,4,0,0,1,2.98,3.43ZM12,2A4.48,4.48,0,0,0,7.52,6.5a2.46,2.46,0,0,0-1.88.88A4.48,4.48,0,0,0,5.52,12a2.46,2.46,0,0,0-.88,1.88A4.48,4.48,0,0,0,9.12,18.4l1.3-1.3A2.47,2.47,0,0,1,10.1,16h-1a2.48,2.48,0,0,1,0-4.95A4.45,4.45,0,0,1,11.5,10.6a4,4,0,0,1,2.98-3.43A4,4,0,0,0,12,2ZM14.48,22A4.48,4.48,0,0,0,19,17.5a2.46,2.46,0,0,0,1.88-.88A4.48,4.48,0,0,0,21,12a2.46,2.46,0,0,0,.88-1.88A4.48,4.48,0,0,0,17.4,5.6l-1.3,1.3A2.47,2.47,0,0,1,16.42,8h1A2.48,2.48,0,0,1,17.42,13a4.45,4.45,0,0,1-2.4,1.4,4,4,0,0,1-2.98,3.43A4,4,0,0,0,14.48,22Z" transform="translate(-3.64 -2)"/></svg>
                <span>{{ block.settings.text_before }}</span>
                &nbsp;<strong id="twinkle-fire-num-{{ block.id }}" style="color: inherit;"></strong>&nbsp;
                <span>{{ block.settings.text_after }}</span>
              </div>
              <script>
                document.addEventListener('DOMContentLoaded', function() {
                  const min = {{ block.settings.min_val }};
                  const max = {{ block.settings.max_val }};
                  const randomNum = Math.floor(Math.random() * (max - min + 1)) + min;
                  document.getElementById('twinkle-fire-num-{{ block.id }}').innerText = randomNum;
                });
              </script>

            {% when 'description_bullets' %}
              <div class="twinkle-block" {{ block.shopify_attributes }}>
                <ul class="twinkle-bullets">
                  {% if product.metafields.custom.bullet_1 != blank %}
                    <li>{{ product.metafields.custom.bullet_1 }}</li>
                    <li>{{ product.metafields.custom.bullet_2 }}</li>
                    <li>{{ product.metafields.custom.bullet_3 }}</li>
                  {% else %}
                    <li>{{ block.settings.bullet_1 }}</li>
                    <li>{{ block.settings.bullet_2 }}</li>
                    <li>{{ block.settings.bullet_3 }}</li>
                  {% endif %}
                </ul>
              </div>

            {% when 'countdown' %}
              <div class="twinkle-block twinkle-countdown-box" {{ block.shopify_attributes }}>
                <div class="twinkle-countdown-title">{{ block.settings.title }}</div>
                <div class="twinkle-timer" id="twinkle-timer-{{ section.id }}" data-date="{{ block.settings.end_date }}">
                    <div class="twinkle-t-box"><span class="twinkle-t-val d-val">00</span><span class="twinkle-t-lbl">{{ block.settings.lbl_day }}</span></div>
                    <div class="twinkle-t-box"><span class="twinkle-t-val h-val">00</span><span class="twinkle-t-lbl">{{ block.settings.lbl_hour }}</span></div>
                    <div class="twinkle-t-box"><span class="twinkle-t-val m-val">00</span><span class="twinkle-t-lbl">{{ block.settings.lbl_min }}</span></div>
                    <div class="twinkle-t-box"><span class="twinkle-t-val s-val">00</span><span class="twinkle-t-lbl">{{ block.settings.lbl_sec }}</span></div>
                </div>
              </div>

            {% when 'buy_buttons' %}
              <div class="twinkle-block" {{ block.shopify_attributes }}>
                <form method="post" action="/cart/add" id="twinkle-add-form">
                  <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
                  
                  {% unless product.has_only_default_variant %}
                    <div style="margin-bottom: 15px;">
                      <label style="font-size:14px; font-weight:600; margin-bottom:5px; display:block;">{{ block.settings.opt_label }}</label>
                      <select name="id" style="width:100%; padding:10px; border-radius:8px; border:1px solid var(--tw-border);">
                        {% for variant in product.variants %}
                          <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected="selected"{% endif %}>
                            {{ variant.title }} - {{ variant.price | money }}
                          </option>
                        {% endfor %}
                      </select>
                    </div>
                  {% endunless %}

                  <div class="twinkle-add-form">
                    <div class="twinkle-qty">
                      <button type="button" onclick="const input = this.nextElementSibling; input.value = Math.max(1, parseInt(input.value) - 1);">&minus;</button>
                      <input type="number" name="quantity" value="1" min="1">
                      <button type="button" onclick="const input = this.previousElementSibling; input.value = parseInt(input.value) + 1;">&plus;</button>
                    </div>
                    
                    <button type="submit" class="twinkle-add-btn" {% unless product.available %}disabled{% endunless %}>
                      {% if product.available %}{{ block.settings.btn_add }}{% else %}{{ block.settings.btn_sold }}{% endif %}
                    </button>
                  </div>
                  
                  {% if product.available %}
                    <div style="margin-top: 15px;">
                       {{ form | payment_button }}
                    </div>
                  {% endif %}
                </form>

                <div class="twinkle-actions">
                  <button type="button" class="twinkle-action-btn twinkle-wishlist-btn" aria-label="Favorilere ekle"
                    data-product-id="{{ product.id }}"
                    data-product-handle="{{ product.handle }}"
                    data-product-title="{{ product.title | escape }}"
                    data-product-price="{{ product.price }}"
                    data-product-compare-price="{{ product.compare_at_price | default: 0 }}"
                    data-product-image="{{ product.featured_image | img_url: '600x600', crop: 'center' }}"
                    data-variant-id="{{ product.selected_or_first_available_variant.id }}"
                    data-product-url="{{ product.url }}">
                    <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                    {{ block.settings.btn_wishlist }}
                  </button>
                </div>
              </div>

            {% when 'info_list' %}
              <div class="twinkle-block twinkle-info-list" {{ block.shopify_attributes }}>
                <div class="twinkle-info-item">
                  <svg viewBox="0 0 24 24"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                  <span><strong>Şu an <span id="twinkle-view-num-{{ block.id }}"></span> kişi</strong> {{ block.settings.view_text }}</span>
                </div>
                <div class="twinkle-info-item">
                  <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                  <span><strong>{{ block.settings.del_title }}</strong> {{ block.settings.del_text }}</span>
                </div>
                <div class="twinkle-info-item">
                  <svg viewBox="0 0 24 24"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  <span><strong>{{ block.settings.ship_title }}</strong> {{ block.settings.ship_text }}</span>
                </div>
              </div>
              <script>
                document.addEventListener('DOMContentLoaded', function() {
                  const minV = {{ block.settings.min_view }};
                  const maxV = {{ block.settings.max_view }};
                  const randomView = Math.floor(Math.random() * (maxV - minV + 1)) + minV;
                  document.getElementById('twinkle-view-num-{{ block.id }}').innerText = randomView;
                });
              </script>

            {% when 'safe_checkout' %}
              <div class="twinkle-block twinkle-safe-checkout" {{ block.shopify_attributes }}>
                <p>{{ block.settings.title }}</p>
                <div class="twinkle-payment-icons">
                  {% if block.settings.safe_checkout_image != blank %}
                    <img src="{{ block.settings.safe_checkout_image | img_url: 'master' }}" 
                         alt="{{ block.settings.title | escape }}"
                         style="width: {{ block.settings.safe_checkout_image_width }}px;"
                         loading="lazy">
                  {% else %}
                    {% for type in shop.enabled_payment_types %}
                      {{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}
                    {% else %}
                      <img src="https://cdn.shopify.com/s/assets/payment_icons/visa-319d545c6fd255c9aad5eeaad21fd6f7f7b4fdbdb1a35ce83b89cca12a187f00.svg" alt="Visa">
                      <img src="https://cdn.shopify.com/s/assets/payment_icons/master-173035bc8124581983d4efa50cf8626e8553c2b311353fbf67485f9c1a2b88d1.svg" alt="Mastercard">
                      <img src="https://cdn.shopify.com/s/assets/payment_icons/amex-c023d6edde9ce7eec115da7383a5477d94f71a086ea78e6308ba6ab73c524024.svg" alt="Amex">
                    {% endfor %}
                  {% endif %}
                </div>
              </div>

          {% endcase %}
        {% endfor %}
      </div>

    </div>
  </div>
</div>

<script>
  (function() {
    const initGallery = () => {
      const thumbs = document.querySelectorAll('.twinkle-thumb-item');
      const mainImg = document.getElementById('twinkle-main-img');
      const track = document.getElementById('twinkle-thumb-track');
      const btnUp = document.querySelector('.nav-up');
      const btnDown = document.querySelector('.nav-down');

      if (!thumbs.length || !mainImg || !track) return;

      thumbs.forEach(thumb => {
        thumb.addEventListener('click', function() {
          thumbs.forEach(t => t.classList.remove('active'));
          this.classList.add('active');
          mainImg.src = this.getAttribute('data-img');
        });
      });

      if (btnUp && btnDown) {
        btnUp.addEventListener('click', () => {
          track.scrollBy({ top: -100, behavior: 'smooth' });
        });
        btnDown.addEventListener('click', () => {
          track.scrollBy({ top: 100, behavior: 'smooth' });
        });
      }
    };

    const initTimer = () => {
      const timerBox = document.getElementById('twinkle-timer-{{ section.id }}');
      if (!timerBox) return;

      const dateStr = timerBox.getAttribute('data-date');
      if (!dateStr) return;

      const endDate = new Date(dateStr.replace(/-/g, '/')).getTime();

      const updateTimer = () => {
        const now = new Date().getTime();
        const distance = endDate - now;

        if (distance < 0 || isNaN(distance)) {
           timerBox.innerHTML = '<div style="font-size:14px; font-weight:bold; color:var(--tw-primary);">İndirim Sona Erdi</div>';
           return;
        }

        const days = Math.floor(distance / (1000 * 60 * 60 * 24));
        const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((distance % (1000 * 60)) / 1000);

        timerBox.querySelector('.d-val').innerText = days < 10 ? '0' + days : days;
        timerBox.querySelector('.h-val').innerText = hours < 10 ? '0' + hours : hours;
        timerBox.querySelector('.m-val').innerText = minutes < 10 ? '0' + minutes : minutes;
        timerBox.querySelector('.s-val').innerText = seconds < 10 ? '0' + seconds : seconds;
      };

      updateTimer();
      setInterval(updateTimer, 1000);
    };

    document.addEventListener('DOMContentLoaded', () => {
      initGallery();
      initTimer();
    });
    
    document.addEventListener('shopify:section:load', function(event) {
      if (event.detail.sectionId === '{{ section.id }}') {
        initGallery();
        initTimer();
      }
    });
  })();
</script>

