{%- liquid
  assign primary    = section.settings.primary_color | default: '#7C3AED'
  assign desktop    = section.settings.desktop_columns | default: 4
  assign tablet     = section.settings.tablet_columns | default: 3
  assign mobile     = section.settings.mobile_columns | default: 2
  assign per_page   = section.settings.results_per_page | default: 24
  assign trends     = section.settings.trends | default: 'kedi maması,köpek maması,kum,oyuncak'
  assign trend_list = trends | split: ','
  assign terms      = search.terms | default: '' | strip
  assign has_terms  = false
  if terms != ''
    assign has_terms = true
  endif
-%}

{% style %}
  .tw-srch-{{ section.id }} {
    --c-pp: {{ primary }};
    --c-pp-tint: rgba(124, 58, 237, 0.10);
    --c-pp-soft: #FAF7FF;
    --c-ink: #1F1342;
    --c-body: #4B5563;
    --c-muted: #6B7280;
    --c-line: #ECE9F5;
    --c-soft: #FAF7FF;
    --c-r-card: 14px;
    --c-r-btn: 10px;
    --c-r-chip: 8px;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.bg_color | default: '#fff' }};
    color: var(--c-ink);
    font-family: inherit;
  }
  .tw-srch-{{ section.id }} *,
  .tw-srch-{{ section.id }} *::before,
  .tw-srch-{{ section.id }} *::after { box-sizing: border-box; }

  .tw-srch-inner-{{ section.id }} {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero */
  .tw-srch-hero-{{ section.id }} {
    background: linear-gradient(180deg, var(--c-soft) 0%, #fff 100%);
    border-radius: var(--c-r-card);
    padding: 36px 32px 32px;
    margin-bottom: 24px;
  }
  .tw-srch-crumbs-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 12.5px;
    color: var(--c-muted);
    margin-bottom: 12px;
  }
  .tw-srch-crumbs-{{ section.id }} a { color: var(--c-muted); text-decoration: none; padding: 2px 4px; transition: color .15s ease; }
  .tw-srch-crumbs-{{ section.id }} a:hover { color: var(--c-pp); }
  .tw-srch-crumbs-{{ section.id }} svg { width: 12px; height: 12px; stroke: currentColor; fill: none; stroke-width: 2.4; }
  .tw-srch-crumbs-{{ section.id }} .curr { color: var(--c-ink); font-weight: 700; padding: 2px 4px; }

  .tw-srch-title-{{ section.id }} {
    margin: 0 0 6px;
    font-size: clamp(24px, 3vw, 32px);
    font-weight: 800;
    letter-spacing: -0.025em;
    line-height: 1.15;
    color: var(--c-ink);
  }
  .tw-srch-title-{{ section.id }} em {
    font-style: normal;
    color: var(--c-pp);
  }
  .tw-srch-hero-hasq-{{ section.id }} {
    padding: 24px 28px 22px;
  }
  .tw-srch-hero-hasq-{{ section.id }} .tw-srch-title-{{ section.id }} {
    margin-bottom: 14px;
  }
  .tw-srch-sub-{{ section.id }} {
    margin: 0 0 22px;
    font-size: 14.5px;
    color: var(--c-body);
    line-height: 1.5;
  }
  .tw-srch-sub-{{ section.id }} strong { color: var(--c-ink); font-weight: 700; }

  /* CTA buton (boş durum) */
  .tw-srch-submit-{{ section.id }} {
    background: linear-gradient(135deg, var(--c-pp) 0%, #5B2FB2 100%);
    color: #fff;
    border: none;
    padding: 10px 22px;
    border-radius: var(--c-r-btn);
    font: inherit;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    transition: filter .18s ease, box-shadow .18s ease, transform .18s ease;
    box-shadow: 0 6px 18px -8px rgba(124, 58, 237, 0.45);
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }
  .tw-srch-submit-{{ section.id }}:hover { filter: brightness(1.05); transform: translateY(-1px); box-shadow: 0 10px 22px -8px rgba(124, 58, 237, 0.55); }
  .tw-srch-submit-{{ section.id }} svg { width: 14px; height: 14px; }

  /* Trends — tek satır, yatay kaydırma */
  .tw-srch-trends-{{ section.id }} {
    margin-top: 12px;
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--c-muted);
    min-width: 0;
  }
  .tw-srch-trends-label-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-weight: 700;
    color: var(--c-ink);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .tw-srch-trends-label-{{ section.id }} svg { width: 13px; height: 13px; color: var(--c-pp); flex-shrink: 0; }
  .tw-srch-trends-scroll-{{ section.id }} {
    display: flex;
    flex-wrap: nowrap;
    align-items: center;
    gap: 6px;
    overflow-x: auto;
    overflow-y: hidden;
    min-width: 0;
    flex: 1;
    padding-bottom: 2px;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
  }
  .tw-srch-trends-scroll-{{ section.id }}::-webkit-scrollbar { display: none; }
  .tw-srch-chip-{{ section.id }} {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    background: #fff;
    border: 1px solid var(--c-line);
    color: var(--c-ink);
    padding: 5px 10px;
    border-radius: var(--c-r-chip);
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background .15s ease, border-color .15s ease, color .15s ease;
  }
  .tw-srch-chip-{{ section.id }}:hover { background: var(--c-soft); border-color: var(--c-pp); color: var(--c-pp); }

  /* Toolbar */
  .tw-srch-toolbar-{{ section.id }} {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 14px;
    margin-bottom: 16px;
    padding: 12px 0;
    border-bottom: 1px solid var(--c-line);
  }
  .tw-srch-tb-count-{{ section.id }} {
    font-size: 13.5px;
    color: var(--c-body);
    font-weight: 500;
  }
  .tw-srch-tb-count-{{ section.id }} strong { color: var(--c-ink); font-weight: 800; }

  /* Grid */
  .tw-srch-grid-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat({{ desktop }}, minmax(0, 1fr));
    gap: {{ section.settings.grid_gap }}px;
    margin-bottom: 28px;
  }

  /* Empty / No-query state */
  .tw-srch-empty-{{ section.id }} {
    padding: 40px 24px;
    text-align: center;
    background: var(--c-soft);
    border: 1px dashed rgba(124, 58, 237, 0.18);
    border-radius: var(--c-r-card);
    margin-bottom: 24px;
  }
  .tw-srch-empty-ico-{{ section.id }} {
    width: 64px;
    height: 64px;
    margin: 0 auto 14px;
    background: #fff;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--c-pp);
    box-shadow: 0 8px 22px -10px rgba(124, 58, 237, 0.35);
  }
  .tw-srch-empty-ico-{{ section.id }} svg { width: 30px; height: 30px; stroke: currentColor; fill: none; stroke-width: 2; }
  .tw-srch-empty-{{ section.id }} h3 {
    margin: 0 0 6px;
    font-size: 18px;
    font-weight: 800;
    color: var(--c-ink);
    letter-spacing: -0.01em;
  }
  .tw-srch-empty-{{ section.id }} p {
    margin: 0 0 18px;
    font-size: 14px;
    color: var(--c-body);
    line-height: 1.55;
  }
  .tw-srch-empty-tips-{{ section.id }} {
    display: inline-flex;
    flex-direction: column;
    gap: 6px;
    text-align: left;
    margin: 0 auto 18px;
    color: var(--c-body);
    font-size: 13px;
  }
  .tw-srch-empty-tips-{{ section.id }} li {
    display: flex;
    gap: 8px;
    align-items: flex-start;
    list-style: none;
  }
  .tw-srch-empty-tips-{{ section.id }} li::before {
    content: "✓";
    color: var(--c-pp);
    font-weight: 800;
    line-height: 1.4;
  }

  /* Quick suggestions */
  .tw-srch-suggest-{{ section.id }} {
    margin-bottom: 32px;
  }
  .tw-srch-suggest-h-{{ section.id }} {
    font-size: 16px;
    font-weight: 800;
    color: var(--c-ink);
    margin: 0 0 14px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .tw-srch-suggest-h-{{ section.id }} svg { width: 18px; height: 18px; color: var(--c-pp); }
  .tw-srch-cats-{{ section.id }} {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 14px;
  }
  .tw-srch-cat-{{ section.id }} {
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--c-line);
    border-radius: var(--c-r-card);
    overflow: hidden;
    text-decoration: none;
    transition: border-color .18s ease, transform .18s ease, box-shadow .18s ease;
  }
  .tw-srch-cat-{{ section.id }}:hover {
    border-color: var(--c-pp);
    transform: translateY(-2px);
    box-shadow: 0 16px 32px -16px rgba(124, 58, 237, 0.25);
  }
  .tw-srch-cat-img-{{ section.id }} {
    aspect-ratio: 16 / 9;
    background: var(--c-pp-soft);
    overflow: hidden;
    position: relative;
  }
  .tw-srch-cat-img-{{ section.id }} img { width: 100%; height: 100%; object-fit: cover; transition: transform .35s cubic-bezier(0.2, 0.8, 0.2, 1); }
  .tw-srch-cat-{{ section.id }}:hover .tw-srch-cat-img-{{ section.id }} img { transform: scale(1.04); }
  .tw-srch-cat-body-{{ section.id }} {
    padding: 12px 14px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 10px;
  }
  .tw-srch-cat-name-{{ section.id }} {
    font-size: 13.5px;
    font-weight: 700;
    color: var(--c-ink);
    line-height: 1.25;
  }
  .tw-srch-cat-count-{{ section.id }} {
    font-size: 11.5px;
    color: var(--c-muted);
    margin-top: 2px;
  }
  .tw-srch-cat-go-{{ section.id }} {
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: var(--c-pp-tint);
    color: var(--c-pp);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .tw-srch-cat-go-{{ section.id }} svg { width: 14px; height: 14px; transition: transform .18s ease; }
  .tw-srch-cat-{{ section.id }}:hover .tw-srch-cat-go-{{ section.id }} svg { transform: translateX(3px); }

  /* Pagination */
  .tw-srch-pag-{{ section.id }} {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 6px;
    margin-top: 32px;
  }
  .tw-srch-pag-{{ section.id }} a,
  .tw-srch-pag-{{ section.id }} span {
    min-width: 36px;
    height: 36px;
    padding: 0 10px;
    border-radius: var(--c-r-btn);
    font-size: 13px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    border: 1px solid var(--c-line);
    background: #fff;
    color: var(--c-ink);
    transition: border-color .15s ease, color .15s ease, background .15s ease;
  }
  .tw-srch-pag-{{ section.id }} a:hover { border-color: var(--c-pp); color: var(--c-pp); background: var(--c-soft); }
  .tw-srch-pag-{{ section.id }} .is-current { background: var(--c-pp); border-color: var(--c-pp); color: #fff; }
  .tw-srch-pag-{{ section.id }} svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.2; stroke-linecap: round; }

  /* Responsive */
  @media (max-width: 991px) {
    .tw-srch-grid-{{ section.id }} { grid-template-columns: repeat({{ tablet }}, minmax(0, 1fr)); }
    .tw-srch-cats-{{ section.id }} { grid-template-columns: repeat(3, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .tw-srch-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.5 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round }}px;
    }
    .tw-srch-inner-{{ section.id }} { padding: 0 14px; }
    .tw-srch-hero-{{ section.id }} { padding: 20px 18px 22px; margin-bottom: 18px; border-radius: 12px; }
    .tw-srch-title-{{ section.id }} { font-size: 22px; }
    .tw-srch-sub-{{ section.id }} { font-size: 13px; margin-bottom: 14px; }
    .tw-srch-submit-{{ section.id }} { padding: 10px 14px; font-size: 13px; }
    .tw-srch-grid-{{ section.id }} { grid-template-columns: repeat({{ mobile }}, minmax(0, 1fr)); gap: 10px; }
    .tw-srch-cats-{{ section.id }} { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
  }
{% endstyle %}

<section class="tw-srch-{{ section.id }}">
  <div class="tw-srch-inner-{{ section.id }}">

    {%- comment -%} HERO {%- endcomment -%}
    <div class="tw-srch-hero-{{ section.id }}{% if has_terms %} tw-srch-hero-hasq-{{ section.id }}{% endif %}">
      <nav class="tw-srch-crumbs-{{ section.id }}" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">Anasayfa</a>
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        <span class="curr">Arama</span>
      </nav>

      {% if has_terms %}
        <h1 class="tw-srch-title-{{ section.id }}">
          {%- if search.performed and search.results_count > 0 -%}
            <em>{{ search.results_count }}</em> sonuç bulundu
          {%- elsif search.performed and search.results_count == 0 -%}
            Sonuç bulunamadı
          {%- else -%}
            Arama Sonuçları
          {%- endif -%}
        </h1>
      {% else %}
        <h1 class="tw-srch-title-{{ section.id }}">Patilerin için <em>doğru ürün</em></h1>
        <p class="tw-srch-sub-{{ section.id }}">Mama, kum, oyuncak, aksesuar — ne arıyorsan yazmaya başla.</p>
      {% endif %}

      {% if trend_list.size > 0 %}
        <div class="tw-srch-trends-{{ section.id }}">
          <span class="tw-srch-trends-label-{{ section.id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>
            Popüler
          </span>
          <div class="tw-srch-trends-scroll-{{ section.id }}">
            {% for t in trend_list limit: 4 %}
              {% assign t_clean = t | strip %}
              {% if t_clean != blank %}
                <a class="tw-srch-chip-{{ section.id }}" href="{{ routes.search_url }}?q={{ t_clean | url_encode }}&type=product">{{ t_clean }}</a>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      {% endif %}
    </div>

    {%- comment -%} RESULTS or STATES {%- endcomment -%}
    {% if search.performed and has_terms %}
      {% paginate search.results by per_page %}

        {% if search.results_count > 0 %}
          <div class="tw-srch-toolbar-{{ section.id }}">
            <span class="tw-srch-tb-count-{{ section.id }}"><strong>{{ search.results_count }}</strong> ürün listeleniyor</span>
          </div>

          <div class="tw-srch-grid-{{ section.id }}">
            {% for item in search.results %}
              {% if item.object_type == 'product' %}
                {% render 'product-card', product: item %}
              {% endif %}
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <nav class="tw-srch-pag-{{ section.id }}" aria-label="Sayfalar">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" aria-label="Önceki sayfa">
                  <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
                </a>
              {% endif %}
              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}">{{ part.title }}</a>
                {% else %}
                  <span class="{% if part.title == paginate.current_page %}is-current{% endif %}">{{ part.title }}</span>
                {% endif %}
              {% endfor %}
              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" aria-label="Sonraki sayfa">
                  <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              {% endif %}
            </nav>
          {% endif %}

        {% else %}
          {%- comment -%} No results {%- endcomment -%}
          <div class="tw-srch-empty-{{ section.id }}">
            <div class="tw-srch-empty-ico-{{ section.id }}">
              <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/><line x1="8" y1="11" x2="14" y2="11"/></svg>
            </div>
            <h3>"{{ terms | escape }}" için sonuç bulamadık</h3>
            <p>Aradığını farklı bir şekilde ifade etmeyi dene veya aşağıdaki popüler kategorilerden birine göz at.</p>
            <ul class="tw-srch-empty-tips-{{ section.id }}">
              <li>Yazımı kontrol et</li>
              <li>Daha az veya farklı kelime kullan</li>
              <li>Genel bir terim dene: "mama", "kum", "oyuncak"</li>
            </ul>
            <a href="{{ routes.all_products_collection_url }}" class="tw-srch-submit-{{ section.id }}">
              Tüm Ürünleri Gör
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        {% endif %}

      {% endpaginate %}
    {% endif %}

    {%- comment -%} CATEGORIES — show when no query OR when search returned 0 {%- endcomment -%}
    {% if has_terms == false or search.results_count == 0 %}
      {%- liquid
        assign cat_handles = section.settings.featured_collections | default: 'kedi-mamasi,kopek-mamasi,kum,oyuncak'
        assign cat_list = cat_handles | split: ','
      -%}
      <div class="tw-srch-suggest-{{ section.id }}">
        <h2 class="tw-srch-suggest-h-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          {% if has_terms %}Bu kategorilere göz atmak ister misin?{% else %}Popüler kategoriler{% endif %}
        </h2>
        <div class="tw-srch-cats-{{ section.id }}">
          {% for ch in cat_list limit: 4 %}
            {%- assign handle = ch | strip -%}
            {%- assign coll = collections[handle] -%}
            {% if coll and coll.handle != '' %}
              <a class="tw-srch-cat-{{ section.id }}" href="{{ coll.url }}">
                <div class="tw-srch-cat-img-{{ section.id }}">
                  {% if coll.image %}
                    <img src="{{ coll.image | image_url: width: 500 }}" alt="{{ coll.title | escape }}" loading="lazy" width="500" height="282">
                  {% elsif coll.products.first.featured_image %}
                    <img src="{{ coll.products.first.featured_image | image_url: width: 500 }}" alt="{{ coll.title | escape }}" loading="lazy" width="500" height="282">
                  {% endif %}
                </div>
                <div class="tw-srch-cat-body-{{ section.id }}">
                  <div>
                    <div class="tw-srch-cat-name-{{ section.id }}">{{ coll.title }}</div>
                    <div class="tw-srch-cat-count-{{ section.id }}">{{ coll.products_count }} ürün</div>
                  </div>
                  <span class="tw-srch-cat-go-{{ section.id }}" aria-hidden="true">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </span>
                </div>
              </a>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}

  </div>
</section>

{% schema %}
{
  "name": "Twinkle Search Page",
  "settings": [
    { "type": "header", "content": "Metinler" },
    { "type": "paragraph", "content": "Arama kutusu site başlığındaki aramadan kullanılıyor. Bu sayfa sadece sonuçları ve popüler kategorileri göstermek için tasarlandı." },
    { "type": "textarea", "id": "trends", "label": "Popüler aramalar (virgülle, en fazla 4 gösterilir)", "default": "kedi maması,köpek maması,kum,oyuncak" },
    { "type": "text", "id": "featured_collections", "label": "Önerilen koleksiyon handle'ları (virgülle)", "default": "kedi-mamasi,kopek-mamasi,kum,oyuncak" },

    { "type": "header", "content": "Grid" },
    { "type": "range", "id": "results_per_page", "min": 8, "max": 48, "step": 4, "label": "Sayfa başına ürün", "default": 24 },
    { "type": "range", "id": "desktop_columns", "min": 2, "max": 6, "step": 1, "label": "Masaüstü sütun", "default": 4 },
    { "type": "range", "id": "tablet_columns", "min": 2, "max": 4, "step": 1, "label": "Tablet sütun", "default": 3 },
    { "type": "range", "id": "mobile_columns", "min": 1, "max": 3, "step": 1, "label": "Mobil sütun", "default": 2 },
    { "type": "range", "id": "grid_gap", "min": 8, "max": 32, "step": 2, "unit": "px", "label": "Kartlar arası boşluk", "default": 18 },

    { "type": "header", "content": "Renk & Düzen" },
    { "type": "color", "id": "bg_color", "label": "Arka plan", "default": "#ffffff" },
    { "type": "color", "id": "primary_color", "label": "Vurgu rengi", "default": "#7C3AED" },
