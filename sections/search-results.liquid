{% style %}
  :root {
    --tw-search-bg: {{ section.settings.bg_color }};
    --tw-search-text: {{ section.settings.text_color }};
    --tw-search-primary: {{ section.settings.primary_color }};
    --tw-search-border: {{ section.settings.border_color }};
  }

  .tw-search-section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background-color: var(--tw-search-bg);
    color: var(--tw-search-text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
  }

  .tw-search-container {
    max-width: {{ section.settings.container_max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .tw-search-header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 50px auto;
  }

  .tw-search-title {
    font-size: 32px;
    font-weight: 700;
    margin-bottom: 10px;
    color: var(--tw-search-text);
  }

  .tw-search-subtitle {
    font-size: 15px;
    color: #666;
    margin-bottom: 30px;
  }

  .tw-search-form {
    position: relative;
    display: flex;
    width: 100%;
  }

  .tw-search-input {
    width: 100%;
    padding: 16px 20px 16px 50px;
    font-size: 16px;
    border: 1px solid var(--tw-search-border);
    border-radius: 8px;
    outline: none;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
  }

  .tw-search-input:focus {
    border-color: var(--tw-search-primary);
    box-shadow: 0 0 0 3px rgba(138, 59, 142, 0.1);
  }

  .tw-search-icon {
    position: absolute;
    left: 18px;
    top: 50%;
    transform: translateY(-50%);
    width: 20px;
    height: 20px;
    fill: #999;
  }

  .tw-search-submit {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    background: var(--tw-search-primary);
    color: #fff;
    border: none;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .tw-search-submit:hover {
    opacity: 0.9;
  }

  .tw-search-results-info {
    font-size: 14px;
    color: #555;
    margin-bottom: 30px;
    text-align: left;
    border-bottom: 1px solid var(--tw-search-border);
    padding-bottom: 15px;
  }

  .tw-search-grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.desktop_columns }}, 1fr);
    gap: {{ section.settings.grid_gap }}px;
  }

  .tw-search-empty {
    text-align: center;
    padding: 60px 20px;
    background: #fdfdfd;
    border: 1px dashed var(--tw-search-border);
    border-radius: 8px;
  }

  .tw-search-empty svg {
    width: 48px;
    height: 48px;
    fill: #ccc;
    margin-bottom: 15px;
  }

  .tw-search-empty h3 {
    font-size: 20px;
    margin-bottom: 10px;
  }

  .tw-pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 50px;
  }

  .tw-page-link, .tw-page-current {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 40px;
    height: 40px;
    padding: 0 10px;
    border-radius: 6px;
    text-decoration: none;
    font-size: 14px;
    font-weight: 600;
  }

  .tw-page-link {
    background: #fff;
    color: var(--tw-search-text);
    border: 1px solid var(--tw-search-border);
    transition: all 0.2s ease;
  }

  .tw-page-link:hover {
    border-color: var(--tw-search-primary);
    color: var(--tw-search-primary);
  }

  .tw-page-current {
    background: var(--tw-search-primary);
    color: #fff;
    border: 1px solid var(--tw-search-primary);
  }

  @media screen and (max-width: 991px) {
    .tw-search-grid {
      grid-template-columns: repeat({{ section.settings.tablet_columns }}, 1fr);
    }
  }

  @media screen and (max-width: 767px) {
    .tw-search-title { font-size: 26px; }
    .tw-search-grid {
      grid-template-columns: repeat({{ section.settings.mobile_columns }}, 1fr);
      gap: 15px;
    }
    .tw-search-submit {
      padding: 8px 12px;
      font-size: 13px;
    }
  }
{% endstyle %}

<div class="tw-search-section-{{ section.id }}">
  <div class="tw-search-container">
    
    <div class="tw-search-header">
      <h1 class="tw-search-title">{{ section.settings.heading }}</h1>
      <p class="tw-search-subtitle">{{ section.settings.subheading }}</p>

      <form action="{{ routes.search_url }}" method="get" role="search" class="tw-search-form">
        <input type="hidden" name="type" value="product">
        <input type="hidden" name="options[prefix]" value="last">
        
        <svg class="tw-search-icon" viewBox="0 0 24 24">
          <path d="M15.5 14h-.79l-.28-.27A6.471 6.471 0 0 0 16 9.5 6.5 6.5 0 1 0 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z"/>
        </svg>

        <input 
          type="search" 
          name="q" 
          value="{{ search.terms | escape }}" 
          placeholder="{{ section.settings.placeholder_text }}" 
          class="tw-search-input"
        >
        <button type="submit" class="tw-search-submit">{{ section.settings.button_text }}</button>
      </form>
    </div>

    {% if search.performed %}
      {% paginate search.results by section.settings.results_per_page %}
        
        <div class="tw-search-results-info">
          "<strong>{{ search.terms | escape }}</strong>" için {{ search.results_count }} sonuç bulundu.
        </div>

        {% if search.results_count == 0 %}
          <div class="tw-search-empty">
            <svg viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>
            <h3>Sonuç Bulunamadı</h3>
            <p>Farklı kelimeler kullanarak tekrar aramayı deneyebilirsiniz.</p>
          </div>
        {% else %}
          
          <div class="tw-search-grid">
            {% for item in search.results %}
              {% if item.object_type == 'product' %}
                {% render 'product-card', product: item %}
              {% endif %}
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="tw-pagination">
              {% if paginate.previous %}
                <a href="{{ paginate.previous.url }}" class="tw-page-link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
                </a>
              {% endif %}

              {% for part in paginate.parts %}
                {% if part.is_link %}
                  <a href="{{ part.url }}" class="tw-page-link">{{ part.title }}</a>
                {% else %}
                  <span class="{% if part.title == paginate.current_page %}tw-page-current{% else %}tw-page-link{% endif %}">{{ part.title }}</span>
                {% endif %}
              {% endfor %}

              {% if paginate.next %}
                <a href="{{ paginate.next.url }}" class="tw-page-link">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
                </a>
              {% endif %}
            </div>
          {% endif %}

        {% endif %}

      {% endpaginate %}
    {% endif %}

  </div>
</div>

{% schema %}
{
  "name": "Twinkle Search Page",
  "settings": [
    {
      "type": "header",
      "content": "Metinler ve Başlıklar"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Ana Başlık",
      "default": "Mağazada Ara"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Alt Başlık",
      "default": "Aradığınız ürünü bulmak için aşağıdaki alanı kullanın."
    },
    {
      "type": "text",
      "id": "placeholder_text",
      "label": "Arama Kutusu Metni",
      "default": "Ürün adı, marka veya kategori yazın..."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Buton Metni",
      "default": "Ara"
    },
    {
      "type": "header",
      "content": "Grid ve Sayfalama Ayarları"
    },
    {
      "type": "range",
      "id": "results_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Sayfa Başına Ürün",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_columns",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Masaüstü Sütun Sayısı",
      "default": 4
    },
    {
      "type": "range",
      "id": "tablet_columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Tablet Sütun Sayısı",
      "default": 3
    },
    {
      "type": "range",
      "id": "mobile_columns",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Mobil Sütun Sayısı",
      "default": 2
    },
    {
      "type": "range",
      "id": "grid_gap",
      "min": 10,
      "max": 40,
      "step": 5,
      "label": "Ürünler Arası Boşluk",
      "default": 20
    },
    {
      "type": "header",
      "content": "Renk ve Stil Ayarları"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Arkaplan Rengi",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Metin Rengi",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Vurgu Rengi (Buton/Hover)",
      "default": "#8a3b8e"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Çizgi Rengi",
      "default": "#eeeeee"
    },
    {
      "type": "header",
      "content": "Boşluk Ayarları"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 1000,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Maksimum İçerik Genişliği",
      "default": 1200
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Üst Boşluk (Padding Top)",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "label": "Alt Boşluk (Padding Bottom)",
      "default": 60
    }
  ]
}
{% endschema %}