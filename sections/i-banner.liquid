{%- assign promo_cols = section.blocks.size -%}
{%- if promo_cols > 2 -%}{%- assign promo_cols = 2 -%}{%- endif -%}
{%- if promo_cols < 1 -%}{%- assign promo_cols = 1 -%}{%- endif -%}

<style>
.pet-promo-{{ section.id }} {
  --pet-primary: {{ section.settings.primary_color }};
  --pet-primary-light: {{ section.settings.primary_light_color }};
  --pet-primary-deep: {{ section.settings.primary_deep_color }};
  --pet-bg: {{ section.settings.bg_color }};
  --pet-ink: #1F1342;
  --pet-body: #5A4F75;
  --pet-line: rgba(123, 63, 242, 0.14);
  --pet-card: #FFFFFF;
  --pet-radius: 28px;

  position: relative;
  background:
    radial-gradient(600px 400px at 80% 20%, rgba(123, 63, 242, 0.06), transparent 60%),
    radial-gradient(500px 350px at 10% 80%, rgba(123, 63, 242, 0.04), transparent 55%),
    var(--pet-bg);
  padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  font-family: inherit;
  overflow: hidden;
  isolation: isolate;
}

.pet-promo-{{ section.id }} *,
.pet-promo-{{ section.id }} *::before,
.pet-promo-{{ section.id }} *::after {
  box-sizing: border-box;
}

.pet-promo-{{ section.id }}::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(123, 63, 242, 0.12) 1px, transparent 1px);
  background-size: 26px 26px;
  opacity: 0.3;
  mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  pointer-events: none;
  z-index: 0;
}

.pet-promo-container-{{ section.id }} {
  position: relative;
  z-index: 1;
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ===== SECTION HEADER ===== */
.pet-promo-header-{{ section.id }} {
  text-align: center;
  margin-bottom: 32px;
}

.pet-promo-section-badge-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background-color: var(--pet-card);
  color: var(--pet-ink);
  padding: 7px 16px 7px 7px;
  border-radius: 100px;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  margin-bottom: 16px;
  border: 1px solid var(--pet-line);
  box-shadow: 0 4px 12px -6px rgba(123, 63, 242, 0.18);
}

.pet-promo-section-badge-dot-{{ section.id }} {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: var(--pet-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pet-promo-section-badge-dot-{{ section.id }} svg {
  width: 10px;
  height: 10px;
  fill: #fff;
}

.pet-promo-section-title-{{ section.id }} {
  font-size: clamp(24px, 3vw, 36px);
  font-weight: 800;
  color: var(--pet-ink);
  line-height: 1.15;
  margin: 0;
  letter-spacing: -0.025em;
  text-wrap: balance;
}

.pet-promo-section-title-{{ section.id }} .highlight {
  color: var(--pet-primary);
  position: relative;
  display: inline-block;
}

.pet-promo-section-title-{{ section.id }} .highlight::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0.06em;
  height: 0.2em;
  background: var(--pet-primary-light);
  opacity: 0.4;
  border-radius: 4px;
  z-index: -1;
}

/* ===== GRID ===== */
.pet-promo-grid-{{ section.id }} {
  display: grid;
  grid-template-columns: repeat({{ promo_cols }}, minmax(0, 1fr));
  gap: 20px;
}

/* ===== CARD ===== */
.pet-promo-card-{{ section.id }} {
  position: relative;
  border-radius: var(--pet-radius);
  padding: 40px 44px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  text-decoration: none;
  overflow: hidden;
  isolation: isolate;
  min-height: 210px;
  border: 1px solid rgba(255,255,255,0.7);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  -webkit-tap-highlight-color: transparent;
  box-shadow:
    0 1px 2px rgba(31, 19, 66, 0.03),
    0 8px 24px -8px rgba(123, 63, 242, 0.08);
}

.pet-promo-card-{{ section.id }}::before {
  content: "";
  position: absolute;
  top: -50%;
  right: -12%;
  width: 300px;
  height: 300px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255,255,255,0.45) 0%, rgba(255,255,255,0) 70%);
  z-index: 0;
  pointer-events: none;
}

.pet-promo-card-{{ section.id }}::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: var(--pet-radius);
  background: linear-gradient(160deg, rgba(255,255,255,0.18) 0%, transparent 50%);
  z-index: 0;
  pointer-events: none;
}

@media (hover: hover) {
  .pet-promo-card-{{ section.id }}:hover {
    transform: translateY(-5px);
    box-shadow:
      0 1px 2px rgba(31, 19, 66, 0.04),
      0 24px 48px -16px rgba(123, 63, 242, 0.22),
      0 48px 80px -32px rgba(123, 63, 242, 0.12);
  }
}

/* ===== CONTENT ===== */
.pet-promo-content-{{ section.id }} {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  position: relative;
  z-index: 2;
  flex: 1;
  min-width: 0;
}

.pet-promo-eyebrow-{{ section.id }} {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  margin: 0 0 12px 0;
  display: inline-flex;
  align-items: center;
  gap: 8px;
}

.pet-promo-eyebrow-line-{{ section.id }} {
  display: inline-block;
  width: 20px;
  height: 2px;
  border-radius: 2px;
  background: currentColor;
}

.pet-promo-title-{{ section.id }} {
  font-size: clamp(22px, 2.4vw, 30px);
  font-weight: 800;
  line-height: 1.15;
  margin: 0 0 22px 0;
  color: var(--pet-ink);
  letter-spacing: -0.025em;
  text-wrap: balance;
}

.pet-promo-btn-{{ section.id }} {
  padding: 12px 20px 12px 24px;
  border-radius: 100px;
  font-size: 13.5px;
  font-weight: 600;
  color: #FFFFFF;
  display: inline-flex;
  align-items: center;
  gap: 9px;
  letter-spacing: 0.01em;
  transition: box-shadow 0.3s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 0 6px 16px -6px rgba(31, 19, 66, 0.3);
  white-space: nowrap;
}

.pet-promo-btn-{{ section.id }} .pet-btn-arrow-{{ section.id }} {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  background: rgba(255,255,255,0.25);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), background 0.3s ease;
}

.pet-promo-btn-{{ section.id }} .pet-btn-arrow-{{ section.id }} svg {
  width: 11px;
  height: 11px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
}

@media (hover: hover) {
  .pet-promo-card-{{ section.id }}:hover .pet-promo-btn-{{ section.id }} {
    box-shadow: 0 10px 24px -6px rgba(31, 19, 66, 0.4);
    transform: translateY(-1px);
  }
  .pet-promo-card-{{ section.id }}:hover .pet-btn-arrow-{{ section.id }} {
    background: rgba(255,255,255,0.4);
    transform: translateX(2px);
  }
}

/* ===== VISUAL / ICON ===== */
.pet-promo-visual-{{ section.id }} {
  position: relative;
  z-index: 1;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-left: 24px;
}

.pet-promo-icon-wrap-{{ section.id }} {
  width: 130px;
  height: 130px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255,255,255,0.5);
  border: 1px solid rgba(255,255,255,0.8);
  box-shadow: 0 8px 24px -8px rgba(31, 19, 66, 0.12);
}

.pet-promo-icon-{{ section.id }} {
  width: 72px;
  height: 72px;
  display: block;
  stroke-width: 1.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  fill: none;
  filter: drop-shadow(0 4px 8px rgba(31, 19, 66, 0.1));
}

@media (hover: hover) {
  .pet-promo-icon-wrap-{{ section.id }} {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease;
  }
  .pet-promo-card-{{ section.id }}:hover .pet-promo-icon-wrap-{{ section.id }} {
    transform: scale(1.06) rotate(-3deg);
    box-shadow: 0 12px 32px -8px rgba(31, 19, 66, 0.18);
  }
}

/* ===== TABLET (≤990px) ===== */
@media screen and (max-width: 990px) {
  .pet-promo-card-{{ section.id }} {
    padding: 32px 32px;
    min-height: 180px;
  }
  .pet-promo-icon-wrap-{{ section.id }} { width: 110px; height: 110px; }
  .pet-promo-icon-{{ section.id }} { width: 60px; height: 60px; }
}

/* ===== MOBİL (≤768px) ===== */
@media screen and (max-width: 768px) {
  .pet-promo-{{ section.id }} {
    padding: {{ section.settings.padding_top | times: 0.6 | round }}px 0 {{ section.settings.padding_bottom | times: 0.6 | round }}px;
  }

  .pet-promo-{{ section.id }}::before { opacity: 0.2; }

  .pet-promo-container-{{ section.id }} { padding: 0 16px; }

  .pet-promo-header-{{ section.id }} { margin-bottom: 24px; }

  .pet-promo-section-badge-{{ section.id }} {
    font-size: 11px;
    padding: 6px 14px 6px 6px;
    margin-bottom: 12px;
  }

  .pet-promo-section-title-{{ section.id }} {
    font-size: clamp(20px, 5.5vw, 28px);
  }

  .pet-promo-grid-{{ section.id }} {
    grid-template-columns: 1fr;
    gap: 14px;
  }

  .pet-promo-card-{{ section.id }} {
    padding: 26px 24px;
    min-height: 150px;
    border-radius: 22px;
  }

  .pet-promo-card-{{ section.id }}::before {
    width: 200px;
    height: 200px;
  }

  .pet-promo-eyebrow-{{ section.id }} { font-size: 10px; letter-spacing: 0.12em; margin-bottom: 10px; }

  .pet-promo-title-{{ section.id }} {
    font-size: clamp(18px, 4.5vw, 23px);
    margin-bottom: 16px;
  }

  .pet-promo-btn-{{ section.id }} {
    padding: 10px 16px 10px 20px;
    font-size: 12.5px;
    min-height: 40px;
  }

  .pet-promo-btn-{{ section.id }} .pet-btn-arrow-{{ section.id }} {
    width: 18px;
    height: 18px;
  }

  .pet-promo-icon-wrap-{{ section.id }} { width: 96px; height: 96px; }
  .pet-promo-icon-{{ section.id }} { width: 52px; height: 52px; }
  .pet-promo-visual-{{ section.id }} { margin-left: 16px; }
}

/* ===== KÜÇÜK MOBİL (≤420px) ===== */
@media screen and (max-width: 420px) {
  .pet-promo-{{ section.id }} { padding: 20px 0; }
  .pet-promo-container-{{ section.id }} { padding: 0 12px; }
  .pet-promo-grid-{{ section.id }} { gap: 10px; }

  .pet-promo-card-{{ section.id }} {
    padding: 22px 18px;
    border-radius: 18px;
  }

  .pet-promo-title-{{ section.id }} {
    font-size: 17px;
    margin-bottom: 14px;
  }

  .pet-promo-icon-wrap-{{ section.id }} { width: 80px; height: 80px; }
  .pet-promo-icon-{{ section.id }} { width: 44px; height: 44px; }

  .pet-promo-btn-{{ section.id }} {
    padding: 9px 14px 9px 16px;
    font-size: 12px;
    min-height: 38px;
  }

  .pet-promo-visual-{{ section.id }} { margin-left: 12px; }
}

@media (prefers-reduced-motion: reduce) {
  .pet-promo-card-{{ section.id }},
  .pet-promo-icon-wrap-{{ section.id }},
  .pet-promo-btn-{{ section.id }},
  .pet-btn-arrow-{{ section.id }} {
    transition: none !important;
  }
}
</style>

<section class="pet-promo-{{ section.id }}" aria-label="Ürün Kategorileri">
  <div class="pet-promo-container-{{ section.id }}">

    {% if section.settings.section_title != blank or section.settings.section_badge != blank %}
      <div class="pet-promo-header-{{ section.id }}">
        {% if section.settings.section_badge != blank %}
          <div class="pet-promo-section-badge-{{ section.id }}">
            <span class="pet-promo-section-badge-dot-{{ section.id }}">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.6L22 12l-7.6 2.4L12 22l-2.4-7.6L2 12l7.6-2.4L12 2z"/></svg>
            </span>
            {{ section.settings.section_badge }}
          </div>
        {% endif %}

        {% if section.settings.section_title != blank %}
          <h2 class="pet-promo-section-title-{{ section.id }}">
            {{ section.settings.section_title | replace: '[', '<span class="highlight">' | replace: ']', '</span>' }}
          </h2>
        {% endif %}
      </div>
    {% endif %}

    <div class="pet-promo-grid-{{ section.id }}">

      {% for block in section.blocks %}
        {%- assign card_link = block.settings.link | default: '#' -%}
        {%- assign accent = block.settings.accent_color -%}

        <a href="{{ card_link }}"
           class="pet-promo-card-{{ section.id }}"
           style="background: linear-gradient(145deg, {{ block.settings.bg_start }} 0%, {{ block.settings.bg_end }} 100%);"
           aria-label="{{ block.settings.title | strip_html }} — {{ block.settings.btn_text }}"
           {{ block.shopify_attributes }}>

          <div class="pet-promo-content-{{ section.id }}">
            {% if block.settings.eyebrow != blank %}
              <span class="pet-promo-eyebrow-{{ section.id }}" style="color: {{ accent }};">
                <span class="pet-promo-eyebrow-line-{{ section.id }}"></span>
                {{ block.settings.eyebrow }}
              </span>
            {% endif %}

            {% if block.settings.title != blank %}
              <h3 class="pet-promo-title-{{ section.id }}">{{ block.settings.title }}</h3>
            {% endif %}

            {% if block.settings.btn_text != blank %}
              <span class="pet-promo-btn-{{ section.id }}" style="background-color: {{ accent }};" aria-hidden="true">
                {{ block.settings.btn_text }}
                <span class="pet-btn-arrow-{{ section.id }}">
                  <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                </span>
              </span>
            {% endif %}
          </div>

          <div class="pet-promo-visual-{{ section.id }}">
            <div class="pet-promo-icon-wrap-{{ section.id }}" style="background: rgba(255,255,255,0.5); border-color: {{ accent }}20;">
              <svg class="pet-promo-icon-{{ section.id }}" style="color: {{ accent }};"
                   viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" stroke="currentColor" aria-hidden="true">
                {% case block.settings.icon %}

                  {% when 'cat' %}
                    <path d="M12 5c.67 0 1.35.09 2 .26 1.78-2 5.03-2.84 6.42-2.26 1.4.58-.42 7-.42 7 .57 1.07 1 2.24 1 3.44C21 17.9 16.97 21 12 21s-9-3-9-7.56c0-1.25.5-2.4 1-3.44 0 0-1.89-6.42-.5-7 1.39-.58 4.72.23 6.5 2.23A9.04 9.04 0 0 1 12 5Z"/>
                    <path d="M8 14v.5"/>
                    <path d="M16 14v.5"/>
                    <path d="M11.25 16.25h1.5L12 17l-.75-.75Z"/>

                  {% when 'dog' %}
                    <path d="M11.25 16.25h1.5L12 17z"/>
                    <path d="M16 14v.5"/>
                    <path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444a11.702 11.702 0 0 0-.493-3.309"/>
                    <path d="M8 14v.5"/>
                    <path d="M8.5 8.5c-.384 1.05-1.083 2.028-2.344 2.5-1.931.722-3.576-.297-3.656-1-.113-.994 1.177-6.53 4-7 1.923-.321 3.651.845 3.651 2.235A7.497 7.497 0 0 1 14 5.277c0-1.39 1.844-2.598 3.767-2.277 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/>

                {% endcase %}
              </svg>
            </div>
          </div>

        </a>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Premium Promo Banners",
  "max_blocks": 2,
  "settings": [
    { "type": "header", "content": "Section" },
    { "type": "color", "id": "bg_color",            "label": "Section Background", "default": "#FDFBFF" },
    { "type": "color", "id": "primary_color",       "label": "Primary Color",      "default": "#7B3FF2" },
    { "type": "color", "id": "primary_light_color", "label": "Light Accent",       "default": "#B794F4" },
    { "type": "color", "id": "primary_deep_color",  "label": "Deep Accent",        "default": "#5B2FB2" },
    { "type": "range", "id": "max_width",      "min": 1000, "max": 1800, "step": 50, "unit": "px", "label": "Max Width",      "default": 1300 },

    { "type": "header", "content": "Section Heading" },
    {
      "type": "text",
      "id": "section_badge",
      "label": "Badge Text",
      "default": "Kategoriler"
    },
    {
      "type": "textarea",
      "id": "section_title",
      "label": "Section Title",
      "info": "Mor vurgu için köşeli parantez kullanın: [kelime]",
      "default": "Dostunuz İçin [Premium] Seçenekler"
    },

    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top",    "min": 0,    "max": 120,  "step": 5,  "unit": "px", "label": "Padding Top",    "default": 50 },
    { "type": "range", "id": "padding_bottom", "min": 0,    "max": 120,  "step": 5,  "unit": "px", "label": "Padding Bottom", "default": 50 }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Kategori Kartı",
      "settings": [
        { "type": "header", "content": "Renkler" },
        { "type": "color", "id": "bg_start",     "label": "Gradient Start",  "default": "#F8F4FF" },
        { "type": "color", "id": "bg_end",       "label": "Gradient End",    "default": "#EDE3FF" },
        { "type": "color", "id": "accent_color", "label": "Accent Color",    "default": "#7B3FF2" },

        { "type": "header", "content": "İçerik" },
        { "type": "text",     "id": "eyebrow",  "label": "Eyebrow",     "default": "LUXURY" },
        { "type": "textarea", "id": "title",    "label": "Title",       "default": "Premium Kedi Ürünleri" },
        { "type": "text",     "id": "btn_text", "label": "Button Text", "default": "Keşfet" },
        { "type": "url",      "id": "link",     "label": "Card Link" },

        { "type": "header", "content": "İkon" },
        {
          "type": "select",
          "id": "icon",
          "label": "İkon",
          "options": [
            { "value": "cat", "label": "Kedi" },
            { "value": "dog", "label": "Köpek" }
          ],
          "default": "cat"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Promo Banners",
      "settings": {
        "section_badge": "Kategoriler",
        "section_title": "Dostunuz İçin [Premium] Seçenekler"
      },
      "blocks": [
        {
          "type": "banner",
          "settings": {
            "bg_start": "#F8F4FF",
            "bg_end": "#EDE3FF",
            "accent_color": "#7B3FF2",
            "eyebrow": "LUXURY",
            "title": "Premium Kedi Ürünleri",
            "btn_text": "Keşfet",
            "icon": "cat"
          }
        },
        {
          "type": "banner",
          "settings": {
            "bg_start": "#F0EBFF",
            "bg_end": "#DDD0FF",
            "accent_color": "#5B2FB2",
            "eyebrow": "EXCLUSIVE",
            "title": "Premium Köpek Ürünleri",
            "btn_text": "Keşfet",
            "icon": "dog"
          }
        }
      ]
    }
  ]
}
{% endschema %}