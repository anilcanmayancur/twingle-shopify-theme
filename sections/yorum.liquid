{{ 'section-customer-reviews.css' | asset_url | stylesheet_tag }}

<section class="pet-reviews" id="section-{{ section.id }}">
  <div class="pet-reviews__container">
    <header class="pet-reviews__header">
      <h2 class="pet-reviews__title">{{ section.settings.title }}{% if section.settings.title_highlight != blank %} <span class="pet-reviews__hl">{{ section.settings.title_highlight }}</span>{% endif %}</h2>
      {%- if section.settings.show_summary -%}
        <div class="pet-reviews__summary">
          <div class="pet-reviews__stars-row">
            {%- for i in (1..5) -%}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="#F5A623" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
          <span class="pet-reviews__avg">{{ section.settings.average_rating }}</span>
          <span class="pet-reviews__divider"></span>
          <span class="pet-reviews__count">{{ section.settings.review_count }} yorum</span>
        </div>
      {%- endif -%}
    </header>

    <div class="pet-reviews__track">
      {%- for block in section.blocks -%}
        <article class="pet-reviews__card" {{ block.shopify_attributes }}>
          <div class="pet-reviews__stars">
            {%- assign rating = block.settings.rating | default: 5 -%}
            {%- for i in (1..rating) -%}
              <svg width="13" height="13" viewBox="0 0 24 24" fill="#F5A623" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {%- endfor -%}
          </div>
          <p class="pet-reviews__text">{{ block.settings.review_text }}</p>
          <div class="pet-reviews__author">
            <div class="pet-reviews__avatar">
              {%- if block.settings.author_image != blank -%}
                <img src="{{ block.settings.author_image | image_url: width: 64 }}" alt="{{ block.settings.author_name }}" width="32" height="32" loading="lazy">
              {%- else -%}
                <span>{{ block.settings.author_name | slice: 0 }}</span>
              {%- endif -%}
            </div>
            <div class="pet-reviews__meta">
              <span class="pet-reviews__name">{{ block.settings.author_name }}{% if block.settings.verified %} <span class="pet-reviews__verified">✓</span>{% endif %}</span>
              {%- if block.settings.pet_type != blank -%}
                <span class="pet-reviews__pet">{{ block.settings.pet_type }}</span>
              {%- endif -%}
            </div>
          </div>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .pet-reviews {
    --pet-primary: #7B3FF2;
    --pet-ink: #1F1342;
    --pet-body: #5A4F75;
    padding: 48px 0;
    background: #FAFAFA;
  }

  .pet-reviews__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .pet-reviews__header {
    display: flex;
    align-items: baseline;
    gap: 20px;
    margin-bottom: 24px;
  }

  .pet-reviews__title {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700;
    color: var(--pet-ink);
    margin: 0;
    line-height: 1.3;
  }

  .pet-reviews__hl {
    background: linear-gradient(135deg, var(--pet-primary), #A78BFA);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .pet-reviews__summary {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .pet-reviews__stars-row {
    display: flex;
    gap: 1px;
  }

  .pet-reviews__avg {
    font-size: 15px;
    font-weight: 700;
    color: var(--pet-ink);
  }

  .pet-reviews__divider {
    width: 1px;
    height: 14px;
    background: rgba(0, 0, 0, 0.12);
  }

  .pet-reviews__count {
    font-size: 13px;
    color: var(--pet-body);
  }

  .pet-reviews__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    gap: 16px;
    padding-bottom: 4px;
  }

  .pet-reviews__track::-webkit-scrollbar {
    height: 3px;
  }

  .pet-reviews__track::-webkit-scrollbar-track {
    background: transparent;
  }

  .pet-reviews__track::-webkit-scrollbar-thumb {
    background: rgba(123, 63, 242, 0.12);
    border-radius: 10px;
  }

  .pet-reviews__card {
    min-width: 270px;
    max-width: 300px;
    flex-shrink: 0;
    scroll-snap-align: start;
    padding: 20px;
    background: white;
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 16px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: box-shadow 0.3s ease;
  }

  @media (hover: hover) {
    .pet-reviews__card:hover {
      box-shadow: 0 4px 20px rgba(123, 63, 242, 0.08);
    }
  }

  .pet-reviews__stars {
    display: flex;
    gap: 1px;
  }

  .pet-reviews__text {
    margin: 0;
    font-size: 14px;
    line-height: 1.55;
    color: var(--pet-ink);
    flex: 1;
  }

  .pet-reviews__author {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 12px;
    border-top: 1px solid rgba(0, 0, 0, 0.04);
  }

  .pet-reviews__avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: linear-gradient(135deg, var(--pet-primary), #A78BFA);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pet-reviews__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .pet-reviews__avatar span {
    font-size: 13px;
    font-weight: 700;
    color: white;
  }

  .pet-reviews__meta {
    display: flex;
    flex-direction: column;
    min-width: 0;
  }

  .pet-reviews__name {
    font-size: 13px;
    font-weight: 600;
    color: var(--pet-ink);
  }

  .pet-reviews__verified {
    color: #10B981;
    font-weight: 700;
  }

  .pet-reviews__pet {
    font-size: 11px;
    color: var(--pet-body);
  }

  @media (max-width: 768px) {
    .pet-reviews {
      padding: 32px 0;
    }

    .pet-reviews__container {
      padding: 0 16px;
    }

    .pet-reviews__header {
      flex-direction: column;
      align-items: center;
      text-align: center;
      gap: 8px;
      margin-bottom: 16px;
    }

    .pet-reviews__card {
      min-width: 240px;
      max-width: 72vw;
      padding: 16px;
    }

    .pet-reviews__track {
      margin: 0 -16px;
      padding-left: 16px;
      padding-right: 16px;
    }
  }
</style>

