{% style %}
  .tw-coll-{{ section.id }} {
    --c-primary: {{ section.settings.primary_color | default: '#7b3ff2' }};
    --c-primary-dark: #5b2fb2;
    --c-primary-tint: rgba(123, 63, 242, 0.08);
    --c-primary-soft: rgba(123, 63, 242, 0.04);
    --c-ink: #1f1342;
    --c-muted: #5a4f75;
    --c-line: rgba(123, 63, 242, 0.1);
    --c-soft: #faf7ff;
    --c-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --c-text: {{ section.settings.text_color | default: '#1f1342' }};

    --c-r-card: 14px;
    --c-r-chip: 8px;
    --c-r-btn: 10px;

    background: var(--c-bg);
    color: var(--c-text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, sans-serif;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .tw-coll-{{ section.id }} * { box-sizing: border-box; }
  .tw-coll-{{ section.id }} a { color: inherit; }

  .tw-coll-{{ section.id }}__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ============ HERO ============ */
  .tw-coll-{{ section.id }}__hero {
    padding: 28px 0 22px;
    margin-bottom: 14px;
  }
  .tw-coll-{{ section.id }}__crumbs {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: var(--c-muted);
    margin-bottom: 14px;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-weight: 600;
  }
  .tw-coll-{{ section.id }}__crumbs a {
    color: var(--c-muted);
    text-decoration: none;
    transition: color 0.18s ease;
  }
  .tw-coll-{{ section.id }}__crumbs a:hover { color: var(--c-primary); }
  .tw-coll-{{ section.id }}__crumbs .sep { color: #d0c9de; margin: 0 6px; font-size: 10px; }
  .tw-coll-{{ section.id }}__crumbs .curr { color: var(--c-ink); }

  .tw-coll-{{ section.id }}__title {
    margin: 0;
    font-size: clamp(30px, 4vw, 46px);
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -0.028em;
    line-height: 1.05;
  }
  .tw-coll-{{ section.id }}__meta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-top: 10px;
    font-size: 12.5px;
    color: var(--c-muted);
    letter-spacing: 0.02em;
  }
  .tw-coll-{{ section.id }}__meta strong { color: var(--c-ink); font-weight: 700; }
  .tw-coll-{{ section.id }}__meta-sep {
    width: 3px; height: 3px;
    background: #c8c1d6;
    border-radius: 50%;
  }
  .tw-coll-{{ section.id }}__desc {
    margin: 14px 0 0;
    color: var(--c-muted);
    font-size: 14.5px;
    line-height: 1.6;
    max-width: 640px;
  }

  /* ============ BODY LAYOUT ============ */
  .tw-coll-{{ section.id }}__body {
    display: grid;
    grid-template-columns: 264px minmax(0, 1fr);
    gap: 28px;
    align-items: start;
  }

  /* ============ SIDEBAR ============ */
  .tw-coll-{{ section.id }}__sidebar {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--c-line);
    border-radius: var(--c-r-card);
    overflow: hidden;
    max-height: calc(100vh - 100px);
  }
  .tw-coll-{{ section.id }}__sidebar-head,
  .tw-coll-{{ section.id }}__sidebar-foot { display: none; }

  .tw-coll-{{ section.id }}__filter-form {
    flex: 1;
    overflow-y: auto;
    padding: 6px;
  }

  .tw-coll-{{ section.id }}__widget {
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 2px;
  }
  .tw-coll-{{ section.id }}__widget + .tw-coll-{{ section.id }}__widget {
    border-top: 1px solid var(--c-line);
    border-radius: 0;
    margin-top: 2px;
  }
  .tw-coll-{{ section.id }}__w-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 14px;
    font-size: 13px;
    font-weight: 800;
    color: var(--c-ink);
    cursor: pointer;
    user-select: none;
    background: transparent;
    border: none;
    width: 100%;
    text-align: left;
    font-family: inherit;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background 0.15s ease;
  }
  .tw-coll-{{ section.id }}__w-title:hover { background: var(--c-soft); }
  .tw-coll-{{ section.id }}__w-title svg {
    width: 12px; height: 12px;
    color: var(--c-muted);
    transition: transform 0.22s ease;
    flex-shrink: 0;
  }
  .tw-coll-{{ section.id }}__w-title.collapsed svg { transform: rotate(-90deg); }

  .tw-coll-{{ section.id }}__w-body {
    padding: 4px 14px 14px;
    max-height: 320px;
    overflow-y: auto;
    transition: max-height 0.22s ease, padding 0.22s ease, opacity 0.18s ease;
  }
  .tw-coll-{{ section.id }}__w-body.collapsed {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    opacity: 0;
    overflow: hidden;
  }
  .tw-coll-{{ section.id }}__w-body::-webkit-scrollbar { width: 6px; }
  .tw-coll-{{ section.id }}__w-body::-webkit-scrollbar-thumb { background: var(--c-line); border-radius: 100px; }

  /* Kategori liste */
  .tw-coll-{{ section.id }}__cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .tw-coll-{{ section.id }}__cat-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 8px;
    color: var(--c-muted);
    font-size: 13.5px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tw-coll-{{ section.id }}__cat-link::before {
    content: '';
    width: 4px; height: 4px;
    border-radius: 50%;
    background: #d8d0e8;
    flex-shrink: 0;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .tw-coll-{{ section.id }}__cat-link:hover {
    background: var(--c-soft);
    color: var(--c-ink);
  }
  .tw-coll-{{ section.id }}__cat-link:hover::before { background: var(--c-primary); }
  .tw-coll-{{ section.id }}__cat-link.is-active {
    background: var(--c-primary-tint);
    color: var(--c-primary);
    font-weight: 700;
  }
  .tw-coll-{{ section.id }}__cat-link.is-active::before {
    background: var(--c-primary);
    transform: scale(1.4);
  }

  /* Filter checkboxes */
  .tw-coll-{{ section.id }}__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 2px;
  }
  .tw-coll-{{ section.id }}__check {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 8px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    color: var(--c-muted);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tw-coll-{{ section.id }}__check:hover { background: var(--c-soft); color: var(--c-ink); }
  .tw-coll-{{ section.id }}__check input[type="checkbox"] { display: none; }
  .tw-coll-{{ section.id }}__box {
    width: 18px; height: 18px;
    border: 1.5px solid var(--c-line);
    border-radius: 5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: #fff;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .tw-coll-{{ section.id }}__box svg {
    width: 11px; height: 11px;
    stroke: #fff; stroke-width: 3;
    fill: none; opacity: 0;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .tw-coll-{{ section.id }}__check input:checked + .tw-coll-{{ section.id }}__box {
    background: var(--c-primary);
    border-color: var(--c-primary);
  }
  .tw-coll-{{ section.id }}__check input:checked + .tw-coll-{{ section.id }}__box svg { opacity: 1; }
  .tw-coll-{{ section.id }}__check input:checked ~ .tw-coll-{{ section.id }}__lbl { color: var(--c-ink); font-weight: 600; }
  .tw-coll-{{ section.id }}__check input:disabled ~ .tw-coll-{{ section.id }}__lbl { opacity: 0.45; }
  .tw-coll-{{ section.id }}__lbl { flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tw-coll-{{ section.id }}__c-count {
    font-size: 11.5px;
    color: #a89db8;
    background: var(--c-soft);
    padding: 2px 7px;
    border-radius: 100px;
    flex-shrink: 0;
    font-weight: 600;
  }

  /* Price range */
  .tw-coll-{{ section.id }}__price {
    display: flex; align-items: center; gap: 8px;
  }
  .tw-coll-{{ section.id }}__price-input {
    width: 100%;
    padding: 10px 12px;
    border: 1.5px solid var(--c-line);
    border-radius: var(--c-r-chip);
    font-size: 13px;
    color: var(--c-ink);
    background: #fff;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .tw-coll-{{ section.id }}__price-input:focus {
    border-color: var(--c-primary);
    box-shadow: 0 0 0 3px var(--c-primary-tint);
  }
  .tw-coll-{{ section.id }}__price span {
    color: var(--c-muted);
    font-weight: 600;
  }

  /* ============ MAIN ============ */
  .tw-coll-{{ section.id }}__main { min-width: 0; }

  .tw-coll-{{ section.id }}__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding: 10px 0 14px;
    border-bottom: 1px solid var(--c-line);
    margin-bottom: 20px;
    flex-wrap: wrap;
  }
  .tw-coll-{{ section.id }}__tool-left {
    font-size: 12.5px;
    color: var(--c-muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .tw-coll-{{ section.id }}__tool-right {
    display: inline-flex;
    align-items: center;
    gap: 18px;
  }
  .tw-coll-{{ section.id }}__sort-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: var(--c-ink);
    font-weight: 600;
    cursor: pointer;
  }
  .tw-coll-{{ section.id }}__sort-label {
    color: var(--c-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .tw-coll-{{ section.id }}__sort {
    appearance: none;
    -webkit-appearance: none;
    padding: 6px 22px 6px 4px;
    border: none;
    background: transparent;
    font-size: 13px;
    font-weight: 700;
    color: var(--c-ink);
    cursor: pointer;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='10' height='10' viewBox='0 0 24 24' fill='none' stroke='%231f1342' stroke-width='2.6' stroke-linecap='round' stroke-linejoin='round'><polyline points='6 9 12 15 18 9'/></svg>");
    background-repeat: no-repeat;
    background-position: right 0 center;
    font-family: inherit;
    outline: none;
    border-bottom: 1.5px solid transparent;
    transition: border-color 0.18s ease;
  }
  .tw-coll-{{ section.id }}__sort:hover,
  .tw-coll-{{ section.id }}__sort:focus { border-bottom-color: var(--c-ink); }

  /* Active filter chips */
  .tw-coll-{{ section.id }}__active {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin-bottom: 16px;
  }
  .tw-coll-{{ section.id }}__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px 5px 12px;
    background: var(--c-primary-tint);
    color: var(--c-primary);
    border-radius: 100px;
    font-size: 12.5px;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid rgba(123, 63, 242, 0.2);
    transition: background 0.15s ease;
  }
  .tw-coll-{{ section.id }}__chip:hover { background: rgba(123, 63, 242, 0.14); }
  .tw-coll-{{ section.id }}__chip-x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px; height: 18px;
    background: #fff;
    border-radius: 50%;
  }
  .tw-coll-{{ section.id }}__chip-x svg { width: 9px; height: 9px; stroke: var(--c-primary); fill: none; stroke-width: 2.6; stroke-linecap: round; }
  .tw-coll-{{ section.id }}__clear {
    color: var(--c-muted);
    font-size: 12.5px;
    font-weight: 600;
    text-decoration: none;
    padding: 5px 10px;
    border-radius: 100px;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .tw-coll-{{ section.id }}__clear:hover { color: var(--c-primary); background: var(--c-soft); }

  /* Grid */
  .tw-coll-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: 16px;
  }
  .tw-coll-{{ section.id }}__grid.is-list {
    grid-template-columns: 1fr;
  }
  .tw-coll-{{ section.id }}__grid-item { min-width: 0; }

  /* Empty */
  .tw-coll-{{ section.id }}__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 64px 24px;
    background: var(--c-soft);
    border-radius: var(--c-r-card);
    color: var(--c-muted);
    border: 1px dashed var(--c-line);
  }
  .tw-coll-{{ section.id }}__empty-icon {
    width: 64px; height: 64px;
    margin: 0 auto 16px;
    background: #fff;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--c-primary);
    box-shadow: 0 8px 24px -10px rgba(123, 63, 242, 0.2);
  }
  .tw-coll-{{ section.id }}__empty-icon svg { width: 28px; height: 28px; stroke: currentColor; fill: none; stroke-width: 1.7; }
  .tw-coll-{{ section.id }}__empty-title { font-size: 18px; font-weight: 800; color: var(--c-ink); margin: 0 0 6px; }
  .tw-coll-{{ section.id }}__empty-desc { font-size: 14px; margin: 0 0 18px; max-width: 360px; margin-left: auto; margin-right: auto; line-height: 1.5; }
  .tw-coll-{{ section.id }}__empty-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 20px;
    border-radius: var(--c-r-btn);
    background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
    color: #fff;
    font-size: 13.5px;
    font-weight: 700;
    text-decoration: none;
    transition: filter 0.18s ease, transform 0.18s ease;
    box-shadow: 0 8px 20px -8px rgba(123, 63, 242, 0.4);
  }
  .tw-coll-{{ section.id }}__empty-btn:hover { filter: brightness(1.05); transform: translateY(-1px); }

  /* Pagination */
  .tw-coll-{{ section.id }}__paginate {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .tw-coll-{{ section.id }}__paginate a,
  .tw-coll-{{ section.id }}__paginate span {
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1.5px solid var(--c-line);
    border-radius: var(--c-r-btn);
    color: var(--c-ink);
    text-decoration: none;
    font-weight: 700;
    font-size: 13.5px;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  .tw-coll-{{ section.id }}__paginate a:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    background: var(--c-primary-tint);
    transform: translateY(-1px);
  }
  .tw-coll-{{ section.id }}__paginate .current {
    background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 8px 20px -8px rgba(123, 63, 242, 0.4);
  }

  /* Mobile filter toggle */
  .tw-coll-{{ section.id }}__mobile-toggle {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 9px 16px;
    background: transparent;
    color: var(--c-ink);
    border: 1.5px solid var(--c-line);
    border-radius: 100px;
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.18s ease, background 0.18s ease;
    letter-spacing: 0.02em;
  }
  .tw-coll-{{ section.id }}__mobile-toggle:hover {
    border-color: var(--c-ink);
    background: var(--c-soft);
  }
  .tw-coll-{{ section.id }}__mobile-toggle svg { width: 14px; height: 14px; fill: none; stroke: currentColor; stroke-width: 2.2; }
  .tw-coll-{{ section.id }}__mobile-toggle-count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 18px;
    height: 18px;
    padding: 0 5px;
    background: var(--c-primary);
    color: #fff;
    border-radius: 100px;
    font-size: 11px;
    font-weight: 700;
    margin-left: 4px;
  }

  .tw-coll-{{ section.id }}__overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(20, 14, 40, 0.55);
    z-index: 9998;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .tw-coll-{{ section.id }}__overlay.is-open { display: block; opacity: 1; }

  /* ============ RESPONSIVE ============ */
  @media screen and (max-width: 1100px) {
    .tw-coll-{{ section.id }}__body {
      grid-template-columns: 240px minmax(0, 1fr);
      gap: 22px;
    }
  }

  @media screen and (max-width: 991px) {
    .tw-coll-{{ section.id }}__body {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .tw-coll-{{ section.id }}__mobile-toggle { display: inline-flex; }

    .tw-coll-{{ section.id }}__sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: min(360px, 86%);
      max-height: none;
      transform: translateX(-100%);
      transition: transform 0.32s cubic-bezier(0.2, 0.8, 0.2, 1);
      border-radius: 0;
      border: none;
      box-shadow: 16px 0 48px -12px rgba(20, 14, 40, 0.25);
      z-index: 9999;
    }
    .tw-coll-{{ section.id }}__sidebar.is-open { transform: translateX(0); }

    .tw-coll-{{ section.id }}__sidebar-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 16px 18px;
      border-bottom: 1px solid var(--c-line);
      background: var(--c-soft);
      flex-shrink: 0;
    }
    .tw-coll-{{ section.id }}__sidebar-head h3 {
      margin: 0;
      font-size: 16px;
      font-weight: 800;
      color: var(--c-ink);
    }
    .tw-coll-{{ section.id }}__sidebar-close {
      width: 32px; height: 32px;
      background: #fff;
      border: 1px solid var(--c-line);
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--c-muted);
    }
    .tw-coll-{{ section.id }}__sidebar-close svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.4; stroke-linecap: round; }

    .tw-coll-{{ section.id }}__filter-form {
      padding: 12px;
      flex: 1;
    }

    .tw-coll-{{ section.id }}__sidebar-foot {
      display: flex;
      gap: 8px;
      padding: 14px 16px;
      border-top: 1px solid var(--c-line);
      background: #fff;
      flex-shrink: 0;
    }
    .tw-coll-{{ section.id }}__apply,
    .tw-coll-{{ section.id }}__reset {
      flex: 1;
      padding: 12px;
      border-radius: var(--c-r-btn);
      font-size: 13.5px;
      font-weight: 700;
      cursor: pointer;
      border: none;
      font-family: inherit;
      transition: filter 0.18s ease, background 0.15s ease;
    }
    .tw-coll-{{ section.id }}__apply {
      background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
      color: #fff;
      box-shadow: 0 8px 20px -8px rgba(123, 63, 242, 0.4);
    }
    .tw-coll-{{ section.id }}__apply:hover { filter: brightness(1.05); }
    .tw-coll-{{ section.id }}__reset {
      background: #fff;
      color: var(--c-ink);
      border: 1.5px solid var(--c-line);
    }
    .tw-coll-{{ section.id }}__reset:hover { background: var(--c-soft); }

    .tw-coll-{{ section.id }}__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
  }

  @media screen and (max-width: 749px) {
    .tw-coll-{{ section.id }}__inner { padding: 0 14px; }
    .tw-coll-{{ section.id }}__hero { padding: 22px 0 18px; margin-bottom: 18px; }
    .tw-coll-{{ section.id }}__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
    .tw-coll-{{ section.id }}__toolbar {
      padding: 10px 12px;
      gap: 10px;
    }
    .tw-coll-{{ section.id }}__count-line { font-size: 12.5px; flex: 1 1 100%; }
    .tw-coll-{{ section.id }}__tool-right { width: 100%; justify-content: space-between; }
    .tw-coll-{{ section.id }}__sort { flex: 1; }
  }
{% endstyle %}

{%- liquid
  assign active_filter_count = 0
  for f in collection.filters
    case f.type
      when 'list', 'boolean'
        assign active_filter_count = active_filter_count | plus: f.active_values.size
      when 'price_range'
        if f.min_value.value or f.max_value.value
          assign active_filter_count = active_filter_count | plus: 1
        endif
    endcase
  endfor
-%}

<section class="tw-coll-{{ section.id }}">

  {% comment %} HERO {% endcomment %}
  <div class="tw-coll-{{ section.id }}__hero">
    <div class="tw-coll-{{ section.id }}__inner">
      <nav class="tw-coll-{{ section.id }}__crumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">{{ section.settings.bc_home }}</a>
        <span class="sep">/</span>
        <a href="{{ routes.all_products_collection_url }}">{{ section.settings.bc_shop }}</a>
        <span class="sep">/</span>
        <span class="curr">{{ collection.title }}</span>
      </nav>

      <h1 class="tw-coll-{{ section.id }}__title">{{ collection.title }}</h1>

      {% if section.settings.show_description and collection.description != blank %}
        <p class="tw-coll-{{ section.id }}__desc">{{ collection.description | strip_html | truncate: 240 }}</p>
      {% endif %}
    </div>
  </div>

  <div class="tw-coll-{{ section.id }}__inner">
    <div class="tw-coll-{{ section.id }}__overlay" data-tw-filter-overlay></div>

    <div class="tw-coll-{{ section.id }}__body">

      <aside class="tw-coll-{{ section.id }}__sidebar" data-tw-sidebar>
        <div class="tw-coll-{{ section.id }}__sidebar-head">
          <h3>Filtreler</h3>
          <button type="button" class="tw-coll-{{ section.id }}__sidebar-close" data-tw-filter-close aria-label="Kapat">
            <svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>

        <form id="CollectionFiltersForm-{{ section.id }}" class="tw-coll-{{ section.id }}__filter-form">
          <input type="hidden" name="sort_by" value="{{ collection.sort_by | default: collection.default_sort_by }}">

          {% for block in section.blocks %}
            {% case block.type %}

              {% when 'menu' %}
                <div class="tw-coll-{{ section.id }}__widget" {{ block.shopify_attributes }}>
                  <button type="button" class="tw-coll-{{ section.id }}__w-title" data-tw-acc>
                    {{ block.settings.title }}
                    <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <div class="tw-coll-{{ section.id }}__w-body">
                    <ul class="tw-coll-{{ section.id }}__cat-list">
                      {% for link in linklists[block.settings.menu].links %}
                        <li>
                          <a href="{{ link.url }}" class="tw-coll-{{ section.id }}__cat-link{% if link.active or link.child_active %} is-active{% endif %}">
                            {{ link.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>

              {% when 'filters' %}
                {% for filter in collection.filters %}
                  <div class="tw-coll-{{ section.id }}__widget" {{ block.shopify_attributes }}>
                    <button type="button" class="tw-coll-{{ section.id }}__w-title" data-tw-acc>
                      {{ filter.label }}
                      <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <div class="tw-coll-{{ section.id }}__w-body">
                      {% case filter.type %}
                        {% when 'list', 'boolean' %}
                          <ul class="tw-coll-{{ section.id }}__list">
                            {% for filter_value in filter.values %}
                              <li>
                                <label class="tw-coll-{{ section.id }}__check">
                                  <input type="checkbox"
                                    name="{{ filter_value.param_name }}"
                                    value="{{ filter_value.value }}"
                                    {% if filter_value.active -%}checked{%- endif %}
                                    {% if filter_value.count == 0 and filter_value.active == false -%}disabled{%- endif %}
                                    onchange="document.getElementById('CollectionFiltersForm-{{ section.id }}').submit();">
                                  <span class="tw-coll-{{ section.id }}__box">
                                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                  </span>
                                  <span class="tw-coll-{{ section.id }}__lbl">{{ filter_value.label }}</span>
                                  <span class="tw-coll-{{ section.id }}__c-count">{{ filter_value.count }}</span>
                                </label>
                              </li>
                            {% endfor %}
                          </ul>

                        {% when 'price_range' %}
                          <div class="tw-coll-{{ section.id }}__price">
                            <input type="number"
                                   name="{{ filter.min_value.param_name }}"
                                   placeholder="Min ₺"
                                   class="tw-coll-{{ section.id }}__price-input"
                                   {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                                   onchange="document.getElementById('CollectionFiltersForm-{{ section.id }}').submit();">
                            <span>–</span>
                            <input type="number"
                                   name="{{ filter.max_value.param_name }}"
                                   placeholder="Max ₺"
                                   class="tw-coll-{{ section.id }}__price-input"
                                   {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                                   onchange="document.getElementById('CollectionFiltersForm-{{ section.id }}').submit();">
                          </div>
                      {% endcase %}
                    </div>
                  </div>
                {% endfor %}
            {% endcase %}
          {% endfor %}
        </form>

        <div class="tw-coll-{{ section.id }}__sidebar-foot">
          <a href="{{ collection.url }}" class="tw-coll-{{ section.id }}__reset">Temizle</a>
          <button type="button" class="tw-coll-{{ section.id }}__apply" data-tw-filter-close>Sonuçları Göster</button>
        </div>
      </aside>

      <main class="tw-coll-{{ section.id }}__main">
        {% paginate collection.products by section.settings.products_per_page %}

          <div class="tw-coll-{{ section.id }}__toolbar">
            <div class="tw-coll-{{ section.id }}__tool-left">
              {{ collection.products_count }} ürün
              {%- if paginate.pages > 1 %} · Sayfa {{ paginate.current_page }}/{{ paginate.pages }}{% endif -%}
            </div>
            <div class="tw-coll-{{ section.id }}__tool-right">
              <button type="button" class="tw-coll-{{ section.id }}__mobile-toggle" data-tw-filter-open>
                <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="4" y1="6" x2="14" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="10" y2="18"/><circle cx="17" cy="6" r="2.2"/><circle cx="7" cy="12" r="2.2"/><circle cx="13" cy="18" r="2.2"/></svg>
                {{ section.settings.filter_btn_text }}
                {% if active_filter_count > 0 %}
                  <span class="tw-coll-{{ section.id }}__mobile-toggle-count">{{ active_filter_count }}</span>
                {% endif %}
              </button>
              <label class="tw-coll-{{ section.id }}__sort-wrap">
                <span class="tw-coll-{{ section.id }}__sort-label">Sırala</span>
                <select class="tw-coll-{{ section.id }}__sort" aria-label="Sırala"
                        onchange="document.querySelector('#CollectionFiltersForm-{{ section.id }} input[name=sort_by]').value = this.value; document.getElementById('CollectionFiltersForm-{{ section.id }}').submit();">
                  {% for option in collection.sort_options %}
                    <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
                  {% endfor %}
                </select>
              </label>
            </div>
          </div>

          {% if active_filter_count > 0 %}
            <div class="tw-coll-{{ section.id }}__active">
              {% for filter in collection.filters %}
                {% case filter.type %}
                  {% when 'list', 'boolean' %}
                    {% for value in filter.active_values %}
                      <a href="{{ value.url_to_remove }}" class="tw-coll-{{ section.id }}__chip">
                        <span>{{ filter.label }}: {{ value.label }}</span>
                        <span class="tw-coll-{{ section.id }}__chip-x"><svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg></span>
                      </a>
                    {% endfor %}
                  {% when 'price_range' %}
                    {% if filter.min_value.value or filter.max_value.value %}
                      <a href="{{ filter.url_to_remove }}" class="tw-coll-{{ section.id }}__chip">
                        <span>{{ filter.label }}: {{ filter.min_value.value | default: 0 | money }} – {{ filter.max_value.value | default: filter.range_max | money }}</span>
                        <span class="tw-coll-{{ section.id }}__chip-x"><svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg></span>
                      </a>
                    {% endif %}
                {% endcase %}
              {% endfor %}
              <a href="{{ collection.url }}" class="tw-coll-{{ section.id }}__clear">Tümünü Temizle</a>
            </div>
          {% endif %}

          <div class="tw-coll-{{ section.id }}__grid" data-tw-grid>
            {% for product in collection.products %}
              <div class="tw-coll-{{ section.id }}__grid-item">
                {% render 'product-card', product: product %}
              </div>
            {% else %}
              <div class="tw-coll-{{ section.id }}__empty">
                <span class="tw-coll-{{ section.id }}__empty-icon">
                  <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </span>
                <h3 class="tw-coll-{{ section.id }}__empty-title">Bu kategoride henüz ürün yok</h3>
                <p class="tw-coll-{{ section.id }}__empty-desc">Filtreleri temizlemeyi ya da farklı bir kategoriye göz atmayı dene.</p>
                <a href="{{ routes.all_products_collection_url }}" class="tw-coll-{{ section.id }}__empty-btn">
                  Tüm Ürünleri Gör
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </div>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="tw-coll-{{ section.id }}__paginate">
              {{ paginate | default_pagination }}
            </div>
          {% endif %}

        {% endpaginate %}
      </main>

    </div>
  </div>
</section>

<script>
(function() {
  var root = document.currentScript.closest('section.tw-coll-{{ section.id }}') || document.querySelector('.tw-coll-{{ section.id }}');
  if (!root) return;

  // Accordion toggles
  root.querySelectorAll('[data-tw-acc]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      btn.classList.toggle('collapsed');
      var body = btn.nextElementSibling;
      if (body) body.classList.toggle('collapsed');
    });
  });

  // View toggles
  var grid = root.querySelector('[data-tw-grid]');
  root.querySelectorAll('[data-tw-view]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      root.querySelectorAll('[data-tw-view]').forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      if (!grid) return;
      grid.classList.toggle('is-list', btn.dataset.twView === 'list');
    });
  });

  // Mobile filter drawer
  var sidebar = root.querySelector('[data-tw-sidebar]');
  var overlay = root.querySelector('[data-tw-filter-overlay]');

  function openDrawer() {
    if (!sidebar) return;
    sidebar.classList.add('is-open');
    if (overlay) overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    if (!sidebar) return;
    sidebar.classList.remove('is-open');
    if (overlay) overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  root.querySelectorAll('[data-tw-filter-open]').forEach(function(el) { el.addEventListener('click', openDrawer); });
  root.querySelectorAll('[data-tw-filter-close]').forEach(function(el) { el.addEventListener('click', closeDrawer); });
  if (overlay) overlay.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && sidebar && sidebar.classList.contains('is-open')) closeDrawer();
  });
})();
</script>

{% schema %}
{
  "name": "Twinkle Collection Page",
  "settings": [
    {
      "type": "header",
      "content": "Renkler"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Arkaplan Rengi",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Vurgu Rengi",
      "default": "#7b3ff2"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Metin Rengi",
      "default": "#1f1342"
    },
    {
      "type": "header",
      "content": "Breadcrumb"
    },
    {
      "type": "text",
      "id": "bc_home",
      "label": "Anasayfa Metni",
      "default": "Anasayfa"
    },
    {
      "type": "text",
      "id": "bc_shop",
      "label": "Mağaza Metni",
      "default": "Tüm Ürünler"
    },
    {
      "type": "header",
      "content": "İçerik"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Koleksiyon açıklamasını göster",
      "default": true
    },
    {
      "type": "text",
      "id": "filter_btn_text",
      "label": "Mobil Filtre Butonu Metni",
      "default": "Filtrele"
    },
    {
      "type": "header",
      "content": "Düzen"
    },
    {
      "type": "range",
      "id": "products_per_page",
      "min": 8,
      "max": 48,
      "step": 4,
      "label": "Sayfa Başına Ürün",
      "default": 24
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "min": 2,
      "max": 5,
      "step": 1,
      "label": "Masaüstü Sütun Sayısı",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Alt Boşluk",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Kategoriler (Menü)",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Başlık",
          "default": "Kategoriler"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menü Seçin"
        }
      ]
    },
    {
      "type": "filters",
      "name": "Detaylı Filtreler",
      "limit": 1,
      "settings": [
        {
          "type": "paragraph",
          "content": "Marka, fiyat ve özellik filtreleri Shopify Search & Discovery'den otomatik çekilir."
        }
      ]
    }
  ]
}
{% endschema %}
