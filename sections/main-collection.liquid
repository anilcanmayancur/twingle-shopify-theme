{% style %}
  .tw-coll-{{ section.id }} {
    --c-primary: {{ section.settings.primary_color | default: '#7b3ff2' }};
    --c-primary-dark: #5b2fb2;
    --c-primary-tint: rgba(123, 63, 242, 0.08);
    --c-primary-soft: rgba(123, 63, 242, 0.04);
    --c-ink: #1f1342;
    --c-muted: #5a4f75;
    --c-line: rgba(123, 63, 242, 0.1);
    --c-soft: #faf7ff;
    --c-bg: {{ section.settings.bg_color | default: '#ffffff' }};
    --c-text: {{ section.settings.text_color | default: '#1f1342' }};

    --c-r-card: 14px;
    --c-r-chip: 8px;
    --c-r-btn: 10px;

    background: var(--c-bg);
    color: var(--c-text);
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, sans-serif;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .tw-coll-{{ section.id }} * { box-sizing: border-box; }
  .tw-coll-{{ section.id }} a { color: inherit; }

  .tw-coll-{{ section.id }}__inner {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ============ HERO ============ */
  .tw-coll-{{ section.id }}__hero {
    background: #ffffff;
    padding: 24px 0 20px;
    margin-bottom: 18px;
  }

  .tw-coll-{{ section.id }}__crumbs {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 4px;
    font-size: 12.5px;
    color: var(--c-muted);
    margin-bottom: 14px;
    font-weight: 500;
  }
  .tw-coll-{{ section.id }}__crumbs a {
    color: var(--c-muted);
    text-decoration: none;
    padding: 3px 0;
    transition: color 0.18s ease;
  }
  .tw-coll-{{ section.id }}__crumbs a:hover { color: var(--c-primary); }
  .tw-coll-{{ section.id }}__crumbs .sep {
    display: inline-flex;
    align-items: center;
    color: #c8c1d6;
    margin: 0 4px;
  }
  .tw-coll-{{ section.id }}__crumbs .sep svg { width: 10px; height: 10px; }
  .tw-coll-{{ section.id }}__crumbs .curr {
    color: var(--c-ink);
    font-weight: 600;
  }

  .tw-coll-{{ section.id }}__badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 11px;
    background: var(--c-primary-tint);
    color: var(--c-primary);
    border-radius: var(--c-r-chip);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.02em;
    margin-bottom: 10px;
  }
  .tw-coll-{{ section.id }}__badge::before {
    content: '';
    width: 6px; height: 6px;
    background: var(--c-primary);
    border-radius: 50%;
  }

  .tw-coll-{{ section.id }}__title {
    margin: 0;
    font-size: clamp(26px, 3.2vw, 34px);
    font-weight: 800;
    color: var(--c-ink);
    letter-spacing: -0.022em;
    line-height: 1.15;
  }
  .tw-coll-{{ section.id }}__sub {
    margin: 6px 0 0;
    color: var(--c-muted);
    font-size: 13.5px;
    font-weight: 500;
  }
  .tw-coll-{{ section.id }}__sub strong { color: var(--c-ink); font-weight: 700; }
  .tw-coll-{{ section.id }}__desc {
    margin: 10px 0 0;
    color: var(--c-muted);
    font-size: 14px;
    line-height: 1.55;
    max-width: 640px;
  }

  /* ============ BODY LAYOUT ============ */
  .tw-coll-{{ section.id }}__body {
    display: grid;
    grid-template-columns: 264px minmax(0, 1fr);
    gap: 28px;
    align-items: start;
  }

  /* ============ SIDEBAR ============ */
  .tw-coll-{{ section.id }}__sidebar {
    position: sticky;
    top: 88px;
    display: flex;
    flex-direction: column;
    background: #fff;
    border: 1px solid var(--c-line);
    border-radius: var(--c-r-card);
    overflow: hidden;
    max-height: calc(100vh - 100px);
  }
  .tw-coll-{{ section.id }}__sidebar-head { display: none; }

  .tw-coll-{{ section.id }}__sidebar-foot {
    position: sticky;
    bottom: 0;
    display: flex;
    gap: 8px;
    padding: 12px;
    margin-top: 6px;
    border-top: 1px solid var(--c-line);
    background: rgba(255, 255, 255, 0.96);
    backdrop-filter: saturate(180%) blur(6px);
    -webkit-backdrop-filter: saturate(180%) blur(6px);
    border-radius: 0 0 16px 16px;
    z-index: 2;
  }
  .tw-coll-{{ section.id }}__apply,
  .tw-coll-{{ section.id }}__reset {
    flex: 1;
    padding: 11px 12px;
    border-radius: var(--c-r-btn);
    font-size: 13.5px;
    font-weight: 700;
    cursor: pointer;
    border: none;
    font-family: inherit;
    transition: filter 0.18s ease, background 0.15s ease, opacity 0.15s ease, box-shadow 0.18s ease;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    line-height: 1;
  }
  .tw-coll-{{ section.id }}__apply {
    background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
    color: #fff;
    box-shadow: 0 6px 18px -10px rgba(123, 63, 242, 0.55);
    opacity: 0.55;
    pointer-events: none;
  }
  .tw-coll-{{ section.id }}__apply.is-dirty {
    opacity: 1;
    pointer-events: auto;
    box-shadow: 0 10px 24px -8px rgba(123, 63, 242, 0.45);
  }
  .tw-coll-{{ section.id }}__apply.is-dirty:hover { filter: brightness(1.06); }
  .tw-coll-{{ section.id }}__apply-count {
    background: rgba(255, 255, 255, 0.22);
    border-radius: 6px;
    padding: 2px 7px;
    font-size: 11.5px;
    font-weight: 800;
    line-height: 1;
  }
  .tw-coll-{{ section.id }}__reset {
    background: #fff;
    color: var(--c-ink);
    border: 1.5px solid var(--c-line);
    text-decoration: none;
  }
  .tw-coll-{{ section.id }}__reset:hover { background: var(--c-soft); }

  .tw-coll-{{ section.id }}__filter-form {
    flex: 1;
    overflow-y: auto;
    padding: 6px;
  }

  .tw-coll-{{ section.id }}__widget {
    border-radius: 10px;
    overflow: hidden;
    margin-bottom: 2px;
  }
  .tw-coll-{{ section.id }}__widget + .tw-coll-{{ section.id }}__widget {
    border-top: 1px solid var(--c-line);
    border-radius: 0;
    margin-top: 2px;
  }
  .tw-coll-{{ section.id }}__w-title {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 14px 14px;
    font-size: 13px;
    font-weight: 800;
    color: var(--c-ink);
    cursor: pointer;
    user-select: none;
    background: transparent;
    border: none;
    width: 100%;
    text-align: left;
    font-family: inherit;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    transition: background 0.15s ease;
  }
  .tw-coll-{{ section.id }}__w-title:hover { background: var(--c-soft); }
  .tw-coll-{{ section.id }}__w-title svg {
    width: 12px; height: 12px;
    color: var(--c-muted);
    transition: transform 0.22s ease;
    flex-shrink: 0;
  }
  .tw-coll-{{ section.id }}__w-title.collapsed svg { transform: rotate(-90deg); }

  .tw-coll-{{ section.id }}__w-body {
    padding: 4px 14px 14px;
    max-height: 320px;
    overflow-y: auto;
    transition: max-height 0.22s ease, padding 0.22s ease, opacity 0.18s ease;
  }
  .tw-coll-{{ section.id }}__w-body.collapsed {
    max-height: 0;
    padding-top: 0;
    padding-bottom: 0;
    opacity: 0;
    overflow: hidden;
  }
  .tw-coll-{{ section.id }}__w-body::-webkit-scrollbar { width: 6px; }
  .tw-coll-{{ section.id }}__w-body::-webkit-scrollbar-thumb { background: var(--c-line); border-radius: 100px; }

  /* Kategori liste */
  .tw-coll-{{ section.id }}__cat-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .tw-coll-{{ section.id }}__cat-link {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 8px 10px;
    border-radius: 8px;
    color: var(--c-muted);
    font-size: 13.5px;
    font-weight: 500;
    text-decoration: none;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tw-coll-{{ section.id }}__cat-link::before {
    content: '';
    width: 4px; height: 4px;
    border-radius: 50%;
    background: #d8d0e8;
    flex-shrink: 0;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .tw-coll-{{ section.id }}__cat-link:hover {
    background: var(--c-soft);
    color: var(--c-ink);
  }
  .tw-coll-{{ section.id }}__cat-link:hover::before { background: var(--c-primary); }
  .tw-coll-{{ section.id }}__cat-link.is-active {
    background: var(--c-primary-tint);
    color: var(--c-primary);
    font-weight: 700;
  }
  .tw-coll-{{ section.id }}__cat-link.is-active::before {
    background: var(--c-primary);
    transform: scale(1.4);
  }

  /* Filter checkboxes */
  .tw-coll-{{ section.id }}__list {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-direction: column; gap: 2px;
  }
  .tw-coll-{{ section.id }}__check {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 7px 8px;
    border-radius: 8px;
    cursor: pointer;
    font-size: 13px;
    color: var(--c-muted);
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tw-coll-{{ section.id }}__check:hover { background: var(--c-soft); color: var(--c-ink); }
  .tw-coll-{{ section.id }}__check input[type="checkbox"] { display: none; }
  .tw-coll-{{ section.id }}__box {
    width: 18px; height: 18px;
    border: 1.5px solid var(--c-line);
    border-radius: 5px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    background: #fff;
    transition: background 0.15s ease, border-color 0.15s ease;
  }
  .tw-coll-{{ section.id }}__box svg {
    width: 11px; height: 11px;
    stroke: #fff; stroke-width: 3;
    fill: none; opacity: 0;
    stroke-linecap: round; stroke-linejoin: round;
  }
  .tw-coll-{{ section.id }}__check input:checked + .tw-coll-{{ section.id }}__box {
    background: var(--c-primary);
    border-color: var(--c-primary);
  }
  .tw-coll-{{ section.id }}__check input:checked + .tw-coll-{{ section.id }}__box svg { opacity: 1; }
  .tw-coll-{{ section.id }}__check input:checked ~ .tw-coll-{{ section.id }}__lbl { color: var(--c-ink); font-weight: 600; }
  .tw-coll-{{ section.id }}__check input:disabled ~ .tw-coll-{{ section.id }}__lbl { opacity: 0.45; }
  .tw-coll-{{ section.id }}__lbl { flex: 1; min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .tw-coll-{{ section.id }}__c-count {
    font-size: 11.5px;
    color: #a89db8;
    background: var(--c-soft);
    padding: 2px 7px;
    border-radius: 100px;
    flex-shrink: 0;
    font-weight: 600;
  }

  /* Price range */
  .tw-coll-{{ section.id }}__price {
    display: flex; align-items: center; gap: 8px;
  }
  .tw-coll-{{ section.id }}__price-input {
    width: 100%;
    padding: 10px 12px;
    border: 1.5px solid var(--c-line);
    border-radius: var(--c-r-chip);
    font-size: 13px;
    color: var(--c-ink);
    background: #fff;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s ease, box-shadow 0.15s ease;
  }
  .tw-coll-{{ section.id }}__price-input:focus {
    border-color: var(--c-primary);
    box-shadow: 0 0 0 3px var(--c-primary-tint);
  }
  .tw-coll-{{ section.id }}__price span {
    color: var(--c-muted);
    font-weight: 600;
  }

  /* ============ MAIN ============ */
  .tw-coll-{{ section.id }}__main { min-width: 0; }

  .tw-coll-{{ section.id }}__toolbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    padding: 4px 0 16px;
    margin-bottom: 18px;
    border-bottom: 1px solid var(--c-line);
    flex-wrap: wrap;
  }
  .tw-coll-{{ section.id }}__tool-left {
    font-size: 13px;
    color: var(--c-muted);
    font-weight: 500;
  }
  .tw-coll-{{ section.id }}__tool-left strong {
    color: var(--c-ink);
    font-weight: 700;
  }
  .tw-coll-{{ section.id }}__tool-right {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  /* Sort styled as a button */
  .tw-coll-{{ section.id }}__sort-wrap {
    position: relative;
    display: inline-flex;
    align-items: center;
    height: 38px;
    padding: 0 32px 0 36px;
    background: #fff;
    border: 1.5px solid var(--c-line);
    border-radius: var(--c-r-btn);
    transition: border-color 0.18s ease, background 0.18s ease;
    cursor: pointer;
  }
  .tw-coll-{{ section.id }}__sort-wrap:hover {
    border-color: var(--c-primary);
    background: var(--c-soft);
  }
  .tw-coll-{{ section.id }}__sort-wrap::before {
    content: '';
    position: absolute;
    left: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 14px; height: 14px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%231f1342' stroke-width='2' stroke-linecap='square' stroke-linejoin='miter'><line x1='3' y1='6' x2='14' y2='6'/><line x1='3' y1='12' x2='11' y2='12'/><line x1='3' y1='18' x2='8' y2='18'/><polyline points='15 14 18 18 21 14'/><line x1='18' y1='6' x2='18' y2='18'/></svg>");
    background-repeat: no-repeat;
    background-size: contain;
  }
  .tw-coll-{{ section.id }}__sort-wrap::after {
    content: '';
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    width: 10px; height: 10px;
    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='%231f1342' stroke-width='2.5' stroke-linecap='square' stroke-linejoin='miter'><polyline points='6 9 12 15 18 9'/></svg>");
    background-repeat: no-repeat;
    background-size: contain;
    pointer-events: none;
  }
  .tw-coll-{{ section.id }}__sort {
    appearance: none;
    -webkit-appearance: none;
    border: none;
    background: transparent;
    font-size: 13px;
    font-weight: 600;
    color: var(--c-ink);
    cursor: pointer;
    font-family: inherit;
    outline: none;
    padding: 0;
    line-height: 1;
  }

  /* Active filter chips */
  .tw-coll-{{ section.id }}__active {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px;
    margin-bottom: 16px;
  }
  .tw-coll-{{ section.id }}__chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 5px 8px 5px 12px;
    background: var(--c-primary-tint);
    color: var(--c-primary);
    border-radius: 100px;
    font-size: 12.5px;
    font-weight: 700;
    text-decoration: none;
    border: 1px solid rgba(123, 63, 242, 0.2);
    transition: background 0.15s ease;
  }
  .tw-coll-{{ section.id }}__chip:hover { background: rgba(123, 63, 242, 0.14); }
  .tw-coll-{{ section.id }}__chip-x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px; height: 18px;
    background: #fff;
    border-radius: 50%;
  }
  .tw-coll-{{ section.id }}__chip-x svg { width: 9px; height: 9px; stroke: var(--c-primary); fill: none; stroke-width: 2.6; stroke-linecap: round; }
  .tw-coll-{{ section.id }}__clear {
    color: var(--c-muted);
    font-size: 12.5px;
    font-weight: 600;
    text-decoration: none;
    padding: 5px 10px;
    border-radius: 100px;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .tw-coll-{{ section.id }}__clear:hover { color: var(--c-primary); background: var(--c-soft); }

  /* Grid */
  .tw-coll-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_desktop }}, minmax(0, 1fr));
    gap: 16px;
  }
  .tw-coll-{{ section.id }}__grid.is-list {
    grid-template-columns: 1fr;
  }
  .tw-coll-{{ section.id }}__grid-item { min-width: 0; }

  /* Empty */
  .tw-coll-{{ section.id }}__empty {
    grid-column: 1 / -1;
    text-align: center;
    padding: 64px 24px;
    background: var(--c-soft);
    border-radius: var(--c-r-card);
    color: var(--c-muted);
    border: 1px dashed var(--c-line);
  }
  .tw-coll-{{ section.id }}__empty-icon {
    width: 64px; height: 64px;
    margin: 0 auto 16px;
    background: #fff;
    border-radius: 16px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--c-primary);
    box-shadow: 0 8px 24px -10px rgba(123, 63, 242, 0.2);
  }
  .tw-coll-{{ section.id }}__empty-icon svg { width: 28px; height: 28px; stroke: currentColor; fill: none; stroke-width: 1.7; }
  .tw-coll-{{ section.id }}__empty-title { font-size: 18px; font-weight: 800; color: var(--c-ink); margin: 0 0 6px; }
  .tw-coll-{{ section.id }}__empty-desc { font-size: 14px; margin: 0 0 18px; max-width: 360px; margin-left: auto; margin-right: auto; line-height: 1.5; }
  .tw-coll-{{ section.id }}__empty-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 11px 20px;
    border-radius: var(--c-r-btn);
    background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
    color: #fff;
    font-size: 13.5px;
    font-weight: 700;
    text-decoration: none;
    transition: filter 0.18s ease, transform 0.18s ease;
    box-shadow: 0 8px 20px -8px rgba(123, 63, 242, 0.4);
  }
  .tw-coll-{{ section.id }}__empty-btn:hover { filter: brightness(1.05); transform: translateY(-1px); }

  /* Pagination */
  .tw-coll-{{ section.id }}__paginate {
    margin-top: 40px;
    display: flex;
    justify-content: center;
    gap: 6px;
    flex-wrap: wrap;
  }
  .tw-coll-{{ section.id }}__paginate a,
  .tw-coll-{{ section.id }}__paginate span {
    min-width: 40px;
    height: 40px;
    padding: 0 12px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border: 1.5px solid var(--c-line);
    border-radius: var(--c-r-btn);
    color: var(--c-ink);
    text-decoration: none;
    font-weight: 700;
    font-size: 13.5px;
    transition: border-color 0.15s ease, color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }
  .tw-coll-{{ section.id }}__paginate a:hover {
    border-color: var(--c-primary);
    color: var(--c-primary);
    background: var(--c-primary-tint);
    transform: translateY(-1px);
  }
  .tw-coll-{{ section.id }}__paginate .current {
    background: linear-gradient(135deg, var(--c-primary) 0%, var(--c-primary-dark) 100%);
    color: #fff;
    border-color: transparent;
    box-shadow: 0 8px 20px -8px rgba(123, 63, 242, 0.4);
  }

  /* ============ MOBILE SEGMENTED TOOLBAR (Trendyol-style) ============ */
  .tw-coll-{{ section.id }}__mbar {
    display: none;
    margin-bottom: 14px;
  }
  .tw-coll-{{ section.id }}__mbar-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: #fff;
    border: 1px solid var(--c-line);
    border-radius: var(--c-r-card);
    overflow: hidden;
    position: relative;
  }
  .tw-coll-{{ section.id }}__mbar-row::after {
    content: '';
    position: absolute;
    top: 12px; bottom: 12px;
    left: 50%;
    width: 1px;
    background: var(--c-line);
  }
  .tw-coll-{{ section.id }}__mbar-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 50px;
    background: transparent;
    border: none;
    color: var(--c-ink);
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    font-family: inherit;
    padding: 0 10px;
    transition: background 0.15s ease, color 0.15s ease;
  }
  .tw-coll-{{ section.id }}__mbar-btn:active { background: var(--c-soft); }
  .tw-coll-{{ section.id }}__mbar-btn svg {
    width: 16px; height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: square;
    stroke-linejoin: miter;
    color: var(--c-primary);
  }
  .tw-coll-{{ section.id }}__mbar-btn-count {
    color: var(--c-primary);
    font-weight: 800;
  }

  /* Horizontal quick-filter chips */
  .tw-coll-{{ section.id }}__chips-row {
    margin-top: 10px;
    display: flex;
    gap: 8px;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    padding: 2px 0 4px;
  }
  .tw-coll-{{ section.id }}__chips-row::-webkit-scrollbar { display: none; }
  .tw-coll-{{ section.id }}__qchip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
    height: 34px;
    padding: 0 12px;
    background: #fff;
    color: var(--c-ink);
    border: 1px solid var(--c-line);
    border-radius: var(--c-r-btn);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    font-family: inherit;
    white-space: nowrap;
    transition: background 0.15s ease, border-color 0.15s ease, color 0.15s ease;
  }
  .tw-coll-{{ section.id }}__qchip:hover { border-color: var(--c-primary); }
  .tw-coll-{{ section.id }}__qchip.is-active {
    background: var(--c-primary-tint);
    border-color: var(--c-primary);
    color: var(--c-primary);
  }
  .tw-coll-{{ section.id }}__qchip svg {
    width: 11px; height: 11px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.4;
    stroke-linecap: square;
    stroke-linejoin: miter;
    opacity: 0.6;
  }
  .tw-coll-{{ section.id }}__qchip-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 16px;
    height: 16px;
    padding: 0 4px;
    background: var(--c-primary);
    color: #fff;
    border-radius: 4px;
    font-size: 10.5px;
    font-weight: 800;
  }

  .tw-coll-{{ section.id }}__overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(20, 14, 40, 0.55);
    z-index: 9998;
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .tw-coll-{{ section.id }}__overlay.is-open { display: block; opacity: 1; }

  /* ============ RESPONSIVE ============ */
  @media screen and (max-width: 1100px) {
    .tw-coll-{{ section.id }}__body {
      grid-template-columns: 240px minmax(0, 1fr);
      gap: 22px;
    }
  }

  @media screen and (max-width: 991px) {
    .tw-coll-{{ section.id }}__body {
      grid-template-columns: 1fr;
      gap: 0;
    }
    .tw-coll-{{ section.id }}__mbar { display: block; }
    .tw-coll-{{ section.id }}__toolbar { display: none; }
    .tw-coll-{{ section.id }}__sub { display: none; }

    /* Bottom sheet drawer */
    .tw-coll-{{ section.id }}__sidebar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      top: auto;
      width: 100%;
      max-height: 90vh;
      transform: translateY(100%);
      transition: transform 0.32s cubic-bezier(0.2, 0.8, 0.2, 1);
      border-radius: 16px 16px 0 0;
      border: none;
      box-shadow: 0 -20px 56px -12px rgba(20, 14, 40, 0.28);
      z-index: 9999;
    }
    .tw-coll-{{ section.id }}__sidebar.is-open { transform: translateY(0); }

    .tw-coll-{{ section.id }}__sidebar::before {
      content: '';
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 40px;
      height: 4px;
      border-radius: 100px;
      background: #d8d0e8;
    }

    .tw-coll-{{ section.id }}__sidebar-head {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 22px 18px 14px;
      border-bottom: 1px solid var(--c-line);
      background: #fff;
      flex-shrink: 0;
    }
    .tw-coll-{{ section.id }}__sidebar-head h3 {
      margin: 0;
      font-size: 16px;
      font-weight: 800;
      color: var(--c-ink);
    }
    .tw-coll-{{ section.id }}__sidebar-close {
      width: 32px; height: 32px;
      background: var(--c-soft);
      border: none;
      border-radius: 8px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--c-muted);
    }
    .tw-coll-{{ section.id }}__sidebar-close svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.4; stroke-linecap: round; }

    .tw-coll-{{ section.id }}__filter-form {
      padding: 12px;
      flex: 1;
    }

    .tw-coll-{{ section.id }}__sidebar-foot {
      position: sticky;
      bottom: 0;
      padding: 14px 16px calc(14px + env(safe-area-inset-bottom, 0px));
      margin-top: 0;
      border-radius: 0;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      background: #fff;
      flex-shrink: 0;
    }
    .tw-coll-{{ section.id }}__apply,
    .tw-coll-{{ section.id }}__reset {
      padding: 12px;
    }

    .tw-coll-{{ section.id }}__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 12px;
    }
  }

  @media screen and (max-width: 749px) {
    .tw-coll-{{ section.id }}__inner { padding: 0 14px; }
    .tw-coll-{{ section.id }}__hero { padding: 22px 0 18px; margin-bottom: 18px; }
    .tw-coll-{{ section.id }}__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }
    .tw-coll-{{ section.id }}__toolbar {
      padding: 10px 12px;
      gap: 10px;
    }
    .tw-coll-{{ section.id }}__count-line { font-size: 12.5px; flex: 1 1 100%; }
    .tw-coll-{{ section.id }}__tool-right { width: 100%; justify-content: space-between; }
    .tw-coll-{{ section.id }}__sort { flex: 1; }
  }
{% endstyle %}

{%- liquid
  assign active_filter_count = 0
  for f in collection.filters
    case f.type
      when 'list', 'boolean'
        assign active_filter_count = active_filter_count | plus: f.active_values.size
      when 'price_range'
        if f.min_value.value or f.max_value.value
          assign active_filter_count = active_filter_count | plus: 1
        endif
    endcase
  endfor
-%}

<section class="tw-coll-{{ section.id }}">

  {% comment %} HERO {% endcomment %}
  <div class="tw-coll-{{ section.id }}__hero">
    <div class="tw-coll-{{ section.id }}__inner">
      <nav class="tw-coll-{{ section.id }}__crumbs" aria-label="Breadcrumb">
        <a href="{{ routes.root_url }}">{{ section.settings.bc_home }}</a>
        <span class="sep" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><polyline points="9 18 15 12 9 6"/></svg></span>
        <a href="{{ routes.all_products_collection_url }}">{{ section.settings.bc_shop }}</a>
        <span class="sep" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><polyline points="9 18 15 12 9 6"/></svg></span>
        <span class="curr">{{ collection.title }}</span>
      </nav>

      {% if section.settings.show_hero_badge %}
        <span class="tw-coll-{{ section.id }}__badge">{{ section.settings.hero_badge_text }}</span>
      {% endif %}

      <h1 class="tw-coll-{{ section.id }}__title">{{ collection.title }}</h1>
      <p class="tw-coll-{{ section.id }}__sub"><strong>{{ collection.products_count }}</strong> ürün</p>

      {% if section.settings.show_description and collection.description != blank %}
        <p class="tw-coll-{{ section.id }}__desc">{{ collection.description | strip_html | truncate: 240 }}</p>
      {% endif %}
    </div>
  </div>

  <div class="tw-coll-{{ section.id }}__inner">
    <div class="tw-coll-{{ section.id }}__overlay" data-tw-filter-overlay></div>

    <div class="tw-coll-{{ section.id }}__body">

      <aside class="tw-coll-{{ section.id }}__sidebar" data-tw-sidebar>
        <div class="tw-coll-{{ section.id }}__sidebar-head">
          <h3>Filtreler</h3>
          <button type="button" class="tw-coll-{{ section.id }}__sidebar-close" data-tw-filter-close aria-label="Kapat">
            <svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
        </div>

        <form id="CollectionFiltersForm-{{ section.id }}" class="tw-coll-{{ section.id }}__filter-form">
          <input type="hidden" name="sort_by" value="{{ collection.sort_by | default: collection.default_sort_by }}">

          {% for block in section.blocks %}
            {% case block.type %}

              {% when 'menu' %}
                <div class="tw-coll-{{ section.id }}__widget" {{ block.shopify_attributes }}>
                  <button type="button" class="tw-coll-{{ section.id }}__w-title" data-tw-acc>
                    {{ block.settings.title }}
                    <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                  </button>
                  <div class="tw-coll-{{ section.id }}__w-body">
                    <ul class="tw-coll-{{ section.id }}__cat-list">
                      {% for link in linklists[block.settings.menu].links %}
                        <li>
                          <a href="{{ link.url }}" class="tw-coll-{{ section.id }}__cat-link{% if link.active or link.child_active %} is-active{% endif %}">
                            {{ link.title }}
                          </a>
                        </li>
                      {% endfor %}
                    </ul>
                  </div>
                </div>

              {% when 'filters' %}
                {% for filter in collection.filters %}
                  <div class="tw-coll-{{ section.id }}__widget" {{ block.shopify_attributes }}>
                    <button type="button" class="tw-coll-{{ section.id }}__w-title" data-tw-acc>
                      {{ filter.label }}
                      <svg viewBox="0 0 24 24"><path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.4" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </button>
                    <div class="tw-coll-{{ section.id }}__w-body">
                      {% case filter.type %}
                        {% when 'list', 'boolean' %}
                          <ul class="tw-coll-{{ section.id }}__list">
                            {% for filter_value in filter.values %}
                              <li>
                                <label class="tw-coll-{{ section.id }}__check">
                                  <input type="checkbox"
                                    name="{{ filter_value.param_name }}"
                                    value="{{ filter_value.value }}"
                                    {% if filter_value.active -%}checked{%- endif %}
                                    {% if filter_value.count == 0 and filter_value.active == false -%}disabled{%- endif %}
                                    data-tw-filter-input>
                                  <span class="tw-coll-{{ section.id }}__box">
                                    <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
                                  </span>
                                  <span class="tw-coll-{{ section.id }}__lbl">{{ filter_value.label }}</span>
                                  <span class="tw-coll-{{ section.id }}__c-count">{{ filter_value.count }}</span>
                                </label>
                              </li>
                            {% endfor %}
                          </ul>

                        {% when 'price_range' %}
                          <div class="tw-coll-{{ section.id }}__price">
                            <input type="number"
                                   name="{{ filter.min_value.param_name }}"
                                   placeholder="Min ₺"
                                   class="tw-coll-{{ section.id }}__price-input"
                                   {% if filter.min_value.value %}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                                   data-tw-filter-input>
                            <span>–</span>
                            <input type="number"
                                   name="{{ filter.max_value.param_name }}"
                                   placeholder="Max ₺"
                                   class="tw-coll-{{ section.id }}__price-input"
                                   {% if filter.max_value.value %}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' }}"{% endif %}
                                   data-tw-filter-input>
                          </div>
                      {% endcase %}
                    </div>
                  </div>
                {% endfor %}
            {% endcase %}
          {% endfor %}
        </form>

        <div class="tw-coll-{{ section.id }}__sidebar-foot">
          <a href="{{ collection.url }}" class="tw-coll-{{ section.id }}__reset">Temizle</a>
          <button type="button"
                  class="tw-coll-{{ section.id }}__apply"
                  data-tw-filter-apply
                  data-form="CollectionFiltersForm-{{ section.id }}">
            <span data-tw-apply-label>Sonuçları Göster</span>
            <span class="tw-coll-{{ section.id }}__apply-count" data-tw-apply-count hidden></span>
          </button>
        </div>
      </aside>

      <main class="tw-coll-{{ section.id }}__main">
        {% paginate collection.products by section.settings.products_per_page %}

          {% comment %} Mobile segmented bar + quick filter chips {% endcomment %}
          <div class="tw-coll-{{ section.id }}__mbar">
            <div class="tw-coll-{{ section.id }}__mbar-row">
              <button type="button" class="tw-coll-{{ section.id }}__mbar-btn" data-tw-filter-open>
                <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="4" y1="6" x2="14" y2="6"/><line x1="4" y1="12" x2="20" y2="12"/><line x1="4" y1="18" x2="10" y2="18"/><circle cx="17" cy="6" r="2.2"/><circle cx="7" cy="12" r="2.2"/><circle cx="13" cy="18" r="2.2"/></svg>
                <span>Filtrele{% if active_filter_count > 0 %} <span class="tw-coll-{{ section.id }}__mbar-btn-count">({{ active_filter_count }})</span>{% endif %}</span>
              </button>
              <label class="tw-coll-{{ section.id }}__mbar-btn" style="position:relative;">
                <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="3 7 7 3 11 7"/><line x1="7" y1="3" x2="7" y2="21"/><polyline points="13 17 17 21 21 17"/><line x1="17" y1="3" x2="17" y2="21"/></svg>
                <span>Sıralama</span>
                <select aria-label="Sırala" style="position:absolute;inset:0;opacity:0;cursor:pointer;font-size:16px;"
                        onchange="document.querySelector('#CollectionFiltersForm-{{ section.id }} input[name=sort_by]').value = this.value; document.getElementById('CollectionFiltersForm-{{ section.id }}').submit();">
                  {% for option in collection.sort_options %}
                    <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
                  {% endfor %}
                </select>
              </label>
            </div>

            {% if collection.filters.size > 0 %}
              <div class="tw-coll-{{ section.id }}__chips-row">
                {% for filter in collection.filters %}
                  {%- liquid
                    assign chip_active = false
                    assign chip_count = 0
                    case filter.type
                      when 'list', 'boolean'
                        assign chip_count = filter.active_values.size
                        if chip_count > 0
                          assign chip_active = true
                        endif
                      when 'price_range'
                        if filter.min_value.value or filter.max_value.value
                          assign chip_active = true
                          assign chip_count = 1
                        endif
                    endcase
                  -%}
                  <button type="button" class="tw-coll-{{ section.id }}__qchip{% if chip_active %} is-active{% endif %}" data-tw-filter-open data-tw-filter-target="{{ filter.label | escape }}">
                    {{ filter.label }}
                    {% if chip_count > 0 %}<span class="tw-coll-{{ section.id }}__qchip-num">{{ chip_count }}</span>{% endif %}
                    <svg viewBox="0 0 24 24" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </button>
                {% endfor %}
              </div>
            {% endif %}
          </div>

          {% comment %} Desktop toolbar (count + sort) {% endcomment %}
          <div class="tw-coll-{{ section.id }}__toolbar">
            <div class="tw-coll-{{ section.id }}__tool-left">
              <strong>{{ collection.products_count }}</strong> ürün listeleniyor
              {%- if paginate.pages > 1 %} · sayfa {{ paginate.current_page }}/{{ paginate.pages }}{% endif -%}
            </div>
            <div class="tw-coll-{{ section.id }}__tool-right">
              <label class="tw-coll-{{ section.id }}__sort-wrap" aria-label="Sıralama">
                <select class="tw-coll-{{ section.id }}__sort"
                        onchange="document.querySelector('#CollectionFiltersForm-{{ section.id }} input[name=sort_by]').value = this.value; document.getElementById('CollectionFiltersForm-{{ section.id }}').submit();">
                  {% for option in collection.sort_options %}
                    <option value="{{ option.value }}" {% if option.value == collection.sort_by %}selected{% endif %}>{{ option.name }}</option>
                  {% endfor %}
                </select>
              </label>
            </div>
          </div>

          {% if active_filter_count > 0 %}
            <div class="tw-coll-{{ section.id }}__active">
              {% for filter in collection.filters %}
                {% case filter.type %}
                  {% when 'list', 'boolean' %}
                    {% for value in filter.active_values %}
                      <a href="{{ value.url_to_remove }}" class="tw-coll-{{ section.id }}__chip">
                        <span>{{ filter.label }}: {{ value.label }}</span>
                        <span class="tw-coll-{{ section.id }}__chip-x"><svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg></span>
                      </a>
                    {% endfor %}
                  {% when 'price_range' %}
                    {% if filter.min_value.value or filter.max_value.value %}
                      <a href="{{ filter.url_to_remove }}" class="tw-coll-{{ section.id }}__chip">
                        <span>{{ filter.label }}: {{ filter.min_value.value | default: 0 | money }} – {{ filter.max_value.value | default: filter.range_max | money }}</span>
                        <span class="tw-coll-{{ section.id }}__chip-x"><svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg></span>
                      </a>
                    {% endif %}
                {% endcase %}
              {% endfor %}
              <a href="{{ collection.url }}" class="tw-coll-{{ section.id }}__clear">Tümünü Temizle</a>
            </div>
          {% endif %}

          <div class="tw-coll-{{ section.id }}__grid" data-tw-grid>
            {% for product in collection.products %}
              <div class="tw-coll-{{ section.id }}__grid-item">
                {% render 'product-card', product: product %}
              </div>
            {% else %}
              <div class="tw-coll-{{ section.id }}__empty">
                <span class="tw-coll-{{ section.id }}__empty-icon">
                  <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                </span>
                <h3 class="tw-coll-{{ section.id }}__empty-title">Bu kategoride henüz ürün yok</h3>
                <p class="tw-coll-{{ section.id }}__empty-desc">Filtreleri temizlemeyi ya da farklı bir kategoriye göz atmayı dene.</p>
                <a href="{{ routes.all_products_collection_url }}" class="tw-coll-{{ section.id }}__empty-btn">
                  Tüm Ürünleri Gör
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"><polyline points="9 18 15 12 9 6"/></svg>
                </a>
              </div>
            {% endfor %}
          </div>

          {% if paginate.pages > 1 %}
            <div class="tw-coll-{{ section.id }}__paginate">
              {{ paginate | default_pagination }}
            </div>
          {% endif %}

        {% endpaginate %}
      </main>

    </div>
  </div>
</section>

<script>
(function() {
  var root = document.currentScript.closest('section.tw-coll-{{ section.id }}') || document.querySelector('.tw-coll-{{ section.id }}');
  if (!root) return;

  // Accordion toggles
  root.querySelectorAll('[data-tw-acc]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      btn.classList.toggle('collapsed');
      var body = btn.nextElementSibling;
      if (body) body.classList.toggle('collapsed');
    });
  });

  // View toggles
  var grid = root.querySelector('[data-tw-grid]');
  root.querySelectorAll('[data-tw-view]').forEach(function(btn) {
    btn.addEventListener('click', function() {
      root.querySelectorAll('[data-tw-view]').forEach(function(b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      if (!grid) return;
      grid.classList.toggle('is-list', btn.dataset.twView === 'list');
    });
  });

  // Mobile filter drawer
  var sidebar = root.querySelector('[data-tw-sidebar]');
  var overlay = root.querySelector('[data-tw-filter-overlay]');

  function openDrawer() {
    if (!sidebar) return;
    sidebar.classList.add('is-open');
    if (overlay) overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }
  function closeDrawer() {
    if (!sidebar) return;
    sidebar.classList.remove('is-open');
    if (overlay) overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  root.querySelectorAll('[data-tw-filter-open]').forEach(function(el) {
    el.addEventListener('click', function() {
      openDrawer();
      var target = el.dataset.twFilterTarget;
      if (!target) return;
      requestAnimationFrame(function() {
        var widgets = root.querySelectorAll('.tw-coll-{{ section.id }}__widget');
        widgets.forEach(function(w) {
          var titleEl = w.querySelector('.tw-coll-{{ section.id }}__w-title');
          if (titleEl && titleEl.textContent.trim().toLowerCase().indexOf(target.toLowerCase()) !== -1) {
            var body = titleEl.nextElementSibling;
            if (titleEl.classList.contains('collapsed')) {
              titleEl.classList.remove('collapsed');
              if (body) body.classList.remove('collapsed');
            }
            setTimeout(function() {
              w.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }, 200);
          }
        });
      });
    });
  });
  root.querySelectorAll('[data-tw-filter-close]').forEach(function(el) { el.addEventListener('click', closeDrawer); });
  if (overlay) overlay.addEventListener('click', closeDrawer);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && sidebar && sidebar.classList.contains('is-open')) closeDrawer();
  });

  /* ---------- Batch filter: dirty state + apply on click ---------- */
  var filterForm = root.querySelector('#CollectionFiltersForm-{{ section.id }}');
  var applyBtn   = root.querySelector('[data-tw-filter-apply]');
  var applyLbl   = root.querySelector('[data-tw-apply-label]');
  var applyCount = root.querySelector('[data-tw-apply-count]');

  function serialize(form) {
    if (!form) return '';
    var data = new FormData(form);
    var pairs = [];
    data.forEach(function(v, k) {
      if (v !== '' && v !== null && v !== undefined) pairs.push(k + '=' + v);
    });
    pairs.sort();
    return pairs.join('&');
  }
  function countSelected(form) {
    if (!form) return 0;
    var n = 0;
    form.querySelectorAll('input[type="checkbox"]').forEach(function(el) { if (el.checked) n++; });
    form.querySelectorAll('input[type="number"]').forEach(function(el) {
      if (el.value !== '' && el.value !== null && el.value !== undefined) n++;
    });
    return n;
  }

  if (filterForm && applyBtn) {
    var initialState = serialize(filterForm);

    function refreshApply() {
      var current = serialize(filterForm);
      var dirty = current !== initialState;
      var total = countSelected(filterForm);
      applyBtn.classList.toggle('is-dirty', dirty);
      applyBtn.setAttribute('aria-disabled', dirty ? 'false' : 'true');
      if (applyLbl) applyLbl.textContent = dirty ? 'Sonuçları Göster' : (total > 0 ? 'Filtreler Uygulandı' : 'Sonuçları Göster');
      if (applyCount) {
        if (dirty && total > 0) {
          applyCount.textContent = total;
          applyCount.hidden = false;
        } else {
          applyCount.hidden = true;
        }
      }
    }

    filterForm.addEventListener('change', refreshApply);
    filterForm.addEventListener('input', refreshApply);
    refreshApply();

    applyBtn.addEventListener('click', function() {
      if (!applyBtn.classList.contains('is-dirty')) {
        closeDrawer();
        return;
      }
      var sortInput = filterForm.querySelector('input[name="sort_by"]');
      if (sortInput && !sortInput.value) sortInput.removeAttribute('name');
      filterForm.submit();
    });
  }
})();
</script>

{% schema %}
{
  "name": "Twinkle Collection Page",
  "settings": [
    {
      "type": "header",
      "content": "Renkler"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Arkaplan Rengi",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Vurgu Rengi",
      "default": "#7b3ff2"
    },
    {
      "type": "color",
