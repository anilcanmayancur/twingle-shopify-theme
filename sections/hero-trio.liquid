{%- comment -%}
  Hero Trio – 1 main banner + 2 helper banners
  Klasik e-ticaret hero düzeni: solda büyük ana banner, sağda iki yardımcı banner.
{%- endcomment -%}

{%- liquid
  assign blocks = section.blocks
  assign main_block = blocks[0]
-%}

<style>
  .tw-hero-{{ section.id }} {
    --tw-r: 16px;
    --tw-r-btn: 10px;
    --tw-line: rgba(123, 63, 242, 0.10);
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    font-family: inherit;
  }
  .tw-hero-{{ section.id }} *,
  .tw-hero-{{ section.id }} *::before,
  .tw-hero-{{ section.id }} *::after { box-sizing: border-box; }

  .tw-hero-{{ section.id }}__inner {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .tw-hero-{{ section.id }}__grid {
    display: grid;
    grid-template-columns: 2fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 16px;
    height: {{ section.settings.height_desktop }}px;
  }

  .tw-hero-{{ section.id }}__card {
    position: relative;
    border-radius: var(--tw-r);
    overflow: hidden;
    background: #1a1140;
    box-shadow: 0 1px 2px rgba(20, 14, 40, 0.04), 0 12px 32px -16px rgba(20, 14, 40, 0.18);
    isolation: isolate;
    text-decoration: none;
    color: inherit;
    display: block;
    transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.25s ease;
  }
  .tw-hero-{{ section.id }}__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(20, 14, 40, 0.06), 0 18px 40px -16px rgba(123, 63, 242, 0.28);
  }
  .tw-hero-{{ section.id }}__card--main { grid-column: 1; grid-row: 1 / span 2; }
  .tw-hero-{{ section.id }}__card--side { grid-column: 2; }

  /* Image */
  .tw-hero-{{ section.id }}__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .tw-hero-{{ section.id }}__card:hover .tw-hero-{{ section.id }}__img { transform: scale(1.04); }

  .tw-hero-{{ section.id }}__placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #7B3FF2, #5B2FB2);
    z-index: 0;
  }
  .tw-hero-{{ section.id }}__placeholder svg {
    position: absolute;
    inset: 0;
    margin: auto;
    width: 56px;
    height: 56px;
    color: rgba(255, 255, 255, 0.35);
  }

  /* Overlay */
  .tw-hero-{{ section.id }}__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .tw-hero-{{ section.id }}__overlay--main {
    background: linear-gradient(90deg, rgba(20, 14, 40, 0.55) 0%, rgba(20, 14, 40, 0.20) 60%, rgba(20, 14, 40, 0.0) 100%);
  }
  .tw-hero-{{ section.id }}__overlay--side {
    background: linear-gradient(180deg, rgba(20, 14, 40, 0.10) 0%, rgba(20, 14, 40, 0.65) 100%);
  }

  /* Content */
  .tw-hero-{{ section.id }}__content {
    position: relative;
    z-index: 2;
    height: 100%;
    padding: 36px;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    color: #fff;
  }
  .tw-hero-{{ section.id }}__card--main .tw-hero-{{ section.id }}__content {
    justify-content: center;
    max-width: 60%;
    padding: 40px 44px;
  }

  .tw-hero-{{ section.id }}__tag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    background: rgba(255, 255, 255, 0.16);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.22);
    color: #fff;
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 5px 11px;
    border-radius: 999px;
    align-self: flex-start;
    margin-bottom: 12px;
    line-height: 1;
  }
  .tw-hero-{{ section.id }}__tag .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.22);
  }

  .tw-hero-{{ section.id }}__title {
    font-size: 36px;
    font-weight: 800;
    line-height: 1.08;
    letter-spacing: -0.025em;
    margin: 0 0 10px;
  }
  .tw-hero-{{ section.id }}__title em {
    font-style: normal;
    background: linear-gradient(90deg, #FCD34D, #F59E0B);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .tw-hero-{{ section.id }}__card--side .tw-hero-{{ section.id }}__title {
    font-size: 22px;
    line-height: 1.15;
  }

  .tw-hero-{{ section.id }}__sub {
    font-size: 15px;
    line-height: 1.45;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 22px;
    max-width: 92%;
    font-weight: 500;
  }
  .tw-hero-{{ section.id }}__card--side .tw-hero-{{ section.id }}__sub {
    font-size: 13px;
    margin-bottom: 14px;
    color: rgba(255, 255, 255, 0.82);
  }

  .tw-hero-{{ section.id }}__btn {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: #fff;
    color: #1F1342;
    font-size: 14px;
    font-weight: 700;
    padding: 12px 20px;
    border-radius: var(--tw-r-btn);
    line-height: 1;
    text-decoration: none;
    transition: background 0.18s ease, color 0.18s ease, transform 0.18s ease;
  }
  .tw-hero-{{ section.id }}__card--side .tw-hero-{{ section.id }}__btn {
    background: rgba(255, 255, 255, 0.95);
    padding: 10px 16px;
    font-size: 13px;
  }
  .tw-hero-{{ section.id }}__btn svg {
    width: 14px;
    height: 14px;
    transition: transform 0.2s ease;
  }
  .tw-hero-{{ section.id }}__card:hover .tw-hero-{{ section.id }}__btn { background: #FCD34D; color: #1F1342; }
  .tw-hero-{{ section.id }}__card:hover .tw-hero-{{ section.id }}__btn svg { transform: translateX(3px); }

  /* Price chip (optional, side cards) */
  .tw-hero-{{ section.id }}__pricechip {
    position: absolute;
    top: 18px;
    right: 18px;
    z-index: 3;
    background: #fff;
    color: var(--tw-primary, #7B3FF2);
    font-size: 12.5px;
    font-weight: 800;
    padding: 6px 12px;
    border-radius: 999px;
    box-shadow: 0 8px 22px -8px rgba(20, 14, 40, 0.35);
    letter-spacing: -0.01em;
  }
  .tw-hero-{{ section.id }}__pricechip small {
    font-size: 10px;
    font-weight: 600;
    color: rgba(31, 19, 66, 0.55);
    display: block;
    line-height: 1;
    margin-bottom: 2px;
  }

  /* ============ TABLET (≤990px) ============ */
  @media screen and (max-width: 990px) {
    .tw-hero-{{ section.id }}__grid {
      grid-template-columns: 1fr 1fr;
      grid-template-rows: auto auto;
      height: auto;
    }
    .tw-hero-{{ section.id }}__card--main {
      grid-column: 1 / -1;
      grid-row: 1;
      aspect-ratio: 16 / 7;
    }
    .tw-hero-{{ section.id }}__card--side {
      grid-column: auto;
      aspect-ratio: 4 / 3;
    }
    .tw-hero-{{ section.id }}__title { font-size: 28px; }
    .tw-hero-{{ section.id }}__card--side .tw-hero-{{ section.id }}__title { font-size: 18px; }
    .tw-hero-{{ section.id }}__sub { font-size: 14px; }
    .tw-hero-{{ section.id }}__card--main .tw-hero-{{ section.id }}__content {
      max-width: 70%;
      padding: 28px;
    }
  }

  /* ============ MOBILE (≤640px) ============ */
  @media screen and (max-width: 640px) {
    .tw-hero-{{ section.id }} {
      padding-top: {{ section.settings.padding_top | times: 0.6 | round }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.6 | round }}px;
    }
    .tw-hero-{{ section.id }}__inner { padding: 0 14px; }
    .tw-hero-{{ section.id }}__grid {
      grid-template-columns: 1fr;
      gap: 10px;
    }
    .tw-hero-{{ section.id }}__card--main {
      aspect-ratio: 3 / 4;
      min-height: 340px;
    }
    .tw-hero-{{ section.id }}__card--main .tw-hero-{{ section.id }}__content {
      max-width: 100%;
      padding: 22px;
      justify-content: flex-end;
    }
    .tw-hero-{{ section.id }}__card--side {
      aspect-ratio: 16 / 9;
    }
    .tw-hero-{{ section.id }}__title { font-size: 26px; }
    .tw-hero-{{ section.id }}__card--side .tw-hero-{{ section.id }}__title { font-size: 17px; }
    .tw-hero-{{ section.id }}__sub { font-size: 13.5px; margin-bottom: 16px; }
    .tw-hero-{{ section.id }}__card--side .tw-hero-{{ section.id }}__sub { font-size: 12.5px; margin-bottom: 10px; }
    .tw-hero-{{ section.id }}__content { padding: 20px; }
    .tw-hero-{{ section.id }}__btn { padding: 10px 16px; font-size: 13px; }
    .tw-hero-{{ section.id }}__tag { font-size: 10.5px; padding: 4px 9px; margin-bottom: 10px; }
  }
</style>

<section class="tw-hero-{{ section.id }}">
  <div class="tw-hero-{{ section.id }}__inner">
    <div class="tw-hero-{{ section.id }}__grid">

      {%- if main_block -%}
        {%- assign m = main_block.settings -%}
        <a class="tw-hero-{{ section.id }}__card tw-hero-{{ section.id }}__card--main"
           href="{{ m.link | default: '#' }}"
           {{ main_block.shopify_attributes }}
           aria-label="{{ m.title | default: 'Ana banner' | strip_html }}">
          {%- if m.image != blank -%}
            <img class="tw-hero-{{ section.id }}__img"
                 src="{{ m.image | image_url: width: 1600 }}"
                 srcset="{{ m.image | image_url: width: 800 }} 800w, {{ m.image | image_url: width: 1200 }} 1200w, {{ m.image | image_url: width: 1600 }} 1600w, {{ m.image | image_url: width: 2000 }} 2000w"
                 sizes="(min-width: 1024px) 66vw, 100vw"
                 alt="{{ m.title | default: 'Banner' | strip_html }}"
                 width="1600" height="1000" loading="eager" fetchpriority="high">
          {%- else -%}
            <div class="tw-hero-{{ section.id }}__placeholder" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="9" cy="9" r="2"/>
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
              </svg>
            </div>
          {%- endif -%}
          <div class="tw-hero-{{ section.id }}__overlay tw-hero-{{ section.id }}__overlay--main"></div>
          <div class="tw-hero-{{ section.id }}__content">
            {%- if m.tag != blank -%}
              <span class="tw-hero-{{ section.id }}__tag"><span class="dot"></span>{{ m.tag }}</span>
            {%- endif -%}
            {%- if m.title != blank -%}
              <h2 class="tw-hero-{{ section.id }}__title">{{ m.title }}</h2>
            {%- endif -%}
            {%- if m.subtitle != blank -%}
              <p class="tw-hero-{{ section.id }}__sub">{{ m.subtitle }}</p>
            {%- endif -%}
            {%- if m.cta_text != blank -%}
              <span class="tw-hero-{{ section.id }}__btn">
                {{ m.cta_text }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            {%- endif -%}
          </div>
        </a>
      {%- endif -%}

      {%- for side_block in blocks offset: 1 limit: 2 -%}
        {%- assign s = side_block.settings -%}
        <a class="tw-hero-{{ section.id }}__card tw-hero-{{ section.id }}__card--side"
           href="{{ s.link | default: '#' }}"
           {{ side_block.shopify_attributes }}
           aria-label="{{ s.title | default: 'Yardımcı banner' | strip_html }}">
          {%- if s.image != blank -%}
            <img class="tw-hero-{{ section.id }}__img"
                 src="{{ s.image | image_url: width: 900 }}"
                 srcset="{{ s.image | image_url: width: 500 }} 500w, {{ s.image | image_url: width: 800 }} 800w, {{ s.image | image_url: width: 1100 }} 1100w"
                 sizes="(min-width: 1024px) 33vw, (min-width: 640px) 50vw, 100vw"
                 alt="{{ s.title | default: 'Banner' | strip_html }}"
                 width="900" height="600" loading="eager">
          {%- else -%}
            <div class="tw-hero-{{ section.id }}__placeholder" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="9" cy="9" r="2"/>
                <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/>
              </svg>
            </div>
          {%- endif -%}
          <div class="tw-hero-{{ section.id }}__overlay tw-hero-{{ section.id }}__overlay--side"></div>
          {%- if s.price_label != blank -%}
            <span class="tw-hero-{{ section.id }}__pricechip" aria-hidden="true">
              {%- if s.price_caption != blank -%}<small>{{ s.price_caption }}</small>{%- endif -%}
              {{ s.price_label }}
            </span>
          {%- endif -%}
          <div class="tw-hero-{{ section.id }}__content">
            {%- if s.tag != blank -%}
              <span class="tw-hero-{{ section.id }}__tag"><span class="dot"></span>{{ s.tag }}</span>
            {%- endif -%}
            {%- if s.title != blank -%}
              <h3 class="tw-hero-{{ section.id }}__title">{{ s.title }}</h3>
            {%- endif -%}
            {%- if s.subtitle != blank -%}
              <p class="tw-hero-{{ section.id }}__sub">{{ s.subtitle }}</p>
            {%- endif -%}
            {%- if s.cta_text != blank -%}
              <span class="tw-hero-{{ section.id }}__btn">
                {{ s.cta_text }}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>
                </svg>
              </span>
            {%- endif -%}
          </div>
        </a>
      {%- endfor -%}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero Trio Banner",
  "tag": "section",
  "class": "tw-section-hero-trio",
  "settings": [
    { "type": "header", "content": "Düzen" },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Arka Plan",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1100,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "label": "Maksimum Genişlik",
      "default": 1440
    },
    {
      "type": "range",
      "id": "height_desktop",
      "min": 380,
      "max": 640,
      "step": 10,
      "unit": "px",
      "label": "Yükseklik (Masaüstü)",
      "default": 480
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Üst Boşluk",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Alt Boşluk",
      "default": 20
    },
    {
      "type": "paragraph",
      "content": "İlk blok ana banner (sol büyük), 2. ve 3. bloklar yardımcı bannerlardır. Sıralamayı sürükleyerek değiştirebilirsin."
    }
  ],
  "blocks": [
    {
      "type": "tw_hero_card",
      "name": "Banner",
      "limit": 3,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Görsel" },
        { "type": "text", "id": "tag", "label": "Üst Etiket", "info": "Örn: Yeni Sezon · Çok Satan" },
        { "type": "text", "id": "title", "label": "Başlık", "info": "İçindeki kelimeleri vurgulamak için <em>kelime</em> kullan." },
        { "type": "textarea", "id": "subtitle", "label": "Alt Yazı" },
        { "type": "text", "id": "cta_text", "label": "Buton Metni" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "header", "content": "Yardımcı Banner için (opsiyonel)" },
        { "type": "text", "id": "price_caption", "label": "Fiyat Üst Metni", "info": "Örn: Başlangıç" },
        { "type": "text", "id": "price_label", "label": "Fiyat", "info": "Örn: 199₺" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Trio Banner",
      "blocks": [
        {
          "type": "tw_hero_card",
          "settings": {
            "tag": "Yeni Sezon",
            "title": "Patilerin için <em>premium</em> beslenme",
            "subtitle": "Veteriner onaylı, %85 hayvansal protein içerikli mamalarda büyük indirim.",
            "cta_text": "Hemen Keşfet",
            "link": "/collections/all"
          }
        },
        {
          "type": "tw_hero_card",
          "settings": {
            "tag": "Çok Satan",
            "title": "Yavru Kedi Maması",
            "subtitle": "Sağlıklı gelişim için özel formül",
            "cta_text": "Şimdi Al",
            "link": "/collections/all",
            "price_caption": "Başlangıç",
            "price_label": "199₺"
          }
        },
        {
          "type": "tw_hero_card",
          "settings": {
            "tag": "Aynı Gün Kargo",
            "title": "Köpek Maması",
            "subtitle": "Her ırk için doğru beslenme",
            "cta_text": "İncele",
            "link": "/collections/all",
            "price_caption": "Başlangıç",
            "price_label": "249₺"
          }
        }
      ]
    }
  ]
}
{% endschema %}
