<div class="petibi-wrap ptabs-{{ section.id }}">

  {%- comment -%}
    Ürün bazlı içerik: Admin > Ayarlar > Özel veri > Ürünler altında metafield tanımlayıp ürün düzenleme sayfasından doldurun.
    Boş bırakılan alanlarda bu bölümün tema ayarları (varsayılan metinler) kullanılır.

    | Metafield (namespace: custom, tür: çok satırlı metin önerilir) | Açıklama |
    | details_bullets | Açıklama sekmesindeki tikli madde listesi — satır başına bir madde |
    | nutrition_rows | Beslenme sekmesi sol tablo — satır başına Etiket|Değer |
    | analytics_heading | Sol sütun başlığı (tek satır, opsiyonel) |
    | ingredients_heading | Sağ sütun başlığı (opsiyonel) |
    | ingredients_body | İçindekiler paragrafı |
    | ingredients_rows | Sağ alttaki Etiket|Değer satırları |
    | feeding_note_title, feeding_note | Sarı besleme uyarısı |
    | faq_items | Her satır: Soru|||Cevap (üç adet pipe) — doluysa tema SSS blokları yerine bunu gösterir |
  {%- endcomment -%}
  {%- liquid
    assign bullets_src = section.settings.description_features
    if product.metafields.custom.details_bullets != blank and product.metafields.custom.details_bullets.value != blank
      assign bullets_src = product.metafields.custom.details_bullets.value
    endif

    assign analytics_src = section.settings.analytics_rows
    if product.metafields.custom.nutrition_rows != blank and product.metafields.custom.nutrition_rows.value != blank
      assign analytics_src = product.metafields.custom.nutrition_rows.value
    endif

    assign analytics_h = section.settings.analytics_title
    if product.metafields.custom.analytics_heading != blank and product.metafields.custom.analytics_heading.value != blank
      assign analytics_h = product.metafields.custom.analytics_heading.value
    endif

    assign ing_title = section.settings.ingredients_title
    if product.metafields.custom.ingredients_heading != blank and product.metafields.custom.ingredients_heading.value != blank
      assign ing_title = product.metafields.custom.ingredients_heading.value
    endif

    assign ing_body = section.settings.ingredients_text
    if product.metafields.custom.ingredients_body != blank and product.metafields.custom.ingredients_body.value != blank
      assign ing_body = product.metafields.custom.ingredients_body.value
    endif

    assign ing_extras_src = section.settings.ingredients_extras
    if product.metafields.custom.ingredients_rows != blank and product.metafields.custom.ingredients_rows.value != blank
      assign ing_extras_src = product.metafields.custom.ingredients_rows.value
    endif

    assign feed_note = section.settings.feeding_note
    if product.metafields.custom.feeding_note != blank and product.metafields.custom.feeding_note.value != blank
      assign feed_note = product.metafields.custom.feeding_note.value
    endif
    assign feed_title = section.settings.feeding_note_title
    if product.metafields.custom.feeding_note_title != blank and product.metafields.custom.feeding_note_title.value != blank
      assign feed_title = product.metafields.custom.feeding_note_title.value
    endif

    assign faq_from_meta = false
    if product.metafields.custom.faq_items != blank and product.metafields.custom.faq_items.value != blank
      assign faq_from_meta = true
    endif
  %}

  <div class="tabs" id="petibiTabNav" role="tablist">
    <button type="button" class="tab act" role="tab" aria-selected="true" onclick="petibiSwitchTab('desc')">{{ section.settings.tab1_label }}</button>
    <button type="button" class="tab" role="tab" aria-selected="false" onclick="petibiSwitchTab('nut')">{{ section.settings.tab2_label }}</button>
    <button type="button" class="tab" role="tab" aria-selected="false" onclick="petibiSwitchTab('rvw')">{{ section.settings.tab3_label }} <span class="tab-count">{{ section.settings.review_count }}</span></button>
    <button type="button" class="tab" role="tab" aria-selected="false" onclick="petibiSwitchTab('faq')">{{ section.settings.tab4_label }}</button>
  </div>

  <div class="tc act" id="petibiTab-desc" role="tabpanel">
    {% if product.description != blank %}
      <div class="desc-p rte">{{ product.description }}</div>
    {% endif %}
    {% if bullets_src != blank %}
      <div class="feat-grid2">
        {% assign features = bullets_src | newline_to_br | split: '<br />' %}
        {% for feat in features %}
          {% assign feat_clean = feat | strip %}
          {% if feat_clean != blank %}
            <div class="fi">
              <span class="fc" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              <span class="fi-txt">{{ feat_clean }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="tc" id="petibiTab-nut">
    <div class="ng">
      <div class="nc">
        <h4>{{ analytics_h }}</h4>
        {% assign analytics = analytics_src | newline_to_br | split: '<br />' %}
        {% for row in analytics %}
          {% assign row_clean = row | strip %}
          {% if row_clean != blank %}
            {% assign parts = row_clean | split: '|' %}
            <div class="nr"><span>{{ parts[0] }}</span><span class="v">{{ parts[1] }}</span></div>
          {% endif %}
        {% endfor %}
      </div>
      <div class="nc">
        <h4>{{ ing_title }}</h4>
        <p style="font-size:11px;color:var(--g600);line-height:1.6;margin-bottom:8px">{{ ing_body }}</p>
        {% assign extras = ing_extras_src | newline_to_br | split: '<br />' %}
        {% for row in extras %}
          {% assign row_clean = row | strip %}
          {% if row_clean != blank %}
            {% assign parts = row_clean | split: '|' %}
            <div class="nr"><span>{{ parts[0] }}</span><span class="v">{{ parts[1] }}</span></div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
    {% if feed_note != blank %}
      <div style="margin-top:12px;background:#FEF3C7;border-radius:9px;padding:11px;font-size:12px;color:#92400E;line-height:1.5">
        <strong>⚠️ {{ feed_title }}:</strong> {{ feed_note }}
      </div>
    {% endif %}
  </div>

  <div class="tc" id="petibiTab-rvw">
    <div class="rv-sum">
      <div>
        <span class="rv-big">{{ section.settings.review_avg }}</span>
        <span class="rv-st">★★★★★</span>
        <span style="font-size:11px;color:var(--g400);display:block;text-align:center">{{ section.settings.review_count }} {{ section.settings.reviews_label }}</span>
      </div>
      <div>
        {% assign bars = section.settings.rating_bars | newline_to_br | split: '<br />' %}
        {% for bar in bars %}
          {% assign bar_clean = bar | strip %}
          {% if bar_clean != blank %}
            {% assign parts = bar_clean | split: '|' %}
            <div class="br">
              <span>{{ parts[0] }}</span>
              <div class="bb"><div class="bf" style="width:{{ parts[1] }}%"></div></div>
              <span class="bc2">{{ parts[2] }}</span>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    {% for block in section.blocks %}
      {% if block.type == 'review' %}
        <div class="rv-card" {{ block.shopify_attributes }}>
          <div class="rv-head">
            <div style="display:flex;align-items:center;gap:7px">
              <div class="rv-av">{{ block.settings.initials }}</div>
              <div>
                <div class="rv-nm">{{ block.settings.name }}</div>
                <div class="rv-pet">{{ block.settings.location }}</div>
              </div>
            </div>
            <div style="text-align:right">
              <div style="color:var(--amber);font-size:12px">
                {% for i in (1..block.settings.stars) %}★{% endfor %}
              </div>
              <div style="font-size:10px;color:var(--g400)">{{ block.settings.date }}</div>
            </div>
          </div>
          <p class="rv-txt">{{ block.settings.text }}</p>
          {% if block.settings.tag != blank %}
            <span class="rv-b">{{ block.settings.tag }}</span>
          {% endif %}
          {% if block.settings.verified %}
            <div style="font-size:10px;color:var(--green);font-weight:600;margin-top:5px">✓ {{ section.settings.verified_label }}</div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}

    {% if section.settings.show_all_reviews_text != blank %}
      <button class="btn-all-reviews" onclick="petibiShowToast('💬', '...')">
        {{ section.settings.show_all_reviews_text }}
      </button>
    {% endif %}
  </div>

  <div class="tc" id="petibiTab-faq" role="tabpanel">
    {%- if faq_from_meta -%}
      {%- assign faq_blob = product.metafields.custom.faq_items.value -%}
      {%- assign faq_lines = faq_blob | strip | newline_to_br | replace: '<br />', '###NL###' | replace: '<br/>', '###NL###' | replace: '<br>', '###NL###' | split: '###NL###' -%}
      {%- for raw_line in faq_lines -%}
        {%- assign fq = raw_line | strip -%}
        {%- if fq == blank -%}{%- continue -%}{%- endif -%}
        {%- assign seg = fq | split: '|||' -%}
        {%- assign fq_q = seg[0] | strip -%}
        {%- assign fq_a = seg[1] | strip -%}
        {%- if fq_q == blank -%}{%- continue -%}{%- endif -%}
        <div class="faq-item">
          <button type="button" class="faq-q" onclick="petibiToggleFaq(this)" aria-expanded="false">
            <span>{{ fq_q | escape }}</span>
            <span class="far" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
            </span>
          </button>
          <div class="faq-a">{{ fq_a | newline_to_br }}</div>
        </div>
      {%- endfor -%}
    {%- else -%}
      {% for block in section.blocks %}
        {% if block.type == 'faq_item' %}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button type="button" class="faq-q" onclick="petibiToggleFaq(this)" aria-expanded="false">
              <span>{{ block.settings.question }}</span>
              <span class="far" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
              </span>
            </button>
            <div class="faq-a">{{ block.settings.answer }}</div>
          </div>
        {% endif %}
      {% endfor %}
    {%- endif -%}
  </div>

</div>

<style>
  .ptabs-{{ section.id }} {
    --pp: var(--p, #7C3AED);
    --pp-tint: var(--p1, #EDE9FE);
    --ink: #1F1342;
    --body: #4B5563;
    --muted: #6B7280;
    --line: #ECE9F5;
    --soft: #FAF7FF;
    --r-card: 14px;
    --r-btn: 10px;
    --r-chip: 8px;
  }

  /* ---- TAB BAR ---- */
  .ptabs-{{ section.id }} .tabs {
    position: relative;
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    margin: 8px 0 20px;
    gap: 4px;
    scrollbar-width: none;
    border-bottom: 1px solid var(--line);
  }
  .ptabs-{{ section.id }} .tabs::-webkit-scrollbar { display: none; }
  .ptabs-{{ section.id }} .tab {
    appearance: none;
    background: transparent;
    border: none;
    padding: 12px 16px 13px;
    font: inherit;
    font-size: 13.5px;
    font-weight: 600;
    color: var(--muted);
    cursor: pointer;
    white-space: nowrap;
    position: relative;
    transition: color .18s ease;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: -1px;
  }
  .ptabs-{{ section.id }} .tab::after {
    content: "";
    position: absolute;
    left: 12px;
    right: 12px;
    bottom: 0;
    height: 2.5px;
    border-radius: 3px 3px 0 0;
    background: transparent;
    transition: background .2s ease;
  }
  .ptabs-{{ section.id }} .tab:hover { color: var(--ink); }
  .ptabs-{{ section.id }} .tab.act { color: var(--pp); }
  .ptabs-{{ section.id }} .tab.act::after { background: var(--pp); }
  .ptabs-{{ section.id }} .tab-count {
    background: var(--soft);
    color: var(--muted);
    font-size: 11px;
    font-weight: 700;
    padding: 2px 7px;
    border-radius: 99px;
    transition: background .2s ease, color .2s ease;
  }
  .ptabs-{{ section.id }} .tab.act .tab-count { background: var(--pp-tint); color: var(--pp); }

  /* ---- TAB PANELS ---- */
  .ptabs-{{ section.id }} .tc { display: none; animation: tw-tab-in .22s ease both; }
  .ptabs-{{ section.id }} .tc.act { display: block; }
  @keyframes tw-tab-in {
    from { opacity: 0; transform: translateY(4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ---- DESCRIPTION ---- */
  .ptabs-{{ section.id }} .desc-p { font-size: 14px; color: var(--body); line-height: 1.75; margin-bottom: 18px; }
  .ptabs-{{ section.id }} .desc-p p { margin: 0 0 12px; }
  .ptabs-{{ section.id }} .desc-p p:last-child { margin-bottom: 0; }
  .ptabs-{{ section.id }} .feat-grid2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 8px 18px;
    margin-bottom: 6px;
  }
  .ptabs-{{ section.id }} .fi {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 13.5px;
    color: var(--ink);
    font-weight: 500;
    padding: 8px 0;
  }
  .ptabs-{{ section.id }} .fc {
    width: 24px; height: 24px;
    flex-shrink: 0;
    background: var(--pp-tint);
    color: var(--pp);
    border-radius: var(--r-chip);
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .ptabs-{{ section.id }} .fc svg { width: 14px; height: 14px; }
  .ptabs-{{ section.id }} .fi-txt { line-height: 1.4; }

  /* ---- NUTRITION ---- */
  .ptabs-{{ section.id }} .ng { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
  .ptabs-{{ section.id }} .nc {
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: 16px 18px;
  }
  .ptabs-{{ section.id }} .nc h4 {
    font-size: 11px;
    font-weight: 800;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: .08em;
    margin: 0 0 10px;
  }
  .ptabs-{{ section.id }} .nr {
    display: flex;
    justify-content: space-between;
    padding: 7px 0;
    border-bottom: 1px dashed var(--line);
    font-size: 13px;
    color: var(--body);
  }
  .ptabs-{{ section.id }} .nr:last-child { border-bottom: none; }
  .ptabs-{{ section.id }} .nr .v { font-weight: 700; color: var(--ink); }

  /* ---- REVIEWS ---- */
  .ptabs-{{ section.id }} .rv-sum {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 22px;
    background: var(--soft);
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    padding: 18px 20px;
    margin-bottom: 16px;
    align-items: center;
  }
  .ptabs-{{ section.id }} .rv-big { font-size: 44px; font-weight: 800; color: var(--ink); display: block; line-height: 1; text-align: center; }
  .ptabs-{{ section.id }} .rv-st { font-size: 16px; color: #F59E0B; display: block; text-align: center; margin: 4px 0; letter-spacing: 1px; }
  .ptabs-{{ section.id }} .br { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
  .ptabs-{{ section.id }} .br span { font-size: 11px; color: var(--muted); width: 12px; text-align: right; font-weight: 600; }
  .ptabs-{{ section.id }} .bb { flex: 1; height: 6px; background: rgba(124, 58, 237, 0.08); border-radius: 999px; overflow: hidden; }
  .ptabs-{{ section.id }} .bf { height: 100%; background: linear-gradient(90deg, #F59E0B, #FBBF24); border-radius: 999px; }
  .ptabs-{{ section.id }} .bc2 { font-size: 11px; color: var(--muted); width: 24px; font-weight: 500; }
  .ptabs-{{ section.id }} .rv-card { background: #fff; border: 1px solid var(--line); border-radius: var(--r-card); padding: 14px 16px; margin-bottom: 10px; }
  .ptabs-{{ section.id }} .rv-head { display: flex; justify-content: space-between; margin-bottom: 9px; align-items: flex-start; }
  .ptabs-{{ section.id }} .rv-av { width: 36px; height: 36px; border-radius: 10px; background: var(--pp-tint); color: var(--pp); font-size: 12px; font-weight: 800; display: flex; align-items: center; justify-content: center; flex-shrink: 0; letter-spacing: -0.02em; }
  .ptabs-{{ section.id }} .rv-nm { font-size: 13.5px; font-weight: 700; color: var(--ink); }
  .ptabs-{{ section.id }} .rv-pet { font-size: 11px; color: var(--muted); }
  .ptabs-{{ section.id }} .rv-txt { font-size: 13px; color: var(--body); line-height: 1.6; margin-bottom: 7px; }
  .ptabs-{{ section.id }} .rv-b { font-size: 10px; background: rgba(16, 185, 129, 0.1); color: #047857; padding: 3px 8px; border-radius: var(--r-chip); font-weight: 700; display: inline-block; margin-right: 4px; }
  .ptabs-{{ section.id }} .btn-all-reviews {
    width: 100%;
    background: #fff;
    border: 1px solid var(--line);
    padding: 12px;
    border-radius: var(--r-btn);
    font-size: 13px;
    font-weight: 700;
    cursor: pointer;
    color: var(--pp);
    margin-top: 8px;
    transition: background .18s ease, border-color .18s ease;
  }
  .ptabs-{{ section.id }} .btn-all-reviews:hover { background: var(--soft); border-color: var(--pp-tint); }

  /* ---- FAQ ---- */
  .ptabs-{{ section.id }} .faq-item {
    border: 1px solid var(--line);
    border-radius: var(--r-card);
    margin-bottom: 8px;
    background: #fff;
    overflow: hidden;
    transition: border-color .18s ease, background .18s ease;
  }
  .ptabs-{{ section.id }} .faq-item.is-open { border-color: var(--pp-tint); background: var(--soft); }
  .ptabs-{{ section.id }} .faq-q {
    appearance: none;
    background: transparent;
    border: none;
    width: 100%;
    text-align: left;
    padding: 14px 16px;
    font: inherit;
    font-size: 14px;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    color: var(--ink);
  }
  .ptabs-{{ section.id }} .faq-q:hover { color: var(--pp); }
  .ptabs-{{ section.id }} .far {
    width: 24px; height: 24px;
    border-radius: var(--r-chip);
    background: var(--pp-tint);
    color: var(--pp);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    transition: transform .2s ease;
    flex-shrink: 0;
  }
  .ptabs-{{ section.id }} .far.open { transform: rotate(180deg); }
  .ptabs-{{ section.id }} .faq-a {
    padding: 0 16px;
    font-size: 13px;
    color: var(--body);
    line-height: 1.65;
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    transition: max-height .25s ease, opacity .2s ease, padding .25s ease;
  }
  .ptabs-{{ section.id }} .faq-a.open {
    padding: 0 16px 14px;
    max-height: 500px;
    opacity: 1;
  }

  @media (max-width: 768px) {
    .ptabs-{{ section.id }} .feat-grid2 { grid-template-columns: 1fr; gap: 4px 12px; }
    .ptabs-{{ section.id }} .ng { grid-template-columns: 1fr; gap: 10px; }
    .ptabs-{{ section.id }} .rv-sum { grid-template-columns: 1fr; gap: 14px; padding: 14px; }
    .ptabs-{{ section.id }} .tab { font-size: 13px; padding: 10px 12px 11px; }
  }
</style>

<script>
  function petibiSwitchTab(id) {
    var nav = document.getElementById('petibiTabNav');
    if (!nav) return;
    nav.querySelectorAll('.tab').forEach(function(t) {
      t.classList.remove('act');
      t.setAttribute('aria-selected', 'false');
    });
    var scope = nav.closest('.petibi-wrap') || document;
    scope.querySelectorAll('.tc').forEach(function(c) { c.classList.remove('act'); });
    var panel = scope.querySelector('#petibiTab-' + id);
    if (panel) panel.classList.add('act');
    var tabs = nav.querySelectorAll('.tab');
    var map = { desc: 0, nut: 1, rvw: 2, faq: 3 };
    if (tabs[map[id]]) {
      tabs[map[id]].classList.add('act');
      tabs[map[id]].setAttribute('aria-selected', 'true');
    }
  }
  function petibiToggleFaq(el) {
    var item = el.closest('.faq-item');
    var answer = el.nextElementSibling;
    var arrow = el.querySelector('.far');
    if (item) item.classList.toggle('is-open');
    if (answer) answer.classList.toggle('open');
    if (arrow) arrow.classList.toggle('open');
  }
</script>

{% schema %}
{
  "name": "Product Tabs",
  "settings": [
    {
      "type": "paragraph",
      "content": "Ürün bazlı içerik: Ayarlar > Özel veri > Ürünler’de custom namespace ile tanımlayın. Dolu metafield, aşağıdaki varsayılanı geçersiz kılar: details_bullets (satır başına madde), nutrition_rows (Etiket|Değer), analytics_heading, ingredients_heading, ingredients_body, ingredients_rows, feeding_note_title, feeding_note, faq_items (satır: Soru|||Cevap — üç pipe; doluysa SSS blokları yerine bu kullanılır)."
    },
    {
      "type": "header",
      "content": "Tab Labels"
    },
    {
      "type": "text",
      "id": "tab1_label",
      "label": "Tab 1 Label",
      "default": "Ürün Açıklaması"
    },
    {
      "type": "text",
      "id": "tab2_label",
      "label": "Tab 2 Label",
      "default": "Beslenme Değerleri"
    },
    {
      "type": "text",
      "id": "tab3_label",
      "label": "Tab 3 Label",
      "default": "Yorumlar"
    },
    {
      "type": "text",
      "id": "tab4_label",
      "label": "Tab 4 Label",
      "default": "Sıkça Sorulanlar"
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "textarea",
      "id": "description_features",
      "label": "Feature Checklist (one per line)",
      "default": "%85 hayvansal kaynaklı protein\nSağlıklı kas gelişimini destekler\nKemik & eklem sağlığını güçlendirir\nParlak tüy & sağlıklı cilt formülü\nPrebiyotik ile sindirim desteği\nOmega-3 bağışıklık güçlendirici\nDüşük tahıllı formül\n0-1 yaş özel geliştirme"
    },
    {
      "type": "header",
      "content": "Nutrition"
