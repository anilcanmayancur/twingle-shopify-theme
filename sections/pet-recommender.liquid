            <span class="pet-rec-opt-desc-{{ section.id }}">Kolay sindirim</span>
          </span>
        </button>
        <button class="pet-rec-opt-{{ section.id }}" data-q="need" data-v="organik" data-tag="organik">
          <span class="pet-rec-opt-emoji-{{ section.id }}">🌾</span>
          <span class="pet-rec-opt-content-{{ section.id }}">
            <span class="pet-rec-opt-title-{{ section.id }}">Organik / Doğal</span>
            <span class="pet-rec-opt-desc-{{ section.id }}">Temiz içerik</span>
          </span>
        </button>
        <button class="pet-rec-opt-{{ section.id }}" data-q="need" data-v="kisirlastirilmis" data-tag="kısırlaştırılmış">
          <span class="pet-rec-opt-emoji-{{ section.id }}">⚖️</span>
          <span class="pet-rec-opt-content-{{ section.id }}">
            <span class="pet-rec-opt-title-{{ section.id }}">Kısırlaştırılmış</span>
            <span class="pet-rec-opt-desc-{{ section.id }}">Kilo kontrolü</span>
          </span>
        </button>
        <button class="pet-rec-opt-{{ section.id }}" data-q="need" data-v="standart" data-tag="">
          <span class="pet-rec-opt-emoji-{{ section.id }}">✨</span>
          <span class="pet-rec-opt-content-{{ section.id }}">
            <span class="pet-rec-opt-title-{{ section.id }}">En İyileri Göster</span>
            <span class="pet-rec-opt-desc-{{ section.id }}">Genel öneri</span>
          </span>
        </button>
      </div>
    </div>

    <div class="pet-rec-loading-{{ section.id }}" id="PRecLoad-{{ section.id }}">
      <div class="pet-rec-orb-{{ section.id }}">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square" stroke-linejoin="miter"><path d="M12 2l2.5 7.5L22 12l-7.5 2.5L12 22l-2.5-7.5L2 12l7.5-2.5L12 2z"/></svg>
      </div>
      <div class="pet-rec-loading-text-{{ section.id }}" id="PRecLoadText-{{ section.id }}">Tercihlerini analiz ediyorum...</div>
      <div class="pet-rec-loading-sub-{{ section.id }}">Veteriner onaylı ürünlerimiz arasından dostun için en uygun seçimleri yapıyorum.</div>
      <div class="pet-rec-loading-dots-{{ section.id }}">
        <span></span><span></span><span></span>
      </div>
    </div>

    <div class="pet-rec-results-{{ section.id }}" id="PRecResults-{{ section.id }}">
      <div class="pet-rec-results-head-{{ section.id }}">
        <span class="pet-rec-results-icon-{{ section.id }}">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="square" stroke-linejoin="miter"><polyline points="20 6 9 17 4 12"/></svg>
        </span>
        <div class="pet-rec-results-text-{{ section.id }}">
          <span class="pet-rec-results-title-{{ section.id }}">Senin için seçtiklerim</span>
          <span class="pet-rec-results-sub-{{ section.id }}" id="PRecResultsSub-{{ section.id }}">4 ürün eşleşti</span>
        </div>
      </div>
      <div class="pet-rec-products-{{ section.id }}" id="PRecProducts-{{ section.id }}"></div>
    </div>

  </div>

  <div class="pet-rec-foot-{{ section.id }}">
    <button class="pet-rec-back-{{ section.id }}" id="PRecBack-{{ section.id }}" disabled>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square" stroke-linejoin="miter"><polyline points="15 18 9 12 15 6"/></svg>
      Geri
    </button>
    <a class="pet-rec-cta-{{ section.id }}" id="PRecCta-{{ section.id }}" href="{{ section.settings.base_collection.url | default: '/collections/all' }}" style="display:none;">
      Tüm Önerileri Gör
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square" stroke-linejoin="miter"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
    </a>
  </div>

</div>

<script>
(function() {
  var TRIGGER_SELECTOR = '{{ section.settings.trigger_selector | default: ".pet-rec-trigger,[data-pet-recommender]" }}';
  var BASE_URL = '{{ section.settings.base_collection.url | default: "/collections/all" }}';

  var modal = document.getElementById('PRecModal-{{ section.id }}');
  var overlay = document.getElementById('PRecOver-{{ section.id }}');
  var closeBtn = document.getElementById('PRecClose-{{ section.id }}');
  var backBtn = document.getElementById('PRecBack-{{ section.id }}');
  var ctaBtn = document.getElementById('PRecCta-{{ section.id }}');
  var fill = document.getElementById('PRecFill-{{ section.id }}');
  var stepLabel = document.getElementById('PRecStepLabel-{{ section.id }}');
  var loadEl = document.getElementById('PRecLoad-{{ section.id }}');
  var loadTextEl = document.getElementById('PRecLoadText-{{ section.id }}');
  var resultsEl = document.getElementById('PRecResults-{{ section.id }}');
  var productsEl = document.getElementById('PRecProducts-{{ section.id }}');
  var resultsSub = document.getElementById('PRecResultsSub-{{ section.id }}');

  if (!modal) return;

  var steps = modal.querySelectorAll('.pet-rec-step-{{ section.id }}');
  var totalSteps = steps.length;
  var currentStep = 1;
  var answers = {};
  var loadingMessages = [
    'Tercihlerini analiz ediyorum...',
    'Veteriner onaylı ürünleri tarıyorum...',
    'Dostun için en iyi eşleşmeleri buluyorum...',
    'Son rötuşları yapıyorum...'
  ];

  function open() {
    modal.classList.add('is-open');
    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    reset();
  }

  function close() {
    modal.classList.remove('is-open');
    overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  function reset() {
    currentStep = 1;
    answers = {};
    showStep(1);
    loadEl.classList.remove('is-active');
    resultsEl.classList.remove('is-active');
    ctaBtn.style.display = 'none';
    productsEl.innerHTML = '';
    modal.querySelectorAll('.pet-rec-opt-{{ section.id }}').forEach(function(b) {
      b.classList.remove('is-selected');
    });
  }

  function showStep(n) {
    steps.forEach(function(s) {
      s.classList.toggle('is-active', parseInt(s.dataset.step, 10) === n);
    });
    var pct = (n / totalSteps) * 100;
    fill.style.width = pct + '%';
    stepLabel.textContent = n + ' / ' + totalSteps;
    backBtn.disabled = n === 1;
    ctaBtn.style.display = 'none';
  }

  function nextStep() {
    if (currentStep < totalSteps) {
      currentStep++;
      showStep(currentStep);
    } else {
      runRecommendation();
    }
  }

  function prevStep() {
    if (loadEl.classList.contains('is-active') || resultsEl.classList.contains('is-active')) {
      loadEl.classList.remove('is-active');
      resultsEl.classList.remove('is-active');
      showStep(currentStep);
      return;
    }
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
    }
  }

  function renderProducts(products, query) {
    if (products.length === 0) {
      productsEl.innerHTML = '<div class="pet-rec-empty-{{ section.id }}">Henüz ürün bulamadım. Tüm ürünleri keşfetmek için aşağıdaki butona tıkla.</div>';
      resultsSub.textContent = 'Genel öneriler hazır';
    } else {
      resultsSub.textContent = products.length + ' ürün eşleşti';
      productsEl.innerHTML = products.map(function(p) {
        var img = p.image || (p.featured_image && p.featured_image.url) || '';
        var price = p.price || '';
        return ''
          + '<a href="' + p.url + '" class="pet-rec-product-{{ section.id }}">'
          + '<div class="pet-rec-product-img-{{ section.id }}">'
          + (img ? '<img src="' + img + '" alt="' + (p.title || '') + '" loading="lazy">' : '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7B3FF2" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>')
          + '</div>'
          + '<div class="pet-rec-product-info-{{ section.id }}">'
          + '<div class="pet-rec-product-name-{{ section.id }}">' + (p.title || '') + '</div>'
          + (price ? '<div class="pet-rec-product-price-{{ section.id }}">' + price + '</div>' : '')
          + '</div>'
          + '<span class="pet-rec-product-arrow-{{ section.id }}"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square" stroke-linejoin="miter"><polyline points="9 18 15 12 9 6"/></svg></span>'
          + '</a>';
      }).join('');
    }

    ctaBtn.style.display = 'inline-flex';
    ctaBtn.href = BASE_URL + (query ? '?q=' + encodeURIComponent(query) : '');
  }

  function showResults(products, query, msgInt) {
    setTimeout(function() {
      clearInterval(msgInt);
      loadEl.classList.remove('is-active');
      resultsEl.classList.add('is-active');
      backBtn.disabled = false;
      renderProducts(products, query);
    }, 1800);
  }

  function runRecommendation() {
    steps.forEach(function(s) { s.classList.remove('is-active'); });
    loadEl.classList.add('is-active');
    fill.style.width = '100%';
    stepLabel.textContent = 'Analiz ediyor...';
    backBtn.disabled = true;

    var msgIdx = 0;
    var msgInt = setInterval(function() {
      msgIdx = (msgIdx + 1) % loadingMessages.length;
      loadTextEl.style.opacity = '0';
      setTimeout(function() {
        loadTextEl.textContent = loadingMessages[msgIdx];
        loadTextEl.style.opacity = '1';
      }, 200);
    }, 1100);

    var allTags = [];
    Object.keys(answers).forEach(function(k) {
      if (answers[k].tag) allTags.push(answers[k].tag);
    });

    // Aramayı geniş tut: önce tüm tag'ler, sonra ilk 2, sonra ilki, sonra fallback
    var queries = [
      allTags.join(' '),
      allTags.slice(0, 2).join(' '),
      allTags[0] || '',
      ''
    ];

    function tryQuery(idx) {
      if (idx >= queries.length) {
        showResults([], '', msgInt);
        return;
      }
      var q = queries[idx];
      var url = q
        ? '/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=4'
        : '/products.json?limit=4';

      fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var products;
          if (q) {
            products = (data.resources && data.resources.results && data.resources.results.products) || [];
          } else {
            products = (data.products || []).map(function(p) {
              return {
                title: p.title,
                url: '/products/' + p.handle,
                image: p.images && p.images[0] && (p.images[0].src || p.images[0]),
                price: p.variants && p.variants[0] ? '₺' + p.variants[0].price : ''
              };
            });
          }

          if (products.length > 0) {
            showResults(products, q, msgInt);
          } else {
            tryQuery(idx + 1);
          }
        })
        .catch(function() { tryQuery(idx + 1); });
    }

    tryQuery(0);
  }

  modal.addEventListener('click', function(e) {
    var opt = e.target.closest('.pet-rec-opt-{{ section.id }}');
    if (opt) {
      var step = opt.closest('.pet-rec-step-{{ section.id }}');
      step.querySelectorAll('.pet-rec-opt-{{ section.id }}').forEach(function(b) {
        b.classList.remove('is-selected');
      });
      opt.classList.add('is-selected');
      answers[opt.dataset.q] = { value: opt.dataset.v, tag: opt.dataset.tag || '' };
      setTimeout(nextStep, 280);
    }
  });

  closeBtn.addEventListener('click', close);
  overlay.addEventListener('click', close);
  backBtn.addEventListener('click', prevStep);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) close();
  });

  document.addEventListener('click', function(e) {
    var trigger = e.target.closest(TRIGGER_SELECTOR);
    if (trigger) {
      e.preventDefault();
      open();
    }
  });
})();
</script>

{% schema %}
{
  "name": "Pet Öneri Asistanı",
  "settings": [
    {
      "type": "paragraph",
      "content": "Bu modül arka planda çalışır. Hero'daki 'Petim İçin Öner' butonuna pet-rec-trigger class'ı eklenmiş olmalı."
    },
    {
      "type": "text",
      "id": "trigger_selector",
      "label": "Trigger CSS Selector",
      "info": "Bu selector'a uyan tüm linkler/butonlar modal'ı açar.",
      "default": ".pet-rec-trigger,[data-pet-recommender]"
    },
    {
      "type": "collection",
      "id": "base_collection",
      "label": "Tüm Öneriler Koleksiyonu",
      "info": "Sonuç ekranındaki 'Tüm Önerileri Gör' butonu bu koleksiyona yönlendirir."
    }
  ],
  "presets": [
    {
      "name": "Pet Öneri Asistanı"
    }
  ]
}
{% endschema %}