<div class="petibi-wrap">
  <div class="rec-sec">
    <div class="rec-hd">
      <h2 id="petibiRelTitle">{{ section.settings.default_title }}</h2>
      {% if section.settings.see_all_text != blank %}
        <span class="see-all" onclick="petibiShowToast('⭐', '...')">{{ section.settings.see_all_text }}</span>
      {% endif %}
    </div>

    <div class="rtabs">
      {% for block in section.blocks %}
        {% if block.type == 'product_tab' %}
          <div
            class="rtab {% if forloop.first %}act{% endif %}"
            onclick="petibiShowRelated('{{ block.settings.tab_id }}', this, '{{ block.settings.heading | escape }}')"
            {{ block.shopify_attributes }}
          >
            {{ block.settings.label }}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% for block in section.blocks %}
      {% if block.type == 'product_tab' %}
        <div class="rg" id="petibiRel-{{ block.settings.tab_id }}" {% unless forloop.first %}style="display:none"{% endunless %}>
          {% assign rel_collection = collections[block.settings.collection] %}
          {% if rel_collection and rel_collection.products_count > 0 %}
            {% for rel_product in rel_collection.products limit: 4 %}
              
              {% render 'product-card', product: rel_product %}
              
            {% endfor %}
          {% else %}
            <p style="color: #888; font-size: 14px; grid-column: 1 / -1;">Bu sekme için henüz ürün seçilmedi.</p>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}

  </div>
</div>

<style>
  .rec-sec { margin-bottom: 24px; font-family: inherit; }
  .rec-hd { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; }
  .rec-hd h2 { font-size: 22px; font-weight: 800; margin: 0; color: #111; letter-spacing: -0.02em; }
  
  .see-all { 
    font-size: 13px; 
    color: #7B3FF2; 
    font-weight: 600; 
    background: #F4F0FF; 
    padding: 8px 16px; 
    border-radius: 50px; 
    cursor: pointer; 
    transition: opacity 0.2s; 
    white-space: nowrap;
  }
  .see-all:hover { opacity: 0.8; }
  
  .rtabs { 
    display: flex; 
    background: #FAFAFA; 
    border: 1px solid #EAEAEA;
    border-radius: 50px; 
    padding: 6px; 
    width: fit-content; 
    margin-bottom: 24px; 
    overflow-x: auto; 
    scrollbar-width: none; 
  }
  .rtabs::-webkit-scrollbar { display: none; }
  
  .rtab { 
    padding: 10px 24px; 
    font-size: 14px; 
    font-weight: 600; 
    border-radius: 50px; 
    cursor: pointer; 
    color: #666; 
    transition: all .2s; 
    white-space: nowrap; 
  }
  .rtab.act { 
    background: #FFFFFF; 
    color: #7B3FF2; 
    box-shadow: 0 4px 12px rgba(0,0,0,.05); 
  }
  
  /* Ürün Kartı Grid Yapısı */
  .rg { 
    display: grid; 
    grid-template-columns: repeat(4, 1fr); 
    gap: 24px; 
  }
  
  @media(max-width: 1024px) { 
    .rg { grid-template-columns: repeat(3, 1fr); } 
  }
  @media(max-width: 768px) { 
    .rg { grid-template-columns: repeat(2, 1fr); gap: 16px; } 
    .rec-hd h2 { font-size: 18px; }
    .rtab { padding: 8px 16px; font-size: 13px; }
  }
  @media(max-width: 480px) { 
    .rg { gap: 12px; } 
  }
</style>

<script>
  function petibiShowRelated(type, el, title) {
    // Aktif tab'ı değiştir
    document.querySelectorAll('.rtab').forEach(function(t) { t.classList.remove('act'); });
    el.classList.add('act');
    
    // Tüm gridleri gizle ve sadece tıklananı göster
    document.querySelectorAll('[id^="petibiRel-"]').forEach(function(g) { g.style.display = 'none'; });
    var grid = document.getElementById('petibiRel-' + type);
    if (grid) grid.style.display = 'grid';
    
    // Başlığı güncelle
    var titleEl = document.getElementById('petibiRelTitle');
    if (titleEl && title) titleEl.textContent = title;
  }
</script>

{% schema %}
{
  "name": "Related Products Tabs",
  "settings": [
    {
      "type": "text",
      "id": "default_title",
      "label": "Default Title",
      "default": "Aynı Kategoriden Ürünler"
    },
    {
      "type": "text",
      "id": "see_all_text",
      "label": "See All Button Text",
      "default": "Tümünü Gör →"
    }
  ],
  "blocks": [
    {
      "type": "product_tab",
      "name": "Product Tab",
      "settings": [
        {
          "type": "text",
          "id": "tab_id",
          "label": "Tab ID (Benzersiz olmalı, boşluk kullanmayın)",
          "default": "same"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Tab Buton Yazısı",
          "default": "🐱 Aynı Kategoriden"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Aktif Olduğunda Üst Başlık",
          "default": "Aynı Kategoriden Ürünler"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Koleksiyon Seçimi"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Related Products Tabs",
      "blocks": [
        { "type": "product_tab", "settings": { "tab_id": "same", "label": "🐱 Aynı Kategoriden", "heading": "Aynı Kategoriden Ürünler" } },
        { "type": "product_tab", "settings": { "tab_id": "comp", "label": "🛒 Tamamlayıcı", "heading": "Tamamlayıcı Ürünler" } },
        { "type": "product_tab", "settings": { "tab_id": "rec", "label": "🕐 Son Görüntülenenler", "heading": "Son Görüntülenenler" } }
      ]
    }
  ]
}
{% endschema %}