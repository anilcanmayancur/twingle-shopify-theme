{{ 'petibi-product.css' | asset_url | stylesheet_tag }}

<div class="petibi-toast" id="petibiToast">
  <span id="petibiToastIcon">🛒</span>
  <span id="petibiToastMsg"></span>
</div>

<div class="petibi-wrap">

  {%- render 'product-breadcrumb', product: product -%}

  <div class="petibi-top">

    <div class="petibi-gallery-col">
      {%- render 'product-gallery',
        product: product,
        badge_text: section.settings.gallery_badge_text,
        show_zoom_hint: section.settings.gallery_show_zoom_hint,
        zoom_label: section.settings.gallery_zoom_label
      -%}
    </div>

    <div class="petibi-info-col">
      {%- for block in section.blocks -%}

        {%- case block.type -%}

        {%- when 'product_header' -%}
          {%- render 'product-header',
            product: product,
            block: block
          -%}

        {%- when 'product_price' -%}
          {%- render 'product-price',
            product: product,
            block: block
          -%}

        {%- when 'vet_note' -%}
          {%- render 'product-vet-note', block: block -%}

        {%- when 'features' -%}
          {%- render 'product-features', block: block -%}

        {%- when 'variant_picker' -%}
          {%- render 'product-variant-picker',
            product: product,
            block: block
          -%}

        {%- when 'purchase_type' -%}
          {%- render 'product-purchase-type',
            product: product,
            block: block
          -%}

        {%- when 'buy_buttons' -%}
          {%- render 'product-buy-buttons',
            product: product,
            section: section,
            block: block
          -%}

        {%- when 'delivery_info' -%}
          {%- render 'product-delivery', block: block -%}

        {%- when 'trust_badges' -%}
          {%- render 'product-trust', block: block -%}

        {%- endcase -%}

      {%- endfor -%}
    </div>

  </div>

</div>

<script>
  var petibiToastTimer;
  function petibiShowToast(icon, msg) {
    clearTimeout(petibiToastTimer);
    document.getElementById('petibiToastIcon').textContent = icon;
    document.getElementById('petibiToastMsg').textContent = msg;
    document.getElementById('petibiToast').classList.add('show');
    petibiToastTimer = setTimeout(function() {
      document.getElementById('petibiToast').classList.remove('show');
    }, 2800);
  }
</script>

