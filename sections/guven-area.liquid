<section class="pet-trust" id="section-{{ section.id }}">
  <div class="pet-trust__container">
    {%- for block in section.blocks -%}
      <div class="pet-trust__card" {{ block.shopify_attributes }}>
        <span class="pet-trust__icon">
          {%- case block.settings.icon -%}
            {%- when 'truck' -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            {%- when 'shield' -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            {%- when 'refresh' -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
            {%- when 'headphones' -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
            {%- when 'heart' -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
            {%- when 'star' -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            {%- when 'lock' -%}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          {%- endcase -%}
        </span>
        <div class="pet-trust__text">
          <span class="pet-trust__label">{{ block.settings.text }}</span>
          {%- if block.settings.desc != blank -%}
            <span class="pet-trust__sub">{{ block.settings.desc }}</span>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>
</section>

<style>
  .pet-trust {
    padding: 28px 0;
    background: white;
  }

  .pet-trust__container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
  }

  .pet-trust__card {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    background: #F8F6FF;
    border-radius: 12px;
    border: 1px solid rgba(123, 63, 242, 0.08);
  }

  .pet-trust__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: white;
    border-radius: 8px;
    color: #7B3FF2;
    flex-shrink: 0;
    box-shadow: 0 2px 8px rgba(123, 63, 242, 0.08);
  }

  .pet-trust__text {
    display: flex;
    flex-direction: column;
    gap: 2px;
    min-width: 0;
  }

  .pet-trust__label {
    font-size: 13px;
    font-weight: 700;
    color: #1F1342;
    line-height: 1.3;
  }

  .pet-trust__sub {
    font-size: 11px;
    color: #5A4F75;
    line-height: 1.3;
  }

  @media (max-width: 1024px) {
    .pet-trust__container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .pet-trust {
      padding: 20px 0;
    }

    .pet-trust__container {
      padding: 0 16px;
      gap: 8px;
    }

    .pet-trust__card {
      padding: 12px;
      gap: 10px;
    }

    .pet-trust__icon {
      width: 32px;
      height: 32px;
    }

    .pet-trust__icon svg {
      width: 16px;
      height: 16px;
    }

    .pet-trust__label {
      font-size: 12px;
    }

    .pet-trust__sub {
      font-size: 10px;
    }
  }
</style>

{% schema %}
{
  "name": "Premium Güven Barı",
  "settings": [],
  "blocks": [
    {
      "type": "feature",
      "name": "Özellik",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "İkon",
          "options": [
            { "value": "truck", "label": "Kargo" },
            { "value": "shield", "label": "Güvenlik" },
            { "value": "refresh", "label": "İade" },
            { "value": "headphones", "label": "Destek" },
            { "value": "heart", "label": "Kalp" },
            { "value": "star", "label": "Yıldız" },
            { "value": "lock", "label": "Kilit" }
          ],
          "default": "truck"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Metin",
          "default": "Ücretsiz Kargo"
        },
              {
          "type": "text",
          "id": "desc",
          "label": "Alt Metin",
          "default": "Detay"
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Premium Güven Barı",
      "blocks": [
        { "type": "feature", "settings": { "icon": "truck", "text": "Ücretsiz Kargo", "desc": "500₺ üzeri siparişlerde" } },
        { "type": "feature", "settings": { "icon": "shield", "text": "Güvenli Ödeme", "desc": "256-bit SSL şifreleme" } },
        { "type": "feature", "settings": { "icon": "refresh", "text": "14 Gün İade", "desc": "Koşulsuz iade garantisi" } },
        { "type": "feature", "settings": { "icon": "headphones", "text": "7/24 Destek", "desc": "Her zaman yanınızdayız" } }
      ]
    }
  ]
}
{% endschema %}