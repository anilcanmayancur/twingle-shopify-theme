<style>
.pet-hero-{{ section.id }} {
  --pet-primary: {{ section.settings.primary_color }};
  --pet-primary-light: {{ section.settings.primary_light_color }};
  --pet-primary-deep: {{ section.settings.primary_deep_color }};
  --pet-bg: {{ section.settings.bg_color }};
  --pet-bg-soft: {{ section.settings.bg_color_soft }};
  --pet-ink: #1F1342;
  --pet-body: #5A4F75;
  --pet-line: rgba(123, 63, 242, 0.14);
  --pet-line-strong: rgba(123, 63, 242, 0.22);
  --pet-card: #FFFFFF;

  position: relative;
  background:
    radial-gradient(900px 500px at 90% 0%, rgba(123, 63, 242, 0.10), transparent 60%),
    radial-gradient(800px 460px at 0% 100%, rgba(123, 63, 242, 0.07), transparent 55%),
    linear-gradient(180deg, var(--pet-bg) 0%, var(--pet-bg-soft) 100%);
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
  font-family: inherit, 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  overflow: hidden;
  isolation: isolate;
}

.pet-hero-{{ section.id }} *,
.pet-hero-{{ section.id }} *::before,
.pet-hero-{{ section.id }} *::after { box-sizing: border-box; }

.pet-hero-{{ section.id }}::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image: radial-gradient(rgba(123, 63, 242, 0.16) 1px, transparent 1px);
  background-size: 26px 26px;
  opacity: 0.4;
  mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  -webkit-mask-image: radial-gradient(ellipse at center, black 30%, transparent 75%);
  pointer-events: none;
  z-index: 0;
}

.pet-hero-container-{{ section.id }} {
  position: relative;
  z-index: 1;
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 24px;
  display: grid;
  grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
  gap: 64px;
  align-items: center;
}

/* SOL */
.pet-hero-content-{{ section.id }} {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  opacity: 0;
  animation: pet-fade-up-{{ section.id }} 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) 0.1s forwards;
}

@keyframes pet-fade-up-{{ section.id }} {
  from { opacity: 0; transform: translateY(20px); }
  to   { opacity: 1; transform: translateY(0); }
}

.pet-hero-badge-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background-color: var(--pet-card);
  color: var(--pet-ink);
  padding: 7px 16px 7px 7px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 26px;
  border: 1px solid var(--pet-line);
  box-shadow: 0 6px 16px -8px rgba(123, 63, 242, 0.22);
}

.pet-hero-badge-icon-{{ section.id }} {
  width: 22px; height: 22px;
  border-radius: 6px;
  background: var(--pet-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.pet-hero-badge-icon-{{ section.id }} svg { width: 12px; height: 12px; fill: #fff; }

.pet-hero-title-{{ section.id }} {
  font-size: clamp(34px, 5.4vw, {{ section.settings.title_size }}px);
  font-weight: 800;
  color: var(--pet-ink);
  line-height: 1.08;
  margin: 0 0 22px 0;
  letter-spacing: -0.025em;
  text-wrap: balance;
}

.pet-hero-title-{{ section.id }} .highlight {
  color: var(--pet-primary);
  position: relative;
  display: inline-block;
}

.pet-hero-title-{{ section.id }} .highlight::after {
  content: "";
  position: absolute;
  left: 0; right: 0; bottom: 0.06em;
  height: 0.22em;
  background: var(--pet-primary-light);
  opacity: 0.45;
  border-radius: 4px;
  z-index: -1;
}

.pet-hero-desc-{{ section.id }} {
  font-size: clamp(15px, 1.4vw, 17px);
  color: var(--pet-body);
  line-height: 1.6;
  margin: 0 0 32px 0;
  max-width: 92%;
}

.pet-hero-buttons-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 32px;
  flex-wrap: wrap;
}

.pet-btn-primary-{{ section.id }} {
  background-color: var(--pet-primary);
  color: #FFFFFF;
  padding: 14px 22px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 600;
  font-size: 14.5px;
  transition: transform 0.2s ease, background-color 0.2s ease, box-shadow 0.2s ease;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 1.5px solid var(--pet-primary);
  box-shadow: 0 6px 16px -8px rgba(123, 63, 242, 0.5);
}

.pet-btn-primary-{{ section.id }}:hover {
  background-color: var(--pet-primary-deep);
  border-color: var(--pet-primary-deep);
  transform: translateY(-1px);
  box-shadow: 0 10px 24px -8px rgba(123, 63, 242, 0.55);
}

.pet-btn-primary-{{ section.id }} svg {
  width: 14px; height: 14px;
  transition: transform 0.2s ease;
}

.pet-btn-primary-{{ section.id }}:hover svg { transform: translateX(2px); }

.pet-btn-secondary-{{ section.id }} {
  background-color: var(--pet-card);
  color: var(--pet-ink);
  padding: 14px 22px;
  border-radius: 10px;
  text-decoration: none;
  font-weight: 600;
  font-size: 14.5px;
  transition: all 0.2s ease;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border: 1.5px solid var(--pet-line-strong);
}

.pet-btn-secondary-{{ section.id }}:hover {
  border-color: var(--pet-primary);
  color: var(--pet-primary);
  transform: translateY(-1px);
}

.pet-btn-secondary-{{ section.id }} svg { width: 16px; height: 16px; }

/* Trust Row */
.pet-hero-trust-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 14px;
  margin-bottom: 36px;
  padding-bottom: 28px;
  border-bottom: 1px solid var(--pet-line);
  width: 100%;
  max-width: 460px;
}

.pet-trust-avatars-{{ section.id }} { display: flex; align-items: center; flex-shrink: 0; }

.pet-trust-avatar-{{ section.id }} {
  width: 36px; height: 36px;
  border-radius: 50%;
  border: 2px solid var(--pet-bg);
  margin-left: -10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  background: linear-gradient(135deg, var(--pet-primary), var(--pet-primary-light));
}
.pet-trust-avatar-{{ section.id }}:first-child { margin-left: 0; }
.pet-trust-avatar-{{ section.id }}:nth-child(2) { background: linear-gradient(135deg, var(--pet-primary-deep), var(--pet-primary)); }
.pet-trust-avatar-{{ section.id }}:nth-child(3) { background: linear-gradient(135deg, var(--pet-primary-light), var(--pet-primary)); }
.pet-trust-avatar-{{ section.id }}:nth-child(4) { background: linear-gradient(135deg, var(--pet-primary), var(--pet-primary-deep)); }

.pet-trust-text-{{ section.id }} { font-size: 13px; color: var(--pet-body); line-height: 1.4; }
.pet-trust-stars-{{ section.id }} {
  color: var(--pet-primary);
  font-size: 14px;
  letter-spacing: 1px;
  display: block;
  margin-bottom: 1px;
}
.pet-trust-text-{{ section.id }} strong { color: var(--pet-ink); font-weight: 700; }

/* Stats */
.pet-hero-stats-{{ section.id }} {
  display: flex;
  align-items: stretch;
  gap: 28px;
  flex-wrap: wrap;
}

.pet-stat-item-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 4px;
  position: relative;
  padding-right: 28px;
}

.pet-stat-item-{{ section.id }}:not(:last-child)::after {
  content: "";
  position: absolute;
  right: 0; top: 4px; bottom: 4px;
  width: 1px;
  background: var(--pet-line);
}

.pet-stat-value-{{ section.id }} {
  font-size: 26px;
  font-weight: 800;
  color: var(--pet-ink);
  display: flex;
  align-items: center;
  gap: 4px;
  line-height: 1;
  letter-spacing: -0.025em;
}

.pet-stat-value-{{ section.id }} svg { color: var(--pet-primary); }
.pet-stat-label-{{ section.id }} { font-size: 13px; color: var(--pet-body); font-weight: 500; }

/* SAĞ — Trust Showcase */
.pet-hero-media-{{ section.id }} {
  position: relative;
  width: 100%;
  opacity: 0;
  animation: pet-fade-in-{{ section.id }} 1s cubic-bezier(0.2, 0.8, 0.2, 1) 0.3s forwards;
}

@keyframes pet-fade-in-{{ section.id }} {
  from { opacity: 0; transform: translateY(24px) scale(0.98); }
  to   { opacity: 1; transform: translateY(0) scale(1); }
}

.pet-hero-blob-1-{{ section.id }} {
  position: absolute;
  top: -40px; right: -40px;
  width: 180px; height: 180px;
  background: var(--pet-primary-light);
  border-radius: 50%;
  filter: blur(2px);
  opacity: 0.5;
  z-index: 0;
  animation: pet-float-a-{{ section.id }} 7s ease-in-out infinite;
}
.pet-hero-blob-2-{{ section.id }} {
  position: absolute;
  bottom: -30px; left: -30px;
  width: 120px; height: 120px;
  background: var(--pet-primary);
  border-radius: 50%;
  opacity: 0.18;
  filter: blur(1px);
  z-index: 0;
  animation: pet-float-b-{{ section.id }} 9s ease-in-out infinite;
}

@keyframes pet-float-a-{{ section.id }} {
  0%, 100% { transform: translate(0, 0); }
  50%      { transform: translate(-12px, 18px); }
}
@keyframes pet-float-b-{{ section.id }} {
  0%, 100% { transform: translate(0, 0); }
  50%      { transform: translate(14px, -14px); }
}

.pet-ts-{{ section.id }} {
  position: relative;
  background: var(--pet-card);
  border-radius: 20px;
  padding: 28px;
  border: 1px solid var(--pet-line);
  box-shadow:
    0 1px 2px rgba(31, 19, 66, 0.04),
    0 24px 48px -16px rgba(123, 63, 242, 0.18),
    0 60px 120px -40px rgba(123, 63, 242, 0.14);
  z-index: 1;
}

.pet-ts-header-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 10px;
  padding-bottom: 18px;
  border-bottom: 1px solid var(--pet-line);
  margin-bottom: 20px;
}

.pet-ts-header-icon-{{ section.id }} {
  width: 38px; height: 38px;
  border-radius: 10px;
  background: linear-gradient(135deg, var(--pet-primary), var(--pet-primary-deep));
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  flex-shrink: 0;
}

.pet-ts-header-text-{{ section.id }} { display: flex; flex-direction: column; gap: 2px; }

.pet-ts-header-title-{{ section.id }} {
  font-size: 14px;
  font-weight: 700;
  color: var(--pet-ink);
  letter-spacing: -0.01em;
}

.pet-ts-header-sub-{{ section.id }} {
  font-size: 12px;
  color: var(--pet-body);
}

.pet-ts-list-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.pet-ts-item-{{ section.id }} {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 14px;
  background: #FAF7FF;
  border: 1px solid var(--pet-line);
  border-radius: 12px;
  transition: transform 0.25s cubic-bezier(0.2, 0.8, 0.2, 1), border-color 0.25s ease;
}

.pet-ts-item-{{ section.id }}:hover {
  transform: translateX(4px);
  border-color: var(--pet-line-strong);
}

.pet-ts-item-icon-{{ section.id }} {
  width: 38px; height: 38px;
  border-radius: 10px;
  background: var(--pet-card);
  border: 1px solid var(--pet-line);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: var(--pet-primary);
  flex-shrink: 0;
}

.pet-ts-item-content-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 3px;
  min-width: 0;
  flex: 1;
}

.pet-ts-item-title-{{ section.id }} {
  font-size: 14px;
  font-weight: 700;
  color: var(--pet-ink);
  letter-spacing: -0.01em;
  line-height: 1.3;
}

.pet-ts-item-desc-{{ section.id }} {
  font-size: 12.5px;
  color: var(--pet-body);
  line-height: 1.45;
}

.pet-ts-item-check-{{ section.id }} {
  width: 24px; height: 24px;
  border-radius: 6px;
  background: #ECFDF5;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  color: #059669;
  flex-shrink: 0;
  margin-top: 2px;
}

/* Floating badge */
.pet-hero-floating-badge-{{ section.id }} {
  position: absolute;
  top: -14px;
  left: 24px;
  z-index: 3;
  background: var(--pet-card);
  padding: 8px 14px 8px 8px;
  border-radius: 8px;
  display: inline-flex;
  align-items: center;
  gap: 8px;
  border: 1px solid var(--pet-line);
  box-shadow: 0 8px 20px -6px rgba(31, 19, 66, 0.16);
  animation: pet-float-tag-{{ section.id }} 4s ease-in-out infinite;
}

@keyframes pet-float-tag-{{ section.id }} {
  0%, 100% { transform: translateY(0); }
  50%      { transform: translateY(-3px); }
}

.pet-hero-floating-badge-icon-{{ section.id }} {
  width: 22px; height: 22px;
  border-radius: 6px;
  background: var(--pet-primary);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.pet-hero-floating-badge-icon-{{ section.id }} svg {
  width: 11px; height: 11px;
  stroke: #fff;
  fill: none;
  stroke-width: 3;
}
.pet-hero-floating-badge-text-{{ section.id }} {
  font-size: 12.5px;
  font-weight: 600;
  color: var(--pet-ink);
}

/* Tablet */
@media screen and (max-width: 990px) {
  .pet-hero-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.7 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.7 | round }}px;
  }
  .pet-hero-container-{{ section.id }} {
    grid-template-columns: 1fr;
    gap: 36px;
    text-align: center;
  }
  .pet-hero-content-{{ section.id }} { align-items: center; }
  .pet-hero-desc-{{ section.id }} { max-width: 560px; }
  .pet-hero-buttons-{{ section.id }} { justify-content: center; }
  .pet-hero-trust-{{ section.id }} {
    margin-left: auto;
    margin-right: auto;
    justify-content: center;
  }
  .pet-hero-stats-{{ section.id }} { justify-content: center; gap: 24px; }

  .pet-ts-{{ section.id }} {
    max-width: 480px;
    margin: 0 auto;
    text-align: left;
  }
}

/* Mobil — sağ alanı tamamen gizle */
@media screen and (max-width: 640px) {
  .pet-hero-{{ section.id }} {
    padding-top: 36px;
    padding-bottom: 36px;
  }
  .pet-hero-container-{{ section.id }} {
    padding: 0 16px;
    grid-template-columns: 1fr;
    gap: 0;
  }

  .pet-hero-media-{{ section.id }} { display: none; }

  .pet-hero-badge-{{ section.id }} {
    font-size: 12px;
    padding: 6px 14px 6px 6px;
    margin-bottom: 18px;
  }
  .pet-hero-badge-icon-{{ section.id }} { width: 20px; height: 20px; }
  .pet-hero-badge-icon-{{ section.id }} svg { width: 10px; height: 10px; }

  .pet-hero-title-{{ section.id }} {
    font-size: clamp(26px, 8vw, 34px);
    line-height: 1.1;
    margin-bottom: 14px;
  }
  .pet-hero-desc-{{ section.id }} { font-size: 14px; margin-bottom: 22px; }

  .pet-hero-buttons-{{ section.id }} {
    width: 100%;
    gap: 8px;
    margin-bottom: 22px;
  }
  .pet-btn-primary-{{ section.id }},
  .pet-btn-secondary-{{ section.id }} {
    flex: 1 1 calc(50% - 4px);
    padding: 12px 14px;
    font-size: 13.5px;
    min-width: 0;
  }

  .pet-hero-trust-{{ section.id }} {
    margin-bottom: 22px;
    padding-bottom: 18px;
    gap: 12px;
  }
  .pet-trust-avatar-{{ section.id }} {
    width: 28px; height: 28px;
    font-size: 13px;
    margin-left: -8px;
  }
  .pet-trust-text-{{ section.id }} { font-size: 12px; text-align: left; }
  .pet-trust-stars-{{ section.id }} { font-size: 12px; }

  .pet-hero-stats-{{ section.id }} {
    gap: 0;
    width: 100%;
    justify-content: space-between;
  }
  .pet-stat-item-{{ section.id }} {
    padding-right: 12px;
    flex: 1;
    align-items: center;
    text-align: center;
  }
  .pet-stat-item-{{ section.id }}:last-child { padding-right: 0; }
  .pet-stat-value-{{ section.id }} { font-size: 20px; justify-content: center; }
  .pet-stat-value-{{ section.id }} svg { width: 14px; height: 14px; }
  .pet-stat-label-{{ section.id }} { font-size: 11px; text-align: center; }
}

@media screen and (max-width: 380px) {
  .pet-hero-buttons-{{ section.id }} { flex-direction: column; width: 100%; }
  .pet-btn-primary-{{ section.id }},
  .pet-btn-secondary-{{ section.id }} { flex: 1 1 100%; width: 100%; }
  .pet-stat-value-{{ section.id }} { font-size: 18px; }
  .pet-stat-label-{{ section.id }} { font-size: 10.5px; }
}

@media (prefers-reduced-motion: reduce) {
  .pet-hero-content-{{ section.id }},
  .pet-hero-media-{{ section.id }},
  .pet-hero-floating-badge-{{ section.id }},
  .pet-hero-blob-1-{{ section.id }},
  .pet-hero-blob-2-{{ section.id }} {
    animation: none !important;
    opacity: 1 !important;
    transform: none !important;
  }
}
</style>

<section class="pet-hero-{{ section.id }}">
  <div class="pet-hero-container-{{ section.id }}">

    <div class="pet-hero-content-{{ section.id }}">
      {% if section.settings.badge_text != blank %}
        <div class="pet-hero-badge-{{ section.id }}">
          <span class="pet-hero-badge-icon-{{ section.id }}">
            <svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.6L22 12l-7.6 2.4L12 22l-2.4-7.6L2 12l7.6-2.4L12 2z"/></svg>
          </span>
          {{ section.settings.badge_text }}
        </div>
      {% endif %}

      {% if section.settings.title != blank %}
        <h1 class="pet-hero-title-{{ section.id }}">
          {{ section.settings.title | replace: '[', '<span class="highlight">' | replace: ']', '</span>' }}
        </h1>
      {% endif %}

      {% if section.settings.description != blank %}
        <p class="pet-hero-desc-{{ section.id }}">{{ section.settings.description }}</p>
      {% endif %}

      <div class="pet-hero-buttons-{{ section.id }}">
        {% if section.settings.btn_1_label != blank %}
          <a href="{{ section.settings.btn_1_link | default: '#' }}" class="pet-btn-primary-{{ section.id }}">
            {{ section.settings.btn_1_label }}
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square" stroke-linejoin="miter"><path d="M5 12h14"/><path d="M12 5l7 7-7 7"/></svg>
          </a>
        {% endif %}

        {% if section.settings.btn_2_label != blank %}
          <a href="#" class="pet-btn-secondary-{{ section.id }} pet-rec-trigger" data-pet-recommender>
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter"><path d="M12 2l2.5 7.5L22 12l-7.5 2.5L12 22l-2.5-7.5L2 12l7.5-2.5L12 2z"/></svg>
            {{ section.settings.btn_2_label }}
          </a>
        {% endif %}
      </div>

      {% if section.settings.show_trust_row %}
        <div class="pet-hero-trust-{{ section.id }}">
          <div class="pet-trust-avatars-{{ section.id }}">
            <span class="pet-trust-avatar-{{ section.id }}">🐶</span>
            <span class="pet-trust-avatar-{{ section.id }}">🐱</span>
            <span class="pet-trust-avatar-{{ section.id }}">🐰</span>
            <span class="pet-trust-avatar-{{ section.id }}">🐾</span>
          </div>
          <div class="pet-trust-text-{{ section.id }}">
            <span class="pet-trust-stars-{{ section.id }}">★★★★★</span>
            <strong>{{ section.settings.trust_count }}</strong> {{ section.settings.trust_text }}
          </div>
        </div>
      {% endif %}

      {% assign stat_blocks = section.blocks | where: "type", "stat" %}
      {% if stat_blocks.size > 0 %}
        <div class="pet-hero-stats-{{ section.id }}">
          {% for block in stat_blocks %}
            <div class="pet-stat-item-{{ section.id }}" {{ block.shopify_attributes }}>
              <div class="pet-stat-value-{{ section.id }}">
                {{ block.settings.value }}
                {% if block.settings.show_star %}
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                {% endif %}
              </div>
              <div class="pet-stat-label-{{ section.id }}">{{ block.settings.label }}</div>
            </div>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <div class="pet-hero-media-{{ section.id }}">
      <span class="pet-hero-blob-1-{{ section.id }}"></span>
      <span class="pet-hero-blob-2-{{ section.id }}"></span>

      <div class="pet-ts-{{ section.id }}">
        <div class="pet-ts-header-{{ section.id }}">
          <span class="pet-ts-header-icon-{{ section.id }}">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square" stroke-linejoin="miter"><path d="M9 12l2 2 4-4"/><path d="M12 2l3 7h7l-5.5 4.5L18 21l-6-4-6 4 1.5-7.5L2 9h7z"/></svg>
          </span>
          <div class="pet-ts-header-text-{{ section.id }}">
            <span class="pet-ts-header-title-{{ section.id }}">{{ section.settings.ts_title }}</span>
            <span class="pet-ts-header-sub-{{ section.id }}">{{ section.settings.ts_subtitle }}</span>
          </div>
        </div>

        <div class="pet-ts-list-{{ section.id }}">
          {% assign feature_blocks = section.blocks | where: "type", "feature" %}
          {% for block in feature_blocks %}
            <div class="pet-ts-item-{{ section.id }}" {{ block.shopify_attributes }}>
              <span class="pet-ts-item-icon-{{ section.id }}">
                {% case block.settings.icon %}
                  {% when 'truck' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
                  {% when 'shield' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
                  {% when 'leaf' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19.2 2.5c1 1.5 2 4.5 2 8.5a10 10 0 0 1-10 10z"/><path d="M2 21c0-3 1.85-5.36 5.08-6"/></svg>
                  {% when 'heart' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                  {% when 'refresh' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"/></svg>
                  {% when 'headphones' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
                  {% when 'lock' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                  {% when 'award' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><circle cx="12" cy="8" r="7"/><polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"/></svg>
                  {% when 'stethoscope' %}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="square" stroke-linejoin="miter"><path d="M4.8 2.3A.3.3 0 1 0 5 2H4a2 2 0 0 0-2 2v5a6 6 0 0 0 6 6 6 6 0 0 0 6-6V4a2 2 0 0 0-2-2h-1a.2.2 0 1 0 .3.3"/><path d="M8 15v1a6 6 0 0 0 6 6 6 6 0 0 0 6-6v-4"/><circle cx="20" cy="10" r="2"/></svg>
                {% endcase %}
              </span>
              <div class="pet-ts-item-content-{{ section.id }}">
                <span class="pet-ts-item-title-{{ section.id }}">{{ block.settings.title }}</span>
                {% if block.settings.desc != blank %}
                  <span class="pet-ts-item-desc-{{ section.id }}">{{ block.settings.desc }}</span>
                {% endif %}
              </div>
              <span class="pet-ts-item-check-{{ section.id }}">
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="square" stroke-linejoin="miter"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
            </div>
          {% endfor %}
        </div>
      </div>

      {% if section.settings.show_floating_badge and section.settings.floating_badge_text != blank %}
        <div class="pet-hero-floating-badge-{{ section.id }}">
          <span class="pet-hero-floating-badge-icon-{{ section.id }}">
            <svg viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12"/></svg>
          </span>
          <span class="pet-hero-floating-badge-text-{{ section.id }}">{{ section.settings.floating_badge_text }}</span>
        </div>
      {% endif %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Pet Premium Hero",
  "max_blocks": 12,
  "settings": [
    { "type": "header", "content": "Layout & Colors" },
    { "type": "color", "id": "bg_color", "label": "Background (Top)", "default": "#F4F0FF" },
    { "type": "color", "id": "bg_color_soft", "label": "Background (Bottom)", "default": "#FAF7FF" },
    { "type": "color", "id": "primary_color", "label": "Primary Color", "default": "#7B3FF2" },
    { "type": "color", "id": "primary_light_color", "label": "Açık Mor", "default": "#B794F4" },
    { "type": "color", "id": "primary_deep_color", "label": "Koyu Mor", "default": "#5B2FB2" },
    { "type": "range", "id": "max_width", "min": 1000, "max": 1800, "step": 50, "unit": "px", "label": "Max Width", "default": 1300 },
    { "type": "header", "content": "Content" },
    { "type": "text", "id": "badge_text", "label": "Badge", "default": "Evcil Dostlara Özel Premium" },
    { "type": "textarea", "id": "title", "label": "Heading", "info": "Mor vurgu için kelimeyi köşeli parantez içine alın. Örn: [En İyisini]", "default": "Tüylü Dostların [En İyisini] Hak Ediyor" },
    { "type": "range", "id": "title_size", "min": 40, "max": 80, "step": 2, "unit": "px", "label": "Heading Max Size", "default": 56 },
    { "type": "textarea", "id": "description", "label": "Description", "default": "Kedi ve köpeğiniz için özenle seçilmiş premium mama, yaşam alanı ve bakım ürünleri — veteriner onaylı, sevgiyle paketlenmiş." },
    { "type": "header", "content": "Buttons" },
    { "type": "text", "id": "btn_1_label", "label": "Birincil Buton", "default": "Alışverişe Başla" },
    { "type": "url", "id": "btn_1_link", "label": "Birincil Link" },
    { "type": "text", "id": "btn_2_label", "label": "İkincil Buton", "default": "Petim İçin Öner" },
    { "type": "url", "id": "btn_2_link", "label": "İkincil Link" },
    { "type": "header", "content": "Trust Row" },
    { "type": "checkbox", "id": "show_trust_row", "label": "Trust Row Göster", "default": true },
    { "type": "text", "id": "trust_count", "label": "Müşteri Sayısı", "default": "50.000+" },
    { "type": "text", "id": "trust_text", "label": "Trust Açıklaması", "default": "mutlu pet ailesi tarafından seviliyor" },
    { "type": "header", "content": "Sağ Showcase" },
    { "type": "text", "id": "ts_title", "label": "Showcase Başlık", "default": "Neden Petibi?" },
    { "type": "text", "id": "ts_subtitle", "label": "Showcase Alt Başlık", "default": "Premium hizmet, koşulsuz güven" },
    { "type": "header", "content": "Floating Badge" },
    { "type": "checkbox", "id": "show_floating_badge", "label": "Göster", "default": true },
    { "type": "text", "id": "floating_badge_text", "label": "Yazı", "default": "Veteriner Onaylı" },
    { "type": "header", "content": "Spacing" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 5, "unit": "px", "label": "Padding Top", "default": 80 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 5, "unit": "px", "label": "Padding Bottom", "default": 80 }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "İstatistik",
      "limit": 3,
      "settings": [
        { "type": "text", "id": "value", "label": "Değer", "default": "500+" },
        { "type": "text", "id": "label", "label": "Etiket", "default": "Premium Marka" },
        { "type": "checkbox", "id": "show_star", "label": "Yıldız İkonu", "default": false }
      ]
    },
    {
      "type": "feature",
      "name": "Özellik",
      "settings": [
        {
          "type": "select", "id": "icon", "label": "İkon",
          "options": [
            { "value": "truck", "label": "Kargo" },
            { "value": "shield", "label": "Güvenlik / Onay" },
            { "value": "stethoscope", "label": "Veteriner" },
            { "value": "leaf", "label": "Doğal / Organik" },
            { "value": "heart", "label": "Kalp" },
            { "value": "refresh", "label": "İade" },
            { "value": "headphones", "label": "Destek" },
            { "value": "lock", "label": "Güvenli Ödeme" },
            { "value": "award", "label": "Ödüllü Marka" }
          ],
          "default": "truck"
        },
        { "type": "text", "id": "title", "label": "Başlık", "default": "Ücretsiz Kargo" },
        { "type": "text", "id": "desc", "label": "Açıklama", "default": "500₺ üzeri tüm siparişlerde" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Pet Premium Hero",
      "blocks": [
        { "type": "stat", "settings": { "value": "500+", "label": "Premium Marka" } },
        { "type": "stat", "settings": { "value": "50K+", "label": "Mutlu Müşteri" } },
        { "type": "stat", "settings": { "value": "4.9", "label": "Ortalama Puan", "show_star": true } },
        { "type": "feature", "settings": { "icon": "truck", "title": "Ücretsiz Kargo", "desc": "500₺ üzeri tüm siparişlerde" } },
        { "type": "feature", "settings": { "icon": "stethoscope", "title": "Veteriner Onaylı", "desc": "Uzman ekip tarafından seçildi" } },
        { "type": "feature", "settings": { "icon": "leaf", "title": "Temiz İçerik", "desc": "GDO, koruyucu, suni renk yok" } },
        { "type": "feature", "settings": { "icon": "refresh", "title": "Koşulsuz İade", "desc": "14 gün içinde sorunsuz iade" } }
      ]
    }
  ]
}
{% endschema %}