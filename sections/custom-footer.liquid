<style>
.pet-footer-{{ section.id }} {
  --pet-primary: {{ section.settings.primary_color }};
  --pet-primary-light: {{ section.settings.primary_light_color }};
  --pet-primary-deep: {{ section.settings.primary_deep_color }};
  --pet-bg: {{ section.settings.bg_color }};
  --pet-card-bg: {{ section.settings.card_bg }};
  --pet-text: {{ section.settings.text_color }};
  --pet-heading: {{ section.settings.heading_color }};
  --pet-mute: {{ section.settings.mute_color }};
  --pet-line: {{ section.settings.line_color }};

  background-color: var(--pet-bg);
  color: var(--pet-text);
  font-family: inherit, 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
  padding-top: {{ section.settings.padding_top }}px;
  padding-bottom: {{ section.settings.padding_bottom }}px;
}

.pet-footer-{{ section.id }} *,
.pet-footer-{{ section.id }} *::before,
.pet-footer-{{ section.id }} *::after {
  box-sizing: border-box;
}

.pet-footer-container-{{ section.id }} {
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: 0 24px;
}

/* ============ NEWSLETTER CARD ============ */
.pet-newsletter-{{ section.id }} {
  position: relative;
  background:
    radial-gradient(circle at 90% 0%, rgba(255, 255, 255, 0.16), transparent 55%),
    radial-gradient(circle at 10% 100%, rgba(255, 255, 255, 0.08), transparent 50%),
    linear-gradient(135deg, var(--pet-primary) 0%, var(--pet-primary-deep) 100%);
  border-radius: 24px;
  padding: 32px 36px;
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 24px;
  align-items: center;
  margin-bottom: 40px;
  overflow: hidden;
  isolation: isolate;
  box-shadow: 0 16px 36px -16px rgba(123, 63, 242, 0.4);
}

.pet-newsletter-{{ section.id }}::before {
  content: "";
  position: absolute;
  top: -45%;
  right: -8%;
  width: 280px;
  height: 280px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.06);
  z-index: -1;
}

.pet-newsletter-{{ section.id }}::after {
  content: "";
  position: absolute;
  bottom: -35%;
  left: -5%;
  width: 180px;
  height: 180px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.04);
  z-index: -1;
}

.pet-newsletter-content-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 6px;
  position: relative;
  z-index: 1;
}

.pet-newsletter-eyebrow-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.1em;
  color: rgba(255, 255, 255, 0.85);
}

.pet-newsletter-eyebrow-{{ section.id }} svg {
  width: 12px;
  height: 12px;
  fill: currentColor;
}

.pet-newsletter-title-{{ section.id }} {
  font-size: 22px;
  font-weight: 800;
  color: #FFFFFF;
  margin: 0;
  letter-spacing: -0.025em;
  line-height: 1.2;
}

.pet-newsletter-desc-{{ section.id }} {
  font-size: 13.5px;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
  margin: 2px 0 0 0;
}

.pet-newsletter-form-{{ section.id }} {
  display: flex;
  gap: 6px;
  background: #FFFFFF;
  border-radius: 100px;
  padding: 5px;
  position: relative;
  z-index: 1;
  box-shadow: 0 6px 18px -8px rgba(31, 19, 66, 0.18);
}

.pet-newsletter-input-{{ section.id }} {
  flex: 1;
  min-width: 0;
  background: transparent;
  border: none;
  outline: none;
  padding: 10px 16px;
  color: #1F1342;
  font-size: 13.5px;
  font-family: inherit;
}

.pet-newsletter-input-{{ section.id }}::placeholder {
  color: #8B8299;
}

.pet-newsletter-btn-{{ section.id }} {
  background-color: var(--pet-primary);
  color: #FFFFFF;
  border: none;
  border-radius: 100px;
  padding: 10px 18px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: background-color 0.2s ease, transform 0.2s ease;
  white-space: nowrap;
  font-family: inherit;
  display: inline-flex;
  align-items: center;
  gap: 6px;
}

.pet-newsletter-btn-{{ section.id }}:hover {
  background-color: var(--pet-primary-deep);
}

.pet-newsletter-btn-{{ section.id }} svg {
  width: 13px;
  height: 13px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2.5;
  stroke-linecap: round;
  stroke-linejoin: round;
  transition: transform 0.2s ease;
}

.pet-newsletter-btn-{{ section.id }}:hover svg {
  transform: translateX(2px);
}

/* ============ MAIN GRID ============ */
.pet-footer-main-{{ section.id }} {
  display: grid;
  grid-template-columns: 1.6fr 1fr 1fr 1fr;
  gap: 40px;
  margin-bottom: 32px;
}

/* Brand column */
.pet-footer-brand-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.pet-footer-logo-{{ section.id }} {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
  width: max-content;
  max-width: 100%;
}

/* Logo as image (uploaded via Shopify) */
.pet-footer-logo-image-{{ section.id }} {
  max-height: {{ section.settings.logo_max_height }}px;
  width: auto;
  height: auto;
  display: block;
  object-fit: contain;
  {% if section.settings.logo_invert %}filter: brightness(0) invert(1);{% endif %}
}

/* Logo fallback (emoji + text) */
.pet-footer-logo-icon-{{ section.id }} {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--pet-primary) 0%, var(--pet-primary-deep) 100%);
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  flex-shrink: 0;
  box-shadow: 0 4px 12px -4px rgba(123, 63, 242, 0.55);
}

.pet-footer-logo-text-{{ section.id }} {
  font-size: 20px;
  font-weight: 800;
  color: var(--pet-heading);
  letter-spacing: -0.025em;
}

.pet-footer-desc-{{ section.id }} {
  font-size: 13.5px;
  color: var(--pet-text);
  line-height: 1.6;
  margin: 0;
  max-width: 360px;
  opacity: 0.85;
}

/* Contact info */
.pet-footer-contact-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 8px;
  margin-top: 4px;
}

.pet-footer-contact-item-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 10px;
  color: var(--pet-text);
  font-size: 13px;
  text-decoration: none;
  transition: color 0.2s ease;
  line-height: 1.4;
  opacity: 0.9;
}

.pet-footer-contact-item-{{ section.id }}:hover {
  color: var(--pet-primary-light);
  opacity: 1;
}

.pet-footer-contact-icon-{{ section.id }} {
  width: 28px;
  height: 28px;
  border-radius: 8px;
  background: var(--pet-card-bg);
  color: var(--pet-primary-light);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: background 0.2s ease;
}

.pet-footer-contact-item-{{ section.id }}:hover .pet-footer-contact-icon-{{ section.id }} {
  background: rgba(123, 63, 242, 0.2);
}

.pet-footer-contact-icon-{{ section.id }} svg {
  width: 13px;
  height: 13px;
  stroke: currentColor;
  fill: none;
  stroke-width: 2;
  stroke-linecap: round;
  stroke-linejoin: round;
}

/* Social — rounded square (siteye uyumlu) */
.pet-footer-socials-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-top: 6px;
}

.pet-footer-social-link-{{ section.id }} {
  width: 38px;
  height: 38px;
  border-radius: 11px;
  background: var(--pet-card-bg);
  border: 1px solid var(--pet-line);
  color: var(--pet-text);
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  transition: all 0.2s ease;
}

.pet-footer-social-link-{{ section.id }}:hover {
  background-color: var(--pet-primary);
  border-color: var(--pet-primary);
  color: #FFFFFF;
  transform: translateY(-1px);
}

.pet-footer-social-link-{{ section.id }} svg {
  width: 15px;
  height: 15px;
  fill: currentColor;
}

/* Menu columns */
.pet-footer-col-{{ section.id }} {
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.pet-footer-col-title-{{ section.id }} {
  font-size: 12px;
  font-weight: 700;
  color: var(--pet-heading);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pet-footer-col-toggle-{{ section.id }} {
  display: none;
  width: 24px;
  height: 24px;
  align-items: center;
  justify-content: center;
  position: relative;
  flex-shrink: 0;
}

.pet-footer-col-toggle-{{ section.id }}::before,
.pet-footer-col-toggle-{{ section.id }}::after {
  content: "";
  position: absolute;
  background: var(--pet-primary-light);
  border-radius: 1px;
  transition: transform 0.25s ease;
}

.pet-footer-col-toggle-{{ section.id }}::before {
  width: 10px;
  height: 1.5px;
}

.pet-footer-col-toggle-{{ section.id }}::after {
  width: 1.5px;
  height: 10px;
}

.pet-footer-col-{{ section.id }}.is-open .pet-footer-col-toggle-{{ section.id }}::after {
  transform: rotate(90deg);
}

.pet-footer-menu-{{ section.id }} {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 9px;
}

/* Menu link rengi - default beyaz */
.pet-footer-link-{{ section.id }} {
  text-decoration: none;
  color: {{ section.settings.link_color }};
  font-size: 13.5px;
  font-weight: 500;
  transition: color 0.2s ease, transform 0.2s ease;
  display: inline-block;
}

.pet-footer-link-{{ section.id }}:hover {
  color: var(--pet-primary-light);
  transform: translateX(2px);
}

/* ============ BOTTOM BAR ============ */
.pet-footer-bottom-{{ section.id }} {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 22px;
  border-top: 1px solid var(--pet-line);
  gap: 18px;
  flex-wrap: wrap;
}

.pet-footer-bottom-left-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 14px;
  flex-wrap: wrap;
}

.pet-footer-copyright-{{ section.id }} {
  font-size: 12.5px;
  color: var(--pet-mute);
  margin: 0;
}

.pet-footer-legal-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 14px;
  list-style: none;
  padding: 0;
  margin: 0;
}

.pet-footer-legal-{{ section.id }} li {
  position: relative;
}

.pet-footer-legal-{{ section.id }} li:not(:last-child)::after {
  content: "";
  position: absolute;
  right: -8px;
  top: 50%;
  transform: translateY(-50%);
  width: 3px;
  height: 3px;
  border-radius: 50%;
  background: var(--pet-mute);
  opacity: 0.6;
}

.pet-footer-legal-{{ section.id }} a {
  font-size: 12.5px;
  color: var(--pet-mute);
  text-decoration: none;
  transition: color 0.2s ease;
  font-weight: 500;
}

.pet-footer-legal-{{ section.id }} a:hover {
  color: var(--pet-primary-light);
}

/* Payment badges */
.pet-footer-payments-{{ section.id }} {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
}

.pet-pay-{{ section.id }} {
  height: 26px;
  padding: 0 9px;
  border-radius: 6px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 10.5px;
  font-weight: 700;
  background: #FFFFFF;
}

.pet-pay-visa-{{ section.id }} { color: #1A1F71; font-style: italic; font-size: 12px; letter-spacing: 0.5px; }
.pet-pay-mc-{{ section.id }} { padding: 0 7px; }
.pet-pay-mc-{{ section.id }} svg { width: 24px; height: 15px; }
.pet-pay-iyzico-{{ section.id }} { color: #1E64FF; font-size: 11px; }
.pet-pay-troy-{{ section.id }} { color: #003087; }
.pet-pay-ssl-{{ section.id }} { color: #059669; gap: 3px; }
.pet-pay-ssl-{{ section.id }} svg { width: 11px; height: 11px; stroke: currentColor; fill: none; stroke-width: 2.4; stroke-linecap: round; stroke-linejoin: round; }

/* ============ TABLET (≤990px) ============ */
@media screen and (max-width: 990px) {
  .pet-newsletter-{{ section.id }} {
    grid-template-columns: 1fr;
    padding: 28px 26px;
    gap: 20px;
    margin-bottom: 36px;
  }

  .pet-footer-main-{{ section.id }} {
    grid-template-columns: 1fr 1fr 1fr;
    gap: 28px;
  }

  .pet-footer-brand-{{ section.id }} {
    grid-column: span 3;
  }

  .pet-footer-desc-{{ section.id }} {
    max-width: 540px;
  }
}

/* ============ MOBİL (≤640px) — accordion menüler ============ */
@media screen and (max-width: 640px) {
  .pet-footer-{{ section.id }} {
    padding-top: {{ section.settings.padding_top | times: 0.65 | round }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 1.4 | round }}px;
  }

  .pet-footer-container-{{ section.id }} {
    padding: 0 16px;
  }

  .pet-newsletter-{{ section.id }} {
    padding: 22px 18px;
    border-radius: 18px;
    gap: 18px;
    margin-bottom: 28px;
  }

  .pet-newsletter-eyebrow-{{ section.id }} { font-size: 10.5px; }
  .pet-newsletter-title-{{ section.id }} { font-size: 18px; line-height: 1.25; }
  .pet-newsletter-desc-{{ section.id }} { font-size: 13px; }

  .pet-newsletter-form-{{ section.id }} {
    flex-direction: column;
    background: transparent;
    padding: 0;
    box-shadow: none;
    gap: 8px;
  }

  .pet-newsletter-input-{{ section.id }} {
    background: #FFFFFF;
    border-radius: 100px;
    padding: 12px 18px;
    font-size: 13px;
  }

  .pet-newsletter-btn-{{ section.id }} {
    width: 100%;
    background: #FFFFFF;
    color: var(--pet-primary);
    padding: 12px 18px;
    justify-content: center;
    font-size: 13px;
  }

  .pet-newsletter-btn-{{ section.id }}:hover {
    background: rgba(255, 255, 255, 0.92);
    color: var(--pet-primary-deep);
  }

  .pet-footer-main-{{ section.id }} {
    grid-template-columns: 1fr;
    gap: 0;
    margin-bottom: 22px;
  }

  .pet-footer-brand-{{ section.id }} {
    grid-column: auto;
    gap: 14px;
    padding-bottom: 22px;
    border-bottom: 1px solid var(--pet-line);
    margin-bottom: 4px;
  }

  .pet-footer-logo-text-{{ section.id }} { font-size: 19px; }
  .pet-footer-desc-{{ section.id }} { font-size: 13px; }

  /* Accordion behavior */
  .pet-footer-col-{{ section.id }} {
    border-bottom: 1px solid var(--pet-line);
    gap: 0;
  }

  .pet-footer-col-title-{{ section.id }} {
    cursor: pointer;
    padding: 14px 0;
    user-select: none;
  }

  .pet-footer-col-toggle-{{ section.id }} { display: inline-flex; }

  .pet-footer-menu-wrapper-{{ section.id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.28s ease;
  }

  .pet-footer-col-{{ section.id }}.is-open .pet-footer-menu-wrapper-{{ section.id }} {
    max-height: 500px;
  }

  .pet-footer-menu-{{ section.id }} {
    padding-bottom: 14px;
    gap: 11px;
  }

  /* Bottom bar */
  .pet-footer-bottom-{{ section.id }} {
    flex-direction: column;
    align-items: flex-start;
    gap: 16px;
    padding-top: 18px;
    margin-top: 18px;
  }

  .pet-footer-bottom-left-{{ section.id }} {
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .pet-footer-legal-{{ section.id }} { flex-wrap: wrap; gap: 12px; }
  .pet-footer-payments-{{ section.id }} { width: 100%; }
}
</style>

<footer class="pet-footer-{{ section.id }}">
  <div class="pet-footer-container-{{ section.id }}">

    {% if section.settings.show_newsletter %}
      <div class="pet-newsletter-{{ section.id }}">
        <div class="pet-newsletter-content-{{ section.id }}">
          {% if section.settings.newsletter_eyebrow != blank %}
            <div class="pet-newsletter-eyebrow-{{ section.id }}">
              <svg viewBox="0 0 24 24"><path d="M12 2l2.4 7.6L22 12l-7.6 2.4L12 22l-2.4-7.6L2 12l7.6-2.4L12 2z"/></svg>
              {{ section.settings.newsletter_eyebrow }}
            </div>
          {% endif %}
          <h3 class="pet-newsletter-title-{{ section.id }}">{{ section.settings.newsletter_title }}</h3>
          <p class="pet-newsletter-desc-{{ section.id }}">{{ section.settings.newsletter_desc }}</p>
        </div>

        {%- assign form_class = 'pet-newsletter-form-' | append: section.id -%}
        {% form 'customer', class: form_class %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input type="email" name="contact[email]" class="pet-newsletter-input-{{ section.id }}" placeholder="{{ section.settings.newsletter_placeholder }}" required>
          <button type="submit" class="pet-newsletter-btn-{{ section.id }}">
            {{ section.settings.newsletter_btn }}
            <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>
        {% endform %}
      </div>
    {% endif %}

    <div class="pet-footer-main-{{ section.id }}">

      <div class="pet-footer-brand-{{ section.id }}">
        <a href="/" class="pet-footer-logo-{{ section.id }}">
          {% if section.settings.logo_image != blank %}
            {{ section.settings.logo_image | image_url: width: 400 | image_tag:
                class: 'pet-footer-logo-image-' | append: section.id,
                alt: section.settings.logo_text,
                loading: 'lazy',
                widths: '200,400'
            }}
          {% else %}
            <div class="pet-footer-logo-icon-{{ section.id }}">{{ section.settings.logo_emoji }}</div>
            <span class="pet-footer-logo-text-{{ section.id }}">{{ section.settings.logo_text }}</span>
          {% endif %}
        </a>

        {% if section.settings.brand_desc != blank %}
          <p class="pet-footer-desc-{{ section.id }}">{{ section.settings.brand_desc }}</p>
        {% endif %}

        {% if section.settings.contact_phone != blank or section.settings.contact_email != blank or section.settings.contact_address != blank %}
          <div class="pet-footer-contact-{{ section.id }}">
            {% if section.settings.contact_phone != blank %}
              <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}" class="pet-footer-contact-item-{{ section.id }}">
                <span class="pet-footer-contact-icon-{{ section.id }}">
                  <svg viewBox="0 0 24 24"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </span>
                {{ section.settings.contact_phone }}
              </a>
            {% endif %}
            {% if section.settings.contact_email != blank %}
              <a href="mailto:{{ section.settings.contact_email }}" class="pet-footer-contact-item-{{ section.id }}">
                <span class="pet-footer-contact-icon-{{ section.id }}">
                  <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
                </span>
                {{ section.settings.contact_email }}
              </a>
            {% endif %}
            {% if section.settings.contact_address != blank %}
              <span class="pet-footer-contact-item-{{ section.id }}">
                <span class="pet-footer-contact-icon-{{ section.id }}">
                  <svg viewBox="0 0 24 24"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                </span>
                {{ section.settings.contact_address }}
              </span>
            {% endif %}
          </div>
        {% endif %}

        <div class="pet-footer-socials-{{ section.id }}">
          <a href="{{ section.settings.social_instagram | default: '#' }}" class="pet-footer-social-link-{{ section.id }}" aria-label="Instagram" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="{{ section.settings.social_facebook | default: '#' }}" class="pet-footer-social-link-{{ section.id }}" aria-label="Facebook" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M22.675 0h-21.35C.593 0 0 .593 0 1.325v21.351C0 23.407.593 24 1.325 24H12.82v-9.294H9.692v-3.622h3.128V8.413c0-3.1 1.893-4.788 4.659-4.788 1.325 0 2.463.099 2.795.143v3.24l-1.918.001c-1.504 0-1.795.715-1.795 1.763v2.313h3.587l-.467 3.622h-3.12V24h6.116c.73 0 1.323-.593 1.323-1.325V1.325C24 .593 23.407 0 22.675 0z"/></svg>
          </a>
          <a href="{{ section.settings.social_tiktok | default: '#' }}" class="pet-footer-social-link-{{ section.id }}" aria-label="TikTok" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.95v7.45c-.01 2.72-1.41 5.37-3.72 6.74-2.52 1.5-5.83 1.35-8.08-.38-2.3-1.76-3.32-4.88-2.5-7.66.72-2.45 2.82-4.32 5.33-4.74 1.05-.18 2.14-.13 3.17.15V13.8c-.8-.21-1.64-.26-2.46-.11-1.44.25-2.73 1.25-3.34 2.58-.61 1.3-.57 2.87.1 4.14.64 1.22 1.83 2.1 3.19 2.37 1.52.31 3.18-.08 4.31-1.16 1.06-1 1.6-2.46 1.59-3.95V.02h-1.66z"/></svg>
          </a>
          <a href="{{ section.settings.social_twitter | default: '#' }}" class="pet-footer-social-link-{{ section.id }}" aria-label="X" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M18.901 1.153h3.68l-8.04 9.19L24 22.846h-7.406l-5.8-7.584-6.638 7.584H.474l8.6-9.83L0 1.154h7.594l5.243 6.932ZM17.61 20.644h2.039L6.486 3.24H4.298Z"/></svg>
          </a>
          <a href="{{ section.settings.social_youtube | default: '#' }}" class="pet-footer-social-link-{{ section.id }}" aria-label="YouTube" target="_blank" rel="noopener">
            <svg viewBox="0 0 24 24"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
          </a>
        </div>
      </div>

      {% for block in section.blocks %}
        {% if block.type == 'menu' %}
          <div class="pet-footer-col-{{ section.id }}" data-footer-col {{ block.shopify_attributes }}>
            <h4 class="pet-footer-col-title-{{ section.id }}" data-footer-toggle>
              {{ block.settings.title }}
              <span class="pet-footer-col-toggle-{{ section.id }}" aria-hidden="true"></span>
            </h4>
            <div class="pet-footer-menu-wrapper-{{ section.id }}">
              <ul class="pet-footer-menu-{{ section.id }}">
                {% if block.settings.menu != blank and linklists[block.settings.menu].links.size > 0 %}
                  {% for link in linklists[block.settings.menu].links %}
                    <li><a href="{{ link.url }}" class="pet-footer-link-{{ section.id }}">{{ link.title }}</a></li>
                  {% endfor %}
                {% else %}
                  {% for i in (1..6) %}
                    {%- assign text_key = 'link_' | append: i | append: '_text' -%}
                    {%- assign url_key = 'link_' | append: i | append: '_url' -%}
                    {% if block.settings[text_key] != blank %}
                      <li><a href="{{ block.settings[url_key] | default: '#' }}" class="pet-footer-link-{{ section.id }}">{{ block.settings[text_key] }}</a></li>
                    {% endif %}
                  {% endfor %}
                {% endif %}
              </ul>
            </div>
          </div>
        {% endif %}
      {% endfor %}

    </div>

    <div class="pet-footer-bottom-{{ section.id }}">
      <div class="pet-footer-bottom-left-{{ section.id }}">
        <p class="pet-footer-copyright-{{ section.id }}">
          &copy; {{ 'now' | date: '%Y' }} {{ section.settings.logo_text }} &mdash; {{ section.settings.copyright_text }}
        </p>
        {% if section.settings.legal_menu != blank and linklists[section.settings.legal_menu].links.size > 0 %}
          <ul class="pet-footer-legal-{{ section.id }}">
            {% for link in linklists[section.settings.legal_menu].links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="pet-footer-legal-{{ section.id }}">
            <li><a href="/policies/privacy-policy">Gizlilik</a></li>
            <li><a href="/policies/terms-of-service">Kullanım Şartları</a></li>
            <li><a href="#">Çerez Politikası</a></li>
          </ul>
        {% endif %}
      </div>

      {% if section.settings.show_payments %}
        <div class="pet-footer-payments-{{ section.id }}">
          {% if section.settings.pay_visa %}
            <span class="pet-pay-{{ section.id }} pet-pay-visa-{{ section.id }}">VISA</span>
          {% endif %}
          {% if section.settings.pay_mastercard %}
            <span class="pet-pay-{{ section.id }} pet-pay-mc-{{ section.id }}">
              <svg viewBox="0 0 36 24"><circle cx="13" cy="12" r="8" fill="#EA001B"/><circle cx="23" cy="12" r="8" fill="#FFA200"/><path d="M18 18.4a8 8 0 0 0 0-12.8 8 8 0 0 0 0 12.8z" fill="#FF5F00"/></svg>
            </span>
          {% endif %}
          {% if section.settings.pay_iyzico %}
            <span class="pet-pay-{{ section.id }} pet-pay-iyzico-{{ section.id }}">iyzico</span>
          {% endif %}
          {% if section.settings.pay_troy %}
            <span class="pet-pay-{{ section.id }} pet-pay-troy-{{ section.id }}">TROY</span>
          {% endif %}
          {% if section.settings.pay_ssl %}
            <span class="pet-pay-{{ section.id }} pet-pay-ssl-{{ section.id }}">
              <svg viewBox="0 0 24 24"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
              SSL
            </span>
          {% endif %}
        </div>
      {% endif %}
    </div>

  </div>
</footer>

<script>
(function() {
  var cols = document.querySelectorAll('.pet-footer-{{ section.id }} [data-footer-col]');
  var mobileQuery = window.matchMedia('(max-width: 640px)');

  function isMobile() { return mobileQuery.matches; }

  cols.forEach(function(col) {
    var title = col.querySelector('[data-footer-toggle]');
    if (!title) return;
    title.addEventListener('click', function() {
      if (!isMobile()) return;
      col.classList.toggle('is-open');
    });
  });

  function syncState() {
    cols.forEach(function(col) {
      if (!isMobile()) col.classList.remove('is-open');
    });
  }

  mobileQuery.addEventListener ? mobileQuery.addEventListener('change', syncState) : mobileQuery.addListener(syncState);
  syncState();
})();
</script>

