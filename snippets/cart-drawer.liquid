{%- comment -%}
  Twingle Cart Drawer
  -------------------
  Sağdan açılan mini-cart. Global render — layout/theme.liquid içinde bir kez.
  Açmak için bir butona class veya data ekle:
    <button data-twingle-cart-open>Sepet</button>
    veya class="twingle-cart-open"
  Açılınca /cart.js ile mevcut sepeti getirir, JS ile render eder.
{%- endcomment -%}

<style>
  .twingle-drawer {
    position: fixed;
    inset: 0;
    z-index: 9998;
    visibility: hidden;
    pointer-events: none;
  }
  .twingle-drawer.is-open {
    visibility: visible;
    pointer-events: auto;
  }
  .twingle-drawer__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 14, 40, 0.55);
    opacity: 0;
    transition: opacity 0.2s ease;
    cursor: pointer;
    will-change: opacity;
  }
  .twingle-drawer.is-open .twingle-drawer__backdrop { opacity: 1; }
  html.twingle-cart-locked { overflow: hidden; }
  html.twingle-cart-locked body { overflow: hidden; }
  .twingle-drawer__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    max-width: 420px;
    background: #fff;
    box-shadow: -16px 0 48px -12px rgba(20, 14, 40, 0.25);
    transform: translate3d(100%, 0, 0);
    transition: transform 0.22s cubic-bezier(0.2, 0.8, 0.2, 1);
    will-change: transform;
    contain: layout paint;
    display: flex;
    flex-direction: column;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, sans-serif;
  }
  .twingle-drawer.is-open .twingle-drawer__panel { transform: translate3d(0, 0, 0); }
  @media (max-width: 480px) {
    .twingle-drawer__panel { max-width: 100%; }
  }

  .twingle-drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 20px;
    border-bottom: 1px solid rgba(123, 63, 242, 0.08);
    gap: 12px;
    flex-shrink: 0;
  }
  .twingle-drawer__title {
    margin: 0;
    font-size: 16px;
    font-weight: 800;
    color: #1f1342;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .twingle-drawer__count {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 22px;
    height: 22px;
    padding: 0 7px;
    background: rgba(123, 63, 242, 0.1);
    color: #7b3ff2;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 800;
  }
  .twingle-drawer__close {
    width: 32px;
    height: 32px;
    border: none;
    background: #f5f3fa;
    color: #5a4f75;
    border-radius: 8px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .twingle-drawer__close:hover { background: #ece6f7; color: #1f1342; }
  .twingle-drawer__close svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.4; stroke-linecap: round; stroke-linejoin: round; }

  .twingle-drawer__body {
    flex: 1;
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 16px 20px 20px;
  }

  .twingle-drawer__empty {
    text-align: center;
    padding: 64px 16px;
    color: #5a4f75;
  }
  .twingle-drawer__empty-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 12px;
    border-radius: 12px;
    background: #f6f2ff;
    color: #7b3ff2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .twingle-drawer__empty-icon svg { width: 24px; height: 24px; stroke: currentColor; fill: none; stroke-width: 1.8; }
  .twingle-drawer__empty-title { font-size: 15px; font-weight: 700; color: #1f1342; margin: 0 0 6px; }
  .twingle-drawer__empty-desc { font-size: 13px; margin: 0 0 16px; }
  .twingle-drawer__empty-cta {
    display: inline-block;
    padding: 10px 18px;
    border-radius: 10px;
    background: #7b3ff2;
    color: #fff;
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
  }

  .twingle-drawer__items {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .twingle-drawer__item {
    display: grid;
    grid-template-columns: 64px 1fr auto;
    gap: 12px;
    padding: 12px;
    border: 1px solid rgba(123, 63, 242, 0.08);
    border-radius: 12px;
    background: #fff;
  }

  .twingle-drawer__item-img {
    width: 64px;
    height: 64px;
    border-radius: 8px;
    background: #faf7ff;
    object-fit: contain;
    padding: 4px;
    border: 1px solid rgba(123, 63, 242, 0.06);
    mix-blend-mode: multiply;
  }

  .twingle-drawer__item-info { min-width: 0; display: flex; flex-direction: column; gap: 4px; }
  .twingle-drawer__item-title {
    font-size: 13px;
    font-weight: 600;
    color: #1f1342;
    text-decoration: none;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .twingle-drawer__item-title:hover { color: #7b3ff2; }
  .twingle-drawer__item-variant { font-size: 11px; color: #8B8299; }

  .twingle-drawer__item-qty {
    display: inline-flex;
    align-items: center;
    border: 1px solid rgba(123, 63, 242, 0.18);
    border-radius: 8px;
    overflow: hidden;
    margin-top: 4px;
    width: max-content;
  }
  .twingle-drawer__qty-btn {
    width: 26px;
    height: 26px;
    background: #fff;
    border: none;
    color: #5a4f75;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    line-height: 1;
    font-weight: 600;
    transition: background 0.15s ease;
  }
  .twingle-drawer__qty-btn:hover { background: #f5f3fa; }
  .twingle-drawer__qty-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .twingle-drawer__qty-val {
    min-width: 28px;
    text-align: center;
    font-size: 12px;
    font-weight: 700;
    color: #1f1342;
  }

  .twingle-drawer__item-side { display: flex; flex-direction: column; align-items: flex-end; justify-content: space-between; }
  .twingle-drawer__item-price { font-size: 13.5px; font-weight: 800; color: #7b3ff2; letter-spacing: -0.02em; line-height: 1.1; }
  .twingle-drawer__item-compare { font-size: 11px; color: #8B8299; text-decoration: line-through; }
  .twingle-drawer__item-remove {
    background: none;
    border: none;
    padding: 0;
    color: #8B8299;
    font-size: 11px;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s ease;
  }
  .twingle-drawer__item-remove:hover { color: #b91c1c; }
  .twingle-drawer__item-remove svg { width: 11px; height: 11px; stroke: currentColor; fill: none; stroke-width: 2; }

  .twingle-drawer__footer {
    border-top: 1px solid rgba(123, 63, 242, 0.1);
    padding: 16px 20px 20px;
    background: #faf7ff;
    flex-shrink: 0;
  }
  .twingle-drawer__summary {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 12px;
  }
  .twingle-drawer__summary-label { font-size: 13px; color: #5a4f75; font-weight: 600; }
  .twingle-drawer__summary-total { font-size: 18px; font-weight: 800; color: #1f1342; letter-spacing: -0.02em; }
  .twingle-drawer__actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }
  .twingle-drawer__btn {
    width: 100%;
    padding: 12px 16px;
    border-radius: 10px;
    font-size: 13.5px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    text-align: center;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 6px;
    transition: transform 0.15s ease, filter 0.2s ease, box-shadow 0.2s ease;
    font-family: inherit;
    line-height: 1.2;
  }
  .twingle-drawer__btn--primary {
    background: linear-gradient(135deg, #7b3ff2 0%, #5b2fb2 100%);
    color: #fff;
    box-shadow: 0 6px 16px -6px rgba(123, 63, 242, 0.4);
  }
  .twingle-drawer__btn--primary:hover { filter: brightness(1.05); transform: translateY(-1px); }
  .twingle-drawer__btn--ghost {
    background: #fff;
    color: #1f1342;
    border: 1.5px solid rgba(123, 63, 242, 0.18);
  }
  .twingle-drawer__btn--ghost:hover { border-color: rgba(123, 63, 242, 0.35); background: #faf7ff; }
  .twingle-drawer__btn svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.4; }

  .twingle-drawer.is-loading .twingle-drawer__body { opacity: 0.55; pointer-events: none; }

  @media (prefers-reduced-motion: reduce) {
    .twingle-drawer__panel,
    .twingle-drawer__backdrop,
    .twingle-drawer__btn--primary { transition: none !important; }
  }
</style>

<div id="TwingleCartDrawer" class="twingle-drawer" role="dialog" aria-modal="true" aria-labelledby="TwingleCartDrawerTitle" aria-hidden="true">
  <div class="twingle-drawer__backdrop" data-twingle-drawer-close></div>
  <aside class="twingle-drawer__panel">
    <header class="twingle-drawer__header">
      <h3 id="TwingleCartDrawerTitle" class="twingle-drawer__title">
        Sepetim
        <span class="twingle-drawer__count" data-twingle-drawer-count>{{ cart.item_count }}</span>
      </h3>
      <button type="button" class="twingle-drawer__close" data-twingle-drawer-close aria-label="Sepeti kapat">
        <svg viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </header>

    <div class="twingle-drawer__body" data-twingle-drawer-body>
      <div class="twingle-drawer__empty" data-twingle-drawer-empty {% if cart.item_count > 0 %}hidden{% endif %}>
        <span class="twingle-drawer__empty-icon">
          <svg viewBox="0 0 24 24"><path d="M3 3h2l2.4 12.5a2 2 0 0 0 2 1.5h9.2a2 2 0 0 0 2-1.5L23 7H6"/><circle cx="9" cy="20" r="1"/><circle cx="19" cy="20" r="1"/></svg>
        </span>
        <h4 class="twingle-drawer__empty-title">Sepetin boş</h4>
        <p class="twingle-drawer__empty-desc">Premium ürünleri keşfet ve sevdiklerini sepete ekle.</p>
        <a href="{{ routes.all_products_collection_url | default: '/collections/all' }}" class="twingle-drawer__empty-cta" data-twingle-drawer-close>Alışverişe Başla</a>
      </div>
      <ul class="twingle-drawer__items" data-twingle-drawer-items>
        {%- for item in cart.items -%}
          <li class="twingle-drawer__item" data-key="{{ item.key }}">
            {%- if item.image -%}
              <img class="twingle-drawer__item-img" src="{{ item.image | image_url: width: 128 }}" alt="{{ item.product.title | escape }}" loading="lazy" width="64" height="64">
            {%- else -%}
              <div class="twingle-drawer__item-img"></div>
            {%- endif -%}
            <div class="twingle-drawer__item-info">
              <a href="{{ item.url }}" class="twingle-drawer__item-title">{{ item.product.title }}</a>
              {%- if item.variant.title != 'Default Title' and item.variant.title != blank -%}
                <span class="twingle-drawer__item-variant">{{ item.variant.title }}</span>
              {%- endif -%}
              <div class="twingle-drawer__item-qty">
                <button type="button" class="twingle-drawer__qty-btn" data-action="dec" aria-label="Azalt">−</button>
                <span class="twingle-drawer__qty-val">{{ item.quantity }}</span>
                <button type="button" class="twingle-drawer__qty-btn" data-action="inc" aria-label="Arttır">+</button>
              </div>
            </div>
            <div class="twingle-drawer__item-side">
              <span class="twingle-drawer__item-price">{{ item.final_line_price | money }}</span>
              {%- if item.original_line_price > item.final_line_price -%}
                <span class="twingle-drawer__item-compare">{{ item.original_line_price | money }}</span>
              {%- endif -%}
              <button type="button" class="twingle-drawer__item-remove" data-action="remove" aria-label="Kaldır">
                <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="m19 6-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                Kaldır
              </button>
            </div>
          </li>
        {%- endfor -%}
      </ul>
    </div>

    <footer class="twingle-drawer__footer" data-twingle-drawer-footer {% if cart.item_count == 0 %}hidden{% endif %}>
      <div class="twingle-drawer__summary">
        <span class="twingle-drawer__summary-label">Ara Toplam</span>
        <span class="twingle-drawer__summary-total" data-twingle-drawer-total>{{ cart.total_price | money }}</span>
      </div>
      <div class="twingle-drawer__actions">
        <a href="{{ routes.cart_url | default: '/cart' }}" class="twingle-drawer__btn twingle-drawer__btn--ghost">Sepeti Görüntüle</a>
        <a href="/checkout" class="twingle-drawer__btn twingle-drawer__btn--primary">
          Ödemeye Geç
          <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
        </a>
      </div>
    </footer>
  </aside>
</div>

<script>
(function () {
  if (window.__twingleCartDrawerInit) return;
  window.__twingleCartDrawerInit = true;

  var moneyFormat = {{ shop.money_format | json }};

  function formatMoney(cents) {
    if (typeof cents !== 'number') return '';
    var value = (cents / 100).toFixed(2);
    var parts = value.split('.');
    var intPart = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    var formatted = intPart + ',' + parts[1];
    if (moneyFormat && /\{\{.*\}\}/.test(moneyFormat)) {
      return moneyFormat.replace(/\{\{\s*amount[^}]*\}\}/, formatted);
    }
    return formatted + ' ₺';
  }

  var drawer = document.getElementById('TwingleCartDrawer');
  if (!drawer) return;
  var countEl = drawer.querySelector('[data-twingle-drawer-count]');
  var itemsEl = drawer.querySelector('[data-twingle-drawer-items]');
  var emptyEl = drawer.querySelector('[data-twingle-drawer-empty]');
  var footerEl = drawer.querySelector('[data-twingle-drawer-footer]');
  var totalEl = drawer.querySelector('[data-twingle-drawer-total]');
  var lastFocus = null;
  var cartIsFresh = true;

  function openDrawer() {
    lastFocus = document.activeElement;
    drawer.classList.add('is-open');
    drawer.setAttribute('aria-hidden', 'false');
    document.documentElement.classList.add('twingle-cart-locked');
    if (!cartIsFresh) {
      refresh();
    }
  }

  function closeDrawer() {
    drawer.classList.remove('is-open');
    drawer.setAttribute('aria-hidden', 'true');
    document.documentElement.classList.remove('twingle-cart-locked');
    if (lastFocus && typeof lastFocus.focus === 'function') {
      try { lastFocus.focus(); } catch (e) {}
    }
  }

  drawer.addEventListener('click', function (e) {
    if (e.target.closest('[data-twingle-drawer-close]')) {
      e.preventDefault();
      closeDrawer();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && drawer.classList.contains('is-open')) closeDrawer();
  });

  document.addEventListener('click', function (e) {
    var trigger = e.target.closest('[data-twingle-cart-open], .twingle-cart-open');
    if (!trigger) return;
    e.preventDefault();
    openDrawer();
  });

  function updateBadges(count) {
    var selectors = ['[data-cart-count]', '.cart-count', '[class*="pet-cart-count-"]', '.header__cart-count', '#cart-icon-bubble', '#CartCount'];
    document.querySelectorAll(selectors.join(',')).forEach(function (el) {
      el.textContent = count;
      if (el.dataset) el.dataset.cartCount = count;
    });
  }

  function renderItem(item) {
    var li = document.createElement('li');
    li.className = 'twingle-drawer__item';
    li.dataset.key = item.key;

    var img = (item.featured_image && item.featured_image.url) || item.image || '';
    var imgHtml = img ? '<img class="twingle-drawer__item-img" src="' + img + '" alt="' + (item.product_title || '') + '" loading="lazy">' : '<div class="twingle-drawer__item-img"></div>';

    var variant = '';
    if (item.variant_title && item.variant_title !== 'Default Title') {
      variant = '<span class="twingle-drawer__item-variant">' + item.variant_title + '</span>';
    }

    var comparePrice = '';
    if (item.original_price && item.original_price > item.final_price) {
      comparePrice = '<span class="twingle-drawer__item-compare">' + formatMoney(item.original_price * item.quantity) + '</span>';
    }

    li.innerHTML =
      imgHtml +
      '<div class="twingle-drawer__item-info">' +
        '<a href="' + item.url + '" class="twingle-drawer__item-title">' + (item.product_title || item.title || 'Ürün') + '</a>' +
        variant +
        '<div class="twingle-drawer__item-qty">' +
          '<button type="button" class="twingle-drawer__qty-btn" data-action="dec" aria-label="Azalt">−</button>' +
          '<span class="twingle-drawer__qty-val">' + item.quantity + '</span>' +
          '<button type="button" class="twingle-drawer__qty-btn" data-action="inc" aria-label="Arttır">+</button>' +
        '</div>' +
      '</div>' +
      '<div class="twingle-drawer__item-side">' +
        '<span class="twingle-drawer__item-price">' + formatMoney(item.final_line_price) + '</span>' +
        comparePrice +
        '<button type="button" class="twingle-drawer__item-remove" data-action="remove" aria-label="Kaldır">' +
          '<svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="m19 6-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>' +
          'Kaldır' +
        '</button>' +
      '</div>';
    return li;
  }

  function render(cart) {
    var count = cart.item_count || 0;
    countEl.textContent = count;
    updateBadges(count);

    if (count === 0) {
      itemsEl.innerHTML = '';
      emptyEl.hidden = false;
      footerEl.hidden = true;
      return;
    }
    emptyEl.hidden = true;
    footerEl.hidden = false;
    itemsEl.innerHTML = '';
    cart.items.forEach(function (item) { itemsEl.appendChild(renderItem(item)); });
    totalEl.textContent = formatMoney(cart.total_price);
  }

  function refresh() {
    drawer.classList.add('is-loading');
    return fetch('/cart.js', { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        render(cart);
        cartIsFresh = true;
        return cart;
      })
      .catch(function () {})
      .finally(function () { drawer.classList.remove('is-loading'); });
  }

  function changeLine(key, quantity) {
    drawer.classList.add('is-loading');
    return fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Accept': 'application/json', 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ id: key, quantity: quantity })
    })
      .then(function (r) { return r.json(); })
      .then(function (cart) {
        render(cart);
        cartIsFresh = true;
        document.dispatchEvent(new CustomEvent('twingle:cart:updated', { detail: { cart: cart } }));
        return cart;
      })
      .catch(function () {})
      .finally(function () { drawer.classList.remove('is-loading'); });
  }

  itemsEl.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    var li = btn.closest('.twingle-drawer__item');
    if (!li) return;
    var key = li.dataset.key;
    var action = btn.dataset.action;

    if (action === 'remove') {
      changeLine(key, 0);
      return;
    }
    var qtyEl = li.querySelector('.twingle-drawer__qty-val');
    var current = parseInt(qtyEl.textContent, 10) || 1;
    var next = action === 'inc' ? current + 1 : Math.max(0, current - 1);
    changeLine(key, next);
  });

  function invalidateCart() {
    cartIsFresh = false;
    if (drawer.classList.contains('is-open')) refresh();
  }
  document.addEventListener('twingle:cart:added', invalidateCart);
  document.addEventListener('twingle:cart:refresh', invalidateCart);
  document.addEventListener('twingle:cart:open', function () { openDrawer(); });

  document.addEventListener('visibilitychange', function () {
    if (!document.hidden) cartIsFresh = false;
  });

  window.twingleCart = { open: openDrawer, close: closeDrawer, refresh: refresh };
})();
</script>
