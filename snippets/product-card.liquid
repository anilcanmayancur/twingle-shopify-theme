{%- comment -%}
  Twingle Unified Product Card
  ----------------------------
  Site genelinde TEK ürün kartı tasarımı.
  Optional params:
    product       (required)
    popular       (bool) - top-left "Popüler" pill
    social_proof  (string) - alt satırda "X kişi aldı" benzeri metin
{%- endcomment -%}

{%- liquid
  assign is_new = false
  if product.published_at != blank
    assign published_date = product.published_at | date: "%s"
    assign now_date = 'now' | date: "%s"
    assign diff_seconds = now_date | minus: published_date
    assign diff_days = diff_seconds | divided_by: 86400
    if diff_days <= 7
      assign is_new = true
    endif
  endif

  assign has_discount = false
  if product.compare_at_price > product.price
    assign has_discount = true
    assign discount_amount = product.compare_at_price | minus: product.price
    assign discount_percent = discount_amount | times: 100.0 | divided_by: product.compare_at_price | round
  endif

  assign review_count = product.metafields.reviews.rating_count | default: product.metafields.judgeme.review_count
  assign review_rating = product.metafields.reviews.rating | default: 5
-%}

<style>
  .forspaceon-pc-card {
    background: #FFFFFF;
    border: 1px solid rgba(123, 63, 242, 0.08);
    border-radius: 14px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.3s ease, border-color 0.25s ease;
    font-family: inherit;
    position: relative;
    height: 100%;
  }

  .forspaceon-pc-card:hover {
    border-color: rgba(123, 63, 242, 0.22);
    box-shadow: 0 12px 32px -12px rgba(123, 63, 242, 0.22);
    transform: translateY(-2px);
  }

  .forspaceon-pc-image-wrap {
    position: relative;
    background-color: #f6f2ff;
    padding: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    aspect-ratio: 1 / 1;
    overflow: hidden;
  }

  .forspaceon-pc-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    mix-blend-mode: multiply;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .forspaceon-pc-card:hover .forspaceon-pc-image-wrap img {
    transform: scale(1.04);
  }

  /* Badges (top-left) */
  .forspaceon-pc-badges {
    position: absolute;
    top: 8px;
    left: 8px;
    display: flex;
    flex-direction: column;
    gap: 4px;
    z-index: 2;
  }

  .forspaceon-pc-badge {
    padding: 3px 8px;
    border-radius: 100px;
    font-size: 10px;
    font-weight: 800;
    color: #FFFFFF;
    line-height: 1.2;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    display: inline-flex;
    align-items: center;
    gap: 3px;
  }

  .forspaceon-pc-badge-new {
    background-color: #22c55e;
  }

  .forspaceon-pc-badge-sale {
    background-color: rgba(123, 63, 242, 0.92);
  }

  .forspaceon-pc-badge-popular {
    background: rgba(255, 255, 255, 0.92);
    color: #7B3FF2;
    border: 1px solid rgba(123, 63, 242, 0.18);
  }

  .forspaceon-pc-badge-popular svg {
    width: 9px;
    height: 9px;
    fill: #7B3FF2;
    stroke: none;
  }

  /* Wishlist heart (top-right) */
  .forspaceon-pc-wishlist {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid rgba(123, 63, 242, 0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: #7B3FF2;
    transition: all 0.2s ease;
    z-index: 2;
    padding: 0;
  }

  .forspaceon-pc-wishlist:hover {
    background: #7B3FF2;
    color: #ffffff;
    transform: scale(1.06);
  }

  .forspaceon-pc-wishlist svg {
    width: 13px;
    height: 13px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  /* Info area */
  .forspaceon-pc-info {
    padding: 10px 12px 12px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 4px;
  }

  .forspaceon-pc-vendor {
    font-size: 9.5px;
    font-weight: 800;
    color: #7B3FF2;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    line-height: 1;
  }

  .forspaceon-pc-title {
    font-size: 12.5px;
    font-weight: 600;
    color: #1F1342;
    text-decoration: none;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    margin: 0;
  }

  .forspaceon-pc-title:hover {
    color: #7B3FF2;
  }

  .forspaceon-pc-reviews {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .forspaceon-pc-stars {
    display: inline-flex;
    align-items: center;
    gap: 1px;
    line-height: 1;
  }

  .forspaceon-pc-stars svg {
    width: 11px;
    height: 11px;
    fill: #F59E0B;
  }

  .forspaceon-pc-review-count {
    font-size: 10px;
    color: #8B8299;
    font-weight: 500;
  }

  .forspaceon-pc-proof {
    display: flex;
    align-items: center;
    gap: 3px;
    font-size: 9.5px;
    color: #5A4F75;
    font-weight: 500;
  }

  .forspaceon-pc-proof svg {
    width: 10px;
    height: 10px;
    flex-shrink: 0;
    fill: #7B3FF2;
    opacity: 0.65;
  }

  .forspaceon-pc-prices {
    display: flex;
    align-items: baseline;
    gap: 6px;
    margin-top: 2px;
  }

  .forspaceon-pc-price-current {
    font-size: 14.5px;
    font-weight: 800;
    color: #7B3FF2;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .forspaceon-pc-price-compare {
    font-size: 11px;
    color: #8B8299;
    text-decoration: line-through;
    font-weight: 500;
  }

  .forspaceon-pc-add-form {
    margin: 6px 0 0;
  }

  .forspaceon-pc-add-btn {
    width: 100%;
    background: linear-gradient(135deg, #7B3FF2 0%, #5B2FB2 100%);
    color: #FFFFFF;
    border: none;
    border-radius: 100px;
    padding: 9px 12px;
    font-size: 11.5px;
    font-weight: 700;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.25s ease, opacity 0.2s ease;
    box-shadow: 0 4px 12px -4px rgba(123, 63, 242, 0.35);
    line-height: 1.2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 5px;
    text-decoration: none;
    font-family: inherit;
  }

  .forspaceon-pc-add-btn:hover {
    transform: translateY(-1px);
    box-shadow: 0 6px 16px -4px rgba(123, 63, 242, 0.45);
  }

  .forspaceon-pc-add-btn:disabled {
    background: #D1C9E0;
    box-shadow: none;
    cursor: not-allowed;
    transform: none;
  }

  .forspaceon-pc-add-btn svg {
    width: 11px;
    height: 11px;
    stroke: currentColor;
    fill: none;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
    flex-shrink: 0;
  }

  @media (max-width: 749px) {
    .forspaceon-pc-info {
      padding: 10px 10px 12px;
      gap: 3px;
    }
    .forspaceon-pc-title {
      font-size: 11.5px;
    }
    .forspaceon-pc-price-current {
      font-size: 13.5px;
    }
    .forspaceon-pc-add-btn {
      padding: 8px 10px;
      font-size: 11px;
    }
    .forspaceon-pc-image-wrap {
      padding: 12px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .forspaceon-pc-card,
    .forspaceon-pc-image-wrap img,
    .forspaceon-pc-add-btn,
    .forspaceon-pc-wishlist {
      transition: none !important;
    }
  }
</style>

<div class="forspaceon-pc-card">

  <a href="{{ product.url }}" class="forspaceon-pc-image-wrap" aria-label="{{ product.title | escape }}">
    <div class="forspaceon-pc-badges">
      {% if has_discount %}
        <span class="forspaceon-pc-badge forspaceon-pc-badge-sale">-{{ discount_percent }}%</span>
      {% elsif is_new %}
        <span class="forspaceon-pc-badge forspaceon-pc-badge-new">Yeni</span>
      {% endif %}
      {% if popular %}
        <span class="forspaceon-pc-badge forspaceon-pc-badge-popular">
          <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
          Popüler
        </span>
      {% endif %}
    </div>

    <button type="button" class="forspaceon-pc-wishlist" aria-label="Favorilere ekle" onclick="event.preventDefault();event.stopPropagation();">
      <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
    </button>

    {% if product.featured_image != blank %}
      {{ product.featured_image | image_url: width: 400 | image_tag: loading: 'lazy', widths: '160,240,320,400', sizes: '(max-width:749px) 50vw, 240px', alt: product.title }}
    {% else %}
      {{ 'product-1' | placeholder_svg_tag }}
    {% endif %}
  </a>

  <div class="forspaceon-pc-info">

    {% if product.vendor != blank %}
      <div class="forspaceon-pc-vendor">{{ product.vendor }}</div>
    {% endif %}

    <a href="{{ product.url }}" class="forspaceon-pc-title">{{ product.title }}</a>

    <div class="forspaceon-pc-reviews">
      <span class="forspaceon-pc-stars" aria-label="{{ review_rating }} yıldız">
        {% for i in (1..5) %}
          <svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        {% endfor %}
      </span>
      {% if review_count != blank %}
        <span class="forspaceon-pc-review-count">({{ review_count }})</span>
      {% endif %}
    </div>

    {% if social_proof != blank %}
      <div class="forspaceon-pc-proof">
        <svg viewBox="0 0 24 24"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        <span>{{ social_proof }}</span>
      </div>
    {% endif %}

    <div class="forspaceon-pc-prices">
      <span class="forspaceon-pc-price-current">{{ product.price | money }}</span>
      {% if has_discount %}
        <span class="forspaceon-pc-price-compare">{{ product.compare_at_price | money }}</span>
      {% endif %}
    </div>

    {% if product.available %}
      {% if product.variants.size > 1 %}
        <a href="{{ product.url }}" class="forspaceon-pc-add-btn">
          Seçenekleri Gör
          <svg viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {% else %}
        <form
          method="post"
          action="{{ routes.cart_add_url | default: '/cart/add' }}"
          class="forspaceon-pc-add-form"
          data-product-title="{{ product.title | escape }}"
          data-product-image="{% if product.featured_image != blank %}{{ product.featured_image | image_url: width: 200 }}{% endif %}"
          data-product-price="{{ product.price }}"
          data-product-url="{{ product.url }}"
        >
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="quantity" value="1">
          <button type="submit" class="forspaceon-pc-add-btn">
            Sepete Ekle
            <svg viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4zM3 6h18M16 10a4 4 0 01-8 0"/></svg>
          </button>
        </form>
      {% endif %}
    {% else %}
      <button type="button" class="forspaceon-pc-add-btn" disabled>Tükendi</button>
    {% endif %}

  </div>
</div>
