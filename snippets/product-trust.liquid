<div class="sec sec-trust" {{ block.shopify_attributes }}>
  <ul class="trust-strip" role="list">
    {%- assign badge_nums = '1,2,3,4' | split: ',' -%}
    {%- for n in badge_nums -%}
      {%- assign icon_key  = 'badge' | append: n | append: '_icon' -%}
      {%- assign label_key = 'badge' | append: n | append: '_label' -%}
      {%- if block.settings[label_key] != blank -%}
        <li class="ts-i">
          <span class="ts-ico" aria-hidden="true">{{ block.settings[icon_key] }}</span>
          <span class="ts-lbl">{{ block.settings[label_key] }}</span>
        </li>
      {%- endif -%}
    {%- endfor -%}
  </ul>

  <div class="pay-strip" aria-label="Ödeme yöntemleri">
    <span class="ps-lbl">Güvenli Ödeme</span>
    <div class="ps-items">
      {%- if block.settings.show_visa -%}<span class="pi v">VISA</span>{%- endif -%}
      {%- if block.settings.show_mc -%}<span class="pi m">MC</span>{%- endif -%}
      {%- if block.settings.show_iyzico -%}<span class="pi i">iyzico</span>{%- endif -%}
      {%- if block.settings.show_troy -%}<span class="pi tr">TROY</span>{%- endif -%}
      {%- if block.settings.show_kapida -%}<span class="pi k">{{ block.settings.kapida_label }}</span>{%- endif -%}
      {%- if block.settings.installment_text != blank -%}
        <span class="pi pi-ins">{{ block.settings.installment_text }}</span>
      {%- endif -%}
    </div>
  </div>
</div>
