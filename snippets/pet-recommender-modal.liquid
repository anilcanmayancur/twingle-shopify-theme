{%- comment -%}
  Pet Recommender Modal (global)
  - Tüm sayfalarda theme.liquid tarafından render edilir.
  - `.pet-rec-trigger` veya `[data-pet-recommender]` selector'lı herhangi bir öğeye
    tıklanınca modal açılır.
  - Geriye dönük uyumluluk: eski `sections/pet-recommender.liquid` artık bu snippet'i çağırır.
{%- endcomment -%}

{%- unless content_for_layout contains 'pet-rec-modal-global' -%}{%- endunless -%}

{%- if request.path contains '/cart' -%}{%- endif -%}

<span id="pet-recommender" aria-hidden="true" style="position:absolute;height:0;visibility:hidden;"></span>

{%- comment -%} Prevent duplicate render in case section also mounts it {%- endcomment -%}
{%- assign rec_marker = 'PRecModal-global' -%}

<style>
.pet-rec-trigger-global { cursor: pointer; }

.pet-rec-overlay-global {
  position: fixed; inset: 0;
  background: rgba(15, 10, 38, 0.6);
  backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
  z-index: 9998; opacity: 0; visibility: hidden;
  transition: opacity 0.3s ease, visibility 0.3s ease;
}
.pet-rec-overlay-global.is-open { opacity: 1; visibility: visible; }

.pet-rec-modal-global {
  position: fixed; top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0.96);
  width: min(560px, calc(100vw - 32px));
  max-height: calc(100vh - 32px);
  background: #fff; border-radius: 20px;
  z-index: 9999; opacity: 0; visibility: hidden;
  transition: opacity 0.3s cubic-bezier(0.2, 0.8, 0.2, 1),
              transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1),
              visibility 0.3s ease;
  box-shadow: 0 32px 80px rgba(15, 10, 38, 0.3);
  display: flex; flex-direction: column;
  overflow: hidden; font-family: inherit;
}
.pet-rec-modal-global.is-open { opacity: 1; visibility: visible; transform: translate(-50%, -50%) scale(1); }

.pet-rec-head-global { padding: 22px 24px 0; display: flex; align-items: center; justify-content: space-between; gap: 12px; }
.pet-rec-head-left-global { display: inline-flex; align-items: center; gap: 10px; }
.pet-rec-spark-global { width: 36px; height: 36px; border-radius: 10px; background: linear-gradient(135deg, #7B3FF2, #B794F4); display: inline-flex; align-items: center; justify-content: center; color: #fff; }
.pet-rec-head-text-global { display: flex; flex-direction: column; gap: 2px; }
.pet-rec-title-global { font-size: 15px; font-weight: 800; color: #1F1342; letter-spacing: -0.01em; }
.pet-rec-sub-global { font-size: 12px; color: #5A4F75; }

.pet-rec-close-global { width: 34px; height: 34px; border: none; background: #F5F3FF; color: #1F1342; border-radius: 8px; cursor: pointer; display: inline-flex; align-items: center; justify-content: center; transition: background 0.2s ease, color 0.2s ease; flex-shrink: 0; }
