.pet-rec-prog-global { padding: 14px 24px 0; }
.pet-rec-prog-bar-global { height: 4px; background: #ECE9F5; border-radius: 100px; overflow: hidden; }
.pet-rec-prog-fill-global { height: 100%; background: linear-gradient(90deg, #7B3FF2, #B794F4); border-radius: 100px; width: 0%; transition: width 0.4s cubic-bezier(0.2, 0.8, 0.2, 1); }
.pet-rec-prog-meta-global { display: flex; align-items: center; justify-content: space-between; margin-top: 8px; font-size: 11px; color: #8B82A0; font-weight: 600; }

.pet-rec-body-global { padding: 22px 24px 24px; flex: 1; overflow-y: auto; min-height: 320px; }

.pet-rec-step-global { display: none; flex-direction: column; gap: 16px; animation: pet-rec-fade-global 0.35s cubic-bezier(0.2, 0.8, 0.2, 1); }
