@keyframes pet-rec-fade-global { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

.pet-rec-q-global { font-size: 18px; font-weight: 800; color: #1F1342; margin: 0; letter-spacing: -0.02em; line-height: 1.3; }
.pet-rec-q-sub-global { font-size: 13px; color: #5A4F75; margin: -8px 0 0; }

.pet-rec-opts-global { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; }
.pet-rec-opt-global { display: flex; align-items: center; gap: 12px; padding: 14px 16px; background: #FAF7FF; border: 1.5px solid #ECE9F5; border-radius: 12px; cursor: pointer; text-align: left; font-family: inherit; transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease; color: #1F1342; }
.pet-rec-opt-global:hover { border-color: #7B3FF2; background: #F5F3FF; transform: translateY(-1px); }
