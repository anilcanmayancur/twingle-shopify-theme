@keyframes pet-rec-dot-global { 0%, 60%, 100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-6px); opacity: 1; } }

.pet-rec-results-global { display: none; flex-direction: column; gap: 14px; animation: pet-rec-fade-global 0.45s cubic-bezier(0.2, 0.8, 0.2, 1); }
.pet-rec-results-global.is-active { display: flex; }
.pet-rec-results-head-global { display: flex; align-items: center; gap: 10px; padding: 12px 14px; background: linear-gradient(135deg, #F5F3FF, #FAF7FF); border: 1px solid #ECE9F5; border-radius: 12px; }
.pet-rec-results-icon-global { width: 32px; height: 32px; border-radius: 8px; background: linear-gradient(135deg, #7B3FF2, #B794F4); display: inline-flex; align-items: center; justify-content: center; color: #fff; flex-shrink: 0; }
.pet-rec-results-text-global { display: flex; flex-direction: column; gap: 1px; }
.pet-rec-results-title-global { font-size: 13px; font-weight: 700; color: #1F1342; }
.pet-rec-results-sub-global { font-size: 11.5px; color: #5A4F75; }
.pet-rec-products-global { display: flex; flex-direction: column; gap: 8px; }
.pet-rec-product-global { display: flex; align-items: center; gap: 12px; padding: 10px; background: #fff; border: 1px solid #ECE9F5; border-radius: 12px; text-decoration: none; color: inherit; transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease; }
.pet-rec-product-global:hover { border-color: #7B3FF2; box-shadow: 0 4px 16px rgba(123, 63, 242, 0.08); transform: translateY(-1px); }
.pet-rec-product-img-global { width: 56px; height: 56px; border-radius: 8px; overflow: hidden; background: #F5F3FF; flex-shrink: 0; display: flex; align-items: center; justify-content: center; }
.pet-rec-product-img-global img { width: 100%; height: 100%; object-fit: cover; }
.pet-rec-product-info-global { display: flex; flex-direction: column; gap: 3px; min-width: 0; flex: 1; }
.pet-rec-product-name-global { font-size: 13px; font-weight: 700; color: #1F1342; line-height: 1.3; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
