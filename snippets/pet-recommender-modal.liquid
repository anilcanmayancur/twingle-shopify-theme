.pet-rec-product-arrow-global { color: #8B82A0; flex-shrink: 0; }
.pet-rec-empty-global { display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 24px; text-align: center; color: #5A4F75; font-size: 13px; }

.pet-rec-foot-global { padding: 14px 24px 22px; border-top: 1px solid #ECE9F5; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
.pet-rec-back-global { background: transparent; border: none; color: #5A4F75; font-size: 13px; font-weight: 600; cursor: pointer; padding: 8px 0; display: inline-flex; align-items: center; gap: 6px; font-family: inherit; transition: color 0.2s ease; }
.pet-rec-back-global:hover { color: #7B3FF2; }
