<script>
(function() {
  if (window.__petRecGlobalInit) return;
  window.__petRecGlobalInit = true;

  var TRIGGER_SELECTOR = '.pet-rec-trigger,[data-pet-recommender]';
  var BASE_URL = {{ routes.all_products_collection_url | json }} || '/collections/all';

  var modal = document.getElementById('PRecModal-global');
  var overlay = document.getElementById('PRecOver-global');
  var closeBtn = document.getElementById('PRecClose-global');
  var backBtn = document.getElementById('PRecBack-global');
  var ctaBtn = document.getElementById('PRecCta-global');
  var fill = document.getElementById('PRecFill-global');
  var stepLabel = document.getElementById('PRecStepLabel-global');
  var loadEl = document.getElementById('PRecLoad-global');
  var loadTextEl = document.getElementById('PRecLoadText-global');
  var resultsEl = document.getElementById('PRecResults-global');
  var productsEl = document.getElementById('PRecProducts-global');
  var resultsSub = document.getElementById('PRecResultsSub-global');

  if (!modal || !overlay || !closeBtn || !backBtn || !ctaBtn || !fill || !stepLabel || !loadEl || !loadTextEl || !resultsEl || !productsEl || !resultsSub) return;

  function escAttr(s) {
    return String(s || '').replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  var steps = modal.querySelectorAll('.pet-rec-step-global');
  var totalSteps = steps.length;
  var currentStep = 1;
  var answers = {};
  var loadingMessages = [
    'Tercihlerini analiz ediyorum...',
    'Veteriner onaylı ürünleri tarıyorum...',
    'Dostun için en iyi eşleşmeleri buluyorum...',
    'Son rötuşları yapıyorum...'
  ];

  function openModal() {
    modal.classList.add('is-open');
    if (overlay) overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
    reset();
  }

  function closeModal() {
    modal.classList.remove('is-open');
    if (overlay) overlay.classList.remove('is-open');
    document.body.style.overflow = '';
  }

  function reset() {
    currentStep = 1;
    answers = {};
    showStep(1);
    loadEl.classList.remove('is-active');
    resultsEl.classList.remove('is-active');
    ctaBtn.style.display = 'none';
    productsEl.innerHTML = '';
    modal.querySelectorAll('.pet-rec-opt-global').forEach(function(b) {
      b.classList.remove('is-selected');
    });
  }

  function showStep(n) {
    steps.forEach(function(s) {
      s.classList.toggle('is-active', parseInt(s.dataset.step, 10) === n);
    });
    fill.style.width = ((n / totalSteps) * 100) + '%';
    stepLabel.textContent = n + ' / ' + totalSteps;
    backBtn.disabled = n === 1;
    ctaBtn.style.display = 'none';
  }

  function nextStep() {
    if (currentStep < totalSteps) {
      currentStep++;
      showStep(currentStep);
    } else {
      runRecommendation();
    }
  }

  function prevStep() {
    if (loadEl.classList.contains('is-active') || resultsEl.classList.contains('is-active')) {
      loadEl.classList.remove('is-active');
      resultsEl.classList.remove('is-active');
      showStep(currentStep);
      return;
    }
    if (currentStep > 1) {
      currentStep--;
      showStep(currentStep);
    }
  }

  function productThumb(p) {
    var fi = p.featured_image;
    if (typeof fi === 'string' && fi) return fi;
    if (fi && typeof fi === 'object' && fi.url) return fi.url;
    if (p.image) {
      if (typeof p.image === 'string') return p.image;
      if (p.image.url) return p.image.url;
    }
    return '';
  }

  function productHref(p) {
    var u = p.url || (p.handle ? '/products/' + p.handle : '');
    return u.indexOf('/') === 0 || u.indexOf('http') === 0 ? u : '/products/' + String(p.handle || '');
  }

  function renderProducts(products, query) {
    if (!products.length) {
      productsEl.innerHTML = '<div class="pet-rec-empty-global">Henüz ürün bulamadım. Tüm ürünleri keşfetmek için aşağıdaki butona tıkla.</div>';
      resultsSub.textContent = 'Genel öneriler hazır';
    } else {
      resultsSub.textContent = products.length + ' ürün eşleşti';
      productsEl.innerHTML = products.map(function(p) {
        var img = productThumb(p);
        var price = p.price || '';
        var title = p.title || '';
        var rawHref = productHref(p);
        var href = rawHref ? escAttr(rawHref) : '#';
        return ''
          + '<a href="' + href + '" class="pet-rec-product-global">'
          + '<div class="pet-rec-product-img-global">'
          + (img ? '<img src="' + escAttr(img) + '" alt="' + escAttr(title) + '" loading="lazy">' : '<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#7B3FF2" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2"/></svg>')
          + '</div>'
          + '<div class="pet-rec-product-info-global">'
          + '<div class="pet-rec-product-name-global">' + escAttr(title) + '</div>'
          + (price ? '<div class="pet-rec-product-price-global">' + escAttr(String(price)) + '</div>' : '')
          + '</div>'
          + '<span class="pet-rec-product-arrow-global"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="square" stroke-linejoin="miter"><polyline points="9 18 15 12 9 6"/></svg></span>'
          + '</a>';
      }).join('');
    }
    ctaBtn.style.display = 'inline-flex';
    ctaBtn.href = BASE_URL + (query ? '?q=' + encodeURIComponent(query) : '');
  }

  function showResults(products, query, msgInt) {
    setTimeout(function() {
      clearInterval(msgInt);
      loadEl.classList.remove('is-active');
      resultsEl.classList.add('is-active');
      backBtn.disabled = false;
      renderProducts(products, query);
    }, 1800);
  }

  function runRecommendation() {
    steps.forEach(function(s) { s.classList.remove('is-active'); });
    loadEl.classList.add('is-active');
    fill.style.width = '100%';
    stepLabel.textContent = 'Analiz ediyor...';
    backBtn.disabled = true;

    var msgIdx = 0;
    var msgInt = setInterval(function() {
      msgIdx = (msgIdx + 1) % loadingMessages.length;
      loadTextEl.style.opacity = '0';
      setTimeout(function() {
        loadTextEl.textContent = loadingMessages[msgIdx];
        loadTextEl.style.opacity = '1';
      }, 200);
    }, 1100);

    var allTags = [];
    Object.keys(answers).forEach(function(k) {
      if (answers[k].tag) allTags.push(answers[k].tag);
    });

    var queries = [
      allTags.join(' '),
      allTags.slice(0, 2).join(' '),
      allTags[0] || '',
      ''
    ];

    function tryQuery(idx) {
      if (idx >= queries.length) {
        showResults([], '', msgInt);
        return;
      }
      var q = queries[idx];
      var url = q
        ? '/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=4'
        : '/products.json?limit=4';

      fetch(url)
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var products;
          if (q) {
            products = (data.resources && data.resources.results && data.resources.results.products) || [];
          } else {
            products = (data.products || []).map(function(p) {
              return {
                title: p.title,
                url: '/products/' + p.handle,
                image: p.images && p.images[0] && (p.images[0].src || p.images[0]),
                price: p.variants && p.variants[0] ? '₺' + p.variants[0].price : ''
              };
            });
          }
          if (products.length) showResults(products, q, msgInt);
          else tryQuery(idx + 1);
        })
        .catch(function() { tryQuery(idx + 1); });
    }

    tryQuery(0);
  }

  modal.addEventListener('click', function(e) {
    var opt = e.target.closest('.pet-rec-opt-global');
    if (!opt) return;
    var step = opt.closest('.pet-rec-step-global');
    if (!step) return;
    step.querySelectorAll('.pet-rec-opt-global').forEach(function(b) {
      b.classList.remove('is-selected');
    });
    opt.classList.add('is-selected');
    answers[opt.dataset.q] = { value: opt.dataset.v, tag: opt.dataset.tag || '' };
    setTimeout(nextStep, 280);
  });

  closeBtn.addEventListener('click', closeModal);
  overlay.addEventListener('click', closeModal);
  backBtn.addEventListener('click', prevStep);

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });

  document.addEventListener('click', function(e) {
    var trigger = e.target.closest(TRIGGER_SELECTOR);
    if (!trigger) return;
    e.preventDefault();
    openModal();
  });

  window.TwinklePetRecommender = { open: openModal, close: closeModal };
})();
</script>
