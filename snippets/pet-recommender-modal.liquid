.pet-rec-opt-emoji-global { font-size: 24px; flex-shrink: 0; }
.pet-rec-opt-content-global { display: flex; flex-direction: column; gap: 2px; min-width: 0; flex: 1; }
.pet-rec-opt-title-global { font-size: 13.5px; font-weight: 700; color: #1F1342; line-height: 1.2; }
.pet-rec-opt-desc-global { font-size: 11.5px; color: #5A4F75; line-height: 1.3; }

.pet-rec-loading-global { display: none; flex-direction: column; align-items: center; justify-content: center; gap: 18px; padding: 32px 20px; text-align: center; min-height: 320px; }
.pet-rec-loading-global.is-active { display: flex; }
.pet-rec-orb-global { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, #7B3FF2, #B794F4); display: inline-flex; align-items: center; justify-content: center; color: #fff; position: relative; animation: pet-rec-orb-pulse-global 1.6s ease-in-out infinite; }
.pet-rec-orb-global::before, .pet-rec-orb-global::after { content: ''; position: absolute; inset: 0; border-radius: 50%; border: 2px solid #7B3FF2; opacity: 0; animation: pet-rec-orb-ring-global 2s ease-out infinite; }
.pet-rec-orb-global::after { animation-delay: 1s; }
@keyframes pet-rec-orb-pulse-global { 0%, 100% { transform: scale(1); } 50% { transform: scale(1.06); } }
@keyframes pet-rec-orb-ring-global { 0% { opacity: 0.6; transform: scale(1); } 100% { opacity: 0; transform: scale(1.6); } }
.pet-rec-loading-text-global { font-size: 16px; font-weight: 700; color: #1F1342; letter-spacing: -0.01em; min-height: 22px; transition: opacity 0.3s ease; }
.pet-rec-loading-sub-global { font-size: 13px; color: #5A4F75; max-width: 320px; }
.pet-rec-loading-dots-global { display: inline-flex; gap: 4px; }
