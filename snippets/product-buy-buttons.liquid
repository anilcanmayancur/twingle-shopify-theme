<div class="sec" {{ block.shopify_attributes }}>

  {%- if block.settings.show_urgency -%}
    <div class="urgency" aria-live="polite">
      <span aria-hidden="true">🔥</span>
      <div class="urg-t">
        {{ block.settings.urgency_prefix }}
      </div>
      <div class="cd" aria-label="Geri sayım">
        <div class="cd-i"><span class="cd-n" id="petibiCdH">{{ block.settings.countdown_hours | prepend: '00' | slice: -2, 2 }}</span><span class="cd-l">{{ block.settings.hours_label }}</span></div>
        <div class="cd-i"><span class="cd-n" id="petibiCdM">{{ block.settings.countdown_minutes | prepend: '00' | slice: -2, 2 }}</span><span class="cd-l">{{ block.settings.minutes_label }}</span></div>
        <div class="cd-i"><span class="cd-n" id="petibiCdS">{{ block.settings.countdown_seconds | prepend: '00' | slice: -2, 2 }}</span><span class="cd-l">{{ block.settings.seconds_label }}</span></div>
      </div>
    </div>
  {%- endif -%}

  {%- form 'product', product, id: 'petibiProductForm', novalidate: 'novalidate' -%}
    <input type="hidden" name="id" id="petibiVariantId" value="{{ product.selected_or_first_available_variant.id }}">
    <input type="hidden" name="selling_plan" id="petibiSellingPlan" data-plan-id="" disabled>

    <div class="petibi-buy" id="petibiAddRow">

      <div class="petibi-buy-top">
        <div class="qty-wrap" role="group" aria-label="Miktar">
          <button type="button" class="qty-btn" onclick="petibiChangeQty(-1)" aria-label="Azalt">−</button>
          <input class="qty-n" id="petibiQty" name="quantity" value="1" type="number" min="1" max="99" readonly aria-label="Miktar">
          <button type="button" class="qty-btn" onclick="petibiChangeQty(1)" aria-label="Artır">+</button>
        </div>
        <div class="petibi-tools">
          <button type="button" class="btn-wl" id="petibiWlBtn" onclick="petibiToggleWishlist()" aria-label="Favorilere ekle" aria-pressed="false">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </button>
          <button type="button" class="btn-wl" id="petibiShareBtn" onclick="petibiShareProduct()" aria-label="Paylaş">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.59 13.51l6.83 3.98M15.41 6.51l-6.82 3.98"/></svg>
          </button>
        </div>
      </div>

      <button type="submit" class="btn-cart" id="petibiCartBtn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
        <span>{{ block.settings.add_to_cart_text }}</span>
      </button>

      <button type="button" class="btn-buynow" id="petibiBuyNowBtn">
        <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
        <span>Hemen Satın Al</span>
      </button>

      <div class="petibi-assure">
        <span class="pa-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="4" y="11" width="16" height="10" rx="2"/><path d="M8 11V7a4 4 0 0 1 8 0v4"/></svg>
          Güvenli ödeme
        </span>
        <span class="pa-dot">·</span>
        <span class="pa-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 8h11a5 5 0 0 1 0 10h-3"/><path d="M7 4 3 8l4 4"/></svg>
          14 gün koşulsuz iade
        </span>
        <span class="pa-dot">·</span>
        <span class="pa-item">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 6h11v9H3z"/><path d="M14 9h4l3 3v3h-7z"/><circle cx="7" cy="18" r="1.6"/><circle cx="17.5" cy="18" r="1.6"/></svg>
          Aynı gün kargo
        </span>
      </div>

    </div>
    <style>
      #petibiAddRow.petibi-buy{display:flex;flex-direction:column;gap:10px;}
      .petibi-buy-top{display:flex;align-items:center;gap:10px;}
      .petibi-buy-top .qty-wrap{flex:0 0 auto;}
      .petibi-buy-top .petibi-tools{margin-left:auto;display:flex;gap:8px;flex:0 0 auto;}
      #petibiCartBtn{width:100%!important;flex:0 0 auto!important;min-height:58px;border-radius:14px;}
      .btn-buynow{position:relative;overflow:hidden;width:100%;min-height:58px;box-sizing:border-box;display:flex;align-items:center;justify-content:center;gap:9px;padding:0 22px;border:none;border-radius:14px;cursor:pointer;font-weight:700;font-size:16px;letter-spacing:.3px;line-height:1;color:#fff;background:linear-gradient(135deg,#4A2A9E 0%,#2C1862 100%);box-shadow:0 8px 22px rgba(109,40,224,.45),inset 0 1px 0 rgba(255,255,255,.18);transition:transform .15s ease,box-shadow .15s ease;}
      .btn-buynow:hover{transform:translateY(-1px);box-shadow:0 12px 30px rgba(109,40,224,.6),inset 0 1px 0 rgba(255,255,255,.22);}
      .btn-buynow:active{transform:translateY(0);}
      .btn-buynow:disabled{opacity:.65;cursor:default;}
      .btn-buynow > svg,.btn-buynow > span{position:relative;z-index:1;}
      .btn-buynow::before{content:"";position:absolute;top:0;left:-60%;width:45%;height:100%;background:linear-gradient(115deg,transparent 0%,rgba(255,255,255,.42) 50%,transparent 100%);transform:skewX(-20deg);animation:petibiShine 3.4s ease-in-out infinite;}
      @keyframes petibiShine{0%{left:-60%}40%{left:130%}100%{left:130%}}
      @media (prefers-reduced-motion:reduce){.btn-buynow::before{display:none;}}
      .petibi-assure{display:flex;flex-wrap:wrap;align-items:center;justify-content:center;gap:6px 9px;margin-top:7px;font-size:12.5px;line-height:1.3;color:#6b6b73;font-weight:500;}
      .petibi-assure .pa-item{display:inline-flex;align-items:center;gap:5px;}
      .petibi-assure svg{width:14px;height:14px;flex:0 0 auto;opacity:.8;}
      .petibi-assure .pa-dot{opacity:.4;}
    </style>
    <script>
      (function(){
        var bn = document.getElementById('petibiBuyNowBtn');
        if(!bn) return;
        bn.addEventListener('click', function(){
          bn.disabled = true;
          var sp = bn.querySelector('span');
          var ot = sp ? sp.textContent : '';
          if(sp) sp.textContent = 'Yönlendiriliyor…';
          fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              id: parseInt(document.getElementById('petibiVariantId').value),
              quantity: parseInt(document.getElementById('petibiQty').value)
            })
          })
          .then(function(){ window.location.href = '/checkout'; })
          .catch(function(){ bn.disabled = false; if(sp) sp.textContent = ot; });
        });
      })();
    </script>
  {%- endform -%}

</div>

{%- comment -%} Mobile sticky add-to-cart bar (rendered once, controlled by main form) {%- endcomment -%}
<div class="petibi-stickybar" id="petibiStickyBar" aria-hidden="true">
  <div class="psb-info">
    {%- if product.featured_image -%}
      <img src="{{ product.featured_image | image_url: width: 80 }}" alt="" class="psb-thumb" loading="lazy" width="40" height="40">
    {%- endif -%}
    <div class="psb-text">
      <span class="psb-price" id="petibiStickyPrice">{{ product.selected_or_first_available_variant.price | money }}</span>
      {%- if product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price -%}
        <span class="psb-old">{{ product.selected_or_first_available_variant.compare_at_price | money }}</span>
      {%- endif -%}
    </div>
  </div>
  <button type="button" class="psb-btn" id="petibiStickyBtn" aria-label="{{ block.settings.add_to_cart_text }}">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.7 13.4a2 2 0 0 0 2 1.6h9.7a2 2 0 0 0 2-1.6L23 6H6"/></svg>
    <span>{{ block.settings.add_to_cart_text }}</span>
  </button>
</div>

<script>
  (function() {
    var h = {{ block.settings.countdown_hours }};
    var m = {{ block.settings.countdown_minutes }};
    var s = {{ block.settings.countdown_seconds }};
    setInterval(function() {
      s--;
      if (s < 0) { s = 59; m--; }
      if (m < 0) { m = 59; h--; }
      if (h < 0) h = 23;
      var hEl = document.getElementById('petibiCdH');
      var mEl = document.getElementById('petibiCdM');
      var sEl = document.getElementById('petibiCdS');
      if (hEl) hEl.textContent = String(h).padStart(2, '0');
      if (mEl) mEl.textContent = String(m).padStart(2, '0');
      if (sEl) sEl.textContent = String(s).padStart(2, '0');
    }, 1000);

    var vMin = {{ block.settings.viewers_min }};
    var vMax = {{ block.settings.viewers_max }};
    setInterval(function() {
      var el = document.getElementById('petibiViewers');
      if (!el) return;
      var cur = parseInt(el.textContent) || {{ block.settings.viewers_start }};
      el.textContent = Math.max(vMin, Math.min(vMax, cur + (Math.random() > 0.5 ? 1 : -1)));
    }, 4000);
  })();

  function petibiChangeQty(delta) {
    var input = document.getElementById('petibiQty');
    input.value = Math.max(1, Math.min(99, parseInt(input.value) + delta));
  }

  var petibiWlActive = false;
  function petibiToggleWishlist() {
    petibiWlActive = !petibiWlActive;
    var btn = document.getElementById('petibiWlBtn');
    btn.classList.toggle('act', petibiWlActive);
    btn.setAttribute('aria-pressed', petibiWlActive ? 'true' : 'false');
    petibiShowToast(
      petibiWlActive ? '♥' : '♡',
      petibiWlActive ? '{{ block.settings.wishlist_added }}' : '{{ block.settings.wishlist_removed }}'
    );
  }

  function petibiShareProduct() {
    var url = window.location.href;
    var title = {{ product.title | json }};
    if (navigator.share) {
      navigator.share({ title: title, url: url }).catch(function() {});
    } else if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(url).then(function() {
        if (typeof petibiShowToast === 'function') petibiShowToast('🔗', 'Bağlantı kopyalandı');
      });
    } else {
      window.prompt('Ürün bağlantısı:', url);
    }
  }

  (function() {
    var form = document.getElementById('petibiProductForm');
    var addRow = document.getElementById('petibiAddRow');
    var stickyBar = document.getElementById('petibiStickyBar');
    var stickyBtn = document.getElementById('petibiStickyBtn');
    if (!form || !addRow) return;

    function doAddToCart() {
      var btn = document.getElementById('petibiCartBtn');
      var sbtn = stickyBtn;
      var originalLabel = btn ? btn.querySelector('span') : null;
      var originalText = originalLabel ? originalLabel.textContent : '';
      if (btn) { btn.classList.add('added'); btn.disabled = true; if (originalLabel) originalLabel.textContent = '✓ {{ block.settings.added_text }}'; }
      if (sbtn) { sbtn.classList.add('added'); sbtn.disabled = true; var sl = sbtn.querySelector('span'); if (sl) sl.textContent = '✓ {{ block.settings.added_text }}'; }

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: parseInt(document.getElementById('petibiVariantId').value),
          quantity: parseInt(document.getElementById('petibiQty').value)
        })
      })
      .then(function(r) { return r.json(); })
      .then(function(item) {
        if (typeof petibiShowToast === 'function') {
          petibiShowToast('✓', (item.product_title || '{{ product.title | escape }}') + ' sepete eklendi');
        }
        document.dispatchEvent(new CustomEvent('twingle:cart:refresh'));
      })
      .catch(function() {})
      .finally(function() {
        setTimeout(function() {
          if (btn) { btn.classList.remove('added'); btn.disabled = false; if (originalLabel) originalLabel.textContent = originalText; }
          if (sbtn) { sbtn.classList.remove('added'); sbtn.disabled = false; var sl = sbtn.querySelector('span'); if (sl) sl.textContent = '{{ block.settings.add_to_cart_text }}'; }
        }, 1600);
      });
    }

    form.addEventListener('submit', function(e) { e.preventDefault(); doAddToCart(); });
    if (stickyBtn) stickyBtn.addEventListener('click', doAddToCart);

    if (stickyBar && 'IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            stickyBar.classList.remove('show');
            stickyBar.setAttribute('aria-hidden', 'true');
          } else if (entry.boundingClientRect.top < 0) {
            stickyBar.classList.add('show');
            stickyBar.setAttribute('aria-hidden', 'false');
          } else {
            stickyBar.classList.remove('show');
            stickyBar.setAttribute('aria-hidden', 'true');
          }
        });
      }, { threshold: 0, rootMargin: '0px 0px -40px 0px' });
      io.observe(addRow);
    }
  })();
</script>

{%- comment -%} Ürün yapılandırılmış verisi (Google rich snippet) {%- endcomment -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "Product",
  "name": {{ product.title | json }},
  {% if product.featured_image %}"image": [{{ product.featured_image | image_url: width: 1200 | prepend: 'https:' | json }}],{% endif %}
  "description": {{ product.description | default: product.title | strip_html | truncate: 300 | json }},
  {% if product.selected_or_first_available_variant.sku != blank %}"sku": {{ product.selected_or_first_available_variant.sku | json }},{% endif %}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | default: shop.name | json }}
  },
  "offers": {
    "@type": "Offer",
    "url": {{ shop.url | append: product.url | json }},
    "priceCurrency": {{ shop.currency | json }},
    "price": "{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}",
    "availability": "{% if product.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
    "itemCondition": "https://schema.org/NewCondition"
  }
}
</script>