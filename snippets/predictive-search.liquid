{%- comment -%}
  Twingle Predictive Search
  -------------------------
  Header'daki arama input'una bağlanır. Yazdıkça /search/suggest.json
  endpoint'inden ürün önerileri çeker, panelde gösterir.

  Bir input'a bağlamak için:
    data-twingle-predictive-search
{%- endcomment -%}

<style>
  .twingle-ps {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(100% + 8px);
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 20px 48px -16px rgba(20, 14, 40, 0.28), 0 4px 12px -4px rgba(20, 14, 40, 0.08);
    border: 1px solid rgba(123, 63, 242, 0.08);
    z-index: 9996;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-6px);
    pointer-events: none;
    transition: opacity 0.18s ease, transform 0.2s ease;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, sans-serif;
    max-height: min(560px, 80vh);
    display: flex;
    flex-direction: column;
  }
  .twingle-ps.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .twingle-ps__inner {
    overflow-y: auto;
    overscroll-behavior: contain;
    padding: 8px 0;
  }

  .twingle-ps__section { padding: 8px 14px 6px; }
  .twingle-ps__section + .twingle-ps__section {
    border-top: 1px solid rgba(123, 63, 242, 0.06);
    margin-top: 6px;
    padding-top: 12px;
  }
  .twingle-ps__heading {
    font-size: 10.5px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8B8299;
    font-weight: 800;
    margin: 0 0 8px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }

  .twingle-ps__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  .twingle-ps__chip {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding: 6px 10px;
    background: #faf7ff;
    color: #5a4f75;
    border-radius: 8px;
    font-size: 12px;
    font-weight: 600;
    text-decoration: none;
    border: 1px solid rgba(123, 63, 242, 0.1);
    transition: background 0.15s ease, color 0.15s ease, border-color 0.15s ease;
    cursor: pointer;
  }
  .twingle-ps__chip:hover {
    background: rgba(123, 63, 242, 0.08);
    color: #7b3ff2;
    border-color: rgba(123, 63, 242, 0.3);
  }

  .twingle-ps__queries {
    display: flex;
    flex-direction: column;
    gap: 1px;
  }
  .twingle-ps__query {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 10px;
    border-radius: 8px;
    text-decoration: none;
    color: #1f1342;
    font-size: 13px;
    cursor: pointer;
    transition: background 0.12s ease;
  }
  .twingle-ps__query:hover,
  .twingle-ps__query[aria-selected="true"] { background: #f5f3fa; }
  .twingle-ps__query-icon { color: #8B8299; flex-shrink: 0; }
  .twingle-ps__query-icon svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2; }
  .twingle-ps__query-text mark { background: rgba(123, 63, 242, 0.16); color: #7b3ff2; padding: 0 2px; border-radius: 3px; font-weight: 700; }

  .twingle-ps__products {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .twingle-ps__product {
    display: grid;
    grid-template-columns: 44px 1fr auto;
    gap: 10px;
    align-items: center;
    padding: 8px;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.12s ease;
  }
  .twingle-ps__product:hover,
  .twingle-ps__product[aria-selected="true"] { background: #f5f3fa; }
  .twingle-ps__product-img {
    width: 44px;
    height: 44px;
    border-radius: 8px;
    background: #faf7ff;
    object-fit: contain;
    padding: 3px;
    border: 1px solid rgba(123, 63, 242, 0.06);
    mix-blend-mode: multiply;
  }
  .twingle-ps__product-info { min-width: 0; }
  .twingle-ps__product-title {
    font-size: 12.5px;
    font-weight: 600;
    color: #1f1342;
    line-height: 1.3;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .twingle-ps__product-vendor { font-size: 10.5px; color: #8B8299; text-transform: uppercase; letter-spacing: 0.04em; font-weight: 700; margin-top: 2px; }
  .twingle-ps__product-price {
    font-size: 13px;
    font-weight: 800;
    color: #7b3ff2;
    letter-spacing: -0.02em;
    flex-shrink: 0;
    text-align: right;
    white-space: nowrap;
  }
  .twingle-ps__product-compare { display: block; font-size: 10.5px; color: #8B8299; text-decoration: line-through; font-weight: 600; }

  .twingle-ps__empty {
    padding: 28px 16px;
    text-align: center;
    color: #5a4f75;
    font-size: 13px;
  }
  .twingle-ps__empty strong { color: #1f1342; }

  .twingle-ps__loading {
    padding: 22px;
    display: flex;
    justify-content: center;
  }
  .twingle-ps__spinner {
    width: 20px; height: 20px;
    border: 2.5px solid rgba(123, 63, 242, 0.18);
    border-top-color: #7b3ff2;
    border-radius: 50%;
    animation: tw-ps-spin 0.6s linear infinite;
  }
  @keyframes tw-ps-spin { to { transform: rotate(360deg); } }

  .twingle-ps__footer {
    border-top: 1px solid rgba(123, 63, 242, 0.06);
    padding: 10px 14px;
    background: #faf7ff;
    flex-shrink: 0;
  }
  .twingle-ps__view-all {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 8px 12px;
    border-radius: 8px;
    background: #fff;
    border: 1.5px solid rgba(123, 63, 242, 0.18);
    color: #1f1342;
    font-size: 12.5px;
    font-weight: 700;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.15s ease, border-color 0.15s ease;
    font-family: inherit;
  }
  .twingle-ps__view-all:hover { background: #faf7ff; border-color: rgba(123, 63, 242, 0.35); color: #7b3ff2; }
  .twingle-ps__view-all svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.2; }

  @media (max-width: 749px) {
    .twingle-ps { max-height: 70vh; }
  }
</style>

<template id="TwinglePredictiveSearchTpl">
  <div class="twingle-ps" role="listbox">
    <div class="twingle-ps__inner" data-ps-content></div>
    <div class="twingle-ps__footer" data-ps-footer hidden>
      <button type="button" class="twingle-ps__view-all" data-ps-view-all>
        <span>Tüm sonuçları gör</span>
        <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</template>

<script>
(function () {
  if (window.__twinglePredictiveSearchInit) return;
  window.__twinglePredictiveSearchInit = true;

  var moneyFormat = {{ shop.money_format | json }};

  function formatMoney(cents) {
    if (typeof cents !== 'number') return '';
    var value = (cents / 100).toFixed(2);
    var parts = value.split('.');
    var intPart = parts[0].replace(/\B(?=(\d{3})+(?!\d))/g, '.');
    var formatted = intPart + ',' + parts[1];
    if (moneyFormat && /\{\{.*\}\}/.test(moneyFormat)) {
      return moneyFormat.replace(/\{\{\s*amount[^}]*\}\}/, formatted);
    }
    return formatted + ' ₺';
  }

  function escapeHtml(str) {
    return String(str || '').replace(/[&<>"']/g, function (c) {
      return { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c];
    });
  }

  function highlight(text, query) {
    if (!query) return escapeHtml(text);
    var safe = escapeHtml(text);
    var safeQuery = escapeHtml(query).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
    if (!safeQuery.trim()) return safe;
    return safe.replace(new RegExp('(' + safeQuery + ')', 'gi'), '<mark>$1</mark>');
  }

  function ensurePanel(input) {
    if (input.__twPsPanel) return input.__twPsPanel;
    var container = input.closest('.twingle-ps-anchor') || input.parentElement;
    if (container && getComputedStyle(container).position === 'static') {
      container.style.position = 'relative';
    }
    var tpl = document.getElementById('TwinglePredictiveSearchTpl');
    if (!tpl) return null;
    var node = tpl.content.firstElementChild.cloneNode(true);
    container.appendChild(node);
    input.__twPsPanel = node;
    return node;
  }

  function close(input) {
    var panel = input.__twPsPanel;
    if (panel) panel.classList.remove('is-open');
  }

  function show(input, html) {
    var panel = ensurePanel(input);
    if (!panel) return;
    var content = panel.querySelector('[data-ps-content]');
    content.innerHTML = html;
    panel.classList.add('is-open');
  }

  function renderInitial(input) {
    var trends = (input.dataset.psTrends || '').split(',').map(function (t) { return t.trim(); }).filter(Boolean);
    var html = '';
    if (trends.length) {
      html += '<div class="twingle-ps__section">';
      html += '<h6 class="twingle-ps__heading"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>Popüler Aramalar</h6>';
      html += '<div class="twingle-ps__chips">';
      trends.slice(0, 10).forEach(function (t) {
        html += '<a href="/search?q=' + encodeURIComponent(t) + '" class="twingle-ps__chip">' + escapeHtml(t) + '</a>';
      });
      html += '</div></div>';
    }
    if (!html) html = '<div class="twingle-ps__empty">Aramaya başla, hızlı öneriler burada belirsin.</div>';
    show(input, html);
    var panel = input.__twPsPanel;
    if (panel) panel.querySelector('[data-ps-footer]').hidden = true;
  }

  function renderResults(input, query, data) {
    var products = (data.resources && data.resources.results && data.resources.results.products) || [];
    var queries = (data.resources && data.resources.results && data.resources.results.queries) || [];

    var html = '';

    if (queries.length) {
      html += '<div class="twingle-ps__section">';
      html += '<h6 class="twingle-ps__heading"><svg viewBox="0 0 24 24" width="11" height="11" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>Öneriler</h6>';
      html += '<div class="twingle-ps__queries">';
      queries.slice(0, 4).forEach(function (q) {
        var text = q.text || q;
        html += '<a href="/search?q=' + encodeURIComponent(text) + '" class="twingle-ps__query" role="option">';
        html += '<span class="twingle-ps__query-icon"><svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg></span>';
        html += '<span class="twingle-ps__query-text">' + highlight(text, query) + '</span>';
        html += '</a>';
      });
      html += '</div></div>';
    }

    if (products.length) {
      html += '<div class="twingle-ps__section">';
      html += '<h6 class="twingle-ps__heading">Ürünler</h6>';
      html += '<div class="twingle-ps__products">';
      products.slice(0, 6).forEach(function (p) {
        var img = p.featured_image || (p.image && p.image.url) || p.image || '';
        var price = formatMoney(p.price);
        var compare = '';
        if (p.compare_at_price && p.compare_at_price > p.price) {
          compare = '<span class="twingle-ps__product-compare">' + formatMoney(p.compare_at_price) + '</span>';
        }
        html += '<a href="' + (p.url || ('/products/' + p.handle)) + '" class="twingle-ps__product" role="option">';
        html += img ? '<img class="twingle-ps__product-img" src="' + img + '" alt="' + escapeHtml(p.title) + '" loading="lazy">' : '<div class="twingle-ps__product-img"></div>';
        html += '<div class="twingle-ps__product-info">';
        html += '<p class="twingle-ps__product-title">' + highlight(p.title, query) + '</p>';
        if (p.vendor) html += '<span class="twingle-ps__product-vendor">' + escapeHtml(p.vendor) + '</span>';
        html += '</div>';
        html += '<div class="twingle-ps__product-price">' + price + compare + '</div>';
        html += '</a>';
      });
      html += '</div></div>';
    }

    if (!html) {
      html = '<div class="twingle-ps__empty"><strong>"' + escapeHtml(query) + '"</strong> için sonuç bulunamadı.<br>Farklı bir kelime dene.</div>';
    }

    show(input, html);
    var panel = input.__twPsPanel;
    if (panel) {
      var footer = panel.querySelector('[data-ps-footer]');
      footer.hidden = !(queries.length || products.length);
      var btn = footer.querySelector('[data-ps-view-all]');
      if (btn) {
        btn.onclick = function () {
          var form = input.closest('form');
          if (form) form.submit();
        };
      }
    }
  }

  function renderLoading(input) {
    show(input, '<div class="twingle-ps__loading"><span class="twingle-ps__spinner"></span></div>');
    var panel = input.__twPsPanel;
    if (panel) panel.querySelector('[data-ps-footer]').hidden = true;
  }

  function search(input, query) {
    var url = '/search/suggest.json?q=' + encodeURIComponent(query) +
              '&resources[type]=product,query' +
              '&resources[limit]=6&resources[limit_scope]=each';
    return fetch(url, { headers: { 'Accept': 'application/json' } })
      .then(function (r) { return r.json(); });
  }

  function attach(input) {
    if (input.__twPsBound) return;
    input.__twPsBound = true;

    var debounceId;
    var lastQuery = '';

    input.addEventListener('focus', function () {
      var q = input.value.trim();
      if (q.length < 2) renderInitial(input);
      else renderResults(input, q, { resources: { results: {} } });
    });

    input.addEventListener('input', function () {
      var q = input.value.trim();
      if (q === lastQuery) return;
      lastQuery = q;
      clearTimeout(debounceId);
      if (q.length < 2) {
        renderInitial(input);
        return;
      }
      renderLoading(input);
      debounceId = setTimeout(function () {
        search(input, q).then(function (data) {
          if (input.value.trim() === q) renderResults(input, q, data);
        }).catch(function () {
          show(input, '<div class="twingle-ps__empty">Bir sorun oluştu. Tekrar dene.</div>');
        });
      }, 220);
    });

    input.addEventListener('blur', function () {
      setTimeout(function () { close(input); }, 180);
    });

    input.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') close(input);
    });
  }

  function init() {
    document.querySelectorAll('[data-twingle-predictive-search]').forEach(attach);
  }

  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
  else init();

  document.addEventListener('shopify:section:load', init);
})();
</script>
