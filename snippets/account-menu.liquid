{%- comment -%}
  Twingle Account Menu
  --------------------
  Header'daki üyelik/hesap butonuna popover (desktop) + bottom-sheet (mobile).
  Açmak için butona ekle:
    data-twingle-account-toggle
{%- endcomment -%}

<style>
  .twingle-account {
    position: fixed;
    inset: 0;
    z-index: 9997;
    display: none;
    pointer-events: none;
  }
  .twingle-account.is-open {
    display: block;
    pointer-events: auto;
  }
  .twingle-account__backdrop {
    position: absolute;
    inset: 0;
    background: transparent;
  }
  .twingle-account__panel {
    position: absolute;
    background: #fff;
    border-radius: 14px;
    box-shadow: 0 20px 48px -16px rgba(20, 14, 40, 0.28), 0 4px 12px -4px rgba(20, 14, 40, 0.08);
    border: 1px solid rgba(123, 63, 242, 0.08);
    width: min(320px, calc(100vw - 24px));
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Inter, Roboto, sans-serif;
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.18s ease, transform 0.22s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  .twingle-account.is-open .twingle-account__panel { opacity: 1; transform: translateY(0); }

  @media (max-width: 749px) {
    .twingle-account__backdrop { background: rgba(20, 14, 40, 0.45); }
    .twingle-account__panel {
      bottom: 0 !important;
      top: auto !important;
      left: 0 !important;
      right: 0 !important;
      width: 100% !important;
      max-width: 100%;
      border-radius: 16px 16px 0 0;
      transform: translateY(100%);
    }
    .twingle-account.is-open .twingle-account__panel { transform: translateY(0); }
  }

  .twingle-account__header {
    padding: 18px 18px 14px;
    background: linear-gradient(135deg, #faf7ff 0%, #f3edff 100%);
    border-bottom: 1px solid rgba(123, 63, 242, 0.08);
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .twingle-account__avatar {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: linear-gradient(135deg, #7b3ff2, #5b2fb2);
    color: #fff;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 15px;
    font-weight: 800;
    letter-spacing: -0.02em;
    flex-shrink: 0;
  }
  .twingle-account__avatar svg { width: 18px; height: 18px; stroke: currentColor; fill: none; stroke-width: 2; }
  .twingle-account__greet {
    flex: 1;
    min-width: 0;
  }
  .twingle-account__greet-title { font-size: 14px; font-weight: 800; color: #1f1342; margin: 0; line-height: 1.2; }
  .twingle-account__greet-sub { font-size: 12px; color: #5a4f75; margin: 2px 0 0; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

  .twingle-account__cta {
    display: flex;
    gap: 8px;
    margin-top: 10px;
  }
  .twingle-account__btn {
    flex: 1;
    text-align: center;
    padding: 10px 12px;
    border-radius: 10px;
    font-size: 12.5px;
    font-weight: 700;
    text-decoration: none;
    border: 1.5px solid transparent;
    transition: filter 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    font-family: inherit;
    cursor: pointer;
  }
  .twingle-account__btn--primary {
    background: linear-gradient(135deg, #7b3ff2, #5b2fb2);
    color: #fff;
    box-shadow: 0 4px 12px -4px rgba(123, 63, 242, 0.35);
  }
  .twingle-account__btn--primary:hover { filter: brightness(1.05); }
  .twingle-account__btn--ghost {
    background: #fff;
    color: #1f1342;
    border-color: rgba(123, 63, 242, 0.2);
  }
  .twingle-account__btn--ghost:hover { background: #faf7ff; border-color: rgba(123, 63, 242, 0.35); }

  .twingle-account__list {
    list-style: none;
    margin: 0;
    padding: 8px;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .twingle-account__link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 11px 12px;
    border-radius: 10px;
    text-decoration: none;
    color: #1f1342;
    font-size: 13.5px;
    font-weight: 600;
    transition: background 0.15s ease, color 0.15s ease;
    border: none;
    background: none;
    cursor: pointer;
    width: 100%;
    text-align: left;
    font-family: inherit;
  }
  .twingle-account__link:hover { background: #f5f3fa; color: #7b3ff2; }
  .twingle-account__link-icon {
    width: 30px;
    height: 30px;
    border-radius: 8px;
    background: #f5f3fa;
    color: #7b3ff2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.15s ease;
  }
  .twingle-account__link:hover .twingle-account__link-icon { background: rgba(123, 63, 242, 0.12); }
  .twingle-account__link-icon svg { width: 15px; height: 15px; stroke: currentColor; fill: none; stroke-width: 1.9; stroke-linecap: round; stroke-linejoin: round; }
  .twingle-account__link-text { flex: 1; min-width: 0; }
  .twingle-account__link-chev { color: #c0b9d1; flex-shrink: 0; transition: transform 0.2s ease, color 0.2s ease; }
  .twingle-account__link:hover .twingle-account__link-chev { transform: translateX(2px); color: #7b3ff2; }
  .twingle-account__link-chev svg { width: 14px; height: 14px; stroke: currentColor; fill: none; stroke-width: 2.2; }

  .twingle-account__divider {
    height: 1px;
    background: rgba(123, 63, 242, 0.08);
    margin: 6px 8px;
    border: 0;
  }

  .twingle-account__handle {
    display: none;
  }
  @media (max-width: 749px) {
    .twingle-account__handle {
      display: block;
      width: 40px;
      height: 4px;
      border-radius: 100px;
      background: #d8d0e8;
      margin: 8px auto 4px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .twingle-account__panel { transition: none !important; }
  }
</style>

<div id="TwingleAccountMenu" class="twingle-account" role="dialog" aria-modal="false" aria-labelledby="TwingleAccountTitle" aria-hidden="true">
  <div class="twingle-account__backdrop" data-twingle-account-close></div>
  <div class="twingle-account__panel" role="menu">
    <span class="twingle-account__handle" aria-hidden="true"></span>

    <div class="twingle-account__header">
      <span class="twingle-account__avatar">
        {% if customer %}
          {{ customer.first_name | default: customer.email | slice: 0, 1 | upcase | default: 'U' }}
        {% else %}
          <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
        {% endif %}
      </span>
      <div class="twingle-account__greet">
        {% if customer %}
          <p id="TwingleAccountTitle" class="twingle-account__greet-title">Merhaba, {{ customer.first_name | default: 'Hoş geldin' }}</p>
          <p class="twingle-account__greet-sub">{{ customer.email }}</p>
        {% else %}
          <p id="TwingleAccountTitle" class="twingle-account__greet-title">Merhaba 👋</p>
          <p class="twingle-account__greet-sub">Hesabınla daha hızlı alışveriş yap.</p>
        {% endif %}
      </div>
    </div>

    {% unless customer %}
      <div style="padding: 12px 14px 0;">
        <div class="twingle-account__cta">
          <a href="{{ routes.account_login_url }}" class="twingle-account__btn twingle-account__btn--primary">Giriş Yap</a>
          <a href="{{ routes.account_register_url }}" class="twingle-account__btn twingle-account__btn--ghost">Üye Ol</a>
        </div>
      </div>
    {% endunless %}

    <ul class="twingle-account__list">
      {% if customer %}
        <li>
          <a href="{{ routes.account_url }}" class="twingle-account__link">
            <span class="twingle-account__link-icon">
              <svg viewBox="0 0 24 24"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </span>
            <span class="twingle-account__link-text">Hesabım</span>
            <span class="twingle-account__link-chev"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
          </a>
        </li>
        <li>
          <a href="{{ routes.account_url }}#orders" class="twingle-account__link">
            <span class="twingle-account__link-icon">
              <svg viewBox="0 0 24 24"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
            </span>
            <span class="twingle-account__link-text">Siparişlerim</span>
            <span class="twingle-account__link-chev"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
          </a>
        </li>
        <li>
          <a href="{{ routes.account_addresses_url }}" class="twingle-account__link">
            <span class="twingle-account__link-icon">
              <svg viewBox="0 0 24 24"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </span>
            <span class="twingle-account__link-text">Adreslerim</span>
            <span class="twingle-account__link-chev"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
          </a>
        </li>
      {% endif %}
      <li>
        <a href="/pages/wishlist" class="twingle-account__link">
          <span class="twingle-account__link-icon">
            <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </span>
          <span class="twingle-account__link-text">Favorilerim</span>
          <span class="twingle-account__link-chev"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
        </a>
      </li>
      <li>
        <a href="/pages/iletisim" class="twingle-account__link">
          <span class="twingle-account__link-icon">
            <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          </span>
          <span class="twingle-account__link-text">Yardım & Destek</span>
          <span class="twingle-account__link-chev"><svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg></span>
        </a>
      </li>
      {% if customer %}
        <li><hr class="twingle-account__divider"></li>
        <li>
          <a href="{{ routes.account_logout_url }}" class="twingle-account__link">
            <span class="twingle-account__link-icon" style="background:#fdecec;color:#b91c1c;">
              <svg viewBox="0 0 24 24"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </span>
            <span class="twingle-account__link-text" style="color:#b91c1c;">Çıkış Yap</span>
          </a>
        </li>
      {% endif %}
    </ul>
  </div>
</div>

<script>
(function () {
  if (window.__twingleAccountInit) return;
  window.__twingleAccountInit = true;

  var menu = document.getElementById('TwingleAccountMenu');
  if (!menu) return;
  var panel = menu.querySelector('.twingle-account__panel');
  var currentTrigger = null;

  function positionPanel() {
    if (!currentTrigger || window.innerWidth < 750) {
      panel.style.top = '';
      panel.style.left = '';
      panel.style.right = '';
      return;
    }
    var rect = currentTrigger.getBoundingClientRect();
    var panelWidth = panel.offsetWidth || 320;
    var top = rect.bottom + 8;
    var right = Math.max(12, window.innerWidth - rect.right);
    panel.style.top = top + 'px';
    panel.style.right = right + 'px';
    panel.style.left = 'auto';
  }

  function open(trigger) {
    currentTrigger = trigger;
    if (trigger && trigger.setAttribute) trigger.setAttribute('aria-expanded', 'true');
    menu.classList.add('is-open');
    menu.setAttribute('aria-hidden', 'false');
    positionPanel();
    requestAnimationFrame(positionPanel);
  }

  function close() {
    if (currentTrigger && currentTrigger.setAttribute) currentTrigger.setAttribute('aria-expanded', 'false');
    menu.classList.remove('is-open');
    menu.setAttribute('aria-hidden', 'true');
    currentTrigger = null;
  }

  document.addEventListener('click', function (e) {
    var trigger = e.target.closest('[data-twingle-account-toggle]');
    if (trigger) {
      e.preventDefault();
      if (menu.classList.contains('is-open') && currentTrigger === trigger) {
        close();
      } else {
        open(trigger);
      }
      return;
    }
    if (e.target.closest('[data-twingle-account-close]') || (menu.classList.contains('is-open') && !e.target.closest('.twingle-account__panel') && !e.target.closest('[data-twingle-account-toggle]'))) {
      close();
    }
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && menu.classList.contains('is-open')) close();
  });

  window.addEventListener('resize', positionPanel);
  window.addEventListener('scroll', positionPanel, { passive: true });
})();
</script>
