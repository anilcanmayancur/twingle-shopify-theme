{%- comment -%}
  Pet Recommender Floating Action Button (FAB)
  - Sağ altta sabit duran ikon
  - Üzerinde pet-recommender modal'ı mount edilmişse (homepage) onu açar
  - Diğer sayfalarda /#pet-recommender'a yönlendirir; homepage yüklenince auto-open olur
{%- endcomment -%}

<style>
  .tw-pet-fab {
    position: fixed;
    right: 20px;
    bottom: 22px;
    z-index: 9990;
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 18px 12px 14px;
    background: linear-gradient(135deg, #7C3AED 0%, #5B2FB2 100%);
    color: #fff !important;
    text-decoration: none !important;
    border: none;
    border-radius: 999px;
    font: inherit;
    font-size: 13.5px;
    font-weight: 700;
    line-height: 1;
    box-shadow: 0 12px 28px -8px rgba(124, 58, 237, 0.55), 0 2px 8px -2px rgba(20, 14, 40, 0.18);
    cursor: pointer;
    transition: transform 0.22s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.22s ease, filter 0.18s ease;
    font-family: inherit;
  }
  .tw-pet-fab:hover {
    transform: translateY(-2px);
    filter: brightness(1.06);
    box-shadow: 0 18px 36px -10px rgba(124, 58, 237, 0.6), 0 4px 12px -2px rgba(20, 14, 40, 0.22);
  }
  .tw-pet-fab:active { transform: translateY(0); }

  .tw-pet-fab__icon {
    width: 28px;
    height: 28px;
    background: rgba(255, 255, 255, 0.18);
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .tw-pet-fab__icon svg { width: 16px; height: 16px; }

  /* Pulse halo */
  .tw-pet-fab::before {
    content: "";
    position: absolute;
    inset: -2px;
    border-radius: inherit;
    background: linear-gradient(135deg, #7C3AED, #5B2FB2);
    z-index: -1;
    filter: blur(8px);
    opacity: 0.35;
    animation: twFabPulse 3s ease-in-out infinite;
  }
  @keyframes twFabPulse {
    0%, 100% { opacity: 0.25; transform: scale(1); }
    50%      { opacity: 0.5;  transform: scale(1.04); }
  }

  /* Mobile: hide label, show icon only */
  @media (max-width: 640px) {
    .tw-pet-fab {
      right: 14px;
      bottom: 14px;
      padding: 0;
      width: 52px;
      height: 52px;
      border-radius: 999px;
      justify-content: center;
      gap: 0;
    }
    .tw-pet-fab__label { display: none; }
    .tw-pet-fab__icon { background: transparent; width: auto; height: auto; }
    .tw-pet-fab__icon svg { width: 22px; height: 22px; }
  }

  /* Don't cover the mobile sticky add-to-cart bar */
  body:has(.petibi-stickybar.show) .tw-pet-fab,
  body.tw-fab-lifted .tw-pet-fab {
    bottom: 88px;
  }
  @media (max-width: 640px) {
    body:has(.petibi-stickybar.show) .tw-pet-fab,
    body.tw-fab-lifted .tw-pet-fab {
      bottom: 82px;
      right: 10px;
      width: 46px;
      height: 46px;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .tw-pet-fab::before { animation: none; }
    .tw-pet-fab { transition: none; }
  }
</style>

<button type="button"
   class="tw-pet-fab pet-rec-trigger"
   data-pet-recommender
   data-tw-pet-fab
   aria-label="Petim İçin Öneri">
  <span class="tw-pet-fab__icon" aria-hidden="true">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .962 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.962 0z"/>
      <path d="M20 3v4"/><path d="M22 5h-4"/>
    </svg>
  </span>
  <span class="tw-pet-fab__label">Petim İçin Öneri</span>
</button>

<script>
(function() {
  // Auto-open recommender on #pet-recommender / #pet-quiz hash (any page)
  function tryAutoOpen() {
    var hash = (window.location.hash || '').toLowerCase();
    if (hash !== '#pet-recommender' && hash !== '#pet-quiz') return;
    function fire() {
      if (window.TwinklePetRecommender && typeof window.TwinklePetRecommender.open === 'function') {
        window.TwinklePetRecommender.open();
      } else {
        var t = document.querySelector('.pet-rec-trigger,[data-pet-recommender]');
        if (t) t.click();
      }
      if (history.replaceState) history.replaceState(null, '', window.location.pathname + window.location.search);
    }
    setTimeout(fire, 60);
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', tryAutoOpen);
  } else {
    tryAutoOpen();
  }
  window.addEventListener('hashchange', tryAutoOpen);

  // Lift the FAB above the mobile sticky add-to-cart bar when it's visible.
  function watchStickyBar() {
    var bar = document.querySelector('.petibi-stickybar');
    if (!bar) return;
    function sync() {
      document.body.classList.toggle('tw-fab-lifted', bar.classList.contains('show'));
    }
    sync();
    new MutationObserver(sync).observe(bar, { attributes: true, attributeFilter: ['class'] });
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', watchStickyBar);
  } else {
    watchStickyBar();
  }
})();
</script>
