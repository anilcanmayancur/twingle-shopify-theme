{%- comment -%}
  Top-of-page shipping highlight (rendered right under price).
  Uses delivery_info block settings (row1 = hızlı kargo, row3 = ücretsiz kargo).
{%- endcomment -%}

{%- if block.settings.row1_title != blank or block.settings.row3_title != blank -%}
  <div class="ship-hl" aria-label="Kargo bilgisi">
    {%- if block.settings.row1_title != blank -%}
      <div class="ship-hl-item">
        <span class="shi-ico" aria-hidden="true">{{ block.settings.row1_icon }}</span>
        <span class="shi-text">
          <strong>{{ block.settings.row1_title }}</strong>
          {%- if block.settings.row1_desc != blank -%}<span class="shi-d"> · {{ block.settings.row1_desc }}</span>{%- endif -%}
        </span>
      </div>
    {%- endif -%}
    {%- if block.settings.row3_title != blank -%}
      <div class="ship-hl-item">
        <span class="shi-ico" aria-hidden="true">{{ block.settings.row3_icon }}</span>
        <span class="shi-text">
          <strong>{{ block.settings.row3_title }}</strong>
          {%- if block.settings.row3_desc != blank -%}<span class="shi-d"> · {{ block.settings.row3_desc }}</span>{%- endif -%}
        </span>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}
