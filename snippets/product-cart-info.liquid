{%- comment -%}
  Cart-info: 2 yan yana kutu.
  Sol  -> "Aynı Gün Ücretsiz Kargo" + tahmini teslimat alt yazı
  Sağ  -> "Stokta Var" + adet kaldı vurgusu
  Veriler delivery_info block ayarlarından (row3 başlık, row2 tahmini, row4 stok).
{%- endcomment -%}

<div class="cart-info" aria-live="polite">

  <div class="ci-box">
    <span class="ci-ico" aria-hidden="true">
      <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 17V8h12v9"/>
        <path d="M15 11h4l3 3.5V17h-7"/>
        <circle cx="8" cy="20" r="2"/>
        <circle cx="18.5" cy="20" r="2"/>
        <line x1="2" y1="11" x2="6" y2="11"/>
        <line x1="1" y1="14" x2="5" y2="14"/>
      </svg>
    </span>
    <div class="ci-text">
      <strong>Aynı Gün Ücretsiz Kargo</strong>
      <span class="ci-sub">
        {%- if block.settings.row2_title != blank -%}
          {{ block.settings.row2_title }}: {{ block.settings.row2_desc | default: '1-2 iş günü' }}
        {%- else -%}
          Tahmini Teslimat: 1-2 iş günü
        {%- endif -%}
      </span>
    </div>
  </div>

  <div class="ci-box ci-box--ok">
    <span class="ci-ico ci-ico--ok" aria-hidden="true">
      <svg viewBox="0 0 28 28" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 8 14 4 7 8v8l7 4 7-4V8z"/>
        <path d="M7 8l7 4 7-4"/>
        <path d="M14 12v8"/>
        <path d="M9.5 16.5l2 2 4-4" stroke="#10B981" stroke-width="2.2"/>
      </svg>
    </span>
    <div class="ci-text">
      <strong>{{ block.settings.row4_title | default: 'Stokta Var' }}</strong>
      <span class="ci-sub ci-sub--alert">
        {%- if block.settings.row4_highlight != blank -%}
          {{ block.settings.row4_highlight }}
        {%- else -%}
          Hemen kargoda
        {%- endif -%}
      </span>
    </div>
  </div>

</div>
