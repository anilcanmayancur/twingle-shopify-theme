{%- comment -%}
  Cart info line (rendered right under buy-buttons).
  Uses delivery_info block settings (row2 = tahmini teslimat, row4 = stok).
{%- endcomment -%}

{%- if block.settings.row2_title != blank or block.settings.row4_title != blank -%}
  <div class="cart-info" aria-live="polite">
    {%- if block.settings.row2_title != blank -%}
      <div class="ci-row">
        <span class="ci-ico" aria-hidden="true">{{ block.settings.row2_icon }}</span>
        <span class="ci-text"><strong>{{ block.settings.row2_title }}:</strong> {{ block.settings.row2_desc }}</span>
      </div>
    {%- endif -%}
    {%- if block.settings.row4_title != blank -%}
      <div class="ci-row">
        <span class="ci-ico ci-ok" aria-hidden="true">✓</span>
        <span class="ci-text">
          <strong>{{ block.settings.row4_title }}</strong>
          {%- if block.settings.row4_highlight != blank -%} <span class="ci-h">— {{ block.settings.row4_highlight }}</span>{%- endif -%}
        </span>
      </div>
    {%- endif -%}
  </div>
{%- endif -%}
